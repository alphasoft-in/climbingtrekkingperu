---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import RecommendedTours from '../../../components/RecommendedTours.astro';
import TourGallery from '../../../components/TourGallery.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DIA 01',
    title: 'PAIS ORIGEN – LIMA (180 MSNM)',
    content: 'Recepción personalizada en el aeropuerto Jorge Chávez. Traslado a hotel 3* en Miraflores.',
    stats: { time: 'Transfer' }
  },
  {
    day: 'DIA 02',
    title: 'VUELO LIMA – CUSCO – HOTEL',
    content: 'Traslado al aeropuerto para vuelo a Cusco. Recepción y traslado a hotel 3* en la ciudad imperial.',
    stats: { time: '1h 20m vuelo' }
  },
  {
    day: 'DIA 03',
    title: 'CITY TOURS: TEMPLOS Y PALACIOS INCAS',
    content: 'Visita al Qoricancha (Templo del Sol) y los sitios de Sacsayhuaman, Qenqo, Pukapukara y Tambomachay.',
    stats: { alt: '3399m', time: '5 h' }
  },
  {
    day: 'DIA 04',
    title: 'VALLE SAGRADO VIP – AGUAS CALIENTES',
    content: 'Visita a Chinchero, Salineras de Maras y Moray. Almuerzo buffet en el Valle y tren a Aguas Calientes.',
    stats: { alt: '2800m', time: 'Full Day' }
  },
  {
    day: 'DIA 05',
    title: 'MACHU PICCHU – CUSCO',
    content: 'Tour guiado en la Ciudadela Inca (2.5h). Tiempo libre y retorno en tren Expedition a Cusco.',
    stats: { alt: '2430m', time: 'Expedición' }
  },
  {
    day: 'DIA 06',
    title: 'DÍA LIBRE EN CUSCO',
    content: 'Día para descansar, disfrutar la gastronomía local y realizar compras en los mercados tradicionales.'
  },
  {
    day: 'DIA 07',
    title: 'LAGUNA HUMANTAY',
    content: 'Caminata técnica hacia la laguna turquesa al pie del nevado Humantay (4200m). Almuerzo en Mollepata.',
    stats: { alt: '4200m', time: '12 h' }
  },
  {
    day: 'DIA 08',
    title: 'MONTAÑA 7 COLORES – VALLE ROJO',
    content: 'Caminata al Vinicunca (5100m) y descenso por el espectacular Valle Rojo. Almuerzo buffet en Cusipata.',
    stats: { alt: '5100m', time: '12 h' }
  },
  {
    day: 'DIA 09',
    title: 'CHECCACUPE – PALCOYO',
    content: 'Visita al Bosque de Piedras y la Cordillera de Colores de Palcoyo (4900m). Ceremonia a la Pachamama.',
    stats: { alt: '4900m', time: '10 h' }
  },
  {
    day: 'DIA 10',
    title: '7 LAGUNAS AUSANGATE',
    content: 'Exploración de las lagunas Azulcocha, Otorongo y más. Baño en aguas termales de Pacchanta.',
    stats: { alt: '4300m', time: '14 h' }
  },
  {
    day: 'DIA 11',
    title: 'VUELO CUSCO – LIMA',
    content: 'Traslado al aeropuerto y vuelo de retorno a Lima. Traslado a hotel en Miraflores.',
    stats: { time: '1h 20m vuelo' }
  },
  {
    day: 'DIA 12',
    title: 'LIMA – PAIS DE ORIGEN',
    content: 'Traslado final al aeropuerto Jorge Chávez para su vuelo internacional. Fin de servicios.'
  }
];

const includes = [
  'Vuelos Lima - Cusco - Lima (Opcional en paquete)',
  'Traslados completos Aeropuerto - Hotel (Lima y Cusco)',
  '11 Noches de hotel 3* (Lima, Cusco, Aguas Calientes)',
  'Tour Machu Picchu (Tren Expedition, Bus, Entradas)',
  'City Tour Cusco y Valle Sagrado VIP',
  'Expediciones a Humantay, 7 Colores, Palcoyo y 7 Lagunas',
  'Guía oficial bilingüe en todos los recorridos',
  'Almuerzos buffet y desayunos incluidos según itinerario',
  'Bastones de trekking para todas las caminatas',
  'Balón de oxígeno y botiquín de primeros auxilios'
];

const excludes = [
  'Vuelos internacionales',
  'Alimentación no especificada en ciudades',
  'Tickets de ingreso a Catedral de Cusco',
  'Ascenso a montaña Huaynapicchu',
  'Seguro de viaje (obligatorio)',
  'Propinas y gastos personales'
];
---

<Layout title="Esencia Imperial: Cusco y Machu Picchu 12 Días | Franpisco Adventure" description="La expedición total de 12 días por Cusco y Machu Picchu. Cultura, aventura, lagunas turquesas y montañas de colores.">
  <section class="itinerary-hero imperial">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <h1 class="split-title">
          <span class="thin">CULTURA Y AVENTURA TOTAL</span>
          <span class="bold">ESENCIA IMPERIAL 12D</span>
        </h1>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURACIÓN</span>
            <span class="m-value">12 DÍAS / 11 NOCHES</span>
          </div>
          <div class="metric">
            <span class="m-label">TODO INCLUIDO</span>
            <span class="m-value price">USD. 1,695.00</span>
          </div>
          <div class="metric">
            <span class="m-label">TIPO</span>
            <span class="m-value">
              <span class="dif-tag modplus">PREMIUM</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">DOSSIER IMPERIAL</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">LOG: CSQ-PACK-12D</span>
            <h2 class="dossier-title">El Corazón de <span class="blue">Los Andes</span></h2>
          </div>
          
          <p class="dossier-p">Esta expedición de 12 días es nuestra propuesta más ambiciosa en el sur del Perú. Hemos diseñado un recorrido que equilibra el misticismo de los templos Incas con la adrenalina de las caminatas de altura a más de 5,000 metros.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">COBERTURA</span>
                <span class="d-value">Lima, Cusco y Valle Sagrado</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">PUNTOS CLAVE</span>
                <span class="d-value">Machu Picchu, Humantay, Vinicunca</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">CATEGORÍA</span>
                <span class="d-value">Aventura Confort</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">HOTELES</span>
                <span class="d-value">3 Estrellas Premium</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/slider_4.png" alt="Cusco Esencia Imperial" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>13° 31' 30" S</span>
              <span class="divider">|</span>
              <span>71° 58' 20" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">TRAVESÍA DE 12 DÍAS</span>
            <h2 class="technical-title">Análisis de la <span class="blue">Expedición</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day.split(' ')[1]}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <span class="w-day-label">{item.day}</span>
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">ALTITUD</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.time && (
                        <div class="w-stat">
                          <span class="w-s-label">LOGÍSTICA</span>
                          <span class="w-s-value">{item.stats.time}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}

            <div class="timeline-end">
              <div class="end-mark"></div>
              <span class="end-text">FIN DE LA EXPEDICIÓN</span>
            </div>
          </div>
        </div>

        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">MOD: LOG-INCL</span>
              <h3>Servicios Incluidos</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="logistics-card secondary">
            <div class="card-header">
              <span class="c-id">MOD: LOG-EXCL</span>
              <h3>No Incluye</h3>
            </div>
            <ul class="log-list">
              {excludes.map(ex => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" class="log-icon-alt"><path d="M18 6L6 18M6 6l12 12"/></svg>
                  <span>{ex}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">PLANIFICACIÓN ELITE</span>
              <h3>Reserva tu Viaje</h3>
              <p>Este paquete requiere coordinación de vuelos y hoteles. Contáctanos para asegurar tus fechas.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">FECHA ESTIMADA</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">NOMBRE Y APELLIDOS</label>
                    <input type="text" id="full-name" placeholder="Nombre completo" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  {t('trekking.book')}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>

      <div class="technical-notice">
        <div class="notice-box">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p><strong>REQUERIMIENTO FÍSICO:</strong> Aunque es un tour de confort, incluye caminatas por encima de los 5,000 metros (Montaña 7 Colores). Se recomienda una buena condición física y aclimatación previa en Cusco.</p>
        </div>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={lang}
    images={[
      '/slider_4.png',
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/trekking/huayhuash/360.jpeg'
    ]} 
  />

  <RecommendedTours currentId="cusco-esencia" />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "ESENCIA IMPERIAL: CUSCO Y MACHU PICCHU 12D";
    
    const message = `Hola Franpisco Adventure! Me interesa el paquete total: ${tourName}. Mis datos son:\n\n- Nombre: ${name}\n- Fecha aprox: ${date}`;
    const whatsappUrl = `https://wa.me/51987654321?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  /* Same styles as other itinerary pages */
  .itinerary-hero {
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/slider_4.png') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    color: white;
    padding-top: 5rem;
  
    justify-content: center;
    text-align: center;
  }
  .itinerary-hero.imperial { background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/slider_4.png'); 
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    margin-bottom: 3.5rem;
  
    align-items: center;
    gap: 0.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.9rem, 2.5vw, 1.3rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  .metrics-bar {
    display: flex;
    gap: 4rem;
    padding: 2.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  
    justify-content: center;
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-light);
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  .m-value.price { color: var(--brand-blue); font-size: 1.2rem; }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    letter-spacing: 1px;
  }
  .dif-tag.modplus { background: #f0f9ff; color: #0ea5e9; border-color: #e0f2fe; }

  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .dossier-sidebar {
    display: flex;
    justify-content: center;
  }
  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: var(--brand-light);
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: var(--brand-dark);
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: var(--brand-blue); }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--brand-dark);
    margin-bottom: 4rem;
    max-width: 550px;
    position: relative;
  }
  .dossier-p::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: #f1f5f9;
  }

  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .d-icon {
    margin-top: 0.2rem;
    color: var(--brand-blue);
    opacity: 0.6;
  }
  .d-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .d-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    color: var(--brand-light);
  }
  .d-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--brand-dark);
  }

  .dossier-visual { position: relative; }
  .visual-frame {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 550px;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .visual-frame:hover .dossier-img { transform: scale(1.05); }

  .coordinates-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .coordinates-overlay .divider { opacity: 0.3; font-weight: 300; }

  @media (max-width: 1024px) {
    .dossier-layout { grid-template-columns: 1fr; }
    .dossier-sidebar { display: none; }
    .dossier-img { height: 400px; }
  }

  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid #e2e8f0; }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .details-header-technical { margin-bottom: 2.5rem; }
  .sub-label { font-size: 0.65rem; font-weight: 800; letter-spacing: 5px; color: var(--brand-light); display: block; margin-bottom: 1rem; }
  .technical-title { font-size: 1.8rem; font-weight: 900; color: var(--brand-dark); letter-spacing: -1px; }
  .technical-title .blue { color: var(--brand-blue); }

  .path-timeline { position: relative; padding-left: 2rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--brand-blue), var(--brand-light), var(--brand-light));
  }

  .waypoint-item {
    display: flex;
    gap: 1.5rem;
    position: relative;
    margin-bottom: 1rem;
  }
  
  .waypoint-marker {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }
  .marker-box {
    width: 50px;
    height: 50px;
    background: white;
    border: 2px solid var(--brand-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  .m-day { font-size: 0.9rem; font-weight: 900; color: var(--brand-dark); font-family: 'JetBrains Mono', monospace; }

  .waypoint-content { flex: 1; padding-top: 0.1rem; }
  .waypoint-header { margin-bottom: 0.8rem; }
  .w-day-label { font-size: 0.7rem; font-weight: 800; color: var(--brand-blue); letter-spacing: 2px; text-transform: uppercase; display: block; margin-bottom: 0.2rem; }
  .w-title { font-size: 1.15rem; font-weight: 800; color: var(--brand-dark); letter-spacing: -0.5px; }
  
  .w-description {
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--brand-dark);
    margin-bottom: 1rem;
    max-width: 650px;
  }

  .waypoint-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--brand-light);
  }
