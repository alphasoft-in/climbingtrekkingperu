---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import RecommendedTours from '../../../components/RecommendedTours.astro';
import TourGallery from '../../../components/TourGallery.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DIA 01',
    title: 'LIMA (161 MSNM) – HUARAZ (3100 M)',
    content: 'Llegada a Lima y traslado a Huaraz en bus (8 horas) o vuelo (50 min). Recepción y traslado al hotel. Se recomienda aclimatación previa.',
    stats: { time: '8 hs' }
  },
  {
    day: 'DIA 02',
    title: 'ACLIMATACION: LAGUNA ROCUTOYOC (4450 MSNM)',
    content: 'Visita al mirador Cashapunta, cascada Ruripaccha y caminata al glaciar de Ruripaccha (4650m). Retorno a Huaraz.',
    stats: { alt: '4450m', time: '9-10 hs' }
  },
  {
    day: 'DIA 03',
    title: 'HUARAZ (3100) – VAQUERIA – PARIA (3900 MSNM)',
    content: 'Traslado pasando por el paso Portachuelo (4760m). Inicio del trek en Vaquería hasta campamento Paria.',
    stats: { trans: '05 hs', alt: '4760m', dist: '8.5 km', time: '5 h' }
  },
  {
    day: 'DIA 04',
    title: 'TUCTU (4200 MSNM) - HUECRUNCOCHA (3850 MSNM)',
    content: 'Ascenso al paso Pukaraju (4,650 msnm) con vistas del Taulliraju. Descenso al campamento Huecruncocha.',
    stats: { alt: '4650 m', dist: '13.8 km', time: '8 h' }
  },
  {
    day: 'DIA 05',
    title: 'HUECRUNCOCHA (3850 MSNM) – JANCAPAMPA (3700 MSNM)',
    content: 'Caminata por el valle de Quisuar y cruce del paso Tupa Tupa (4,400 msnm). Llegada a Jancapampa (Callejón de Conchucos).',
    stats: { alt: '4400 m', dist: '13.2 km', time: '6 h' }
  },
  {
    day: 'DIA 06',
    title: 'JANCAPAMPA (3700 MSNM) – WILCA (4150 MSNM)',
    content: 'Ascenso técnico entre arbustos hacia el paso Yanacon (4,600 msnm). Descenso al campamento Wilca.',
    stats: { alt: '4600 m', dist: '14.8 km', time: '9 h' }
  },
  {
    day: 'DIA 07',
    title: 'WILLCA (4200 MSNM) – JANCARURISH (4250 MSNM)',
    content: 'Ascenso por la quebrada Tayapampa hacia el paso Cara Cara (4,800 msnm). Vistas espectaculares de la cara norte del Alpamayo.',
    stats: { alt: '4800 m', dist: '14.4 km', time: '8 h' }
  },
  {
    day: 'DIA 08',
    title: 'JANCARURISH (4250 MSNM) - OSORURI (4,380 MSNM)',
    content: 'Caminata por la quebrada de los Cedros y ascenso al paso Vientunan (4,790 msnm). Campamento balcón en Osoruri.',
    stats: { alt: '4790 m', dist: '8.9 km', time: '8 h' }
  },
  {
    day: 'DIA 09',
    title: 'OSORURI (4380 MSNM) – HUISHCASH (4100 MSNM)',
    content: 'Cruce del paso Toropishtanan (4,850 msnm). Vista de los nevados Santa Cruz y la laguna Cullicocha.',
    stats: { alt: '4850 m', dist: '12.2 km', time: '9 h' }
  },
  {
    day: 'DIA 10',
    title: 'HUISHCASH (4100 MSNM) – HUALCAYAN (3000 MSNM) – HUARAZ',
    content: 'Descenso final en zigzag hacia el pueblo de Hualcayan. Traslado de retorno a la ciudad de Huaraz.',
    stats: { alt: '3000 m', dist: '9.3 km', time: '4 h' }
  },
  {
    day: 'DIA 11',
    title: 'TRASLADO AL TERMINAL O AEROPUERTO',
    content: 'Traslado desde el hotel según su itinerario de salida. Fin de servicios.'
  }
];

const includes = [
  'Información técnica detallada en oficina',
  'Guía oficial de Trekking (AGMP/UIAGM)',
  'Asistente de guía (para grupos de +10)',
  'Cocinero especializado en expediciones',
  '2 Días de aclimatación técnica',
  '8 Días de trekking Los Cedros Alpamayo',
  'Equipo de camping completo (carpas, cocina, comedor)',
  'Acémilas para transporte de equipo general y personal',
  'Arrieros calificados',
  'Woki toki y Botiquín de primeros auxilios'
];

const excludes = [
  'Vuelos internacionales y nacionales',
  'Tickets de bus Lima - Huaraz - Lima',
  'Hoteles en Huaraz y Lima',
  'Tickets de entrada PNH (S/. 150.00)',
  'Bolsa de dormir y esterillas personales',
  'Alimentación en ciudades',
  'Seguro de viaje 100% (obligatorio)',
  'Propinas y gastos personales'
];

const equipment = [
  'Bolsa de dormir (-10°C) y Esterilla',
  'Botas de trekking de alta montaña',
  'Pantalón y casaca impermeable (Gore-Tex)',
  'Casaca de pluma para campamento',
  'Bastones de trekking telescópicos',
  'Frontal con baterías de repuesto',
  'Lentes de sol 100% UV y Bloqueador solar',
  'Mochila de ataque (40L)'
];
---

<Layout title="Ruta Los Cedros Alpamayo 11 Días | Cordillera Blanca | Franpisco Adventure" description="La expedición técnica más espectacular de la Cordillera Blanca. 11 días contemplando la cara norte del Alpamayo y cruzando pasos de alta montaña.">
  <section class="itinerary-hero">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <h1 class="split-title">
          <span class="thin">EXPEDICIÓN TÉCNICA</span>
          <span class="bold">LOS CEDROS ALPAMAYO</span>
        </h1>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURACIÓN</span>
            <span class="m-value">11 DÍAS / 10 NOCHES</span>
          </div>
          <div class="metric">
            <span class="m-label">DESDE</span>
            <span class="m-value price">USD. 895.00</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFICULTAD</span>
            <span class="m-value">
              <span class="dif-tag hard">DIFÍCIL / TÉCNICO</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">DOSSIER ALPAMAYO</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">LOG: BLN-ALP-11D</span>
            <h2 class="dossier-title">La Cara Norte <span class="blue">del Alpamayo</span></h2>
          </div>
          
          <p class="dossier-p">Considerada la ruta más espectacular para fotógrafos y montañistas, Los Cedros permite rodear el Alpamayo para contemplar su perfecta pirámide desde ángulos inaccesibles en otras rutas.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">INICIO / LOGÍSTICA</span>
                <span class="d-value">Huaraz, Perú</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">PUNTO MÁXIMO</span>
                <span class="d-value">Paso Toropishtanan (4,850m)</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">TEMPORADA</span>
                <span class="d-value">Abril - Diciembre</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">SERVICIO</span>
                <span class="d-value">Expedición Técnica Completa</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/slider_1.png" alt="Ruta Los Cedros Alpamayo" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>08° 52' 45" S</span>
              <span class="divider">|</span>
              <span>77° 39' 12" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">ANÁLISIS DE RUTA</span>
            <h2 class="technical-title">Itinerario <span class="blue">Detallado</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day.split(' ')[1]}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <span class="w-day-label">{item.day}</span>
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">ALTITUD</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.dist && (
                        <div class="w-stat">
                          <span class="w-s-label">DISTANCIA</span>
                          <span class="w-s-value">{item.stats.dist}</span>
                        </div>
                      )}
                      {item.stats.time && (
                        <div class="w-stat">
                          <span class="w-s-label">TIEMPO</span>
                          <span class="w-s-value">{item.stats.time}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}

            <div class="timeline-end">
              <div class="end-mark"></div>
              <span class="end-text">FIN DE RUTA</span>
            </div>
          </div>
        </div>

        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">MOD: LOG-INCL</span>
              <h3>Servicios Incluidos</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="logistics-card secondary">
            <div class="card-header">
              <span class="c-id">MOD: TECH-EQ</span>
              <h3>Equipo Sugerido</h3>
            </div>
            <ul class="log-list">
              {equipment.map(eq => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" class="log-icon-alt"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                  <span>{eq}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">SALIDAS DISPONIBLES</span>
              <h3>Reserva tu Expedición</h3>
              <p>Inicia el proceso para recorrer la ruta más salvaje de la Blanca. Dossier técnico disponible bajo pedido.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">FECHA APROXIMADA</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">NOMBRES Y APELLIDOS</label>
                    <input type="text" id="full-name" placeholder="Tu nombre completo" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  SOLICITAR RESERVA
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>

      <div class="technical-notice">
        <div class="notice-box">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p><strong>REQUISITO FÍSICO:</strong> Esta ruta cruza 7 pasos de alta montaña por encima de los 4400m. Se requiere una excelente condición física y experiencia previa en caminatas de varios días.</p>
        </div>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={lang}
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/trekking/huayhuash/clasico.jpeg'
    ]} 
  />

  <RecommendedTours currentId="blanca-alpamayo" />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "RUTA LOS CEDROS ALPAMAYO 11D";
    
    const message = `Hola Franpisco Adventure! Me gustaría reservar un cupo para el Trekking Alpamayo: ${tourName}. Mis datos son:\n\n- Nombre: ${name}\n- Fecha aprox: ${date}`;
    const whatsappUrl = `https://wa.me/51987654321?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  /* Same styles as Santa Cruz and Best of Blanca pages */
  .itinerary-hero {
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/slider_1.png') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    color: white;
    padding-top: 5rem;
  
    justify-content: center;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    margin-bottom: 3.5rem;
  
    align-items: center;
    gap: 0.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.9rem, 2.5vw, 1.3rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  .metrics-bar {
    display: flex;
    gap: 4rem;
    padding: 2.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  
    justify-content: center;
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-light);
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  .m-value.price { color: var(--brand-blue); font-size: 1.2rem; }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    letter-spacing: 1px;
  }
  .dif-tag.hard { background: #fff1f2; color: #ef4444; border-color: #fecdd3; }

  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .dossier-sidebar {
    display: flex;
    justify-content: center;
  }
  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: var(--brand-light);
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: var(--brand-dark);
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: var(--brand-blue); }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--brand-dark);
    margin-bottom: 4rem;
    max-width: 550px;
    position: relative;
  }
  .dossier-p::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: #f1f5f9;
  }

  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .d-icon {
    margin-top: 0.2rem;
    color: var(--brand-blue);
    opacity: 0.6;
  }
  .d-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .d-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    color: var(--brand-light);
  }
  .d-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--brand-dark);
  }

  .dossier-visual { position: relative; }
  .visual-frame {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 550px;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .visual-frame:hover .dossier-img { transform: scale(1.05); }

  .coordinates-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .coordinates-overlay .divider { opacity: 0.3; font-weight: 300; }

  @media (max-width: 1024px) {
    .dossier-layout { grid-template-columns: 1fr; }
    .dossier-sidebar { display: none; }
    .dossier-img { height: 400px; }
  }

  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid #e2e8f0; }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .details-header-technical { margin-bottom: 2.5rem; }
  .sub-label { font-size: 0.65rem; font-weight: 800; letter-spacing: 5px; color: var(--brand-light); display: block; margin-bottom: 1rem; }
  .technical-title { font-size: 1.8rem; font-weight: 900; color: var(--brand-dark); letter-spacing: -1px; }
  .technical-title .blue { color: var(--brand-blue); }

  .path-timeline { position: relative; padding-left: 2rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--brand-blue), var(--brand-light), var(--brand-light));
  }

  .waypoint-item {
    display: flex;
    gap: 1.5rem;
    position: relative;
    margin-bottom: 1rem;
  }
  
  .waypoint-marker {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }
  .marker-box {
    width: 50px;
    height: 50px;
    background: white;
    border: 2px solid var(--brand-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  .m-day { font-size: 0.9rem; font-weight: 900; color: var(--brand-dark); font-family: 'JetBrains Mono', monospace; }

