---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const programs = [
    {
    id: '360',
    title: t('huayhuash.prog1.name'),
    description: t('huayhuash.prog1.desc'),
    image: '/trekking/huayhuash/360.jpeg',
    duration: `12-14 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard'
  },
  {
    id: 'classic',
    title: t('huayhuash.prog2.name'),
    description: t('huayhuash.prog2.desc'),
    image: '/trekking/huayhuash/clasico.jpeg',
    duration: `10-12 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus'
  },
  {
    id: 'mini',
    title: t('huayhuash.prog3.name'),
    description: t('huayhuash.prog3.desc'),
    image: '/trekking/huayhuash/mini.jpeg',
    duration: `4-5 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod'
  }
];
---

<Layout title={`${t('nav.huayhuash')} - Franpisco Adventure`} description={t('huayhuash.subtitle')}>
  <section class="huayhuash-hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <span class="category-label">{t('nav.trekking')}</span>
      <h1>{t('huayhuash.title')}</h1>
      <p>{t('huayhuash.subtitle')}</p>
    </div>
  </section>

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {programs.map((prog) => (
          <div class="program-card">
            <div class="card-image">
              <img src={prog.image} alt={prog.title} loading="lazy" />
              <div class="card-badge">{prog.duration}</div>
            </div>
            <div class="card-body">
              <span class={`difficulty-tag ${prog.difficultyLevel}`}>
                {prog.difficulty}
              </span>
              <h3>{prog.title}</h3>
              <p>{prog.description}</p>
              <a 
                href={
                  prog.id === '360' ? getRelativeLocaleUrl(lang, 'trekking/huayhuash/360') : 
                  prog.id === 'classic' ? getRelativeLocaleUrl(lang, 'trekking/huayhuash/clasico') : 
                  prog.id === 'mini' ? getRelativeLocaleUrl(lang, 'trekking/huayhuash/mini') : 
                  '#'
                } 
                class="card-link"
              >
                {t('trekking.viewMore')}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .huayhuash-hero {
    position: relative;
    height: 60vh;
    min-height: 400px;
    background: url('/images/huayhuash-hero.jpg') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
    background-color: #0f172a; /* Fallback */
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7));
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 900px;
    padding: 0 2rem;
  }

  .category-label {
    text-transform: uppercase;
    letter-spacing: 3px;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-accent);
    margin-bottom: 1rem;
    display: block;
  }

  .hero-content h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  .hero-content p {
    font-size: 1.2rem;
    opacity: 0.9;
    max-width: 700px;
    margin: 0 auto;
  }

  .programs-section {
    padding: 6rem 2rem;
    background: #f8fafc;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  .program-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    display: flex;
    flex-direction: column;
  }

  .program-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }

  .card-image {
    position: relative;
    height: 240px;
    background-color: #e2e8f0;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .program-card:hover .card-image img {
    transform: scale(1.1);
  }

  .card-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(4px);
    padding: 0.5rem 1rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .card-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .difficulty-tag {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    display: inline-block;
    margin-bottom: 1rem;
    width: fit-content;
  }

  .difficulty-tag.hard { background: #fee2e2; color: #ef4444; }
  .difficulty-tag.modplus { background: #fef3c7; color: #f59e0b; }
  .difficulty-tag.mod { background: #ecfdf5; color: #10b981; }

  .card-body h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-primary);
    line-height: 1.4;
  }

  .card-body p {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    flex-grow: 1;
  }

  .card-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    transition: gap 0.3s ease;
  }

  .card-link:hover {
    gap: 1rem;
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .huayhuash-hero {
      height: 50vh;
    }
    .programs-section {
      padding: 4rem 1.5rem;
    }
  }
</style>
