---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import RecommendedTours from '../../../components/RecommendedTours.astro';
import TourGallery from '../../../components/TourGallery.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DIA 01',
    title: 'LIMA PERU (100 MSNM) – HUARAZ (3100 MSNM)',
    content: 'Viaje en bus público hacia Huaraz (8 horas) o en avión (50 min). Se recomienda un día de aclimatación previo en la Cordillera Blanca.'
  },
  {
    day: 'DIA 02',
    title: 'FULL DAY LAGUNA ROCUTOYOC (4450 MSNM) – ACLIMATACIÓN',
    content: 'Visita a la laguna Rocutuyoc, cascada de Ruripaccha, glaciar de Ruripaccha (4,650 msnm). Retorno a Huaraz.',
    stats: { time: '9-10 horas', alt: '4450m' }
  },
  {
    day: 'DIA 03',
    title: 'DIA LIBRE',
    content: 'Descanso estratégico para optimizar la aclimatación antes de iniciar el circuito Huayhuash.'
  },
  {
    day: 'DIA 04',
    title: 'HUARAZ - QUEROPALCA (3831 MSNM) - MITUCOCHA (4230 MSNM)',
    content: 'Traslado a Queropalca. Inicio del trekking hacia el campamento Mitucocha.',
    stats: { trans: '08 horas', alt: '4230m', time: '2 h' }
  },
  {
    day: 'DIA 05',
    title: 'MITUCOCHA (4,230 MSNM) - CARHUACOCHA (4,280 MSNM)',
    content: 'Paso Carhuac (4,650 msnm). Mirador de las tres lagunas con vistas de Yerupaja y Siula.',
    stats: { alt: '4750 m', dist: '13 km', time: '6 hs' }
  },
  {
    day: 'DIA 06',
    title: 'CARHUACOCHA (4280 MSNM) - HUAYHUASH (4350 MSNM)',
    content: 'Día exigente. Paso Siula (4,800 msnm). Vistas de Trapecio y León Dormido.',
    stats: { alt: '4800 m', dist: '15 km', time: '09 h' }
  },
  {
    day: 'DIA 07',
    title: 'HUAYHUASH (4,350 MSNM) - CUYOCPAMPA (4550 MSNM)',
    content: 'Paso Trapecio (5,030 msnm). Vista de la laguna Azulcocha. Opcional: Mirador San Antonio (5,120 msnm).',
    stats: { alt: '5,030 m', dist: '13 km', time: '7 h' }
  },
  {
    day: 'DIA 08',
    title: 'CUYOCPAMPA (4,550 MSNM) - HUAYLLAPA (3630 MSNM)',
    content: 'Paso Santa Rosa (5,080 msnm). Vista increíble de la cara norte de Huayhuash. Descenso a Huayllapa.',
    stats: { alt: '5080 m', dist: '19 km', time: '09 h' }
  },
  {
    day: 'DIA 09',
    title: 'HUAYLLAPA (3,630 MSNM) - GASHPAPAMPA (4555 MSNM)',
    content: 'Subida al paso Tapush (4,800 msnm). Vista del nevado Diablo Mudo (5,350 msnm).',
    stats: { alt: '4.800 m', dist: '15 km', time: '08 h' }
  },
  {
    day: 'DIA 10',
    title: 'GASHPAPAMPA (4555 MSNM) – MIRADOR HUACRISH (4800 MSNM) – HUARAZ',
    content: 'Paso Yaucha (4,800 msnm). Mirador Huacrish con panorámica total. Traslado final a Huaraz.',
    stats: { alt: '4800 m', dist: '15 km', time: '08 h' }
  },
  {
    day: 'DIA 11',
    title: 'HUARAZ – LIMA',
    content: 'Traslado al terminal de bus para el retorno a Lima. Fin de servicios.'
  }
];

const includes = [
  'Información previa en oficina Huaraz',
  'Tours de aclimatación (compartido)',
  'Transporte privado Huaraz - Queropalca',
  'Transporte de retorno Lirio - Huaraz',
  'Guía oficial de Trekking calificado',
  'Cocinero especializado en expediciones',
  '7 días de pensión completa en el trek',
  '6kg de equipaje permitido en mulas',
  'Equipo de camping completo',
  'Botiquín de primeros auxilios y Oxígeno'
];

const equipment = [
  'Bolsa de dormir (-10°C recomendado)',
  'Mochila de ataque (40L)',
  'Botas de montaña impermeables',
  'Ropa técnica de abrigo (capas)',
  'Gorro, guantes y protección solar',
  'Bastones de trekking',
  'Poncho para lluvia',
  'Cantimplora o camelback'
];
---

<Layout title="Trekking Clásico Huayhuash - 11 Días | Franpisco Adventure" description="Explora lo mejor de la Cordillera Huayhuash en un circuito optimizado de 11 días. Desde Queropalca hasta Huaraz.">
  <section class="itinerary-hero">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <h1 class="split-title">
          <span class="thin">TREKKING CORDILLERA</span>
          <span class="bold">HUAYHUASH CLÁSICO</span>
        </h1>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURACIÓN</span>
            <span class="m-value">11 DÍAS / 10 NOCHES</span>
          </div>
          <div class="metric">
            <span class="m-label">DESDE</span>
            <span class="m-value price">USD. 795.00</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFICULTAD</span>
            <span class="m-value">
              <span class="dif-tag hard">MODERADO+</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">PAQUETE TÉCNICO</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">LOG: HYH-CL-11D</span>
            <h2 class="dossier-title">Ruta <span class="blue">Legendaria</span></h2>
          </div>
          
          <p class="dossier-p">Este circuito concentra los paisajes más emblemáticos de la Cordillera Huayhuash iniciando desde Queropalca. Ideal para quienes buscan la máxima belleza escénica en un itinerario optimizado.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">INICIO / LOGÍSTICA</span>
                <span class="d-value">Queropalca, Perú</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">ZONAS TÉCNICAS</span>
                <span class="d-value">Ancash, Huánuco, Lima</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">TEMPORADA</span>
                <span class="d-value">Abril - Diciembre</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">SERVICIO</span>
                <span class="d-value">Clásico Expedición</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/trekking/huayhuash/clasico.jpeg" alt="Trekking Huayhuash Clásico" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>9° 58' 21" S</span>
              <span class="divider">|</span>
              <span>76° 54' 42" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <!-- Main Timeline -->
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">SECUESTRACIÓN DE RUTA</span>
            <h2 class="technical-title">Itinerario <span class="blue">Detallado</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day.split(' ')[1]}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <span class="w-day-label">{item.day}</span>
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">ALTITUD MÁX.</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.dist && (
                        <div class="w-stat">
                          <span class="w-s-label">DISTANCIA</span>
                          <span class="w-s-value">{item.stats.dist}</span>
                        </div>
                      )}
                      {item.stats.time && (
                        <div class="w-stat">
                          <span class="w-s-label">TIEMPO ESTIMADO</span>
                          <span class="w-s-value">{item.stats.time}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}

            <div class="timeline-end">
              <div class="end-mark"></div>
              <span class="end-text">FIN DE RUTA</span>
            </div>
          </div>
        </div>

        <!-- Logistics Sidebar -->
        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">MOD: LOG-INCL</span>
              <h3>Servicios Incluidos</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="logistics-card secondary">
            <div class="card-header">
              <span class="c-id">MOD: TECH-EQ</span>
              <h3>Equipo Sugerido</h3>
            </div>
            <ul class="log-list">
              {equipment.map(eq => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" class="log-icon-alt"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                  <span>{eq}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">DISPONIBILIDAD ABIERTA</span>
              <h3>Inicia tu Expedición</h3>
              <p>Solicita el paquete técnico completo de la ruta y asegura tu cupo para la temporada.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">FECHA APROXIMADA</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">NOMBRES Y APELLIDOS</label>
                    <input type="text" id="full-name" placeholder="Escribe tu nombre completo" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  {t('trekking.book')}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={lang}
    images={[
      '/trekking/huayhuash/clasico.jpeg',
      '/slider_5.png',
      '/slider_3.png',
      '/slider_1.png',
      '/slider_4.png'
    ]} 
  />

  <RecommendedTours currentId="classic" />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "TREKKING CORDILLERA HUAYHUASH CLÁSICO 11D";
    
    const message = `Hola Franpisco Adventure! Me gustaría reservar un cupo para la expedición: ${tourName}. Mis datos son:\n\n- Nombre: ${name}\n- Fecha aprox: ${date}`;
    const whatsappUrl = `https://wa.me/51987654321?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  .itinerary-hero {
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/trekking/huayhuash/clasico.jpeg') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    padding-top: 5rem;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 3.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  /* Metrics Bar */
  .metrics-bar {
    display: flex;
    justify-content: center;
    gap: 4rem;
    padding: 2.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-light);
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  .m-value.price { color: var(--brand-blue); font-size: 1.2rem; }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    letter-spacing: 1px;
  }
  .dif-tag.hard { color: var(--brand-blue); border: 1px solid rgba(0, 144, 204, 0.3); }

  .metric .tag { background: #fee2e2; color: #ef4444; padding: 2px 8px; border-radius: 4px; font-size: 0.8rem; }

  /* Dossier Section - High End Boutique Style */
  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  /* Vertical Label Accent */
  .dossier-sidebar {
    display: flex;
    justify-content: center;
  }
  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: var(--brand-light);
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: var(--brand-dark);
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: var(--brand-blue); }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: #475569;
    margin-bottom: 4rem;
    max-width: 550px;
    position: relative;
  }
  .dossier-p::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: var(--brand-light);
  }

  /* Specs Dashboard */
  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .d-icon {
    margin-top: 0.2rem;
    color: var(--brand-blue);
    opacity: 0.6;
  }
  .d-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .d-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    color: var(--brand-light);
  }
  .d-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--brand-dark);
  }

  /* Visual Frame with Overlays */
  .dossier-visual { position: relative; }
  .visual-frame {
    position: relative;
    border-radius: 4px; /* Hard corner for technical look */
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 550px;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .visual-frame:hover .dossier-img { transform: scale(1.05); }

  .coordinates-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .coordinates-overlay .divider { opacity: 0.3; font-weight: 300; }

  @media (max-width: 1024px) {
    .dossier-layout { grid-template-columns: 1fr; }
    .dossier-sidebar { display: none; }
    .dossier-img { height: 400px; }
  }

  /* Details Layout */
  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid var(--brand-light); }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .details-header-technical { margin-bottom: 2.5rem; }
  .sub-label { font-size: 0.65rem; font-weight: 800; letter-spacing: 5px; color: var(--brand-light); display: block; margin-bottom: 1rem; }
  .technical-title { font-size: 1.8rem; font-weight: 900; color: var(--brand-dark); letter-spacing: -1px; }
  .technical-title .blue { color: var(--brand-blue); }

  /* Path Timeline */
  .path-timeline { position: relative; padding-left: 2rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--brand-blue), var(--brand-light), var(--brand-light));
  }

  .waypoint-item {
    display: flex;
    gap: 1.5rem;
    position: relative;
    margin-bottom: 1rem;
  }
  
  .waypoint-marker {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }
  .marker-box {
    width: 50px;
    height: 50px;
    background: white;
    border: 2px solid var(--brand-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  .m-day { font-size: 0.9rem; font-weight: 900; color: var(--brand-dark); font-family: 'JetBrains Mono', monospace; }

  .waypoint-content { flex: 1; padding-top: 0.1rem; }
  .waypoint-header { margin-bottom: 0.8rem; }
  .w-day-label { font-size: 0.7rem; font-weight: 800; color: var(--brand-blue); letter-spacing: 2px; text-transform: uppercase; display: block; margin-bottom: 0.2rem; }
  .w-title { font-size: 1.15rem; font-weight: 800; color: var(--brand-dark); letter-spacing: -0.5px; }
  
  .w-description {
    font-size: 0.88rem;
    line-height: 1.8;
    color: #475569;
    margin-bottom: 1rem;
    max-width: 650px;
  }

  .waypoint-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--brand-light);
  }
  .w-stat { display: flex; flex-direction: column; gap: 0.4rem; }
  .w-s-label { font-size: 0.6rem; font-weight: 800; color: var(--brand-light); letter-spacing: 1px; }
  .w-s-value { font-size: 0.75rem; font-weight: 700; color: var(--brand-dark); }

  /* Logistics Sidebar */
  .logistics-sidebar { display: flex; flex-direction: column; gap: 3rem; padding-top: 6.5rem; }
  .logistics-card {
    background: white;
    padding: 2.5rem;
    border: 1px solid var(--brand-light);
