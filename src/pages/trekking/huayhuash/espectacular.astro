---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import RecommendedTours from '../../../components/RecommendedTours.astro';
import TourGallery from '../../../components/TourGallery.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DIA 01',
    title: 'LIMA – PERU (100 MSNM) – HUARAZ (3100 M)',
    content: 'Recepción en el aeropuerto de Lima y traslado directo a Huaraz (8 horas) en bus público o vuelo privado opcional. Traslado al hotel.',
    stats: { time: '8 hs' }
  },
  {
    day: 'DIA 02',
    title: 'ACLIMATACION: LAGUNA ROCUTOYOC (4450 MSNM) – CORDILLERA BLANCA',
    content: 'Tour de aclimatación visitando mirador Cashapunta, cascada Ruripaccha, pinturas rupestres y laguna Rocutuyoc. Caminata al glaciar (4,650 msnm).',
    stats: { alt: '4450m', time: '9-10 hs' }
  },
  {
    day: 'DIA 03',
    title: 'DIA LIBRE EN HUARAZ',
    content: 'Descanso estratégico en la ciudad para optimizar la aclimatación y preparación logística antes de la expedición.'
  },
  {
    day: 'DIA 04',
    title: 'HUARAZ (3100M) - CUARTELWAIN (4180M) - MITUCOCHA (4280M)',
    content: 'Traslado a Cuartelwain (5h). Inicio del trekking cruzando el primer paso Cacananpunta (4,700 msnm). Campamento Jancapampa.',
    stats: { alt: '4700 m', time: '5 h' }
  },
  {
    day: 'DIA 05',
    title: 'MITUCOCHA (4230 MSNM) - CARHUACOCHA (4,280 MSNM)',
    content: 'Caminata hacia el mirador Carhuac (4,750 msnm). Vistas espectaculares de los nevados Yerupaja (6,634m) y Siula (6,344m).',
    stats: { alt: '4750 m', dist: '13 km', time: '5 h' }
  },
  {
    day: 'DIA 06',
    title: 'CARHUACOCHA (4280 MSNM) - HUAYHUASH (4350 MSNM)',
    content: 'Día exigente. Visita al mirador de las tres lagunas (Siulacocha, Ganrajanca, Quesillacocha). Paso Siula (4,800 msnm).',
    stats: { alt: '4800 m', dist: '15 km', time: '09 hs' }
  },
  {
    day: 'DIA 07',
    title: 'HUAYHUASH (4,350 MSNM) - CUYOCPAMPA (4550 MSNM)',
    content: 'Cruce entre montañas Trapecio y Putscanturpa hasta el paso Trapecio (5,030 msnm). Opcional: Mirador San Antonio (5,120 msnm).',
    stats: { alt: '5,030 m', dist: '13 km', time: '7 h' }
  },
  {
    day: 'DIA 08',
    title: 'CUYOCPAMPA (4550 MSNM) – CUTATAMBO (4280 MSNM)',
    content: 'Paso Santa Rosa (5,080 msnm) con vista increíble de la cara norte de Huayhuash. Descenso a la laguna Jurao.',
    stats: { alt: '5080 m', dist: '11 km', time: '6 h' }
  },
  {
    day: 'DIA 09',
    title: 'CUTATAMBO – MIRADOR CERO GRAN VISTA (5150 MSNM)',
    content: 'Ascenso al mirador Cero Gran Vista para observar la ruta de Joe Simpson (Tocando el Vacío) en el Siula Grande.',
    stats: { alt: '5150 m', dist: '14 km', time: '8 h' }
  },
  {
    day: 'DIA 10',
    title: 'CUTATAMBO (4280 MSNM) - HUAYLLAPA (3,630 MSNM)',
    content: 'Descenso por el valle de Calinca hasta el pueblo de Huayllapa. Opcional: alojamiento en casa hospedaje con wifi y agua caliente.',
    stats: { dist: '8 km', time: '05 hs' }
  },
  {
    day: 'DIA 11',
    title: 'HUAYLLAPA (3,630 MSNM) - GASHPAPAMPA (4555 MSNM)',
    content: 'Ascenso largo pero suave al paso Tapush (4,800 msnm). Vistas del nevado Diablo Mudo (5,350 msnm).',
    stats: { alt: '4800 m', dist: '15 km', time: '08 h' }
  },
  {
    day: 'DIA 12',
    title: 'GASHPAPAMPA (4555 MSNM) - LAGUNA JAHUACOCHA (4100 MSNM)',
    content: 'Paso Yaucha (4,800 msnm). Mirador Huacrish con panorama total de los picos más altos de la cordillera.',
    stats: { alt: '4800 m', dist: '12 km', time: '07 h' }
  },
  {
    day: 'DIA 13',
    title: 'JAHUACOCHA (4100 MSNM) - LLAMAC (3300 MSNM)',
    content: 'Último día de trek. Paso Pampa Llamac (3,900m). Descenso final a Llamac y traslado de retorno a Huaraz.',
    stats: { alt: '3900 m', dist: '13 km', time: '06 h' }
  },
  {
    day: 'DIA 14',
    title: 'HUARAZ - TRASLADO AL TERMINAL O AEROPUERTO',
    content: 'Traslado del hotel al terminal de bus o aeropuerto para el viaje de retorno a Lima.'
  },
  {
    day: 'DIA 15',
    title: 'LIMA - TRASLADO AL AEROPUERTO',
    content: 'Traslado final al aeropuerto internacional para su vuelo de retorno. Fin de servicios.'
  }
];

const includes = [
  'Recepción en aeropuerto Lima y traslados',
  'Tickets de bus Lima - Huaraz - Lima',
  '4 noches de hotel en Huaraz + 1 noche en Lima',
  'Información detallada en oficina Huaraz',
  '1 Día de aclimatación técnica',
  'Transporte privado a Cuartelwain',
  'Guía oficial de Trekking calificado',
  'Cocinero especializado en alta montaña',
  '10 Días de expedición en Huayhuash',
  '10kg de carga permitida en burros',
  'Equipo de camping completo de alta gama',
  'Woki toki y Botiquín de primeros auxilios'
];

const equipment = [
  'Bolsa de dormir (-10°C recomendado)',
  'Colchoneta / Esterilla térmica',
  'Mochila de ataque (40L)',
  'Botas de trekking de alta montaña',
  'Ropa técnica por capas (Pluma, Gore-Tex)',
  'Protección solar (Gorro, lentes, bloqueador)',
  'Bastones de trekking',
  'Poncho de lluvia'
];
---

<Layout title="La Ruta Espectacular Huayhuash - 15 Días | Franpisco Adventure" description="La expedición definitiva de 15 días en la Cordillera Huayhuash. Servicio confort con mirador Cero Gran Vista y pasos de 5,000m.">
  <section class="itinerary-hero">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <h1 class="split-title">
          <span class="thin">LA MEJOR RUTA</span>
          <span class="bold">HUAYHUASH ESPECTACULAR</span>
        </h1>
        <div class="hero-accent-bar"></div>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURACIÓN</span>
            <span class="m-value">15 DÍAS / 14 NOCHES</span>
          </div>
          <div class="metric">
            <span class="m-label">SERVICIO CONFORT</span>
            <span class="m-value price">USD. 1,995.00</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFICULTAD</span>
            <span class="m-value">
              <span class="dif-tag hard">DIFÍCIL</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">DOSSIER CONFORT</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">CÓDIGO: HYH-SPEC-15D</span>
            <h2 class="dossier-title">Circuito <span class="blue">Supremo</span></h2>
          </div>
          
          <p class="dossier-p">Esta es nuestra ruta más completa y exclusiva. 15 días de inmersión total en la Cordillera Huayhuash, incluyendo el mirador Cero Gran Vista frente al Siula Grande y servicios de logística superior.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">INICIO / LOGÍSTICA</span>
                <span class="d-value">Lima / Huaraz, Perú</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">PUNTOS CLAVE</span>
                <span class="d-value">Cero Gran Vista, Santa Rosa</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">TEMPORADA</span>
                <span class="d-value">Marzo - Diciembre</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">SERVICIO</span>
                <span class="d-value">Logística Confort Full</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/trekking/huayhuash/ruta-huayhuash.png" alt="Ruta Espectacular Huayhuash" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>10° 17' 22" S</span>
              <span class="divider">|</span>
              <span>76° 54' 01" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">ANÁLISIS DE EXPEDICIÓN</span>
            <h2 class="technical-title">Itinerario <span class="blue">de Expedición</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day.split(' ')[1]}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <span class="w-day-label">{item.day}</span>
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">ALTITUD</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.dist && (
                        <div class="w-stat">
                          <span class="w-s-label">DISTANCIA</span>
                          <span class="w-s-value">{item.stats.dist}</span>
                        </div>
                      )}
                      {item.stats.time && (
                        <div class="w-stat">
                          <span class="w-s-label">TIEMPO</span>
                          <span class="w-s-value">{item.stats.time}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}

            <div class="timeline-end">
              <div class="end-mark"></div>
              <span class="end-text">FIN DE RUTA</span>
            </div>
          </div>
        </div>

        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">REF: SRV-INC</span>
              <h3>Servicios Incluidos</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="logistics-card secondary">
            <div class="card-header">
              <span class="c-id">REF: EQP-TCN</span>
              <h3>Equipo Necesario</h3>
            </div>
            <ul class="log-list">
              {equipment.map(eq => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" class="log-icon-alt"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                  <span>{eq}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">ALTA DISPONIBILIDAD</span>
              <h3>Inicia tu Expedición</h3>
              <p>Solicita el dossier técnico de la Ruta Espectacular y asegura tu cupo para esta temporada.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">FECHA APROXIMADA</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">NOMBRES Y APELLIDOS</label>
                    <input type="text" id="full-name" placeholder="Escribe tu nombre completo" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  {t('trekking.book')}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>

      <div class="technical-notice">
        <div class="notice-box">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p><strong>RECOMENDACIÓN TÉCNICA:</strong> Debido a la duración y altitud de esta ruta, se recomienda encarecidamente realizar los días de aclimatación propuestos en Huaraz para garantizar el éxito de la expedición.</p>
        </div>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={lang}
    images={[
      '/trekking/huayhuash/ruta-huayhuash.png',
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png'
    ]} 
  />

  <RecommendedTours currentId="spectacular" />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "LA RUTA ESPECTACULAR HUAYHUASH 15D";
    
    const message = `Hola Franpisco Adventure! Me gustaría reservar un cupo para la expedición espectacular: ${tourName}. Mis datos son:\n\n- Nombre: ${name}\n- Fecha aprox: ${date}`;
    const whatsappUrl = `https://wa.me/51987654321?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  /* Reuse styles from other itinerary pages */
  .itinerary-hero {
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/trekking/huayhuash/ruta-huayhuash.png') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    padding-top: 5rem;
    text-align: center;
  
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom:  1.5rem;
  
    gap: 0.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  .metrics-bar {
    display: flex;
    justify-content: center;
    gap: 4rem;
    padding:  1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-light);
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  .m-value.price { color: var(--brand-blue); font-size: 1.2rem; }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    letter-spacing: 1px;
  }
  .dif-tag.hard { color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }

  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .dossier-sidebar {
    display: flex;
    justify-content: center;
  }
  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: var(--brand-light);
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: var(--brand-dark);
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: var(--brand-blue); }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--brand-dark);
    margin-bottom: 4rem;
    max-width: 550px;
    position: relative;
  }
  .dossier-p::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: #f1f5f9;
  }

  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .d-icon {
    margin-top: 0.2rem;
    color: var(--brand-blue);
    opacity: 0.6;
  }
  .d-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .d-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    color: var(--brand-light);
  }
  .d-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--brand-dark);
  }

  .dossier-visual { position: relative; }
  .visual-frame {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 550px;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .visual-frame:hover .dossier-img { transform: scale(1.05); }

  .coordinates-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .coordinates-overlay .divider { opacity: 0.3; font-weight: 300; }

  @media (max-width: 1024px) {
    .dossier-layout { grid-template-columns: 1fr; }
    .dossier-sidebar { display: none; }
    .dossier-img { height: 400px; }
  }

  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid #e2e8f0; }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .details-header-technical { margin-bottom: 2.5rem; }
  .sub-label { font-size: 0.65rem; font-weight: 800; letter-spacing: 5px; color: var(--brand-light); display: block; margin-bottom: 1rem; }
  .technical-title { font-size: 1.8rem; font-weight: 900; color: var(--brand-dark); letter-spacing: -1px; }
  .technical-title .blue { color: var(--brand-blue); }

  .path-timeline { position: relative; padding-left: 2rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px;
    top: 0;
