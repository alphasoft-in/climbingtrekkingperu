---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import RecommendedTours from '../../../components/RecommendedTours.astro';
import TourGallery from '../../../components/TourGallery.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DIA 01',
    title: 'LIMA PERU (161 MSNM) – HUARAZ (3100 MSNM)',
    content: 'Nosotros FRANPISCO ADVENTURE esperamos en el aeropuerto Jorge Chávez. Luego lo trasladamos al terminal de bus público para trasladarnos a la ciudad Huaraz, en el viaje se tarda unas 8 horas. Una vez que llegamos a Huaraz lo trasladamos al hotel. También hay posibilidad de viajar en avión Lima a Anta - Huaraz.'
  },
  {
    day: 'DIA 02',
    title: 'FULL DAY LAGUNA ROCUTOYOC (4450 MSNM) – ACLLIMATACION',
    content: 'Salida de Huaraz a las 6:00 am. Al tour laguna Rocutuyoc 4,450 msnm. con dirección al norte guiado por nuestro guía oficial de turismo. Visita mirador Cashapunta, cascada de Ruripaccha, pintura rupestre, laguna Rocutuyoc, laguna congelada y glaciar de Ruripaccha 4,650 msnm.'
  },
  {
    day: 'DIA 03',
    title: 'DIA LIBRE',
    content: 'Este dia consideramos un dia libre por precaución de altura y para retomar la energía antes de inicia el circuito cordillera Huayhuash.'
  },
  {
    day: 'DIA 04',
    title: 'TRASLADO HUARAZ (3100M) - CHIQUIÁN - CUARTELWAIN (4180 MSNM)',
    content: 'A las 8:00 am. nos dirigimos hasta Cuartelwain por 5 horas. donde nos esperan los burros y arrieros. Primer campamento en Cuartelwain a 4180 msnm para aclimatación.',
    stats: { trans: '05 horas', alt: '4180m', food: 'Almuerzo y Cena' }
  },
  {
    day: 'DIA 05',
    title: 'CUARTELWAIN (4180M) – MITUCOCHA (4230M)',
    content: 'Paso Cacananpunta 4,700 msnm. Observación de laguna Pucacocha, Yanacocha y el valle de Queropalca. Campamento Jancapampa 4,230 msnm con vista a Ninashanca y Jirishanca.',
    stats: { alt: '4700 m', dist: '09 km', time: '04 a 05 hs' }
  },
  {
    day: 'DIA 06',
    title: 'MITUCOCHA (4,230 MSNM) - CARHUACOCHA (4,280 MSNM)',
    content: 'Paso Carhuac 4,650 msnm. Camino alterno al mirador de tres lagunas. Vistas de montañas Suila, Yerupaja y el Toro.',
    stats: { alt: '4650 m', dist: '13 km', time: '6 hs' }
  },
  {
    day: 'DIA 07',
    title: 'CARHUACOCHA (4,280 MSNM) - HUAYHUASH (4,300 MSNM)',
    content: 'Dia de mayor dificultad. Mirador de las tres lagunas (Siulacocha, Ganrajanca, Azulcocha). Paso Siula 4,800 msnm.',
    stats: { alt: '4800 m', dist: '15 km', time: '09 hs' }
  },
  {
    day: 'DIA 08',
    title: 'HUAYHUASH (4,350 MSNM) - VICONGA (4,330 MSNM)',
    content: 'Paso Portachuelo 4,750 msnm. Vistas de Cordillera Raura. Campamento Viconga y baños termales naturales.',
    stats: { alt: '4750 m', dist: '11 km', time: '06 hs' }
  },
  {
    day: 'DIA 09',
    title: 'VICONGA (4,330 MSNM)- CUYOCPAMPA (4,550 MSNM)',
    content: 'Paso Cuyoc 5,000 msnm. Vistas totales de Raura y Huayhuash. Opcional: Mirador San Antonio 5,120 m.',
    stats: { alt: '5,050 m', dist: '13 km', time: '6 hs' }
  },
  {
    day: 'DIA 10',
    title: 'CUYOCPAMPA (4,550 MSNM) - HUAYLLAPA (3,630 MSNM)',
    content: 'Amanecer en el paso Santa Rosa 5,080 msnm. Descenso por laguna Jurao hasta el pueblo de Huayllapa.',
    stats: { alt: '5080 m', dist: '19 km', time: '10 hs' }
  },
  {
    day: 'DIA 11',
    title: 'HUAYLLAPA (3,630 MSNM) - GASHPAPAMPA (4,550 MSNM)',
    content: 'Subida al paso Tapush 4,800 msnm. Vista del nevado Diablo Mudo. Llegada a Gashpapampa.',
    stats: { alt: '4.800 m', dist: '15 km', time: '8 hs' }
  },
  {
    day: 'DIA 12',
    title: 'GASHPAPAMPA (4,550 MSNM) - LAGUNA JAHUACOCHA (4,100 MSNM)',
    content: 'Paso Yaucha 4,800 msnm. Mirador Huacrish con panorama de Jahuacocha y Soltera Cocha.',
    stats: { alt: '4800 m', dist: '12 km', time: '7 hs' }
  },
  {
    day: 'DIA 13',
    title: 'JAHUACOCHA (4,100 MSNM) - LLAMAC (3,300 MSNM)',
    content: 'Ultimo dia. Paso Pampa Llamac 3,900 m. Descenso al pueblo de Llamac y traslado a Huaraz.',
    stats: { alt: '3950 m', dist: '13 km', time: '6 hs' }
  },
  {
    day: 'DIA 14',
    title: 'HUARAZ – LIMA',
    content: 'Traslado al terminal de bus para el viaje de retorno a Lima.'
  },
  {
    day: 'DIA 15',
    title: 'LIMA – VUELO INTERNACIONAL',
    content: 'Traslado al aeropuerto Jorge Chávez. Fin de nuestros servicios.'
  }
];

const includes = [
  'Espera personalizada en aeropuerto Lima',
  'Tickets de bus Lima - Huaraz - Lima',
  '4 noches hotel (3*) en Huaraz, 1 noche en Lima',
  'Guía oficial de Trekking (AGMP/UIAGM)',
  'Cocinero especializado (menús variados)',
  'Tickets de entrada Huayhuash ($100 included)',
  '10kg equipaje personal en mulas',
  'Carpas de alta montaña y equipo de camping',
  'Alimentación completa durante el trek',
  'Botiquín y Oxígeno de primeros auxilios'
];

const equipment = [
  'Bolsa de dormir (-10°C / -15°C)',
  'Mochila de diario (30-40L)',
  'Botas de trekking (impermeables)',
  'Casaca de pluma y ropa térmica (capas)',
  'Gorro, guantes y lentes de sol',
  'Bloqueador solar y repelente',
  'Bastones de trekking',
  'Poncho de lluvia'
];
---

<Layout title="Trekking Huayhuash 360 - 15 Días | Franpisco Adventure" description="El circuito de trekking más espectacular de los Andes. 15 días explorando la Cordillera Huayhuash en servicio confort.">
  <section class="itinerary-hero">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <h1 class="split-title">
          <span class="thin">TREKKING CORDILLERA</span>
          <span class="bold">HUAYHUASH 360</span>
        </h1>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURACIÓN</span>
            <span class="m-value">15 DÍAS / 14 NOCHES</span>
          </div>
          <div class="metric">
            <span class="m-label">DESDE</span>
            <span class="m-value price">USD. 1,695.00</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFICULTAD</span>
            <span class="m-value">
              <span class="dif-tag hard">DIFÍCIL</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">PAQUETE TÉCNICO</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">LOG: HYH-360-15D</span>
            <h2 class="dossier-title">Exploración <span class="blue">Integral</span></h2>
          </div>
          
          <p class="dossier-p">Esta expedición de 15 días es la experiencia definitiva en los Andes peruanos. Rodearemos la Cordillera Huayhuash en su totalidad, cruzando pasos de más de 5,000 metros y acampando junto a lagunas glaciares de color turquesa intenso.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">BASE LOGÍSTICA</span>
                <span class="d-value">Huaraz, Perú</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">ZONA TÉCNICA</span>
                <span class="d-value">Andes Centrales</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">TEMPORADA</span>
                <span class="d-value">Abril - Diciembre</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">SERVICIO</span>
                <span class="d-value">Confort Superior</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/trekking/huayhuash/360.jpeg" alt="Trekking Huayhuash 360" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>9° 32' 26" S</span>
              <span class="divider">|</span>
              <span>77° 31' 39" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <!-- Main Timeline -->
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">SECUESTRACIÓN DE RUTA</span>
            <h2 class="technical-title">Cronograma <span class="blue">Diario</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day.split(' ')[1]}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <span class="w-day-label">{item.day}</span>
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">ALTITUD MÁX.</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.dist && (
                        <div class="w-stat">
                          <span class="w-s-label">DISTANCIA</span>
                          <span class="w-s-value">{item.stats.dist}</span>
                        </div>
                      )}
                      {item.stats.time && (
                        <div class="w-stat">
                          <span class="w-s-label">TIEMPO ESTIMADO</span>
                          <span class="w-s-value">{item.stats.time}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}

            <div class="timeline-end">
              <div class="end-mark"></div>
              <span class="end-text">FIN DE RUTA</span>
            </div>
          </div>
        </div>

        <!-- Logistics Sidebar -->
        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">MOD: LOG-INCL</span>
              <h3>Servicios Incluidos</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="logistics-card secondary">
            <div class="card-header">
              <span class="c-id">MOD: TECH-EQ</span>
              <h3>Equipo Sugerido</h3>
            </div>
            <ul class="log-list">
              {equipment.map(eq => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" class="log-icon-alt"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                  <span>{eq}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">DISPONIBILIDAD ABIERTA</span>
              <h3>Inicia tu Expedición</h3>
              <p>Solicita el paquete técnico completo de la ruta y asegura tu cupo para la temporada.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">FECHA APROXIMADA</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">NOMBRES Y APELLIDOS</label>
                    <input type="text" id="full-name" placeholder="Escribe tu nombre completo" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  {t('trekking.book')}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={lang}
    images={[
      '/trekking/huayhuash/360.jpeg',
      '/slider_4.png',
      '/slider_2.png',
      '/slider_5.png',
      '/slider_1.png'
    ]} 
  />

  <RecommendedTours currentId="360" />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "TREKKING CORDILLERA HUAYHUASH 360 FULL CIRCUIT 15D";
    
    const message = `Hola Franpisco Adventure! Me gustaría reservar un cupo para la expedición: ${tourName}. Mis datos son:\n\n- Nombre: ${name}\n- Fecha aprox: ${date}`;
    const whatsappUrl = `https://wa.me/51987654321?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  .itinerary-hero {
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/trekking/huayhuash/mini.jpeg') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    padding-top: 5rem;
    text-align: center;
  
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 3.5rem;
  
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  /* Metrics Bar */
  .metrics-bar {
    display: flex;
    justify-content: center;
    gap: 4rem;
    padding: 2.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-light);
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  .m-value.price { color: var(--brand-blue); font-size: 1.2rem; }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    letter-spacing: 1px;
  }
  .dif-tag.hard { color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }

  .metric .tag { background: #fee2e2; color: #ef4444; padding: 2px 8px; border-radius: 4px; font-size: 0.8rem; }

  /* Dossier Section - High End Boutique Style */
  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  /* Vertical Label Accent */
  .dossier-sidebar {
    display: flex;
    justify-content: center;
  }
  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: var(--brand-light);
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: var(--brand-dark);
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: var(--brand-blue); }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: #475569;
    margin-bottom: 4rem;
    max-width: 550px;
    position: relative;
  }
  .dossier-p::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: #f1f5f9;
  }

  /* Specs Dashboard */
  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .d-icon {
    margin-top: 0.2rem;
    color: var(--brand-blue);
    opacity: 0.6;
  }
  .d-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .d-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    color: var(--brand-light);
  }
  .d-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--brand-dark);
  }

  /* Visual Frame with Overlays */
  .dossier-visual { position: relative; }
  .visual-frame {
    position: relative;
    border-radius: 4px; /* Hard corner for technical look */
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 550px;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .visual-frame:hover .dossier-img { transform: scale(1.05); }

  .coordinates-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .coordinates-overlay .divider { opacity: 0.3; font-weight: 300; }

  @media (max-width: 1024px) {
    .dossier-layout { grid-template-columns: 1fr; }
    .dossier-sidebar { display: none; }
    .dossier-img { height: 400px; }
  }

  /* Details Layout */
  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid var(--brand-light); }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .details-header-technical { margin-bottom: 2.5rem; }
  .sub-label { font-size: 0.65rem; font-weight: 800; letter-spacing: 5px; color: var(--brand-light); display: block; margin-bottom: 1rem; }
  .technical-title { font-size: 1.8rem; font-weight: 900; color: var(--brand-dark); letter-spacing: -1px; }
  .technical-title .blue { color: var(--brand-blue); }

  /* Path Timeline */
  .path-timeline { position: relative; padding-left: 2rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--brand-blue), var(--brand-light), var(--brand-light));
  }

  .waypoint-item {
    display: flex;
    gap: 1.5rem;
    position: relative;
    margin-bottom: 1rem;
  }
  
  .waypoint-marker {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
