---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import RecommendedTours from '../../../components/RecommendedTours.astro';
import TourGallery from '../../../components/TourGallery.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DIA 01',
    title: 'LLEGADA A LIMA – PERU (161 MSNM) – HUARAZ (3100 MSNM)',
    content: 'Llegada al aeropuerto Jorge Chávez. Traslado a Huaraz en bus (8 horas) o avión (50 min). Recepción y traslado al hotel.',
    stats: { time: '8 hs' }
  },
  {
    day: 'DIA 02',
    title: 'ACLIMATACION: LAGUNA ROCUTOYOC (4450 MSNM) – CORDILLERA BLANCA',
    content: 'Visita al mirador Cashapunta, cascada Ruripaccha, pinturas rupestres y laguna Rocutuyoc. Caminata al glaciar Ruripaccha (4,650 msnm).',
    stats: { alt: '4450m', time: '9-10 hs' }
  },
  {
    day: 'DIA 03',
    title: 'DIA LIBRE',
    content: 'Día de descanso estratégico para optimizar la aclimatación y retomar energía antes de iniciar la expedición en Huayhuash.'
  },
  {
    day: 'DIA 04',
    title: 'HUARAZ (3100M) - CUARTELWAIN (4180M) - MITUCOCHA (4230M)',
    content: 'Traslado a Cuartelwain. Inicio del trekking cruzando el paso Cacananpunta (4,700 msnm). Vistas de Ninashanca, Rondoy y Jirishanca.',
    stats: { alt: '4700 m', dist: '09 km', time: '04-05 hs' }
  },
  {
    day: 'DIA 05',
    title: 'MITUCOCHA (4230 MSNM) - CARHUACOCHA (4,280 MSNM)',
    content: 'Caminata por el valle de Jancapampa. Paso Carhuac (4,650 msnm) o ruta alterna al mirador de tres lagunas. Vistas de Yerupaja y Siula.',
    stats: { alt: '4650 m', dist: '13 km', time: '6 hs' }
  },
  {
    day: 'DIA 06',
    title: 'CARHUACOCHA (4,280 MSNM) - HUAYHUASH (4,300 MSNM)',
    content: 'Día de mayor dificultad. Mirador de las tres lagunas (Siulacocha, Ganrajanca, Azulcocha). Paso Siula (4,800 msnm).',
    stats: { alt: '4800 m', dist: '15 km', time: '09 hs' }
  },
  {
    day: 'DIA 07',
    title: 'HUAYHUASH (4,350 MSNM) - VICONGA (4,330 MSNM)',
    content: 'Día tranquilo. Paso Portachuelo (4,750 msnm) con vistas de la Cordillera Raura. Campamento junto a las aguas termales de Viconga.',
    stats: { alt: '4750 m', dist: '11 km', time: '06 hs' }
  },
  {
    day: 'DIA 08',
    title: 'ASCENSIÓN MONTAÑA PUMARINRI (5465 MSNM) - CUYOCPAMPA',
    content: 'Ataque a la cumbre (01:30 am). 2 horas de glaciar hasta la cima. Vistas de Raura y Huayhuash. Descenso por el paso Cuyoc (5,000m).',
    stats: { alt: '5465 m', dist: '18 km', time: '14 hs' }
  },
  {
    day: 'DIA 09',
    title: 'CUYOCPAMPA (4,550 MSNM) - HUAYLLAPA (3,630 MSNM)',
    content: 'Paso Santa Rosa (5,080 msnm) al amanecer. Descenso por el valle de Calinca hasta el pueblo de Huayllapa.',
    stats: { alt: '5080 m', dist: '19 km', time: '10 hs' }
  },
  {
    day: 'DIA 10',
    title: 'HUAYLLAPA (3,630 MSNM) - GASHPAPAMPA (4,550 MSNM)',
    content: 'Ascenso exigente al paso Tapush (4,800 msnm). Vista del nevado Diablo Mudo. Campamento base Gashpapampa.',
    stats: { alt: '4800 m', dist: '15 km', time: '08 hs' }
  },
  {
    day: 'DIA 11',
    title: 'ASCENSIÓN MONTAÑA DIABLO MUDO (5350 M) – JAHUACOCHA (4100 M)',
    content: 'Ascenso a la cresta y cumbre (01:30 am). Vista fenomenal de la Cordillera Huayhuash. Descenso a la laguna Jahuacocha.',
    stats: { alt: '5350 m', dist: '19 km', time: '14 hs' }
  },
  {
    day: 'DIA 12',
    title: 'JAHUACOCHA (4,100 MSNM) - LLAMAC (3,300 MSNM)',
    content: 'Último día de caminata. Paso Pampa Llamac (3,900m). Descenso final a Llamac y traslado de retorno a Huaraz.',
    stats: { alt: '3950 m', dist: '13 km', time: '06 hs' }
  },
  {
    day: 'DIA 13',
    title: 'TRASLADO AL TERMINAL O AEROPUERTO',
    content: 'Traslado desde el hotel al terminal de bus o aeropuerto para el retorno a Lima. Fin de servicios.'
  }
];

const includes = [
  'Información técnica en oficina Huaraz',
  '1 Día de aclimatación (compartido)',
  'Traslados privados Huaraz - Huayhuash',
  'Guía oficial de Trekking y Guía de Montaña (UIAGM)',
  'Cocinero especializado en expediciones',
  'Pensión completa durante el trek (opción vegetariana/sin gluten)',
  'Burros y arrieros para carga (6kg equipo personal)',
  'Equipo de camping completo (carpa cocina, comedor, personal)',
  'Equipo técnico: Casco, Piolets, Arnés, Grampones, Cuerdas',
  'Woki toki y Botiquín de primeros auxilios'
];

const excludes = [
  'Tickets aéreos y de bus Lima-Huaraz',
  'Hoteles en Lima y Huaraz',
  'Bolsa de dormir (-10°C) y colchoneta',
  'Tickets de entrada Huayhuash (S/. 280.00)',
  'Seguro de accidentes (obligatorio)',
  'Propinas y gastos personales'
];

const equipment = [
  'Bolsa de dormir -10°C y Colchoneta',
  'Mochila de ataque 40L',
  'Botas de Trekking y Zapatos de Montaña',
  'Ropa técnica por capas (Pluma, Impermeable)',
  'Gorro para frío y sol, Guantes',
  'Lentes de sol con protección UV',
  'Bloqueador solar y Poncho de lluvia',
  'Bastones de trekking'
];
---

<Layout title="Cumbres de Huayhuash: Diablo Mudo y Pumarinri | Franpisco Adventure" description="Expedición de alta montaña en la Cordillera Huayhuash. Escalada en Diablo Mudo (5350m) y Pumarinri (5465m). 13 días de aventura técnica.">
  <section class="itinerary-hero">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <h1 class="split-title">
          <span class="thin">CUMBRES DE LA</span>
          <span class="bold">CORDILLERA HUAYHUASH</span>
        </h1>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURACIÓN</span>
            <span class="m-value">13 DÍAS / 12 NOCHES</span>
          </div>
          <div class="metric">
            <span class="m-label">DESDE</span>
            <span class="m-value price">USD. 1,995.00</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFICULTAD</span>
            <span class="m-value">
              <span class="dif-tag hard">DIFÍCIL</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">EXPEDICIÓN DE MONTAÑA</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">LOG: HYH-CB-13D</span>
            <h2 class="dossier-title">Diablo Mudo <span class="blue">& Pumarinri</span></h2>
          </div>
          
          <p class="dossier-p">Una expedición técnica diseñada para montañistas que buscan combinar el espectacular trekking de Huayhuash con cumbres de más de 5,000 metros, incluyendo el Diablo Mudo y Pumarinri.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">INICIO / LOGÍSTICA</span>
                <span class="d-value">Huaraz, Perú</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">ACTIVIDAD</span>
                <span class="d-value">Caminata y Montañismo</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">TEMPORADA</span>
                <span class="d-value">Abril - Diciembre</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">SERVICIO</span>
                <span class="d-value">Guía UIAGM Especializado</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/trekking/huayhuash/360.jpeg" alt="Cumbres de Huayhuash" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>10° 16' 18" S</span>
              <span class="divider">|</span>
              <span>76° 54' 14" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">PLANIFICACIÓN DE RUTA</span>
            <h2 class="technical-title">Itinerario <span class="blue">de Cumbres</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day.split(' ')[1]}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <span class="w-day-label">{item.day}</span>
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">ALTITUD</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.dist && (
                        <div class="w-stat">
                          <span class="w-s-label">DISTANCIA</span>
                          <span class="w-s-value">{item.stats.dist}</span>
                        </div>
                      )}
                      {item.stats.time && (
                        <div class="w-stat">
                          <span class="w-s-label">TIEMPO</span>
                          <span class="w-s-value">{item.stats.time}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}

            <div class="timeline-end">
              <div class="end-mark"></div>
              <span class="end-text">FIN DE RUTA</span>
            </div>
          </div>
        </div>

        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">MOD: LOG-INCL</span>
              <h3>Servicios Incluidos</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="logistics-card secondary">
            <div class="card-header">
              <span class="c-id">MOD: TECH-EQ</span>
              <h3>Equipo Técnico</h3>
            </div>
            <ul class="log-list">
              {equipment.map(eq => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" class="log-icon-alt"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                  <span>{eq}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">CONSULTAR LOGÍSTICA TÉCNICA</span>
              <h3>Inicia tu Expedición</h3>
              <p>Solicita el dossier técnico y asegura tu cupo para la temporada de cumbres.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">FECHA APROXIMADA</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">NOMBRES Y APELLIDOS</label>
                    <input type="text" id="full-name" placeholder="Escribe tu nombre completo" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  {t('trekking.book')}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>

      <div class="technical-notice">
        <div class="notice-box">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p><strong>REQUISITO OBLIGATORIO:</strong> Es indispensable contar con un seguro de accidentes de montaña al 100% que cubra rescate y gastos médicos.</p>
        </div>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={lang}
    images={[
      '/trekking/huayhuash/360.jpeg',
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png'
    ]} 
  />

  <RecommendedTours currentId="peaks" />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "CUMBRES DE LA CORDILLERA HUAYHUASH 13D";
    
    const message = `Hola Franpisco Adventure! Me gustaría reservar un cupo para la expedición de cumbres: ${tourName}. Mis datos son:\n\n- Nombre: ${name}\n- Fecha aprox: ${date}`;
    const whatsappUrl = `https://wa.me/51987654321?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  .itinerary-hero {
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/trekking/huayhuash/360.jpeg') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    padding-top: 5rem;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 3.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.9rem, 2.5vw, 1.3rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  .metrics-bar {
    display: flex;
    justify-content: center;
    gap: 4rem;
    padding: 2.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-light);
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  .m-value.price { color: var(--brand-blue); font-size: 1.2rem; }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    letter-spacing: 1px;
  }
  .dif-tag.hard { color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }

  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .dossier-sidebar {
    display: flex;
    justify-content: center;
  }
  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: var(--brand-light);
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: var(--brand-dark);
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: var(--brand-blue); }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--brand-dark);
    margin-bottom: 4rem;
    max-width: 550px;
    position: relative;
  }
  .dossier-p::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: #f1f5f9;
  }

  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .d-icon {
    margin-top: 0.2rem;
    color: var(--brand-blue);
    opacity: 0.6;
  }
  .d-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .d-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    color: var(--brand-light);
  }
  .d-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--brand-dark);
  }

  .dossier-visual { position: relative; }
  .visual-frame {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 550px;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .visual-frame:hover .dossier-img { transform: scale(1.05); }

  .coordinates-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .coordinates-overlay .divider { opacity: 0.3; font-weight: 300; }

  @media (max-width: 1024px) {
    .dossier-layout { grid-template-columns: 1fr; }
    .dossier-sidebar { display: none; }
    .dossier-img { height: 400px; }
  }

  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid #e2e8f0; }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .details-header-technical { margin-bottom: 2.5rem; }
  .sub-label { font-size: 0.65rem; font-weight: 800; letter-spacing: 5px; color: var(--brand-light); display: block; margin-bottom: 1rem; }
  .technical-title { font-size: 1.8rem; font-weight: 900; color: var(--brand-dark); letter-spacing: -1px; }
  .technical-title .blue { color: var(--brand-blue); }

  .path-timeline { position: relative; padding-left: 2rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--brand-blue), var(--brand-light), var(--brand-light));
  }

  .waypoint-item {
    display: flex;
    gap: 1.5rem;
    position: relative;
    margin-bottom: 1rem;
  }
  
  .waypoint-marker {
    position: relative;
    z-index: 2;
