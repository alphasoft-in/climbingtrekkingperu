---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import RecommendedTours from '../../components/RecommendedTours.astro';
import TourGallery from '../../components/TourGallery.astro';

const langUrl = getLangFromUrl(Astro.url);
const t = useTranslations(langUrl);

const itinerary = [
  {
    day: 'DÍA 01',
    title: 'LA PAZ – LAGUNA CHIAR KHOTA (4650 M)',
    content: 'Traslado al pie del macizo Condoriri. Caminata suave hasta el campo base a orillas de la laguna.',
    stats: { alt: '4650m' }
  },
  {
    day: 'DÍA 02',
    title: 'PRÁCTICA EN GLACIAR TARIJA',
    content: 'Aclimatación y repaso de técnicas de progresión en hielo en el glaciar Tarija.',
    stats: { status: 'Training', alt: '5000m' }
  },
  {
    day: 'DÍA 03',
    title: 'CUMBRE PEQUEÑO ALPAMAYO (5410 M)',
    content: 'Ascensión técnica por una de las aristas más estéticas de los Andes. Retorno al campo base.',
    stats: { time: '8h Day', alt: '5410m' }
  },
  {
    day: 'DÍA 04',
    title: 'CONDORIRI – REFUGIO HUAYNA POTOSÍ (4680 M)',
    content: 'Traslado logístico hacia el valle de Zongo. Tarde de descanso y preparación.',
    stats: { status: 'Transfer', alt: '4680m' }
  },
  {
    day: 'DÍA 05',
    title: 'REFUGIO – CAMPO ALTO (5280 M)',
    content: 'Ascenso al Campo Alto (Refugio Roca). Hidratación y preparación para el ataque a la cumbre.',
    stats: { time: '3h Ascent', alt: '5280m' }
  },
  {
    day: 'DÍA 06',
    title: 'CUMBRE HUAYNA POTOSÍ (6088 M) – LA PAZ',
    content: 'Ataque a la cumbre a medianoche. Descenso completo hasta Zongo y retorno a La Paz.',
    stats: { time: '10h Day', alt: '6088m' }
  }
];

const includes = [
  'Transporte privado para toda la logística',
  'Guía de Montaña Certificado UIAGM (Ratio 1:2)',
  'Cocinero y alimentación completa en montaña',
  'Mulas de carga para equipo en Condoriri',
  'Pernocte en refugios y carpas de alta montaña',
  'Equipo de campamento grupal',
  'Tickets de entrada (Condoriri y Zongo)',
  'Botiquín y Oxígeno de emergencia'
];

const excludes = [
  'Vuelos y Hotel en La Paz',
  'Equipo técnico personal',
  'Saco de dormir y colchoneta',
  'Seguro de accidentes',
  'Propinas'
];

const equipment = [
  'Botas dobles de montaña',
  'Grampones y Piolet técnico',
  'Arnés, casco y mosquetones',
  'Ropa de abrigo extrema (Capa 3)',
  'Gafas de sol Cat. 4',
  'Linterna frontal'
];
---

<Layout title="Expedición Condoriri & Huayna Potosí | Bolivia | Franpisco Adventure" description="Domina la Cordillera Real con esta expedición de 6 días: Pequeño Alpamayo (5410m) y la cumbre del Huayna Potosí (6088m).">
  <section class="itinerary-hero bolivia-condoriri">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <div class="path-log">
          <a href={getRelativeLocaleUrl(langUrl, 'bolivia')} class="back-project">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3"><path d="M19 12H5m7 7l-7-7 7-7"/></svg>
          </a>
          <span class="p-base">BOLIVIA</span>
          <span class="p-divider">/</span>
          <span class="p-base">TECHNICAL CLIMBING</span>
          <span class="p-divider">/</span>
          <span class="p-current">CONDORIRI & HUAYNA</span>
        </div>
        
        <h1 class="split-title">
          <span class="thin">THE ULTIMATE CLIMB</span>
          <span class="bold">CONDORIRI & HUAYNA</span>
        </h1>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURACIÓN</span>
            <span class="m-value">6 DÍAS</span>
          </div>
          <div class="metric">
            <span class="m-label">ALTITUD MÁX</span>
            <span class="m-value">6,088 MSNM</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFICULTAD</span>
            <span class="m-value">
              <span class="dif-tag hard">TÉCNICA / ALTA</span>
            </span>
          </div>
          <div class="metric">
            <span class="m-label">COSTO</span>
            <span class="m-value">USD 895.00</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">MOUNTAIN LOGBOOK</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">LOG: BOL-CH-06</span>
            <h2 class="dossier-title">La Arista <span class="blue">Perfecta</span></h2>
          </div>
          
          <p class="dossier-p">Esta expedición concentra la esencia del alpinismo en Bolivia. El **Pequeño Alpamayo**, famoso por su arista estética y técnica, sirve como la preparación perfecta para enfrentar el gigante de la región: el **Huayna Potosí**.</p>
          <p class="dossier-p">Diseñado para montañistas que buscan progresar en técnica glaciar y alcanzar su primer 6000m con una logística impecable y guías certificados de alto nivel.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">MACIZOS</span>
                <span class="d-value">Condoriri & Zongo</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">ACTIVIDAD</span>
                <span class="d-value">Alpinismo Técnico</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/slider_5.png" alt="Pequeño Alpamayo Ridge" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>16° 10' 11" S</span>
              <span class="divider">|</span>
              <span>68° 14' 00" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">MISSION LOGBOOK</span>
            <h2 class="technical-title">Itinerario de <span class="blue">Ataque</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">MSNM</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.status && (
                        <div class="w-stat">
                          <span class="w-s-label">ESTADO</span>
                          <span class="w-s-value">{item.stats.status}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">MOD: LOG-INC</span>
              <h3>Servicios Incluidos</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="logistics-card secondary">
            <div class="card-header">
              <span class="c-id">MOD: GEAR-REQ</span>
              <h3>Equipo Técnico</h3>
            </div>
            <ul class="log-list">
              {equipment.map(item => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon-blue"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">6000M MISSION</span>
              <h3>Reserva tu Expedición</h3>
              <p>Únete a la cordada y conquista las cumbres más icónicas de Bolivia.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">FECHA ESTIMADA</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">NOMBRE COMPLETO</label>
                    <input type="text" id="full-name" placeholder="Tu nombre" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  {t('trekking.book')}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={langUrl}
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <RecommendedTours currentId="condoriri-huayna-exp-bol" />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "EXPEDICIÓN CONDORIRI & HUAYNA POTOSÍ";
    
    const message = `¡Hola Franpisco Adventure! Deseo reservar para la expedición Condoriri - Huayna Potosí en Bolivia. Mis datos:\n\n- Nombre: ${name}\n- Fecha: ${date}`;
    const whatsappUrl = `https://wa.me/51962421830?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  .itinerary-hero {
    position: relative;
    height: 70vh;
    min-height: 600px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/slider_5.png') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    color: white;
    padding-top: 5rem;
  }
  .itinerary-hero.bolivia-condoriri { background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/slider_5.png'); }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .path-log {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #94a3b8;
    margin-bottom: 2rem;
  }

  .back-project {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
    border-radius: 4px;
    text-decoration: none;
    transition: 0.3s;
    margin-right: 0.5rem;
  }
  .back-project:hover {
    background: #0090cc;
    border-color: #0090cc;
    transform: translateX(-5px);
  }

  .p-divider { color: rgba(255,255,255,0.2); font-weight: 300; }
  .p-current { color: #0090cc; }

  .split-title {
    display: flex;
    flex-direction: column;
    margin-bottom: 3.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.9rem, 2.5vw, 1.3rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  .metrics-bar {
    display: flex;
    gap: 4rem;
    padding: 2.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
    flex-wrap: wrap;
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #94a3b8;
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    border-radius: 2px;
    letter-spacing: 1px;
    font-weight: 900;
  }
  .dif-tag.hard { background: #fee2e2; color: #ef4444; border: 1px solid #fecaca; }

  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: #94a3b8;
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #0090cc;
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: #030405;
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: #0090cc; }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: #475569;
    margin-bottom: 4rem;
    max-width: 550px;
  }

  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec { display: flex; gap: 1.2rem; align-items: flex-start; }
  .d-icon { color: #0090cc; opacity: 0.6; margin-top: 0.2rem; }
  .d-info { display: flex; flex-direction: column; gap: 0.4rem; }
  .d-label { font-size: 0.6rem; font-weight: 800; color: #94a3b8; letter-spacing: 1.5px; }
  .d-value { font-size: 0.95rem; font-weight: 700; color: #030405; }

  .visual-frame {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 600px;
    object-fit: cover;
  }

  .coordinates-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid #e2e8f0; }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .sub-label { font-size: 0.6rem; font-weight: 800; color: #0090cc; margin-bottom: 0.5rem; display: block; }
  .technical-title { font-size: 2.2rem; font-weight: 900; color: #030405; margin-bottom: 2rem; letter-spacing: -1px; }
  .technical-title .blue { color: #0090cc; }

  .path-timeline { position: relative; padding-left: 2rem; margin-top: 3rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, #0090cc, #94a3b8, #94a3b8);
  }

  .waypoint-item { display: flex; gap: 1.5rem; margin-bottom: 4rem; position: relative; }
  .waypoint-marker { position: relative; z-index: 2; flex-shrink: 0; }
  .marker-box {
    width: 90px;
    height: 40px;
    background: white;
    border: 2px solid #030405;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  .m-day { font-size: 0.75rem; font-weight: 900; color: #030405; }

  .w-title { font-size: 1.15rem; font-weight: 800; color: #030405; margin-bottom: 0.8rem; }
  .w-description { font-size: 0.88rem; line-height: 1.8; color: #475569; margin-bottom: 1rem; }

  .waypoint-stats { display: flex; gap: 2rem; padding-top: 1rem; border-top: 1px solid #e2e8f0; }
  .w-stat { display: flex; flex-direction: column; gap: 0.4rem; }
  .w-s-label { font-size: 0.6rem; font-weight: 800; color: #94a3b8; letter-spacing: 1px; }
  .w-s-value { font-size: 0.75rem; font-weight: 700; color: #030405; }

  .logistics-sidebar { display: flex; flex-direction: column; gap: 3rem; padding-top: 6.5rem; }
  .logistics-card { background: white; padding: 2.5rem; border: 1px solid #e2e8f0; }
  .log-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .log-list li { display: flex; gap: 1rem; align-items: flex-start; font-size: 0.82rem; color: #475569; }
  .log-icon { color: #0090cc; flex-shrink: 0; margin-top: 0.2rem; }
  .log-icon-blue { color: #0090cc; flex-shrink: 0; margin-top: 0.2rem; }

  .mission-cta { background: #030405; color: white; padding: 3rem; }
  .cta-status { font-size: 0.6rem; font-weight: 900; color: #0090cc; letter-spacing: 2px; display: block; margin-bottom: 1.5rem; }
  .mission-cta h3 { font-size: 1.6rem; font-weight: 900; margin-bottom: 1rem; }
  .mission-cta p { font-size: 0.95rem; opacity: 0.7; margin-bottom: 2rem; }

  .btn-tactical {
    width: 100%;
    background: #0090cc;
    color: white;
    border: none;
    padding: 1.2rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    cursor: pointer;
    transition: 0.3s;
  }
  .btn-tactical:hover { background: #0070a0; }

  @media (max-width: 1024px) {
    .dossier-layout { grid-template-columns: 1fr; }
    .details-layout { grid-template-columns: 1fr; }
    .logistics-sidebar { padding-top: 0; }
  }
</style>
