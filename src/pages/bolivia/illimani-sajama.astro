---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import RecommendedTours from '../../components/RecommendedTours.astro';
import TourGallery from '../../components/TourGallery.astro';

const langUrl = getLangFromUrl(Astro.url);
const t = useTranslations(langUrl);

const itinerary = [
  {
    day: 'DÍA 01',
    title: 'LLEGADA A LA PAZ (3640 M)',
    content: 'Recepción en el aeropuerto y traslado al hotel. Revisión de equipo para los colosos bolivianos.',
    stats: { alt: '3640m' }
  },
  {
    day: 'DÍA 02',
    title: 'TOUR ISLA DEL SOL (3850 M)',
    content: 'Viaje al Titicaca. Navegación y caminata en la Isla del Sol para una aclimatación mística.',
    stats: { time: '8h Day', alt: '3850m' }
  },
  {
    day: 'DÍA 03',
    title: 'RETORNO A LA PAZ',
    content: 'Regreso a la ciudad y tarde de descanso.',
    stats: { status: 'Transfer' }
  },
  {
    day: 'DÍA 04',
    title: 'DÍA DE DESCANSO EN LA PAZ',
    content: 'Recuperación de energías antes de las grandes ascensiones.',
    stats: { status: 'Rest' }
  },
  {
    day: 'DÍA 05',
    title: 'LA PAZ – PUEBLO DE PINAYA (3800 M)',
    content: 'Traslado al pie del Illimani. Pernocte en casa familiar andina.',
    stats: { time: '5h Drive', alt: '3800m' }
  },
  {
    day: 'DÍA 06',
    title: 'PINAYA – NIDO DE CÓNDORES (5200 M)',
    content: 'Ascensión al campo alto del Illimani. Vistas impresionantes de la ciudad de La Paz.',
    stats: { time: '5h Ascent', alt: '5200m' }
  },
  {
    day: 'DÍA 07',
    title: 'CUMBRE NEVADO ILLIMANI (6438 M)',
    content: 'Ataque a la cumbre del guardián de La Paz. Descenso hasta el pueblo de Pinaya.',
    stats: { time: '11h Day', alt: '6438m' }
  },
  {
    day: 'DÍA 08',
    title: 'PINAYA – LA PAZ',
    content: 'Regreso a La Paz para reabastecimiento y descanso.',
    stats: { status: 'Transfer' }
  },
  {
    day: 'DÍA 09',
    title: 'LA PAZ – PUEBLO DE SAJAMA (4280 M)',
    content: 'Viaje a la Cordillera Occidental. Visita a la "Capilla Sixtina del Altiplano".',
    stats: { time: '5h Drive', alt: '4280m' }
  },
  {
    day: 'DÍA 10',
    title: 'SAJAMA – CAMPO ALTO (5700 M)',
    content: 'Ascenso al campo alto del volcán más alto de Bolivia con apoyo de porteadores.',
    stats: { time: '6h Ascent', alt: '5700m' }
  },
  {
    day: 'DÍA 11',
    title: 'CUMBRE NEVADO SAJAMA (6542 M)',
    content: 'Cumbre en el techo de Bolivia. Descenso a aguas termales para relajar el cuerpo.',
    stats: { time: '12h Day', alt: '6542m' }
  },
  {
    day: 'DÍA 12',
    title: 'SAJAMA – LA PAZ',
    content: 'Retorno final a La Paz y cena de despedida.',
    stats: { time: '5h Drive' }
  },
  {
    day: 'DÍA 13',
    title: 'LA PAZ – AEROPUERTO',
    content: 'Traslado al aeropuerto El Alto. Fin de la expedición.',
    stats: { status: 'Departure' }
  }
];

const includes = [
  'Traslados Aeropuerto - Hotel - Aeropuerto',
  'Transporte privado 4x4 para toda la logística',
  'Guía de Montaña Certificado UIAGM',
  'Cocinero especializado y alimentación completa',
  'Porteadores para campamentos altos en Sajama',
  'Tickets de entrada a Parques Nacionales (Sajama/Illimani)',
  'Equipo de campamento de alta montaña',
  'Oxígeno suplementario y botiquín avanzado',
  'Hospedaje en pueblos andinos (Pinaya/Sajama)'
];

const excludes = [
  'Vuelos internacionales',
  'Noches de hotel en La Paz',
  'Equipo técnico personal',
  'Seguro de accidentes en montaña',
  'Propinas y extras'
];

const equipment = [
  'Saco de dormir extremo (-30°C)',
  'Botas dobles o triples para 6000m+',
  'Piolets técnicos y Grampones',
  'Arnés, mosquetones y casco',
  'Ropa técnica de expedición (Capa 3, Pluma pesada)',
  'Gafas de sol (Cat. 4) y Goggles',
  'Mochila de 70L y Mochila de ataque 40L',
  'Botiquín personal'
];
---

<Layout title="Illimani & Sajama: Los Gigantes de Bolivia | Franpisco Adventure" description="Escala las dos cumbres más altas de Bolivia: Illimani (6438m) y Sajama (6542m) en una expedición épica de 13 días.">
  <section class="itinerary-hero bolivia-giants">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <h1 class="split-title">
          <span class="thin">BOLIVIA'S HIGHEST SUMMITS</span>
          <span class="bold">ILLIMANI & SAJAMA 6542M</span>
        </h1>
        <div class="hero-accent-bar"></div>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURACIÓN</span>
            <span class="m-value">13 DÍAS</span>
          </div>
          <div class="metric">
            <span class="m-label">ALTITUD MÁX</span>
            <span class="m-value">6,542 MSNM</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFICULTAD</span>
            <span class="m-value">
              <span class="dif-tag hard">ALTA MONTAÑA / EXTREMA</span>
            </span>
          </div>
          <div class="metric">
            <span class="m-label">COSTO</span>
            <span class="m-value">USD 1,795.00</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">ULTIMATE EXPEDITION</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">CÓDIGO: BOL-GIA-13</span>
            <h2 class="dossier-title">Cumbres de <span class="blue">Plata y Fuego</span></h2>
          </div>
          
          <p class="dossier-p">Esta expedición une los dos colosos más emblemáticos de Bolivia. El **Illimani**, guardián de plata que domina el horizonte de La Paz, y el **Sajama**, el volcán más alto del país, ubicado en el remoto altiplano occidental.</p>
          <p class="dossier-p">Es un desafío diseñado para montañistas experimentados que buscan conquistar alturas superiores a los 6400 metros, combinando logística de alta montaña con la cultura viva de los pueblos de Sajama y Pinaya.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">PUNTO PARTIDA</span>
                <span class="d-value">La Paz, Bolivia</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">ACTIVIDAD</span>
                <span class="d-value">Expedición 6400+</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">DURACIÓN</span>
                <span class="d-value">13 Días de Misión</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">DIFICULTAD</span>
                <span class="d-value">Física Intensa</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/slider_1.png" alt="Nevado Sajama" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>18° 06' 14" S</span>
              <span class="divider">|</span>
              <span>68° 52' 55" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">ITINERARIO DE EXPEDICIÓN</span>
            <h2 class="technical-title">El Itinerario <span class="blue">Maestro</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">MSNM</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.time && (
                        <div class="w-stat">
                          <span class="w-s-label">DURACIÓN</span>
                          <span class="w-s-value">{item.stats.time}</span>
                        </div>
                      )}
                      {item.stats.status && (
                        <div class="w-stat">
                          <span class="w-s-label">TIPO</span>
                          <span class="w-s-value">{item.stats.status}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">REF: SRV-INC</span>
              <h3>Servicios Incluidos</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="logistics-card secondary">
            <div class="card-header">
              <span class="c-id">REF: GEAR-REQ</span>
              <h3>Equipo Requerido</h3>
            </div>
            <ul class="log-list">
              {equipment.map(item => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon-blue"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">6500+ CHALLENGE</span>
              <h3>Reserva tu Lugar</h3>
              <p>Únete a la expedición más ambiciosa de Bolivia. Conquista el Sajama y el Illimani con logística de élite.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">FECHA ESTIMADA</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">NOMBRE COMPLETO</label>
                    <input type="text" id="full-name" placeholder="Tu nombre" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  {t('trekking.book')}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={langUrl}
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <RecommendedTours currentId="illimani-sajama-bol" />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "ILLIMANI & SAJAMA: LOS GIGANTES DE BOLIVIA";
    
    const message = `¡Hola Franpisco Adventure! Deseo reservar para la expedición de gigantes en Bolivia (Illimani/Sajama). Mis datos:\n\n- Nombre: ${name}\n- Fecha: ${date}`;
    const whatsappUrl = `https://wa.me/51962421830?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  .itinerary-hero {
    position: relative;
    height: 70vh;
    min-height: 600px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/slider_1.png') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    color: white;
    padding-top: 5rem;
  
    justify-content: center;
    text-align: center;
  }
  .itinerary-hero.bolivia-giants { background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/slider_1.png'); 
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    margin-bottom:  1.5rem;
  
    align-items: center;
    gap: 0.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  .metrics-bar {
    display: flex;
    gap: 4rem;
    padding:  1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
    flex-wrap: wrap;
  
    justify-content: center;
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #94a3b8;
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    border-radius: 2px;
    letter-spacing: 1px;
    font-weight: 900;
  }
  .dif-tag.hard { background: #fee2e2; color: #ef4444; border: 1px solid #fecaca; }

  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: #94a3b8;
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #0090cc;
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: #030405;
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: #0090cc; }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: #475569;
    margin-bottom: 4rem;
    max-width: 550px;
  }

  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec { display: flex; gap: 1.2rem; align-items: flex-start; }
  .d-icon { color: #0090cc; opacity: 0.6; margin-top: 0.2rem; }
  .d-info { display: flex; flex-direction: column; gap: 0.4rem; }
  .d-label { font-size: 0.6rem; font-weight: 800; color: #94a3b8; letter-spacing: 1.5px; }
  .d-value { font-size: 0.95rem; font-weight: 700; color: #030405; }

  .visual-frame {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 600px;
    object-fit: cover;
  }

  .coordinates-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid #e2e8f0; }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .sub-label { font-size: 0.6rem; font-weight: 800; color: #0090cc; margin-bottom: 0.5rem; display: block; }
  .technical-title { font-size: 2.2rem; font-weight: 900; color: #030405; margin-bottom: 2rem; letter-spacing: -1px; }
  .technical-title .blue { color: #0090cc; }

  .path-timeline { position: relative; padding-left: 2rem; margin-top: 3rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, #0090cc, #94a3b8, #94a3b8);
  }

  .waypoint-item { display: flex; gap: 1.5rem; margin-bottom: 4rem; position: relative; }
  .waypoint-marker { position: relative; z-index: 2; flex-shrink: 0; }
  .marker-box {
    width: 90px;
    height: 40px;
    background: white;
    border: 2px solid #030405;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  .m-day { font-size: 0.75rem; font-weight: 900; color: #030405; }

  .w-title { font-size: 1.15rem; font-weight: 800; color: #030405; margin-bottom: 0.8rem; }
  .w-description { font-size: 0.88rem; line-height: 1.8; color: #475569; margin-bottom: 1rem; }

  .waypoint-stats { display: flex; gap: 2rem; padding-top: 1rem; border-top: 1px solid #e2e8f0; }
  .w-stat { display: flex; flex-direction: column; gap: 0.4rem; }
  .w-s-label { font-size: 0.6rem; font-weight: 800; color: #94a3b8; letter-spacing: 1px; }
  .w-s-value { font-size: 0.75rem; font-weight: 700; color: #030405; }

  .logistics-sidebar { display: flex; flex-direction: column; gap: 3rem; padding-top: 6.5rem; }
  .logistics-card { background: white; padding: 2.5rem; border: 1px solid #e2e8f0; }
  .log-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .log-list li { display: flex; gap: 1rem; align-items: flex-start; font-size: 0.82rem; color: #475569; }
  .log-icon { color: #0090cc; flex-shrink: 0; margin-top: 0.2rem; }
  .log-icon-blue { color: #0090cc; flex-shrink: 0; margin-top: 0.2rem; }

  .mission-cta { background: #030405; color: white; padding: 3rem; }
  .cta-status { font-size: 0.6rem; font-weight: 900; color: #0090cc; letter-spacing: 2px; display: block; margin-bottom: 1.5rem; }
  .mission-cta h3 { font-size: 1.6rem; font-weight: 900; margin-bottom: 1rem; }
  .mission-cta p { font-size: 0.95rem; opacity: 0.7; margin-bottom: 2rem; }

  .btn-tactical {
    width: 100%;
    background: #0090cc;
    color: white;
    border: none;
    padding: 1.2rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    cursor: pointer;
    transition: 0.3s;
  }
  .btn-tactical:hover { background: #0070a0; }

  .form-group { margin-bottom: 1.5rem; }
  .form-group label { display: block; font-size: 0.6rem; font-weight: 800; color: #0090cc; margin-bottom: 0.5rem; }
  .form-group input {
    width: 100%;
