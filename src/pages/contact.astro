---
import Layout from '../layouts/Layout.astro';
---

<Layout 
	title="Base Logística y Transmisión - Franpisco Adventure"
	description="Ponte en contacto operativo en Huaraz. WhatsApp habilitado."
>
	<!-- High-End Technical Hero: Editorial Expedition Log (Sync with About Us) -->
	<section class="page-hero">
		<div class="hero-bg" style="background-image: url('/expedicion.jpg');"></div>
		<div class="hero-overlay"></div>
		
		<div class="hero-container">
			<div class="hero-main-layout">
				<div class="hero-text-block">
					<h1 class="hero-title">Central <br/><strong>Logística</strong></h1>
					<div class="hero-accent-bar"></div>
				</div>

				<div class="hero-side-technical">
					<div class="tech-item">
						<label>ELEVATION</label>
						<span>3,052 M.S.N.M.</span>
					</div>
					<div class="tech-item">
						<label>COORDINATES</label>
						<span>9°31′48″S 77°31′44″W</span>
					</div>
					<div class="tech-item">
						<label>FOUNDED</label>
						<span>EST. 2015 / PERÚ</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="dossier-page contact-dossier">
		<div class="container--narrow">
			<div class="dossier-grid">
				<!-- Panel de Briefing -->
				<div class="briefing-panel">
					
					<div class="technical-brief">
						<div class="brief-item">
							<span class="brief-code">01 // GEOLOCALIZACIÓN</span>
							<h3 class="brief-value">HUARAZ HQ</h3>
							<p class="brief-text">Jr. Trinitarias S/N, Pasaje Sarita Colonia 191 2do Piso, Huaraz - Ancash - Perú.</p>
							<div class="coord-tag">HOURS: MON - SAT / 09:00 - 18:00</div>
						</div>

						<div class="brief-item">
							<span class="brief-code">02 // CANAL TRANSMISIÓN</span>
							<h3 class="brief-value">DATA HUB</h3>
							<p class="brief-text">Recepción de planes operativos y expediciones corporativas.</p>
							<div class="email-stack" style="display: flex; flex-direction: column; gap: 5px;">
								<a href="mailto:info@franpiscoadventureperu.com" class="brief-link">info@franpiscoadventureperu.com</a>
								<a href="mailto:franpiscoadventureperu@hotmail.com" class="brief-link" style="font-size: 0.85rem; opacity: 0.8;">franpiscoadventureperu@hotmail.com</a>
							</div>
						</div>

						<div class="brief-item highlight-base">
							<span class="brief-code text-blue">03 // COMUNICACIÓN CRÍTICA</span>
							<h3 class="brief-value">WHATSAPP 24/7</h3>
							<p class="brief-text text-light">Enlace directo para soporte inmediato en campo y oficina.</p>
							<a href="https://wa.me/51962421830" class="huge-contact">+51 962 421 830</a>
						</div>
					</div>

				</div>

				<!-- Formulario Dossier -->
				<div class="form-dossier">
					<form class="surgical-form" action="#" method="POST">
						<div class="form-header">
							<span class="form-tag">DOC: RES-FM-01</span>
							<h3 class="f-title">Formulario de <span class="blue">Reserva Formal</span></h3>
						</div>
						
						<div class="s-row">
							<div class="s-group">
								<label>Nombre Completo / Agencia</label>
								<input type="text" placeholder="EJ: JOHN ALPINE / THE ROCK GROUP" required>
							</div>
							<div class="s-group">
								<label>Correo de Respuesta</label>
								<input type="email" placeholder="EXPLORADOR.BASE@EJEMPLO.COM" required>
							</div>
						</div>

						<div class="s-group">
							<label>Detalles del Plan Logístico</label>
							<textarea rows="6" placeholder="DIGITE MONTAÑAS DE INTERÉS, TAMAÑO DE GRUPO Y FECHAS..." required></textarea>
						</div>

						<button class="mission-action-btn" type="submit">
							<span class="btn-text">SOMETER PLAN A REVISIÓN</span>
							<span class="btn-icon">➔</span>
						</button>
					</form>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
  /* --- TECHNICAL ARCHITECTURAL HERO (SYNC WITH ABOUT) --- */
  .page-hero {
    position: relative;
    height: 75vh;
    min-height: 550px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #06090f;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
    transform: scale(1.05);
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, 
      rgba(6, 9, 15, 0.9) 0%, 
      rgba(6, 9, 15, 0.4) 50%, 
      rgba(6, 9, 15, 0.8) 100%),
      linear-gradient(to bottom, rgba(0,0,0,0.2), rgba(0,0,0,0.5));
  }

  .hero-container {
    position: relative;
    z-index: 10;
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    padding: 0 5%;
    display: flex;
    flex-direction: column;
  }

  .hero-main-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .hero-text-block {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: white;
    text-transform: uppercase;
    font-weight: 200;
    margin: 0;
    line-height: 0.95;
    letter-spacing: -1px;
  }
  .hero-title strong { 
    font-weight: 800; 
    display: block;
  }

  .hero-accent-bar {
    width: 80px;
    height: 5px;
    background: var(--brand-red);
    margin: 1rem auto 0;
  }

  .hero-side-technical {
    display: flex;
    justify-content: center;
    gap: clamp(2rem, 5vw, 4rem);
    padding-top: 1.5rem;
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    width: 100%;
    max-width: 800px;
    margin-top: 2rem;
  }

  .tech-item { display: flex; flex-direction: column; gap: 5px; }
  .tech-item label {
    font-size: 0.65rem;
    color: var(--brand-blue);
    font-weight: 800;
    letter-spacing: 2px;
  }
  .tech-item span {
    font-size: 1rem;
    color: #fff;
    font-weight: 600;
  }

  /* --- DOSSIER CONTENT --- */
  .contact-dossier {
    padding: 10rem 0;
    background: #ffffff;
    min-height: 80vh;
  }

  .container--narrow {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .dossier-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 6rem;
  }

  .technical-brief {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .brief-item {
    position: relative;
    padding-left: 2rem;
    border-left: 2px solid var(--brand-light);
  }

  .brief-code {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-light);
    display: block;
    margin-bottom: 0.8rem;
  }
  .brief-code.text-blue { color: var(--brand-blue); }

  .brief-value {
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--brand-dark);
    margin-bottom: 0.5rem;
    letter-spacing: -0.5px;
  }

  .brief-text {
    font-size: 0.9rem;
    color: var(--brand-dark);
    opacity: 0.7;
    margin-bottom: 1.2rem;
    line-height: 1.6;
  }
  .brief-text.text-light { color: var(--brand-light); opacity: 0.9; }

  .coord-tag {
    font-size: 0.65rem;
    font-weight: 800;
    color: var(--brand-blue);
    background: rgba(0, 144, 204, 0.05);
    padding: 4px 10px;
    display: inline-block;
    border-radius: 2px;
    font-family: inherit;
  }

  .brief-link {
    font-size: 1rem;
    font-weight: 700;
    color: var(--brand-blue);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .highlight-base {
    background: var(--brand-dark);
    padding: 2.5rem;
    border-radius: 4px;
    border-left: none;
  }
  .highlight-base .brief-value { color: #ffffff; }

  .huge-contact {
    font-size: 1.6rem;
    font-weight: 900;
    color: #ffffff;
    text-decoration: none;
    letter-spacing: -1px;
    display: block;
    margin-top: 1rem;
    transition: 0.3s;
  }
  .huge-contact:hover { color: var(--brand-blue); transform: translateX(5px); }

  .form-dossier {
    background: #ffffff;
    padding: 4rem;
    border: 1px solid var(--brand-light);
    box-shadow: 0 40px 80px rgba(0,0,0,0.03);
  }

  .form-header { margin-bottom: 3.5rem; }
  .form-tag {
    font-size: 0.55rem;
    font-weight: 800;
    color: var(--brand-blue);
    letter-spacing: 2px;
    display: block;
    margin-bottom: 0.8rem;
  }
  .form-header .f-title {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--brand-dark);
    letter-spacing: -0.5px;
  }
  .form-header .f-title .blue { color: var(--brand-blue); }

  .surgical-form {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .s-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }

  .s-group {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .s-group label {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-light);
    text-transform: uppercase;
  }

  .s-group input, .s-group textarea {
    padding: 1.2rem;
    border: 1px solid var(--brand-light);
    background: #fafafa;
    font-size: 0.9rem;
    font-family: inherit;
    color: var(--brand-dark);
    font-weight: 500;
    border-radius: 2px;
    transition: 0.3s;
  }

  .s-group input:focus, .s-group textarea:focus {
    outline: none;
    border-color: var(--brand-blue);
    background: #ffffff;
    box-shadow: 0 10px 20px rgba(0, 144, 204, 0.05);
  }

  .mission-action-btn {
    background: var(--brand-dark);
    color: #ffffff;
    border: none;
    padding: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    margin-top: 1rem;
  }

  .btn-text {
    font-size: 0.85rem;
    font-weight: 900;
    letter-spacing: 3px;
  }

  .mission-action-btn:hover {
    background: var(--brand-blue);
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 144, 204, 0.2);
  }

  @media (max-width: 1024px) {
    .dossier-grid { grid-template-columns: 1fr; gap: 4rem; }
    .contact-dossier { padding: 6rem 0; }
    .form-dossier { padding: 2.5rem; }
    .s-row { grid-template-columns: 1fr; }
    .hero-side-technical { flex-wrap: wrap; }
  }
</style>
