---
import Layout from '../layouts/Layout.astro';
import RecommendedTours from '../components/RecommendedTours.astro';
---

<Layout 
	title="Contacto y Reservas | Franpisco Adventure Huaraz"
	description="Contacta con Franpisco Adventure para planificar tu próxima expedición en la Cordillera Blanca. Reservas oficiales y soporte 24/7."
>
	<!-- High-End Technical Hero: Editorial Expedition Log (Sync with About Us) -->
	<!-- High-End Technical Hero: Elite Standard -->
	<section class="hub-hero contact-hero">
		<div class="hero-bg-overlay"></div>
		<div class="hero-content">
			<h1 class="split-title">
				<span class="thin">CONTACTO</span>
				<span class="bold">& RESERVAS</span>
			</h1>
			<div class="hero-accent-bar"></div>
			
			<div class="hero-side-technical">
				<div class="tech-item">
					<label>ELEVACIÓN</label>
					<span>3,052 M.S.N.M.</span>
				</div>
				<div class="tech-item">
					<label>COORDENADAS</label>
					<span>9°31′48″S 77°31′44″W</span>
				</div>
				<div class="tech-item">
					<label>STATUS</label>
					<span>COMMS OPEN 24/7</span>
				</div>
			</div>
		</div>
	</section>

	<section class="dossier-page contact-dossier">
		<div class="container--narrow">
			<div class="dossier-centered-layout">
				<div class="dossier-main-stack">
					<!-- Briefing Panel -->
					<div class="briefing-panel-centered">
						<div class="technical-brief">
							<div class="brief-item-c">
								<h3 class="brief-value">SEDE HUARAZ</h3>
								<p class="brief-text">Jr. Trinitarias S/N, Pasaje Sarita Colonia 191 2do Piso, Huaraz - Ancash - Perú.</p>
								<div class="tech-tag-minimal">HORARIO: LUN - SAB / 09:00 - 18:00</div>
							</div>

							<div class="brief-item-c">
								<h3 class="brief-value">CENTRO DE DATOS</h3>
								<p class="brief-text">Recepción de planes operativos y expediciones corporativas.</p>
								<div class="email-stack-c">
									<a href="mailto:info@franpiscoadventureperu.com" class="brief-link">info@franpiscoadventureperu.com</a>
									<a href="mailto:franpiscoadventureperu@hotmail.com" class="brief-link secondary">franpiscoadventureperu@hotmail.com</a>
								</div>
							</div>

							<div class="brief-item-c highlight-base-c">
								<span class="brief-code-c text-blue">COMUNICACIÓN RÁPIDA</span>
								<h3 class="brief-value">WHATSAPP 24/7</h3>
								<p class="brief-text text-light">Enlace directo para soporte inmediato en campo y oficina.</p>
								<a href="https://wa.me/51962421830" class="huge-contact">+51 962 421 830</a>
							</div>
						</div>
					</div>

					<!-- Formulario Dossier -->
					<div class="form-dossier-centered">
						<form class="surgical-form" id="contact-form">
							<div class="form-header-c">
								<h3 class="f-title">Formulario de <span class="blue">Reserva Formal</span></h3>
								<div class="form-accent-line-c"></div>
							</div>
							
							<div class="s-row">
								<div class="s-group">
									<label>Nombre Completo / Agencia</label>
									<input type="text" placeholder="EJ: JOHN ALPINE / THE ROCK GROUP" required>
								</div>
								<div class="s-group">
									<label>Correo de Respuesta</label>
									<input type="email" placeholder="EXPLORADOR.BASE@EJEMPLO.COM" required>
								</div>
							</div>

							<div class="s-group">
								<label>Detalles del Plan Logístico</label>
								<textarea rows="6" placeholder="DIGITE MONTAÑAS DE INTERÉS, TAMAÑO DE GRUPO Y FECHAS..." required></textarea>
							</div>

							<button class="mission-action-btn" type="submit">
								<span class="btn-text">ENVIAR CONSULTA</span>
								<div class="btn-icon">
									<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
								</div>
							</button>
						</form>
					</div>

					<!-- Operational Map Section -->
					<div class="map-container-c">
						<div class="map-header">
							<span class="map-tag">ANCASH, PERÚ</span>
							<h4 class="map-title">NUESTRA UBICACIÓN</h4>
						</div>
						<div class="map-frame">
							<iframe 
								src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d3739.9948362943383!2d-77.53226062497484!3d-9.536548890546435!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zOcKwMzInMTEuNiJTIDc3wrAzMSc0Ni45Ilc!5e1!3m2!1ses!2spe!4v1776890394707!5m2!1ses!2spe" 
								width="100%" 
								height="450" 
								style="border:0;" 
								allowfullscreen="" 
								loading="lazy" 
								referrerpolicy="no-referrer-when-downgrade">
							</iframe>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<RecommendedTours currentId="contact" />
</Layout>

<style>
  /* --- ELITE HUB HERO STANDARD --- */
  .hub-hero {
    position: relative;
    height: 75vh;
    min-height: 500px;
    background: #06090f url('/expedicion.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, 
      rgba(3, 4, 5, 0.9) 0%, 
      rgba(3, 4, 5, 0.4) 50%, 
      rgba(3, 4, 5, 0.9) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 900px;
    padding: 0 2rem;
    margin-top: 3rem;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    line-height: 1;
    margin-bottom:  1.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 12px;
    opacity: 0.8;
    text-transform: uppercase;
  }
  .split-title .bold {
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -1px;
  }

  .hero-accent-bar {
    width: 80px;
    height: 4px;
    background: var(--brand-red);
    margin:  1.2rem auto 2.5rem;
    box-shadow: 0 0 20px rgba(239, 68, 68, 0.3);
  }

  .hero-side-technical {
    display: flex;
    justify-content: center;
    gap: clamp(2rem, 5vw, 4rem);
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .tech-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
    text-align: center;
  }

  .tech-item label {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
  }

  .tech-item span {
    font-size: 1rem;
    font-weight: 600;
    color: white;
    font-family: 'Inter', sans-serif;
  }

  /* --- DOSSIER CONTENT --- */
  .contact-dossier {
    padding: 10rem 0 4rem;
    background: #ffffff;
  }

  /* --- CENTERED DOSSIER LAYOUT --- */
  .dossier-centered-layout {
    max-width: 900px;
    margin: 0 auto;
  }

  .dossier-main-stack {
    display: flex;
    flex-direction: column;
    gap: 8rem;
  }

  .briefing-panel-centered .technical-brief {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 5rem;
  }

  .brief-item-c {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 600px;
  }

  .brief-code-c {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
    display: block;
    margin-bottom: 1.2rem;
  }

  .tech-tag-minimal {
    font-size: 0.7rem;
    font-weight: 800;
    color: var(--brand-blue);
    border: 1px solid rgba(0, 144, 204, 0.2);
    padding: 8px 16px;
    display: inline-block;
    border-radius: 2px;
    text-transform: uppercase;
    margin-top: 1rem;
  }

  .brief-value {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--brand-dark);
    margin-bottom: 1rem;
    letter-spacing: -0.5px;
    text-transform: uppercase;
  }

  .brief-text {
    font-size: 1rem;
    color: #444;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .email-stack-c {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .brief-link {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--brand-blue);
    text-decoration: none;
    transition: 0.3s;
  }
  .brief-link:hover { opacity: 0.7; transform: translateY(-3px); }
  .brief-link.secondary { font-size: 0.95rem; color: #666; font-weight: 600; }

  .highlight-base-c {
    background: #06090f;
    padding: 3.5rem 2.5rem;
    border-radius: 4px;
    width: 100%;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .highlight-base-c .brief-value { color: #fff; font-size: 1.5rem; }
  .highlight-base-c .brief-text { color: rgba(255,255,255,0.6); font-size: 0.9rem; }

  .huge-contact {
    font-size: 1.6rem;
    font-weight: 900;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.5px;
    display: block;
    margin-top: 1.2rem;
    transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .huge-contact:hover { color: var(--brand-blue); transform: scale(1.05); }

  /* Form Styling Centered */
  .form-dossier-centered {
    background: #ffffff;
    padding: 6rem;
    border: 1px solid #eee;
    box-shadow: 0 50px 100px rgba(0,0,0,0.05);
    border-radius: 4px;
  }

  .form-header-c { margin-bottom: 4rem; text-align: center; }
  .form-tag {
    font-size: 0.65rem;
    font-weight: 800;
    color: var(--brand-blue);
    letter-spacing: 2px;
    display: block;
    margin-bottom: 0.8rem;
    text-transform: uppercase;
  }
  .form-accent-line-c {
    width: 80px;
    height: 4px;
    background: var(--brand-blue);
    margin: 2rem auto 0;
  }

  .f-title {
    font-size: 2.2rem;
    font-weight: 900;
    color: var(--brand-dark);
    letter-spacing: -1px;
    text-transform: uppercase;
  }
  .f-title .blue { color: var(--brand-blue); }

  .surgical-form {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .s-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
  }

  .s-group { display: flex; flex-direction: column; gap: 1.2rem; }
  .s-group label {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #666;
    text-transform: uppercase;
  }

  .s-group input, .s-group textarea {
    padding: 1.4rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.95rem;
    color: var(--brand-dark);
    font-weight: 600;
    transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .s-group input::placeholder, .s-group textarea::placeholder {
    color: #94a3b8;
    font-weight: 400;
  }

  .s-group input:focus, .s-group textarea:focus {
    outline: none;
    border-color: var(--brand-blue);
    background: #fff;
    box-shadow: 0 15px 30px rgba(0,144,204,0.08);
  }

  .mission-action-btn {
    background: #030405;
    color: #fff;
    border: none;
    padding: 1.5rem 2.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    border-radius: 4px;
    transition: 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    margin-top: 1.5rem;
  }

  .btn-text {
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 4px;
  }

  .mission-action-btn:hover {
    background: var(--brand-blue);
    transform: translateY(-5px);
    box-shadow: 0 30px 60px rgba(0,144,204,0.3);
  }

  /* Map Centered */
  .map-container-c {
    margin-top: 2rem;
    padding-top: 6rem;
    border-top: 1px solid #f0f0f0;
  }

  .map-header {
    margin-bottom: 3rem;
    text-align: center;
  }
  .map-tag {
    font-size: 0.65rem;
    font-weight: 800;
    color: var(--brand-blue);
    letter-spacing: 2px;
    display: block;
    margin-bottom: 0.8rem;
    text-transform: uppercase;
  }
  .map-title {
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--brand-dark);
    letter-spacing: -0.5px;
    text-transform: uppercase;
  }

  .map-frame {
    border: 1px solid #eee;
    padding: 10px;
    background: #fff;
    box-shadow: 0 40px 80px rgba(0,0,0,0.03);
    border-radius: 4px;
    overflow: hidden;
  }

  .map-frame iframe {
    filter: grayscale(1) contrast(1.1) opacity(0.8);
    transition: 0.5s;
    border-radius: 2px;
  }
  .map-frame:hover iframe {
    filter: grayscale(0) contrast(1) opacity(1);
  }

  @media (max-width: 1200px) {
    .dossier-main-grid { grid-template-columns: 1fr; gap: 5rem; }
  }

  @media (max-width: 768px) {
    .dossier-layout { grid-template-columns: 1fr; }
    .dossier-sidebar { display: none; }
    .hero-side-technical { gap: 2rem; flex-wrap: wrap; }
    .s-row { grid-template-columns: 1fr; gap: 2rem; }
    .form-dossier { padding: 3rem 2rem; }
    .map-container { margin-top: 4rem; padding-top: 4rem; }
  }
</style>
