---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const categories = [
  { id: 'all', label: 'TODOS' },
  { id: 'peru', label: 'PERÚ' },
  { id: 'bolivia', label: 'BOLIVIA' },
  { id: 'argentina', label: 'ARGENTINA' },
  { id: 'ecuador', label: 'ECUADOR' },
  { id: 'climbing', label: 'ESCALADA' }
];

const galleryItems = [
  { id: 1, category: 'peru', title: 'Nevado Alpamayo', location: 'Cordillera Blanca', image: '/slider_1.png', size: 'large' },
  { id: 2, category: 'bolivia', title: 'Huayna Potosí', location: 'Cordillera Real', image: '/slider_2.png', size: 'medium' },
  { id: 3, category: 'peru', title: 'Laguna 69', location: 'Parque Huascarán', image: '/slider_3.png', size: 'small' },
  { id: 4, category: 'argentina', title: 'Aconcagua Summit', location: 'Mendoza', image: '/slider_4.png', size: 'medium' },
  { id: 5, category: 'climbing', title: 'Ice Climbing', location: 'Glaciar Pastoruri', image: '/slider_5.png', size: 'large' },
  { id: 6, category: 'ecuador', title: 'Cotopaxi Volcano', location: 'Avenida de Volcanes', image: '/slider_1.png', size: 'small' },
  { id: 7, category: 'peru', title: 'Huayhuash Circuit', location: 'Cajatambo', image: '/slider_2.png', size: 'medium' },
  { id: 8, category: 'bolivia', title: 'Salar de Uyuni', location: 'Potosí', image: '/slider_3.png', size: 'large' },
  { id: 9, category: 'climbing', title: 'Technical Ascent', location: 'Tocllaraju', image: '/slider_4.png', size: 'small' },
  { id: 10, category: 'peru', title: 'Machu Picchu', location: 'Cusco', image: '/slider_5.png', size: 'medium' },
  { id: 11, category: 'peru', title: 'Cordillera Blanca', location: 'Ancash', image: '/slider_1.png', size: 'small' },
  { id: 12, category: 'climbing', title: 'Base Camp Life', location: 'Ishinca Valley', image: '/slider_2.png', size: 'small' },
  { id: 13, category: 'bolivia', title: 'Illimani', location: 'La Paz', image: '/slider_3.png', size: 'medium' },
  { id: 14, category: 'ecuador', title: 'Chimborazo', location: 'Riobamba', image: '/slider_4.png', size: 'small' },
];
import RecommendedTours from '../components/RecommendedTours.astro';
---

<Layout title="Galería de Expediciones | Franpisco Adventure" description="Explora nuestro registro visual de expediciones en los Andes. Fotos de alta montaña, trekking y paisajes únicos en Perú, Bolivia y más.">
  <section class="hub-hero">
    
    <div class="hero-bg-overlay"></div>
    <div class="hero-content">
      <h1 class="split-title">
        <span class="thin">GALERÍA</span>
        <span class="bold">GALLERY</span>
      </h1>
      <div class="hero-accent-bar"></div>
      
      <div class="hero-side-technical">
        <div class="tech-item">
          <label>RECURSOS</label>
          <span>124 IMÁGENES</span>
        </div>
        <div class="tech-item">
          <label>COORDENADAS</label>
          <span>9°30′S 77°31′W</span>
        </div>
        <div class="tech-item">
          <label>REGIÓN</label>
          <span>EXPEDICIÓN VISUAL</span>
        </div>
      </div>
    </div>
  </section>

  <section class="gallery-section">
    <div class="container-fluid">
      <!-- Minimalist Filter Bar -->
      <div class="filter-wrapper">
        <div class="filter-bar">
          {categories.map((cat) => (
            <button class="filter-btn" data-filter={cat.id}>
              {cat.label}
              <span class="dot"></span>
            </button>
          ))}
        </div>
      </div>

      <!-- Advanced Masonry-Style Grid -->
      <div class="gallery-grid" id="main-gallery">
        {galleryItems.map((item) => (
          <div class={`gallery-card ${item.size}`} data-category={item.category}>
            <div class="card-inner">
              <img src={item.image} alt={item.title} loading="lazy" />
              <div class="card-glass"></div>
              <div class="card-overlay">
                <div class="overlay-top">
                  <span class="category-tag">{item.category}</span>
                </div>
                <div class="overlay-info">
                  <span class="location">{item.location}</span>
                  <h3 class="title">{item.title}</h3>
                </div>
                <div class="view-btn">
                  <span>EXPANDIR</span>
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Premium Cinematic Lightbox -->
  <div class="lightbox" id="lightbox">
    <div class="lightbox-overlay"></div>
    
    <div class="lightbox-ui">
      <button class="close-lightbox" aria-label="Cerrar">
        <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      
      <div class="lightbox-nav prev" id="lb-prev">
        <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </div>
      <div class="lightbox-nav next" id="lb-next">
        <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </div>
    </div>

    <div class="lightbox-content">
      <div class="img-container">
        <img id="lightbox-img" src="" alt="" />
      </div>
      <div class="lightbox-info">
        <div class="lb-text">
          <span id="lb-location" class="lb-loc"></span>
          <h4 id="lb-title" class="lb-title"></h4>
        </div>
        <div class="lb-counter"><span id="lb-current">1</span> / <span id="lb-total">10</span></div>
      </div>
    </div>
  </div>

  <RecommendedTours currentId="gallery" />
</Layout>

<script>
  // Filtering Logic
  const filterBtns = document.querySelectorAll('.filter-btn');
  const galleryItems = document.querySelectorAll('.gallery-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.getAttribute('data-filter');

      galleryItems.forEach(item => {
        const category = item.getAttribute('data-category');
        if (filter === 'all' || category === filter) {
          (item as HTMLElement).style.display = 'block';
          item.classList.remove('fade-out');
          item.classList.add('fade-in');
        } else {
          item.classList.remove('fade-in');
          item.classList.add('fade-out');
          setTimeout(() => {
             if (item.classList.contains('fade-out')) (item as HTMLElement).style.display = 'none';
          }, 400);
        }
      });
    });
  });

  // Lightbox Logic
  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbTitle = document.getElementById('lb-title');
  const lbLoc = document.getElementById('lb-location');
  const lbCurrent = document.getElementById('lb-current');
  const lbTotal = document.getElementById('lb-total');
  const closeBtn = document.querySelector('.close-lightbox');
  const overlay = document.querySelector('.lightbox-overlay');
  
  const prevBtn = document.getElementById('lb-prev');
  const nextBtn = document.getElementById('lb-next');

  let activeIndex = 0;
  let visibleItems: Element[] = [];

  const updateLightbox = (index: number) => {
    const item = visibleItems[index];
    if (!item) return;
    
    const img = item.querySelector('img')?.src || '';
    const title = item.querySelector('.title')?.textContent || '';
    const loc = item.querySelector('.location')?.textContent || '';

    lbImg.style.opacity = '0';
    setTimeout(() => {
      lbImg.src = img;
      lbTitle!.textContent = title;
      lbLoc!.textContent = loc;
      lbCurrent!.textContent = (index + 1).toString();
      lbImg.style.opacity = '1';
    }, 200);
    
    activeIndex = index;
  };

  const openLightbox = (e: Event) => {
    const card = (e.currentTarget as HTMLElement);
    visibleItems = Array.from(galleryItems).filter(item => (item as HTMLElement).style.display !== 'none');
    lbTotal!.textContent = visibleItems.length.toString();
    
    const index = visibleItems.indexOf(card);
    updateLightbox(index);
    
    lightbox?.classList.add('is-active');
    document.body.style.overflow = 'hidden';
  };

  galleryItems.forEach(item => {
    item.addEventListener('click', openLightbox);
  });

  const closeLightbox = () => {
    lightbox?.classList.remove('is-active');
    document.body.style.overflow = '';
  };

  closeBtn?.addEventListener('click', closeLightbox);
  overlay?.addEventListener('click', closeLightbox);

  prevBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    let nextIdx = activeIndex - 1;
    if (nextIdx < 0) nextIdx = visibleItems.length - 1;
    updateLightbox(nextIdx);
  });

  nextBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    let nextIdx = activeIndex + 1;
    if (nextIdx >= visibleItems.length) nextIdx = 0;
    updateLightbox(nextIdx);
  });

  // Keyboard support
  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('is-active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') nextBtn?.click();
    if (e.key === 'ArrowLeft') prevBtn?.click();
  });

  // Initialize
  document.querySelector('[data-filter="all"]')?.classList.add('active');
</script>


<style>
  .hub-hero {
    position: relative;
    height: 75vh;
    min-height: 500px;
    background: #06090f url('/slider_1.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, 
      rgba(3, 4, 5, 0.9) 0%, 
      rgba(3, 4, 5, 0.4) 50%, 
      rgba(3, 4, 5, 0.9) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 900px;
    padding: 0 2rem;
    margin-top: 3rem;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    line-height: 1;
    margin-bottom:  1.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 12px;
    opacity: 0.8;
    text-transform: uppercase;
  }
  .split-title .bold {
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -1px;
  }

  .hero-accent-bar {
    width: 80px;
    height: 4px;
    background: var(--brand-red);
    margin:  1.2rem auto 2.5rem;
    box-shadow: 0 0 20px rgba(239, 68, 68, 0.3);
  }

  .hero-side-technical {
    display: flex;
    justify-content: center;
    gap: clamp(2rem, 5vw, 4rem);
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .tech-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
    text-align: center;
  }

  .tech-item label {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
  }

  .tech-item span {
    font-size: 1rem;
    font-weight: 600;
    color: white;
    font-family: 'Inter', sans-serif;
  }

  /* Gallery Section */
  .gallery-section {
    padding: 6rem 0 10rem;
    background: #ffffff;
  }

  .container-fluid {
    width: 100%;
    max-width: 1800px;
    margin: 0 auto;
    padding: 0 4%;
  }

  /* Filter Styling */
  .filter-wrapper {
    margin-bottom: 5rem;
    display: flex;
    justify-content: center;
  }

  .filter-bar {
    display: flex;
    gap: 0.5rem;
    background: #f1f5f9;
    padding: 6px;
    border-radius: 100px;
    border: 1px solid #e2e8f0;
  }

  .filter-btn {
    background: transparent;
    border: none;
    color: #64748b;
    padding: 0.8rem 1.8rem;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    border-radius: 100px;
    position: relative;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .filter-btn .dot {
    width: 4px;
    height: 4px;
    background: var(--brand-blue);
    border-radius: 50%;
    opacity: 0;
    transition: 0.3s;
  }

  .filter-btn:hover { color: var(--brand-dark); }

  .filter-btn.active {
    background: #ffffff;
    color: var(--brand-dark);
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  .filter-btn.active .dot { opacity: 1; }

  /* Premium Uniform Grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .gallery-card {
    position: relative;
    cursor: pointer;
    overflow: hidden;
    background: #f8fafc;
    border-radius: 4px;
    aspect-ratio: 3 / 2; /* Uniform aspect ratio */
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-card.fade-in { animation: cardIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .gallery-card.fade-out { animation: cardOut 0.4s ease-in forwards; }

  @keyframes cardIn {
    from { opacity: 0; transform: scale(0.95) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  @keyframes cardOut {
    to { opacity: 0; transform: scale(0.95); }
  }

  /* Remove asymmetrical size logic */
  .gallery-card.large, 
  .gallery-card.medium, 
  .gallery-card.small { 
    grid-column: auto; 
    grid-row: auto; 
  }

  .card-inner {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .card-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .card-glass {
    position: absolute;
    inset: 0;
    background: rgba(6, 9, 15, 0.1);
    transition: 0.4s;
    z-index: 2;
  }

  .gallery-card:hover .card-inner img { transform: scale(1.1); }
  .gallery-card:hover .card-glass { background: rgba(6, 9, 15, 0.3); }

  .card-overlay {
    position: absolute;
    inset: 0;
    z-index: 5;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: linear-gradient(to top, rgba(6, 9, 15, 0.8) 0%, transparent 60%);
    opacity: 0;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-card:hover .card-overlay { opacity: 1; }

  .category-tag {
    font-size: 0.55rem;
    font-weight: 900;
    color: #fff;
    background: var(--brand-blue);
    padding: 4px 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    border-radius: 2px;
  }

  .location {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
    transform: translateY(15px);
    transition: 0.5s 0.1s;
  }

  .title {
    font-size: clamp(1rem, 2vw, 1.4rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.5px;
    line-height: 1.1;
    transform: translateY(15px);
    transition: 0.5s 0.2s;
  }

  .view-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #fff;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 2px;
    margin-top: 1.5rem;
    opacity: 0;
    transform: translateY(10px);
    transition: 0.5s 0.3s;
  }

  .gallery-card:hover .location,
  .gallery-card:hover .title,
  .gallery-card:hover .view-btn { transform: translateY(0); opacity: 1; }

  /* Premium Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 5000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lightbox.is-active { opacity: 1; visibility: visible; }

  .lightbox-overlay {
    position: absolute;
    inset: 0;
    background: rgba(3,4,5,0.98);
    backdrop-filter: blur(15px);
  }

  .lightbox-ui { position: absolute; inset: 0; z-index: 20; pointer-events: none; }
  .lightbox-ui > * { pointer-events: auto; }

  .close-lightbox {
    position: absolute;
    top: 40px; right: 40px;
    background: none; border: none;
    color: #fff; cursor: pointer;
    opacity: 0.5; transition: 0.3s;
  }
  .close-lightbox:hover { opacity: 1; color: var(--brand-red); transform: rotate(90deg); }

  .lightbox-nav {
    position: absolute;
    top: 50%; transform: translateY(-50%);
    width: 80px; height: 80px;
    display: flex; align-items: center; justify-content: center;
    color: #fff; cursor: pointer; opacity: 0.3;
    transition: 0.4s;
    background: rgba(255,255,255,0.03);
    border-radius: 50%;
  }
  .lightbox-nav:hover { opacity: 1; background: rgba(255,255,255,0.1); color: var(--brand-blue); }
  .lightbox-nav.prev { left: 40px; }
  .lightbox-nav.next { right: 40px; }

  .lightbox-content {
    position: relative;
    z-index: 10;
    width: 90%;
    max-width: 1400px;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .img-container {
    width: 100%;
    display: flex;
    justify-content: center;
    perspective: 1000px;
  }

  #lightbox-img {
    max-width: 100%;
    max-height: 75vh;
    object-fit: contain;
    box-shadow: 0 60px 120px rgba(0,0,0,0.6);
    transition: opacity 0.4s, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lightbox-info {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 2rem;
  }

  .lb-loc { font-size: 0.7rem; font-weight: 800; color: var(--brand-blue); letter-spacing: 3px; text-transform: uppercase; display: block; margin-bottom: 0.5rem; }
  .lb-title { font-size: clamp(1.5rem, 4vw, 2.5rem); font-weight: 900; color: #fff; letter-spacing: -1px; margin: 0; }
  .lb-counter { font-size: 0.7rem; font-weight: 800; color: rgba(255,255,255,0.3); letter-spacing: 2px; }

  /* Responsive */
  @media (max-width: 1400px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 1024px) {
    .lightbox-nav { width: 50px; height: 50px; }
    .lightbox-nav.prev { left: 20px; }
    .lightbox-nav.next { right: 20px; }
    .close-lightbox { top: 20px; right: 20px; }
  }

  @media (max-width: 800px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 240px; }
    .gallery-card.large, .gallery-card.medium, .gallery-card.small { grid-column: span 1; grid-row: span 1; }
    .card-overlay { opacity: 1; padding: 1.5rem; }
    .view-btn { display: none; }
    .title { font-size: 1rem; transform: none; }
    .location { transform: none; }
    .gallery-hero { height: 50vh; }
    .lightbox-info { flex-direction: column; align-items: flex-start; gap: 1rem; }
  }

  @media (max-width: 500px) {
    .gallery-grid { grid-template-columns: 1fr; grid-auto-rows: 320px; }
    .filter-bar { padding: 4px; overflow-x: auto; max-width: 100%; justify-content: flex-start; }
    .filter-btn { padding: 0.6rem 1.2rem; font-size: 0.6rem; }
    .lightbox-nav { display: none; }
  }
</style>
