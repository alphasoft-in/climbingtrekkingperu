---

<Layout title={`${t('nav.tours')} - Franpisco Adventure`} description="Explora nuestras expediciones culturales y tours exclusivos en las regiones más emblemáticas del Perú.">
  <section class="hub-hero">
    
    <div class="hero-bg-overlay"></div>
    <div class="hero-content">
      <h1 class="split-title">
        <span class="thin">NUESTROS</span>
        <span class="bold">TOURS</span>
      </h1>
      <div class="hero-accent-bar"></div>
      
      <div class="hero-side-technical">
        <div class="tech-item">
          <label>ELEVACIÓN MÁX</label>
          <span>4,600 M.S.N.M.</span>
        </div>
        <div class="tech-item">
          <label>COORDENADAS</label>
          <span>9°30′S 77°31′W</span>
        </div>
        <div class="tech-item">
          <label>REGIÓN</label>
          <span>CORDILLERA BLANCA</span>
        </div>
      </div>
    </div>
  </section>

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {tours.map((tour) => (
          <TourCard 
            id={tour.id}
            title={tour.title}
            description={tour.description}
            image={tour.image}
            duration={tour.duration}
            difficulty={tour.difficulty}
            difficultyLevel={tour.difficultyLevel as any}
            path={tour.path}
            prefix={tour.prefix}
            type={tour.type}
          />
        ))}
      </div>
    </div>
  </section>
  <RecommendedTours />
</Layout>


<style>
  .hub-hero {
    position: relative;
    height: 75vh;
    min-height: 500px;
    background: #06090f url('/slider_2.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, 
      rgba(3, 4, 5, 0.9) 0%, 
      rgba(3, 4, 5, 0.4) 50%, 
      rgba(3, 4, 5, 0.9) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 900px;
    padding: 0 2rem;
    margin-top: 3rem;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    line-height: 1;
    margin-bottom:  1.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 12px;
    opacity: 0.8;
    text-transform: uppercase;
  }
  .split-title .bold {
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -1px;
  }

  .hero-accent-bar {
    width: 80px;
    height: 4px;
    background: var(--brand-red);
    margin:  1.2rem auto 2.5rem;
    box-shadow: 0 0 20px rgba(239, 68, 68, 0.3);
  }

  .hero-side-technical {
    display: flex;
    justify-content: center;
    gap: clamp(2rem, 5vw, 4rem);
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .tech-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
    text-align: center;
  }

  .tech-item label {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
  }

  .tech-item span {
    font-size: 1rem;
    font-weight: 600;
    color: white;
    font-family: 'Inter', sans-serif;
  }

  .programs-section {
    padding: 8rem 0;
    background: #ffffff;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .hub-hero { height: 50vh; }
    .programs-section { padding: 6rem 1.5rem; }
    .container { padding: 0; }
    .hero-side-technical { gap: 1.5rem; }
  }
</style>
