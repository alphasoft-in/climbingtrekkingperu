---
import { toursData } from '@data/tours/toursData';
import { regionsData } from '@data/regions';
import CategoryTemplate from '@components/CategoryTemplate.astro';

const lang = 'es';
const metadata = regionsData['tours'];
const programs = toursData.filter(t => !t.path.startsWith('climbing/'));
---

<CategoryTemplate lang={lang} metadata={metadata} programs={programs} />
