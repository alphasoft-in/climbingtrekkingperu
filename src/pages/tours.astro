---

<Layout title={`${t('nav.tours')} - Franpisco Adventure`} description="Explora nuestras expediciones culturales y tours exclusivos en las regiones más emblemáticas del Perú.">
  <section class="tours-hero">
    <div class="hero-bg-overlay"></div>
    <div class="hero-content">
      <div class="hero-meta">PROGRAM CATALOG // 2024</div>
      <h1 class="split-title">
        <span class="thin">EXPLORA NUESTROS</span>
        <span class="bold">TOURS Y EXPEDICIONES</span>
      </h1>
      <div class="blue-line"></div>
    </div>
  </section>

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {tours.map((tour) => (
          <TourCard 
            id={tour.id}
            title={tour.title}
            description={tour.description}
            image={tour.image}
            duration={tour.duration}
            difficulty={tour.difficulty}
            difficultyLevel={tour.difficultyLevel as any}
            path={tour.path}
            prefix={tour.prefix}
            type={tour.type}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .tours-hero {
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: #06090f url('/slider_4.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, 
      rgba(6, 9, 15, 0.9) 0%, 
      rgba(6, 9, 15, 0.4) 50%, 
      rgba(6, 9, 15, 0.9) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    padding: 0 2rem;
    margin-top: 3rem;
  }

  .hero-meta {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: var(--brand-blue);
    margin-bottom: 1.5rem;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    line-height: 1;
    margin-bottom: 2rem;
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 12px;
    opacity: 0.8;
    text-transform: uppercase;
  }
  .split-title .bold {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1px;
  }

  .blue-line {
    width: 80px;
    height: 4px;
    background: var(--brand-blue);
    margin: 0 auto 3rem;
    box-shadow: 0 0 20px rgba(0, 144, 204, 0.4);
  }

  .programs-section {
    padding: 8rem 0;
    background: #ffffff;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  @media (max-width: 768px) {
    .tours-hero { height: 50vh; }
    .programs-section { padding: 6rem 1.5rem; }
    .container { padding: 0; }
  }
</style>
