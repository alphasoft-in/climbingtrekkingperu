---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../i18n/utils';
import TourCard from '../components/TourCard.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const climbingPrograms = [
  {
    id: 'alpamayo',
    title: t('climbing.alpamayo.name'),
    description: t('climbing.alpamayo.desc'),
    image: '/slider_1.png',
    duration: `6 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/alpamayo',
    prefix: 'CLB',
    type: 'TECHNICAL EXPEDITION'
  },
  {
    id: 'chopicallqui',
    title: t('climbing.chopicallqui.name'),
    description: t('climbing.chopicallqui.desc'),
    image: '/slider_5.png',
    duration: `4 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/chopicallqui',
    prefix: 'CLB',
    type: 'TECHNICAL ASCENT'
  },
  {
    id: 'huascaran',
    title: t('climbing.huascaran.name'),
    description: t('climbing.huascaran.desc'),
    image: '/slider_4.png',
    duration: `6 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/huascaran',
    prefix: 'CLB',
    type: 'TECHNICAL EXPEDITION'
  },
  {
    id: 'pisco',
    title: t('climbing.pisco.name'),
    description: t('climbing.pisco.desc'),
    image: '/slider_2.png',
    duration: `5 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod',
    path: 'climbing/pisco',
    prefix: 'CLB',
    type: 'ACCLIMATIZATION + CLIMB'
  },
  {
    id: 'ishinca-valley',
    title: t('climbing.ishinca.name'),
    description: t('climbing.ishinca.desc'),
    image: '/slider_3.png',
    duration: `8 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/ishinca-valley',
    prefix: 'CLB',
    type: 'TECHNICAL TRILOGY'
  },
  {
    id: 'prep-package',
    title: t('climbing.prep.name'),
    description: t('climbing.prep.desc'),
    image: '/slider_5.png',
    duration: `6 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/prep-package',
    prefix: 'CLB',
    type: 'TECHNICAL TRAINING'
  },
  {
    id: 'artesonraju',
    title: t('climbing.artesonraju.name'),
    description: t('climbing.artesonraju.desc'),
    image: '/slider_1.png',
    duration: `6 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/artesonraju',
    prefix: 'CLB',
    type: 'ELITE EXPEDITION'
  }
];
---

<Layout title={`${t('nav.climbing')} - Franpisco Adventure`} description="Expediciones técnicas de alta montaña en la Cordillera Blanca y Huayhuash. Cumbre el Alpamayo, Huascarán y más con guías UIAGM.">
  <section class="hub-hero">
    <div class="hero-bg-overlay"></div>
    <div class="hero-content">
      <div class="hero-meta">MOUNTAINEERING // HIGH ALTITUDE</div>
      <h1 class="split-title">
        <span class="thin">EXPEDICIONES DE</span>
        <span class="bold">ALTA MONTAÑA Y ESCALADA</span>
      </h1>
      <div class="blue-line"></div>
    </div>
  </section>

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {climbingPrograms.map((prog) => (
          <TourCard 
            id={prog.id}
            title={prog.title}
            description={prog.description}
            image={prog.image}
            duration={prog.duration}
            difficulty={prog.difficulty}
            difficultyLevel={prog.difficultyLevel as any}
            path={prog.path}
            prefix={prog.prefix}
            type={prog.type}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .hub-hero {
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: #06090f url('/slider_5.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, 
      rgba(6, 9, 15, 0.9) 0%, 
      rgba(6, 9, 15, 0.4) 50%, 
      rgba(6, 9, 15, 0.9) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 900px;
    padding: 0 2rem;
    margin-top: 3rem;
  }

  .hero-meta {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: var(--brand-blue);
    margin-bottom: 1.5rem;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    line-height: 1;
    margin-bottom: 2rem;
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 12px;
    opacity: 0.8;
    text-transform: uppercase;
  }
  .split-title .bold {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1px;
  }

  .blue-line {
    width: 80px;
    height: 4px;
    background: var(--brand-blue);
    margin: 0 auto 2.5rem;
    box-shadow: 0 0 20px rgba(0, 144, 204, 0.4);
  }

  .programs-section {
    padding: 8rem 0;
    background: #ffffff;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  @media (max-width: 768px) {
    .hub-hero { height: 50vh; }
    .programs-section { padding: 6rem 1.5rem; }
    .container { padding: 0; }
  }
</style>
