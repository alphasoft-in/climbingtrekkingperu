---
import Layout from '../../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../../i18n/utils';
import RecommendedTours from '../../../../components/RecommendedTours.astro';
import TourGallery from '../../../../components/TourGallery.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DAY 01',
    title: 'ORIGIN COUNTRY TO LIMA (161 MASL) – HUARAZ (3100 M)',
    content: 'Reception at Lima airport and transfer to bus terminal for the trip to Huaraz (8 hours). Hotel transfer.',
    stats: { time: '8 h' }
  },
  {
    day: 'DAY 02',
    title: 'ACCLIMATIZATION: PARON LAGOON (4250 MASL)',
    content: 'Trip north visiting Carhuaz, Yungay, and Caraz. Stay at Paron Lagoon with options for the lookout, boat, or kayak.',
    stats: { alt: '4250m', time: '9-10 h' }
  },
  {
    day: 'DAY 03',
    title: 'ACCLIMATIZATION: ROCUTOYOC LAGOON (4450 MASL)',
    content: 'Visit Cashapunta lookout, Ruripaccha waterfall, and hike to the Ruripaccha glacier (4650m).',
    stats: { alt: '4450m', time: '9-10 h' }
  },
  {
    day: 'DAY 04',
    title: 'HUARAZ (3100 M) – YURACCORAL (3900 M) – LAGOON 69 (4600 MASL)',
    content: 'Start of trekking in Yuraccoral. Hike through Demanda Canyon to the famous Lagoon 69 facing Chacraraju peak.',
    stats: { alt: '4600 m', dist: '13 km', time: '5 h' }
  },
  {
    day: 'DAY 05',
    title: 'YURACCORAL (3900 M) – VAQUERIA – PARIA (3900 MASL)',
    content: 'Transfer passing through Portachuelo pass (4760m). Meet donkeys in Vaqueria and hike to Paria camp.',
    stats: { alt: '4760m', dist: '09 km', time: '5 h' }
  },
  {
    day: 'DAY 06',
    title: 'PARIA (3900M) - TAULLIPAMPA (4250 MASL)',
    content: 'Crossing Punta Union pass (4,750 masl). Stunning views of Taulliraju and Santa Cruz Canyon.',
    stats: { alt: '4750 m', dist: '13 km', time: '09 h' }
  },
  {
    day: 'DAY 07',
    title: 'TAULLIPAMPA (4250M) - LLAMACORAL (3760 MASL)',
    content: 'Descent through Santa Cruz valley. Visit Alpamayo base camp and Arhuaycocha lagoon (4460m).',
    stats: { alt: '4460 m', dist: '15 km', time: '08 h' }
  },
  {
    day: 'DAY 08',
    title: 'LLAMACORAL (3760M) - CASHAPAMPA (2900 MASL) - HUARAZ',
    content: 'Last descent along Yurakmayu river to Cashapampa. Transfer back to Huaraz hotel.',
    stats: { alt: '2900 m', dist: '08 km', time: '04 h' }
  },
  {
    day: 'DAY 09',
    title: 'RETURN: HUARAZ – LIMA',
    content: 'Transfer to terminal and trip back to Lima. Transfer to hotel in Miraflores district.'
  },
  {
    day: 'DAY 10',
    title: 'LIMA – INTERNATIONAL FLIGHT',
    content: 'Transfer to the airport for your return flight. End of services.'
  }
];

const includes = [
  'Lima airport reception and all transfers',
  'Lima - Huaraz - Lima bus tickets',
  '4 Nights in Huaraz (3*) + 1 night in Lima (3*)',
  '2 Technical acclimatization days (Paron & Rocotuyoc)',
  'Full logistics for Lagoon 69 and Santa Cruz Trek',
  'Official UIAGM/AGMP Trekking Guide',
  'Mountain specialized cook',
  'Full board during mountain days',
  '6kg gear allowance on donkeys',
  'Premium camping equipment (including toilet tent)',
  'Emergency oxygen and Woki toki',
  'White Range entrance fees included'
];

const equipment = [
  'Sleeping bag (-10°C recommended)',
  'Sleeping mat / Thermal pad',
  'Daypack (40L)',
  'Waterproof trekking boots',
  'Layered technical clothing (Down, Gore-Tex)',
  'Sunglasses and Sunblock',
  'Trekking poles',
  'Rain poncho'
];
---

<Layout title="The Best of White Range 10 Days | Franpisco Adventure" description="The ultimate White Range experience. Includes Lagoon 69, Paron, Santa Cruz Trek and 10-day Comfort logistics.">
  <section class="itinerary-hero">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <div class="path-log">
          <a href={getRelativeLocaleUrl(lang, 'trekking/blanca')} class="back-project">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3"><path d="M19 12H5m7 7l-7-7 7-7"/></svg>
          </a>
          <span class="p-base">COMFORT</span>
          <span class="p-divider">/</span>
          <span class="p-base">WHITE RANGE</span>
          <span class="p-divider">/</span>
          <span class="p-current">THE BEST</span>
        </div>
        
        <h1 class="split-title">
          <span class="thin">SUPREME EXPEDITION</span>
          <span class="bold">THE BEST OF WHITE RANGE</span>
        </h1>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURATION</span>
            <span class="m-value">10 DAYS / 09 NIGHTS</span>
          </div>
          <div class="metric">
            <span class="m-label">COMFORT SERVICE</span>
            <span class="m-value price">USD. 1,195.00</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFFICULTY</span>
            <span class="m-value">
              <span class="dif-tag modplus">MODERATE+</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">COMFORT DOSSIER</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">LOG: BLN-BEST-10D</span>
            <h2 class="dossier-title">The Heart <span class="blue">of the Andes</span></h2>
          </div>
          
          <p class="dossier-p">This program combines the most iconic lagoons of the White Range with the classic Santa Cruz Trek, offering superior comfort logistics for total immersion in the Andes.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">START / LOGISTICS</span>
                <span class="d-value">Lima / Huaraz, Peru</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">KEY POINTS</span>
                <span class="d-value">Lagoon 69, Paron, Santa Cruz</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">SEASON</span>
                <span class="d-value">April - December</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">SERVICE</span>
                <span class="d-value">Full Comfort Logistics</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/slider_4.png" alt="Best of White Range" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>09° 00' 25" S</span>
              <span class="divider">|</span>
              <span>77° 39' 11" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">ROUTE ANALYSIS</span>
            <h2 class="technical-title">Expedition <span class="blue">Itinerary</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day.split(' ')[1]}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <span class="w-day-label">{item.day}</span>
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">ALTITUDE</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.dist && (
                        <div class="w-stat">
                          <span class="w-s-label">DISTANCE</span>
                          <span class="w-s-value">{item.stats.dist}</span>
                        </div>
                      )}
                      {item.stats.time && (
                        <div class="w-stat">
                          <span class="w-s-label">TIME</span>
                          <span class="w-s-value">{item.stats.time}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}

            <div class="timeline-end">
              <div class="end-mark"></div>
              <span class="end-text">END OF ROUTE</span>
            </div>
          </div>
        </div>

        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">MOD: LOG-INCL</span>
              <h3>Included Services</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="logistics-card secondary">
            <div class="card-header">
              <span class="c-id">MOD: TECH-EQ</span>
              <h3>Necessary Gear</h3>
            </div>
            <ul class="log-list">
              {equipment.map(eq => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" class="log-icon-alt"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                  <span>{eq}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">HIGH AVAILABILITY</span>
              <h3>Start your Expedition</h3>
              <p>Request the technical Comfort dossier for The Best of White Range and secure your adventure.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">APPROXIMATE DATE</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">FULL NAME</label>
                    <input type="text" id="full-name" placeholder="Enter your full name" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  BOOK MY SPOT
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>

      <div class="technical-notice">
        <div class="notice-box">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p><strong>TECHNICAL RECOMMENDATION:</strong> This program includes 2 mandatory acclimatization days to ensure that the ascent to Lagoon 69 (4600m) and Punta Union pass are performed safely and enjoyably.</p>
        </div>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={lang}
    images={[
      '/slider_4.png',
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/trekking/huayhuash/clasico.jpeg'
    ]} 
  />

  <RecommendedTours currentId="blanca-best" />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "THE BEST OF WHITE RANGE 10D";
    
    const message = `Hello Franpisco Adventure! I'd like to book a spot for the expedition: ${tourName}. My details are:\n\n- Name: ${name}\n- Approx date: ${date}`;
    const whatsappUrl = `https://wa.me/51987654321?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  /* Reuse styles from other itinerary pages */
  .itinerary-hero {
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/slider_4.png') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    color: white;
    padding-top: 5rem;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .path-log {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-light);
    margin-bottom: 2rem;
  }

  .back-project {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
    border-radius: 4px;
    text-decoration: none;
    transition: 0.3s;
    margin-right: 0.5rem;
  }
  .back-project:hover {
    background: var(--brand-blue);
    border-color: var(--brand-blue);
    transform: translateX(-5px);
  }

  .p-divider { color: rgba(255,255,255,0.2); font-weight: 300; }
  .p-current { color: var(--brand-blue); }

  .split-title {
    display: flex;
    flex-direction: column;
    margin-bottom: 3.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.9rem, 2.5vw, 1.3rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  .metrics-bar {
    display: flex;
    gap: 4rem;
    padding: 2.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-light);
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  .m-value.price { color: var(--brand-blue); font-size: 1.2rem; }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    letter-spacing: 1px;
  }
  .dif-tag.modplus { background: #f0f9ff; color: #0090cc; border-color: #bae6fd; }

  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .dossier-sidebar {
    display: flex;
    justify-content: center;
  }
  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: var(--brand-light);
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: var(--brand-dark);
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: var(--brand-blue); }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--brand-dark);
    margin-bottom: 4rem;
    max-width: 550px;
    position: relative;
  }
  .dossier-p::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: #f1f5f9;
  }

  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .d-icon {
    margin-top: 0.2rem;
    color: var(--brand-blue);
    opacity: 0.6;
  }
  .d-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .d-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    color: var(--brand-light);
  }
  .d-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--brand-dark);
  }

  .dossier-visual { position: relative; }
  .visual-frame {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 550px;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .visual-frame:hover .dossier-img { transform: scale(1.05); }

  .coordinates-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .coordinates-overlay .divider { opacity: 0.3; font-weight: 300; }

  @media (max-width: 1024px) {
    .dossier-layout { grid-template-columns: 1fr; }
    .dossier-sidebar { display: none; }
    .dossier-img { height: 400px; }
  }

  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid #e2e8f0; }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .details-header-technical { margin-bottom: 2.5rem; }
  .sub-label { font-size: 0.65rem; font-weight: 800; letter-spacing: 5px; color: var(--brand-light); display: block; margin-bottom: 1rem; }
  .technical-title { font-size: 1.8rem; font-weight: 900; color: var(--brand-dark); letter-spacing: -1px; }
  .technical-title .blue { color: var(--brand-blue); }

  .path-timeline { position: relative; padding-left: 2rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--brand-blue), var(--brand-light), var(--brand-light));
  }

  .waypoint-item {
    display: flex;
    gap: 1.5rem;
    position: relative;
    margin-bottom: 1rem;
  }
  
  .waypoint-marker {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }
  .marker-box {
    width: 50px;
    height: 50px;
    background: white;
    border: 2px solid var(--brand-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  .m-day { font-size: 0.9rem; font-weight: 900; color: var(--brand-dark); font-family: 'JetBrains Mono', monospace; }

  .waypoint-content { flex: 1; padding-top: 0.1rem; }
  .waypoint-header { margin-bottom: 0.8rem; }
  .w-day-label { font-size: 0.7rem; font-weight: 800; color: var(--brand-blue); letter-spacing: 2px; text-transform: uppercase; display: block; margin-bottom: 0.2rem; }
  .w-title { font-size: 1.15rem; font-weight: 800; color: var(--brand-dark); letter-spacing: -0.5px; }
  
  .w-description {
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--brand-dark);
    margin-bottom: 1rem;
    max-width: 650px;
  }

  .waypoint-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--brand-light);
