---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const programs = [
  {
    id: 'classic',
    title: t('blanca.prog1.name'),
    description: t('blanca.prog1.desc'),
    image: '/slider_2.png',
    duration: `4-5 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod'
  },
  {
    id: 'best',
    title: t('blanca.prog2.name'),
    description: t('blanca.prog2.desc'),
    image: '/slider_4.png',
    duration: `10 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus'
  },
  {
    id: 'alpamayo',
    title: t('blanca.prog3.name'),
    description: t('blanca.prog3.desc'),
    image: '/slider_1.png',
    duration: `11 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard'
  },
  {
    id: 'circuit',
    title: t('blanca.prog4.name'),
    description: t('blanca.prog4.desc'),
    image: '/slider_3.png',
    duration: `15 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard'
  }
];
---

<Layout title={`${t('nav.blanca')} - Franpisco Adventure`} description={t('blanca.subtitle')}>
  <section class="blanca-hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 class="split-title">
        <span class="thin">EXPEDITIONS IN THE</span>
        <span class="bold">WHITE RANGE</span>
      </h1>
      
      <div class="red-line"></div>

    </div>
  </section>

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {programs.map((prog, index) => (
          <div class="program-card">
            <div class="card-image">
              <img src={prog.image} alt={prog.title} loading="lazy" />
              <div class="card-image-overlay"></div>
              <div class="card-badge">
                <span class="badge-label">DURATION</span>
                <span class="badge-value">{prog.duration}</span>
              </div>
              <div class="route-id">BLN-{prog.id.toUpperCase()}-0{index + 1}</div>
            </div>
            <div class="card-body">
              <div class="card-meta">
                <span class={`difficulty-tag ${prog.difficultyLevel}`}>
                  <span class="dot"></span>
                  {prog.difficulty}
                </span>
                <div class="meta-sep"></div>
                <span class="expedition-type">TECHNICAL EXPEDITION</span>
              </div>
              
              <h3>{prog.title}</h3>
              <p>{prog.description}</p>
              
              <div class="card-footer">
                <a 
                  href={
                    prog.id === 'classic' ? getRelativeLocaleUrl(lang, 'trekking/blanca/santa-cruz') : 
                    prog.id === 'best' ? getRelativeLocaleUrl(lang, 'trekking/blanca/the-best') :
                    prog.id === 'alpamayo' ? getRelativeLocaleUrl(lang, 'trekking/blanca/alpamayo') :
                    getRelativeLocaleUrl(lang, 'trekking/blanca/circuit')
                  } 
                  class="card-link"
                >
                  <span class="link-text">{t('trekking.viewMore')}</span>
                  <div class="link-arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                  </div>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .blanca-hero {
    position: relative;
    height: 65vh;
    min-height: 500px;
    background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('/slider_2.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.8), rgba(3,4,5,0.2) 30%, rgba(3,4,5,0.8));
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    padding: 0 2rem;
    margin-top: 3rem;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    line-height: 1;
    margin-bottom: 2rem;
  }
  .split-title .thin {
    font-size: clamp(0.9rem, 2.5vw, 1.4rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.9;
  }
  .split-title .bold {
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    font-weight: 900;
    letter-spacing: -1px;
  }

  .red-line {
    width: 60px;
    height: 4px;
    background: var(--brand-red);
    margin: 0 auto 3rem;
    box-shadow: 0 0 15px var(--brand-red);
  }

  .programs-section {
    padding: 6rem 0;
    background: #f8fafc;
  }

  .container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  .program-card {
    background: #ffffff;
    border: 1px solid #eef2f6;
    border-radius: 4px;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
    position: relative;
  }

  .program-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 100%; height: 2px;
    background: var(--brand-blue);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .program-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 30px 60px rgba(0, 144, 204, 0.12);
    border-color: #d1d9e6;
  }

  .program-card:hover::after {
    transform: scaleX(1);
  }

  .card-image {
    position: relative;
    height: 280px;
    overflow: hidden;
  }

  .card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 40%);
    z-index: 1;
    opacity: 0.8;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .program-card:hover .card-image img {
    transform: scale(1.1);
  }

  .card-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: rgba(3, 4, 5, 0.85);
    backdrop-filter: blur(8px);
    padding: 10px 15px;
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    z-index: 10;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }

  .badge-label {
    font-size: 0.55rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
  }

  .badge-value {
    font-size: 0.75rem;
    font-weight: 900;
    color: #fff;
    letter-spacing: 0.5px;
  }

  .route-id {
    position: absolute;
    bottom: 1.2rem;
    left: 1.5rem;
    color: rgba(255,255,255,0.9);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 3px;
    z-index: 10;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
  }

  .card-body {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    background: #fff;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 1.5rem;
  }

  .meta-sep {
    width: 1px;
    height: 10px;
    background: #e2e8f0;
  }

  .expedition-type {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    color: #94a3b8;
    text-transform: uppercase;
  }

  .difficulty-tag {
    font-size: 0.6rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 4px 10px;
    border-radius: 2px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid transparent;
  }

  .difficulty-tag .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .difficulty-tag.hard { background: #fff1f2; color: #ef4444; border-color: #fecdd3; }
  .difficulty-tag.hard .dot { background: #ef4444; box-shadow: 0 0 8px #ef4444; }

  .difficulty-tag.modplus { background: #f0f9ff; color: #0090cc; border-color: #bae6fd; }
  .difficulty-tag.modplus .dot { background: #0090cc; box-shadow: 0 0 8px #0090cc; }

  .difficulty-tag.mod { background: #f8fafc; color: #64748b; border-color: #e2e8f0; }
  .difficulty-tag.mod .dot { background: #64748b; }

  .card-body h3 {
    font-size: 1.4rem;
    font-weight: 900;
    margin-bottom: 1.2rem;
    color: var(--brand-dark);
    line-height: 1.2;
    letter-spacing: -0.5px;
  }

  .card-body p {
    color: #475569;
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 3rem;
    flex-grow: 1;
    font-weight: 400;
  }

  .card-footer {
    padding-top: 1.5rem;
    border-top: 1px solid #f1f5f9;
  }

  .card-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--brand-dark);
    text-decoration: none;
    font-weight: 900;
    font-size: 0.75rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .link-arrow {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f8fafc;
    border-radius: 50%;
    color: var(--brand-blue);
    transition: all 0.3s ease;
  }

  .card-link:hover {
    color: var(--brand-blue);
  }

  .card-link:hover .link-arrow {
    background: var(--brand-blue);
    color: #fff;
    transform: translateX(5px);
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .blanca-hero {
      height: 50vh;
    }
    .programs-section {
      padding: 6rem 1.5rem;
    }
    .container { padding: 0; }
  }
</style>
