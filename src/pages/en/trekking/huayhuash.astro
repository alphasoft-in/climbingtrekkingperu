---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const programs = [
  {
    id: '360',
    title: t('huayhuash.prog1.name'),
    description: t('huayhuash.prog1.desc'),
    image: '/trekking/huayhuash/360.png',
    duration: `12-14 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard'
  },
  {
    id: 'classic',
    title: t('huayhuash.prog2.name'),
    description: t('huayhuash.prog2.desc'),
    image: '/trekking/huayhuash/clasico.png',
    duration: `10-12 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus'
  },
  {
    id: 'mini',
    title: t('huayhuash.prog3.name'),
    description: t('huayhuash.prog3.desc'),
    image: '/trekking/huayhuash/mini.png',
    duration: `4-5 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod'
  },
  {
    id: 'peaks',
    title: t('huayhuash.prog4.name'),
    description: t('huayhuash.prog4.desc'),
    image: '/trekking/huayhuash/cumbres.png',
    duration: `12 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard'
  },
  {
    id: 'spectacular',
    title: t('huayhuash.prog5.name'),
    description: t('huayhuash.prog5.desc'),
    image: '/trekking/huayhuash/ruta-huayhuash.png',
    duration: `15 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus'
  }
];
import RecommendedTours from '../../../components/RecommendedTours.astro';
---

<Layout title={`${t('nav.huayhuash')} - Franpisco Adventure`} description={t('huayhuash.subtitle')}>
  <section class="hub-hero">
    
    <div class="hero-bg-overlay"></div>
    <div class="hero-content">
      <h1 class="split-title">
        <span class="thin">ADVENTURES</span>
        <span class="bold">HUAYHUASH</span>
      </h1>
      <div class="hero-accent-bar"></div>
      
      <div class="hero-side-technical">
        <div class="tech-item">
          <label>MAX ELEVATION</label>
          <span>5,632 M.S.N.M.</span>
        </div>
        <div class="tech-item">
          <label>COORDINATES</label>
          <span>10°16′S 76°54′W</span>
        </div>
        <div class="tech-item">
          <label>REGION</label>
          <span>HUAYHUASH / PERÚ</span>
        </div>
      </div>
    </div>
  </section>

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {programs.map((prog, index) => (
          <div class="program-card">
            <div class="card-image">
              <img src={prog.image} alt={prog.title} loading="lazy" />
              <div class="card-image-overlay"></div>
              <div class="card-badge">
                <span class="badge-label">DURATION</span>
                <span class="badge-value">{prog.duration}</span>
              </div>
              <div class="route-id">HYH-{prog.id.toUpperCase()}-0{index + 1}</div>
            </div>
            <div class="card-body">
              <div class="card-meta">
                <span class={`difficulty-tag ${prog.difficultyLevel}`}>
                  <span class="dot"></span>
                  {prog.difficulty}
                </span>
                <div class="meta-sep"></div>
                <span class="expedition-type">TECHNICAL EXPEDITION</span>
              </div>
              
              <h3>{prog.title}</h3>
              <p>{prog.description}</p>
              
              <div class="card-footer">
                <a 
                  href={
                    prog.id === '360' ? getRelativeLocaleUrl(lang, 'trekking/huayhuash/360') : 
                    prog.id === 'classic' ? getRelativeLocaleUrl(lang, 'trekking/huayhuash/clasico') : 
                    prog.id === 'mini' ? getRelativeLocaleUrl(lang, 'trekking/huayhuash/mini') : 
                    prog.id === 'peaks' ? getRelativeLocaleUrl(lang, 'trekking/huayhuash/peaks') :
                    getRelativeLocaleUrl(lang, 'trekking/huayhuash/spectacular')
                  } 
                  class="card-link"
                >
                  <span class="link-text">{t('trekking.viewMore')}</span>
                  <div class="link-arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                  </div>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <RecommendedTours currentId="huayhuash" />
</Layout>


<style>
  .hub-hero {
    position: relative;
    height: 75vh;
    min-height: 500px;
    background: #06090f url('/trekking/huayhuash/bg-huayhuash.png') top center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, 
      rgba(3, 4, 5, 0.9) 0%, 
      rgba(3, 4, 5, 0.4) 50%, 
      rgba(3, 4, 5, 0.9) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 900px;
    padding: 0 2rem;
    margin-top: 3rem;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    line-height: 1;
    margin-bottom:  1.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 12px;
    opacity: 0.8;
    text-transform: uppercase;
  }
  .split-title .bold {
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -1px;
  }

  .hero-accent-bar {
    width: 80px;
    height: 4px;
    background: var(--brand-red);
    margin:  1.2rem auto 2.5rem;
    box-shadow: 0 0 20px rgba(239, 68, 68, 0.3);
  }

  .hero-side-technical {
    display: flex;
    justify-content: center;
    gap: clamp(2rem, 5vw, 4rem);
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .tech-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
    text-align: center;
  }

  .tech-item label {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
  }

  .tech-item span {
    font-size: 1rem;
    font-weight: 600;
    color: white;
    font-family: 'Inter', sans-serif;
  }

  .programs-section {
    padding: 8rem 0;
    background: #ffffff;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .hub-hero { height: 50vh; }
    .programs-section { padding: 6rem 1.5rem; }
    .container { padding: 0; }
    .hero-side-technical { gap: 1.5rem; }
  }
</style>
