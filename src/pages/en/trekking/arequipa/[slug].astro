---
import { allToursData } from '@data/tours/toursData';
import PackageTemplate from '@components/PackageTemplate.astro';

export async function getStaticPaths() {
  const arequipaTours = Object.entries(allToursData).filter(([_, data]) => data.subCategory === 'arequipa');
  
  return arequipaTours.map(([slug, data]) => ({
    params: { slug },
    props: { data }
  }));
}

const { data } = Astro.props;
const lang = 'en';
---

<PackageTemplate lang={lang} data={data} />
