---
import Layout from '../../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../../i18n/utils';
import RecommendedTours from '../../../../components/RecommendedTours.astro';
import TourGallery from '../../../../components/TourGallery.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DAY 01',
    title: 'LIMA – AREQUIPA – HOTEL',
    content: 'Reception at Arequipa airport or bus terminal and transfer to the selected hotel.',
    stats: { alt: '2335m', dist: 'Transfer', time: '30 min' }
  },
  {
    day: 'DAY 02',
    title: 'CULEBRILLAS & CERRO COLORADO',
    content: 'Visit to sillar quarries to observe extraction and carving. Exploration of the Culebrillas canyon and its ancient petroglyphs.',
    stats: { alt: '2500m', dist: 'Tour', time: '6-7 h' }
  },
  {
    day: 'DAY 03',
    title: 'COLCA CANYON (CONDOR VIEWPOINT)',
    content: 'Early departure to the Cruz del Condor Viewpoint to observe the flight of the largest bird in the Andes. Visit traditional villages and return to Arequipa.',
    stats: { alt: '3600m', dist: 'Tour', time: '14 h' }
  },
  {
    day: 'DAY 04',
    title: 'SALINAS LAGOON',
    content: 'Expedition to the salt lagoon surrounded by volcanoes. Observation of flamingos, vicuñas, and giant yaretas at the foot of Pichu Pichu volcano.',
    stats: { alt: '4300m', dist: 'Tour', time: '9-10 h' }
  },
  {
    day: 'DAY 05',
    title: 'AREQUIPA – CHACHANI BASE CAMP',
    content: '4x4 transfer to the base of the volcano. 3-4 hour hike to the Morena base camp. Night in camp.',
    stats: { alt: '4950m', dist: '4x4 + Trek', time: '4 h' }
  },
  {
    day: 'DAY 06',
    title: 'CHACHANI VOLCANO SUMMIT (6075M)',
    content: 'Technical ascent to the summit of Chachani. Spectacular views of the volcanic range. Descent and transfer to Misti base camp.',
    stats: { alt: '6075m', dist: 'Ascent', time: '5-6 h' }
  },
  {
    day: 'DAY 07',
    title: 'MISTI VOLCANO SUMMIT (5822M) – AREQUIPA',
    content: 'Final ascent to the summit of Misti. Panoramic view of the active crater and the city of Arequipa. Descent and return to the hotel.',
    stats: { alt: '5822m', dist: 'Ascent', time: '5 h' }
  }
];

const includes = [
  'Airport - Hotel - Airport transfers (Arequipa)',
  'Hotel nights in Arequipa',
  'Private tourist transport for all tours',
  'Official tour guide for cultural tours',
  '4x4 transport for Chachani and Misti expeditions',
  'Certified mountain guide for ascents',
  'Full board during expeditions (Dinner/Breakfast)',
  'Chef and porters for camping equipment (Chachani)',
  'Full camping equipment (Tents, kitchen)',
  'Technical gear (Crampons if necessary)',
  'Final transfer to airport'
];

const excludes = [
  'Lima – Arequipa – Lima flights',
  'Meals in Arequipa city',
  'High-mountain technical clothing (Available for rent)',
  'Entrance tickets to museums or parks',
  'Tips for guides and staff',
  'Travel and accident insurance'
];
---

<Layout title="Arequipa and Volcanoes 7 Days | Chachani & Misti | Franpisco Adventure" description="The ultimate Arequipa expedition. 7 days exploring Colca, Salinas, and conquering the summits of Chachani (6075m) and Misti (5822m) volcanoes.">
  <section class="itinerary-hero arequipa-prog">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <div class="path-log">
          <a href={getRelativeLocaleUrl(lang, 'trekking/arequipa')} class="back-project">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3"><path d="M19 12H5m7 7l-7-7 7-7"/></svg>
          </a>
          <span class="p-base">VOLCANOES</span>
          <span class="p-divider">/</span>
          <span class="p-base">AREQUIPA</span>
          <span class="p-divider">/</span>
          <span class="p-current">CULTURE & SUMMITS</span>
        </div>
        
        <h1 class="split-title">
          <span class="thin">THE WHITE CITY</span>
          <span class="bold">AREQUIPA & VOLCANOES 7D</span>
        </h1>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">MAX SUMMIT</span>
            <span class="m-value">6,075 MASL</span>
          </div>
          <div class="metric">
            <span class="m-label">ALL INCLUSIVE</span>
            <span class="m-value price">USD. 795.00</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFFICULTY</span>
            <span class="m-value">
              <span class="dif-tag hard">HARD</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">VOLCANIC DOSSIER</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">LOG: AQP-VOL-07D</span>
            <h2 class="dossier-title">Land of <span class="blue">Fire and Sillar</span></h2>
          </div>
          
          <p class="dossier-p">This expedition is unique in South America. In just one week, you will discover World Heritage architecture, the deepest canyon, and conquer two of the most iconic summits in the central Andes, exceeding 6,000 meters in altitude.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">AREA</span>
                <span class="d-value">Volcanic Range</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">ASCENTS</span>
                <span class="d-value">Misti and Chachani</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">TIME</span>
                <span class="d-value">7 Days / 6 Nights</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">EQUIPMENT</span>
                <span class="d-value">4x4 & High Mountain Guides</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/slider_2.png" alt="Arequipa Misti Chachani" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>16° 23' 55" S</span>
              <span class="divider">|</span>
              <span>71° 32' 12" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">ANDEAN JOURNEY</span>
            <h2 class="technical-title">Expedition <span class="blue">Timeline</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day.split(' ')[1]}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <span class="w-day-label">{item.day}</span>
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">ALTITUDE</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.dist && (
                        <div class="w-stat">
                          <span class="w-s-label">METHOD</span>
                          <span class="w-s-value">{item.stats.dist}</span>
                        </div>
                      )}
                      {item.stats.time && (
                        <div class="w-stat">
                          <span class="w-s-label">TIME</span>
                          <span class="w-s-value">{item.stats.time}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}

            <div class="timeline-end">
              <div class="end-mark"></div>
              <span class="end-text">END OF EXPEDITION</span>
            </div>
          </div>
        </div>

        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">MOD: LOG-FULL</span>
              <h3>Included Services</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="logistics-card secondary">
            <div class="card-header">
              <span class="c-id">MOD: TECH-EQ</span>
              <h3>Not Included / Notes</h3>
            </div>
            <ul class="log-list">
              {excludes.map(ex => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" class="log-icon-alt"><path d="M18 6L6 18M6 6l12 12"/></svg>
                  <span>{ex}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">6,000M CHALLENGE</span>
              <h3>Book Your Summit</h3>
              <p>Conquer the giant volcanoes of the south with certified guides and premium logistics.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">ESTIMATED DATE</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">EXPEDITIONER</label>
                    <input type="text" id="full-name" placeholder="Full name" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  {t('trekking.book')}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>

      <div class="technical-notice">
        <div class="notice-box">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p><strong>PHYSICAL PREPARATION:</strong> This program includes two high-altitude ascents. Excellent physical condition and previous high-altitude hiking experience are recommended. We provide technical gear if necessary.</p>
        </div>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={lang}
    images={[
      '/slider_2.png',
      '/slider_1.png',
      '/slider_3.png',
      '/slider_4.png',
      '/trekking/huayhuash/360.jpeg'
    ]} 
  />

  <RecommendedTours currentId="arequipa-volcanes" />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "AREQUIPA & VOLCANOES 7D";
    
    const message = `Hello Franpisco Adventure! I'm interested in the technical expedition in Arequipa: ${tourName}. My details are:\n\n- Name: ${name}\n- Approx date: ${date}`;
    const whatsappUrl = `https://wa.me/51987654321?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  /* Same styles as ES page */
  .itinerary-hero { position: relative; height: 60vh; min-height: 500px; background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/slider_2.png') center/cover no-repeat fixed; display: flex; align-items: center; color: white; padding-top: 5rem; }
  .itinerary-hero.arequipa-prog { background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/slider_2.png'); }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95)); z-index: 1; }
  .container--narrow { position: relative; z-index: 10; max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
  .path-log { display: flex; align-items: center; gap: 0.8rem; font-size: 0.65rem; font-weight: 800; letter-spacing: 2px; color: var(--brand-light); margin-bottom: 2rem; }
  .back-project { width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; border-radius: 4px; text-decoration: none; transition: 0.3s; margin-right: 0.5rem; }
  .back-project:hover { background: var(--brand-blue); border-color: var(--brand-blue); transform: translateX(-5px); }
  .p-divider { color: rgba(255,255,255,0.2); font-weight: 300; }
  .p-current { color: var(--brand-blue); }
  .split-title { display: flex; flex-direction: column; margin-bottom: 3.5rem; }
  .split-title .thin { font-size: clamp(0.9rem, 2.5vw, 1.3rem); font-weight: 200; letter-spacing: 8px; opacity: 0.8; }
  .split-title .bold { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; letter-spacing: -1px; line-height: 1; }
  .metrics-bar { display: flex; gap: 4rem; padding: 2.5rem 0; border-top: 1px solid rgba(255,255,255,0.1); }
  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label { font-size: 0.6rem; font-weight: 800; letter-spacing: 2px; color: var(--brand-light); }
  .m-value { font-size: 1rem; font-weight: 800; color: #fff; }
  .m-value.price { color: var(--brand-blue); font-size: 1.2rem; }
  .dif-tag { font-size: 0.65rem; padding: 2px 8px; background: rgba(255,255,255,0.1); border-radius: 2px; letter-spacing: 1px; }
  .dif-tag.hard { background: #fff1f2; color: #ef4444; border-color: #fecdd3; }
  .itinerary-intro { padding: 10rem 0; background: #ffffff; overflow: hidden; }
  .dossier-layout { display: grid; grid-template-columns: 40px 1fr 1fr; gap: 4rem; align-items: center; }
  .dossier-sidebar { display: flex; justify-content: center; }
  .vertical-label { writing-mode: vertical-lr; transform: rotate(180deg); font-size: 0.65rem; font-weight: 800; letter-spacing: 5px; color: var(--brand-light); white-space: nowrap; }
  .log-id { font-size: 0.6rem; font-weight: 800; letter-spacing: 2px; color: var(--brand-blue); margin-bottom: 1rem; display: block; }
  .dossier-title { font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -1.5px; line-height: 1; color: var(--brand-dark); margin-bottom: 2.5rem; }
  .dossier-title .blue { color: var(--brand-blue); }
  .dossier-p { font-size: 0.95rem; line-height: 1.9; color: var(--brand-dark); margin-bottom: 4rem; max-width: 550px; position: relative; }
  .dossier-p::before { content: ''; position: absolute; left: -2rem; top: 0.5rem; bottom: 0.5rem; width: 2px; background: #f1f5f9; }
  .dossier-specs { display: grid; grid-template-columns: repeat(2, 1fr); gap: 3rem; }
  .d-spec { display: flex; gap: 1.2rem; align-items: flex-start; }
  .d-icon { margin-top: 0.2rem; color: var(--brand-blue); opacity: 0.6; }
  .d-info { display: flex; flex-direction: column; gap: 0.4rem; }
  .d-label { font-size: 0.6rem; font-weight: 800; letter-spacing: 1.5px; color: var(--brand-light); }
  .d-value { font-size: 0.95rem; font-weight: 700; color: var(--brand-dark); }
  .dossier-visual { position: relative; }
  .visual-frame { position: relative; border-radius: 4px; overflow: hidden; box-shadow: 0 40px 80px rgba(0,0,0,0.15); }
  .dossier-img { width: 100%; height: 550px; object-fit: cover; transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1); }
  .visual-frame:hover .dossier-img { transform: scale(1.05); }
  .coordinates-overlay { position: absolute; bottom: 0; left: 0; right: 0; background: rgba(3,4,5,0.8); backdrop-filter: blur(10px); color: white; padding: 1rem 2rem; display: flex; justify-content: center; gap: 1.5rem; font-size: 0.7rem; font-weight: 700; letter-spacing: 3px; border-top: 1px solid rgba(255,255,255,0.1); }
  .coordinates-overlay .divider { opacity: 0.3; font-weight: 300; }
  @media (max-width: 1024px) { .dossier-layout { grid-template-columns: 1fr; } .dossier-sidebar { display: none; } .dossier-img { height: 400px; } }
  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid #e2e8f0; }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }
  .details-header-technical { margin-bottom: 2.5rem; }
  .sub-label { font-size: 0.65rem; font-weight: 800; letter-spacing: 5px; color: var(--brand-light); display: block; margin-bottom: 1rem; }
  .technical-title { font-size: 1.8rem; font-weight: 900; color: var(--brand-dark); letter-spacing: -1px; }
  .technical-title .blue { color: var(--brand-blue); }
  .path-timeline { position: relative; padding-left: 2rem; }
  .path-timeline::before { content: ''; position: absolute; left: 45px; top: 0; bottom: 0; width: 2px; background: linear-gradient(to bottom, var(--brand-blue), var(--brand-light), var(--brand-light)); }
  .waypoint-item { display: flex; gap: 1.5rem; position: relative; margin-bottom: 1rem; }
  .waypoint-marker { position: relative; z-index: 2; flex-shrink: 0; }
  .marker-box { width: 50px; height: 50px; background: white; border: 2px solid var(--brand-dark); display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
  .m-day { font-size: 0.9rem; font-weight: 900; color: var(--brand-dark); font-family: 'JetBrains Mono', monospace; }
  .waypoint-content { flex: 1; padding-top: 0.1rem; }
  .waypoint-header { margin-bottom: 0.8rem; }
  .w-day-label { font-size: 0.7rem; font-weight: 800; color: var(--brand-blue); letter-spacing: 2px; text-transform: uppercase; display: block; margin-bottom: 0.2rem; }
  .w-title { font-size: 1.15rem; font-weight: 800; color: var(--brand-dark); letter-spacing: -0.5px; }
  .w-description { font-size: 0.88rem; line-height: 1.8; color: var(--brand-dark); margin-bottom: 1rem; max-width: 650px; }
  .waypoint-stats { display: flex; flex-wrap: wrap; gap: 2rem; padding-top: 1rem; border-top: 1px solid var(--brand-light); }
  .w-stat { display: flex; flex-direction: column; gap: 0.4rem; }
  .w-s-label { font-size: 0.6rem; font-weight: 800; color: var(--brand-light); letter-spacing: 1px; }
  .w-s-value { font-size: 0.75rem; font-weight: 700; color: var(--brand-dark); }
  .technical-notice { margin-top: 4rem; }
  .notice-box { display: flex; gap: 1.5rem; padding: 2.5rem; background: #fff; border: 1px solid var(--brand-light); border-left: 4px solid var(--brand-red); color: var(--brand-dark); font-size: 0.95rem; line-height: 1.6; }
  .notice-box svg { color: var(--brand-red); flex-shrink: 0; }
  .logistics-sidebar { display: flex; flex-direction: column; gap: 3rem; padding-top: 6.5rem; }
  .logistics-card { background: white; padding: 2.5rem; border: 1px solid var(--brand-light); box-shadow: 0 10px 30px rgba(0,0,0,0.03); }
  .card-header { margin-bottom: 2rem; }
  .c-id { font-size: 0.55rem; font-weight: 800; color: var(--brand-blue); letter-spacing: 1px; margin-bottom: 0.5rem; display: block; margin-top: 0.5rem; }
  .card-header h3 { font-size: 1.1rem; font-weight: 900; color: var(--brand-dark); text-transform: uppercase; letter-spacing: 0.5px; }
  .log-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .log-list li { display: flex; gap: 1rem; align-items: flex-start; font-size: 0.82rem; line-height: 1.5; color: var(--brand-dark); }
  .log-icon { color: var(--brand-blue); flex-shrink: 0; margin-top: 0.2rem; }
  .log-icon-alt { color: var(--brand-blue); opacity: 0.5; flex-shrink: 0; margin-top: 0.2rem; }
  .mission-cta { background: var(--brand-dark); color: white; padding: 3rem; position: relative; overflow: hidden; }
  .cta-inner { position: relative; z-index: 2; }
  .cta-status { font-size: 0.6rem; font-weight: 900; color: var(--brand-blue); letter-spacing: 2px; display: block; margin-bottom: 1.5rem; }
  .mission-cta h3 { font-size: 1.6rem; font-weight: 900; margin-bottom: 1rem; }
  .mission-cta p { font-size: 0.95rem; opacity: 0.7; margin-bottom: 2rem; line-height: 1.6; }
