---
import Layout from '../../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../../i18n/utils';
import RecommendedTours from '../../../../components/RecommendedTours.astro';
import TourGallery from '../../../../components/TourGallery.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DAY 01',
    title: 'ARRIVAL IN LIMA – PERU (161 MASL) – HUARAZ (3100 MASL)',
    content: 'Arrival at Jorge Chávez Airport. Transfer to Huaraz by bus (8 hours) or flight (50 min). Reception and hotel transfer.',
    stats: { time: '8 h' }
  },
  {
    day: 'DAY 02',
    title: 'ACCLIMATIZATION: ROCUTOYOC LAGOON (4450 MASL) – WHITE RANGE',
    content: 'Visit Cashapunta lookout, Ruripaccha waterfall, cave paintings, and Rocutuyoc lagoon. Hike to Ruripaccha glacier (4,650 masl).',
    stats: { alt: '4450m', time: '9-10 h' }
  },
  {
    day: 'DAY 03',
    title: 'FREE DAY',
    content: 'Strategic rest day to optimize acclimatization and regain energy before starting the Huayhuash expedition.'
  },
  {
    day: 'DAY 04',
    title: 'HUARAZ (3100M) - CUARTELWAIN (4180M) - MITUCOCHA (4230M)',
    content: 'Transfer to Cuartelwain. Start of the trek crossing Cacananpunta pass (4,700 masl). Views of Ninashanca, Rondoy, and Jirishanca.',
    stats: { alt: '4700 m', dist: '09 km', time: '04-05 h' }
  },
  {
    day: 'DAY 05',
    title: 'MITUCOCHA (4230 MASL) - CARHUACOCHA (4,280 MASL)',
    content: 'Hike through Jancapampa valley. Carhuac pass (4,650 masl) or alternative route to the three lagoons lookout. Views of Yerupaja and Siula.',
    stats: { alt: '4650 m', dist: '13 km', time: '6 h' }
  },
  {
    day: 'DAY 06',
    title: 'CARHUACOCHA (4,280 MASL) - HUAYHUASH (4,300 MASL)',
    content: 'Most difficult day. Three lagoons lookout (Siulacocha, Ganrajanca, Azulcocha). Siula pass (4,800 masl).',
    stats: { alt: '4800 m', dist: '15 km', time: '09 h' }
  },
  {
    day: 'DAY 07',
    title: 'HUAYHUASH (4,350 MASL) - VICONGA (4,330 MASL)',
    content: 'Quiet day. Portachuelo pass (4,750 masl) with views of the Raura Range. Camp next to the Viconga thermal baths.',
    stats: { alt: '4750 m', dist: '11 km', time: '06 h' }
  },
  {
    day: 'DAY 08',
    title: 'SUMMIT ATTEMPT PUMARINRI (5465 MASL) - CUYOCPAMPA',
    content: 'Summit push (01:30 am). 2 hours of glacier hike to the top. Views of Raura and Huayhuash. Descent through Cuyoc pass (5,000m).',
    stats: { alt: '5465 m', dist: '18 km', time: '14 h' }
  },
  {
    day: 'DAY 09',
    title: 'CUYOCPAMPA (4,550 MASL) - HUAYLLAPA (3,630 MASL)',
    content: 'Santa Rosa pass (5,080 masl) at sunrise. Incredible view of the north face of Huayhuash. Descent to Huayllapa village.',
    stats: { alt: '5080 m', dist: '19 km', time: '10 h' }
  },
  {
    day: 'DAY 10',
    title: 'HUAYLLAPA (3,630 MASL) - GASHPAPAMPA (4,550 MASL)',
    content: 'Demanding ascent to Tapush pass (4,800 masl). View of Diablo Mudo peak. Gashpapampa base camp.',
    stats: { alt: '4800 m', dist: '15 km', time: '08 h' }
  },
  {
    day: 'DAY 11',
    title: 'SUMMIT ATTEMPT DIABLO MUDO (5350 M) – JAHUACOCHA (4100 M)',
    content: 'Ascent to the ridge and summit (01:30 am). Phenomenal view of the Huayhuash Range. Descent to Jahuacocha lagoon.',
    stats: { alt: '5350 m', dist: '19 km', time: '14 h' }
  },
  {
    day: 'DAY 12',
    title: 'JAHUACOCHA (4,100 MASL) - LLAMAC (3,300 MASL)',
    content: 'Last day of trekking. Pampa Llamac pass (3,900m). Final descent to Llamac village and transfer back to Huaraz.',
    stats: { alt: '3950 m', dist: '13 km', time: '06 h' }
  },
  {
    day: 'DAY 13',
    title: 'TRANSFER TO BUS TERMINAL OR AIRPORT',
    content: 'Transfer from hotel to bus terminal or airport for the return to Lima. End of our services.'
  }
];

const includes = [
  'Technical briefing at Huaraz office',
  '1 Day of acclimatization (shared)',
  'Private transfers Huaraz - Huayhuash',
  'Official Trekking Guide and Mountain Guide (UIAGM)',
  'Expedition specialized cook',
  'Full board during the trek (veg/gluten-free options available)',
  'Donkeys and porters for logistics (6kg personal gear)',
  'Full camping equipment (kitchen, dining, personal tents)',
  'Technical gear: Helmet, Ice axe, Harness, Crampons, Ropes',
  'Woki toki and Basic First Aid kit'
];

const excludes = [
  'International and national flight tickets',
  'Lima - Huaraz - Lima bus tickets',
  'Hoteles in Lima and Huaraz',
  'Sleeping bag (-10°C) and mat',
  'Huayhuash entrance fees (S/. 280.00)',
  'Accident insurance (mandatory)',
  'Tips and personal expenses'
];

const equipment = [
  'Sleeping bag -10°C and Sleeping mat',
  'Daypack 40L',
  'Trekking boots and Mountaineering boots',
  'Layered technical clothing (Down, Waterproof)',
  'Cold and sun hats, Gloves',
  'Sunglasses with UV protection',
  'Sunblock and Rain poncho',
  'Trekking poles'
];
---

<Layout title="Huayhuash Peaks: Diablo Mudo & Pumarinri | Franpisco Adventure" description="High-mountain expedition in the Huayhuash Range. Summiting Diablo Mudo (5350m) and Pumarinri (5465m). 13 days of technical adventure.">
  <section class="itinerary-hero">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <h1 class="split-title">
          <span class="thin">HUAYHUASH RANGE</span>
          <span class="bold">PEAKS EXPEDITION</span>
        </h1>
        <div class="hero-accent-bar"></div>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURATION</span>
            <span class="m-value">13 DAYS / 12 NIGHTS</span>
          </div>
          <div class="metric">
            <span class="m-label">FROM</span>
            <span class="m-value price">USD. 1,995.00</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFFICULTY</span>
            <span class="m-value">
              <span class="dif-tag hard">HARD</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">MOUNTAIN EXPEDITION</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">EXPEDITION ID: HYH-CB-13D</span>
            <h2 class="dossier-title">Diablo Mudo <span class="blue">& Pumarinri</span></h2>
          </div>
          
          <p class="dossier-p">A technical expedition designed for mountaineers seeking to combine the spectacular Huayhuash trek with summits over 5,000 meters, including Diablo Mudo and Pumarinri.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">START / LOGISTICS</span>
                <span class="d-value">Huaraz, Peru</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">ACTIVITY</span>
                <span class="d-value">Trekking & Mountaineering</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">SEASON</span>
                <span class="d-value">April - December</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">SERVICE</span>
                <span class="d-value">Specialized UIAGM Guide</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/trekking/huayhuash/cumbres.png" alt="Huayhuash Peaks" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>10° 16' 18" S</span>
              <span class="divider">|</span>
              <span>76° 54' 14" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">ROUTE PLANNING</span>
            <h2 class="technical-title">Peaks <span class="blue">Itinerary</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day.split(' ')[1]}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <span class="w-day-label">{item.day}</span>
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">ALTITUDE</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.dist && (
                        <div class="w-stat">
                          <span class="w-s-label">DISTANCE</span>
                          <span class="w-s-value">{item.stats.dist}</span>
                        </div>
                      )}
                      {item.stats.time && (
                        <div class="w-stat">
                          <span class="w-s-label">TIME</span>
                          <span class="w-s-value">{item.stats.time}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}

            <div class="timeline-end">
              <div class="end-mark"></div>
              <span class="end-text">END OF ROUTE</span>
            </div>
          </div>
        </div>

        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">REF: SRV-INC</span>
              <h3>Included Services</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="logistics-card secondary">
            <div class="card-header">
              <span class="c-id">REF: EQP-TCN</span>
              <h3>Technical Gear</h3>
            </div>
            <ul class="log-list">
              {equipment.map(eq => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" class="log-icon-alt"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                  <span>{eq}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">TECHNICAL LOGISTICS INQUIRY</span>
              <h3>Start your Expedition</h3>
              <p>Request the technical dossier and secure your spot for the peaks season.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">APPROXIMATE DATE</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">FULL NAME</label>
                    <input type="text" id="full-name" placeholder="Enter your full name" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  BOOK MY SPOT
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>

      <div class="technical-notice">
        <div class="notice-box">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p><strong>MANDATORY REQUIREMENT:</strong> It is essential to have 100% mountain accident insurance that covers rescue and medical expenses.</p>
        </div>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={lang}
    images={[
      '/trekking/huayhuash/cumbres.png',
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png'
    ]} 
  />

  <RecommendedTours currentId="peaks" />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "HUAYHUASH RANGE PEAKS EXPEDITION 13D";
    
    const message = `Hello Franpisco Adventure! I'd like to book a spot for the peaks expedition: ${tourName}. My details are:\n\n- Name: ${name}\n- Approx date: ${date}`;
    const whatsappUrl = `https://wa.me/51987654321?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  /* Reuse styles from ES page or global */
  .itinerary-hero {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/trekking/huayhuash/cumbres.png') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    color: white;
    padding-top: 5rem;
  
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  
  }

  .split-title {
    display: flex;
    flex-direction: column;
    margin-bottom:  1.5rem;
  
    align-items: center;
    gap: 0.5rem;
  
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  .metrics-bar {
    display: flex;
    gap: 4rem;
    padding:  1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  
    justify-content: center;
  
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-light);
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  .m-value.price { color: var(--brand-blue); font-size: 1.2rem; }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    letter-spacing: 1px;
  }
  .dif-tag.hard { color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }

  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .dossier-sidebar {
    display: flex;
    justify-content: center;
  }
  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: var(--brand-light);
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: var(--brand-dark);
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: var(--brand-blue); }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--brand-dark);
    margin-bottom: 4rem;
    max-width: 550px;
    position: relative;
  }
  .dossier-p::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: #f1f5f9;
  }

  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .d-icon {
    margin-top: 0.2rem;
    color: var(--brand-blue);
    opacity: 0.6;
  }
  .d-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .d-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    color: var(--brand-light);
  }
  .d-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--brand-dark);
  }

  .dossier-visual { position: relative; }
  .visual-frame {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 550px;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .visual-frame:hover .dossier-img { transform: scale(1.05); }

  .coordinates-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .coordinates-overlay .divider { opacity: 0.3; font-weight: 300; }

  @media (max-width: 1024px) {
    .dossier-layout { grid-template-columns: 1fr; }
    .dossier-sidebar { display: none; }
    .dossier-img { height: 400px; }
  }

  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid #e2e8f0; }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .details-header-technical { margin-bottom: 2.5rem; }
  .sub-label { font-size: 0.65rem; font-weight: 800; letter-spacing: 5px; color: var(--brand-light); display: block; margin-bottom: 1rem; }
  .technical-title { font-size: 1.8rem; font-weight: 900; color: var(--brand-dark); letter-spacing: -1px; }
  .technical-title .blue { color: var(--brand-blue); }

  .path-timeline { position: relative; padding-left: 2rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--brand-blue), var(--brand-light), var(--brand-light));
  }

  .waypoint-item {
    display: flex;
    gap: 1.5rem;
    position: relative;
    margin-bottom: 1rem;
  }
  
  .waypoint-marker {
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }
  .marker-box {
    width: 50px;
    height: 50px;
    background: white;
    border: 2px solid var(--brand-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  .m-day { font-size: 0.9rem; font-weight: 900; color: var(--brand-dark); font-family: 'JetBrains Mono', monospace; }

  .waypoint-content { flex: 1; padding-top: 0.1rem; }
