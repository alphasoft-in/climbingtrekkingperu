---
import Layout from '../../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../../i18n/utils';
import RecommendedTours from '../../../../components/RecommendedTours.astro';
import TourGallery from '../../../../components/TourGallery.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DAY 01',
    title: 'LIMA – PERU (100 MASL) – HUARAZ (3100 M)',
    content: 'Reception at Lima airport and direct transfer to Huaraz (8 hours) by public bus or optional private flight. Hotel transfer.',
    stats: { time: '8 h' }
  },
  {
    day: 'DAY 02',
    title: 'ACCLIMATIZATION: ROCUTOYOC LAGOON (4450 MASL) – WHITE RANGE',
    content: 'Acclimatization tour visiting Cashapunta lookout, Ruripaccha waterfall, cave paintings, and Rocutuyoc lagoon. Hike to the glacier (4,650 masl).',
    stats: { alt: '4450m', time: '9-10 h' }
  },
  {
    day: 'DAY 03',
    title: 'FREE DAY IN HUARAZ',
    content: 'Strategic rest in the city to optimize acclimatization and logistical preparation before the expedition.'
  },
  {
    day: 'DAY 04',
    title: 'HUARAZ (3100M) - CUARTELWAIN (4180M) - MITUCOCHA (4280M)',
    content: 'Transfer to Cuartelwain (5h). Start of the trekking crossing the first pass Cacananpunta (4,700 masl). Jancapampa camp.',
    stats: { alt: '4700 m', time: '5 h' }
  },
  {
    day: 'DAY 05',
    title: 'MITUCOCHA (4230 MASL) - CARHUACOCHA (4,280 MASL)',
    content: 'Hike to the Carhuac lookout (4,750 masl). Spectacular views of Yerupaja (6,634m) and Siula (6,344m).',
    stats: { alt: '4750 m', dist: '13 km', time: '5 h' }
  },
  {
    day: 'DAY 06',
    title: 'CARHUACOCHA (4280 MASL) - HUAYHUASH (4350 MASL)',
    content: 'Demanding day. Visit to the three lagoons lookout (Siulacocha, Ganrajanca, Quesillacocha). Siula pass (4,800 masl).',
    stats: { alt: '4800 m', dist: '15 km', time: '09 h' }
  },
  {
    day: 'DAY 07',
    title: 'HUAYHUASH (4,350 MASL) - CUYOCPAMPA (4550 MASL)',
    content: 'Crossing between Trapecio and Putscanturpa mountains to the Trapecio pass (5,030 masl). Optional: San Antonio lookout (5,120 masl).',
    stats: { alt: '5,030 m', dist: '13 km', time: '7 h' }
  },
  {
    day: 'DAY 08',
    title: 'CUYOCPAMPA (4550 MASL) – CUTATAMBO (4280 MASL)',
    content: 'Santa Rosa pass (5,080 masl) with an incredible view of the north face of Huayhuash. Descent to Jurao lagoon.',
    stats: { alt: '5080 m', dist: '11 km', time: '6 h' }
  },
  {
    day: 'DAY 09',
    title: 'CUTATAMBO – ZERO GRAND VIEW LOOKOUT (5150 MASL)',
    content: 'Ascent to the Zero Grand View lookout to observe Joe Simpson\'s route (Touching the Void) on Siula Grande.',
    stats: { alt: '5150 m', dist: '14 km', time: '8 h' }
  },
  {
    day: 'DAY 10',
    title: 'CUTATAMBO (4280 MASL) - HUAYLLAPA (3,630 MASL)',
    content: 'Descent through the Calinca valley to the village of Huayllapa. Optional: homestay accommodation with wifi and hot water.',
    stats: { dist: '8 km', time: '05 h' }
  },
  {
    day: 'DAY 11',
    title: 'HUAYLLAPA (3,630 MASL) - GASHPAPAMPA (4555 MASL)',
    content: 'Long but gentle ascent to Tapush pass (4,800 masl). Views of Diablo Mudo peak (5,350 masl).',
    stats: { alt: '4800 m', dist: '15 km', time: '08 h' }
  },
  {
    day: 'DAY 12',
    title: 'GASHPAPAMPA (4555 MASL) - JAHUACOCHA LAGOON (4100 MASL)',
    content: 'Yaucha pass (4,800 masl). Huacrish lookout with total panorama of the highest peaks of the range.',
    stats: { alt: '4800 m', dist: '12 km', time: '07 h' }
  },
  {
    day: 'DAY 13',
    title: 'JAHUACOCHA (4100 MASL) - LLAMAC (3300 MASL)',
    content: 'Last day of trek. Pampa Llamac pass (3,900m). Final descent to Llamac village and transfer back to Huaraz.',
    stats: { alt: '3900 m', dist: '13 km', time: '06 h' }
  },
  {
    day: 'DAY 14',
    title: 'HUARAZ - TRANSFER TO TERMINAL OR AIRPORT',
    content: 'Transfer from hotel to bus terminal or airport for the trip back to Lima.'
  },
  {
    day: 'DAY 15',
    title: 'LIMA - TRANSFER TO AIRPORT',
    content: 'Final transfer to the international airport for your return flight. End of services.'
  }
];

const includes = [
  'Airport reception in Lima and transfers',
  'Bus tickets Lima - Huaraz - Lima',
  '4 nights hotel in Huaraz + 1 night in Lima',
  'Detailed briefing at Huaraz office',
  '1 Day of technical acclimatization',
  'Private transport to Cuartelwain',
  'Official qualified Trekking Guide',
  'Expedition specialized cook',
  '10 Days of expedition in Huayhuash',
  '10kg of gear allowance on donkeys',
  'Full high-end camping equipment',
  'Woki toki and First Aid kit'
];

const equipment = [
  'Sleeping bag (-10°C recommended)',
  'Sleeping mat / Thermal pad',
  'Daypack (40L)',
  'High-mountain trekking boots',
  'Layered technical clothing (Down, Gore-Tex)',
  'Sun protection (Hat, glasses, block)',
  'Trekking poles',
  'Rain poncho'
];
---

<Layout title="The Spectacular Huayhuash Route - 15 Days | Franpisco Adventure" description="The ultimate 15-day expedition in the Huayhuash Range. Comfort service with Zero Grand View lookout and 5,000m passes.">
  <section class="itinerary-hero">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <div class="path-log">
          <a href={getRelativeLocaleUrl(lang, 'trekking/huayhuash')} class="back-project">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3"><path d="M19 12H5m7 7l-7-7 7-7"/></svg>
          </a>
          <span class="p-base">COMFORT</span>
          <span class="p-divider">/</span>
          <span class="p-base">HUAYHUASH</span>
          <span class="p-divider">/</span>
          <span class="p-current">SPECTACULAR</span>
        </div>
        
        <h1 class="split-title">
          <span class="thin">THE BEST OF</span>
          <span class="bold">SPECTACULAR HUAYHUASH</span>
        </h1>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURATION</span>
            <span class="m-value">15 DAYS / 14 NIGHTS</span>
          </div>
          <div class="metric">
            <span class="m-label">COMFORT SERVICE</span>
            <span class="m-value price">USD. 1,995.00</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFFICULTY</span>
            <span class="m-value">
              <span class="dif-tag hard">HARD</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">COMFORT DOSSIER</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">LOG: HYH-SPEC-15D</span>
            <h2 class="dossier-title">Supreme <span class="blue">Circuit</span></h2>
          </div>
          
          <p class="dossier-p">This is our most complete and exclusive route. 15 days of total immersion in the Huayhuash Range, including the Zero Grand View lookout facing Siula Grande and superior logistical services.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">START / LOGISTICS</span>
                <span class="d-value">Lima / Huaraz, Peru</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">KEY POINTS</span>
                <span class="d-value">Zero Grand View, Santa Rosa</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">SEASON</span>
                <span class="d-value">March - December</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">SERVICE</span>
                <span class="d-value">Full Comfort Logistics</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/trekking/huayhuash/clasico.jpeg" alt="Spectacular Huayhuash Route" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>10° 17' 22" S</span>
              <span class="divider">|</span>
              <span>76° 54' 01" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">ROUTE ANALYSIS</span>
            <h2 class="technical-title">Expedition <span class="blue">Itinerary</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day.split(' ')[1]}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <span class="w-day-label">{item.day}</span>
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">ALTITUDE</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.dist && (
                        <div class="w-stat">
                          <span class="w-s-label">DISTANCE</span>
                          <span class="w-s-value">{item.stats.dist}</span>
                        </div>
                      )}
                      {item.stats.time && (
                        <div class="w-stat">
                          <span class="w-s-label">TIME</span>
                          <span class="w-s-value">{item.stats.time}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}

            <div class="timeline-end">
              <div class="end-mark"></div>
              <span class="end-text">END OF ROUTE</span>
            </div>
          </div>
        </div>

        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">MOD: LOG-INCL</span>
              <h3>Included Services</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="logistics-card secondary">
            <div class="card-header">
              <span class="c-id">MOD: TECH-EQ</span>
              <h3>Necessary Gear</h3>
            </div>
            <ul class="log-list">
              {equipment.map(eq => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" class="log-icon-alt"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                  <span>{eq}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">HIGH AVAILABILITY</span>
              <h3>Start your Expedition</h3>
              <p>Request the technical dossier for the Spectacular Route and secure your spot for this season.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">APPROXIMATE DATE</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">FULL NAME</label>
                    <input type="text" id="full-name" placeholder="Enter your full name" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  BOOK MY SPOT
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>

      <div class="technical-notice">
        <div class="notice-box">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p><strong>TECHNICAL RECOMMENDATION:</strong> Due to the duration and altitude of this route, we strongly recommend performing the proposed acclimatization days in Huaraz to ensure the success of the expedition.</p>
        </div>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={lang}
    images={[
      '/trekking/huayhuash/clasico.jpeg',
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png'
    ]} 
  />

  <RecommendedTours currentId="spectacular" />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "THE SPECTACULAR HUAYHUASH ROUTE 15D";
    
    const message = `Hello Franpisco Adventure! I'd like to book a spot for the spectacular expedition: ${tourName}. My details are:\n\n- Name: ${name}\n- Approx date: ${date}`;
    const whatsappUrl = `https://wa.me/51987654321?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  /* Reuse styles from other itinerary pages */
  .itinerary-hero {
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/trekking/huayhuash/clasico.jpeg') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    color: white;
    padding-top: 5rem;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .path-log {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-light);
    margin-bottom: 2rem;
  }

  .back-project {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
    border-radius: 4px;
    text-decoration: none;
    transition: 0.3s;
    margin-right: 0.5rem;
  }
  .back-project:hover {
    background: var(--brand-blue);
    border-color: var(--brand-blue);
    transform: translateX(-5px);
  }

  .p-divider { color: rgba(255,255,255,0.2); font-weight: 300; }
  .p-current { color: var(--brand-blue); }

  .split-title {
    display: flex;
    flex-direction: column;
    margin-bottom: 3.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.9rem, 2.5vw, 1.3rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  .metrics-bar {
    display: flex;
    gap: 4rem;
    padding: 2.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-light);
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  .m-value.price { color: var(--brand-blue); font-size: 1.2rem; }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    letter-spacing: 1px;
  }
  .dif-tag.hard { color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }

  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .dossier-sidebar {
    display: flex;
    justify-content: center;
  }
  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: var(--brand-light);
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: var(--brand-dark);
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: var(--brand-blue); }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--brand-dark);
    margin-bottom: 4rem;
    max-width: 550px;
    position: relative;
  }
  .dossier-p::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: #f1f5f9;
  }

  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec {
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .d-icon {
    margin-top: 0.2rem;
    color: var(--brand-blue);
    opacity: 0.6;
  }
  .d-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .d-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    color: var(--brand-light);
  }
  .d-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--brand-dark);
  }

  .dossier-visual { position: relative; }
  .visual-frame {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 550px;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0, 0.2, 1);
  }
  .visual-frame:hover .dossier-img { transform: scale(1.05); }

  .coordinates-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .coordinates-overlay .divider { opacity: 0.3; font-weight: 300; }

  @media (max-width: 1024px) {
    .dossier-layout { grid-template-columns: 1fr; }
    .dossier-sidebar { display: none; }
    .dossier-img { height: 400px; }
  }

  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid #e2e8f0; }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .details-header-technical { margin-bottom: 2.5rem; }
  .sub-label { font-size: 0.65rem; font-weight: 800; letter-spacing: 5px; color: var(--brand-light); display: block; margin-bottom: 1rem; }
  .technical-title { font-size: 1.8rem; font-weight: 900; color: var(--brand-dark); letter-spacing: -1px; }
  .technical-title .blue { color: var(--brand-blue); }

  .path-timeline { position: relative; padding-left: 2rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px;
    top: 0;
