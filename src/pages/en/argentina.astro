---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import TourCard from '../../components/TourCard.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const argentinaPrograms = [
  {
    id: 'aconcagua',
    title: t('climbing.aconcagua.name'),
    description: t('climbing.aconcagua.desc'),
    image: '/slider_2.png',
    duration: `17 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'argentina/aconcagua',
    prefix: 'ARG',
    type: 'HIGH ALTITUDE EXPEDITION'
  }
];
---

<Layout title={`Argentina - ${t('nav.destinations')} | Franpisco Adventure`} description="Explore the Argentinian Andes with Franpisco Adventure. Expeditions to Aconcagua, the roof of America, with top-tier logistics and expert guides.">
  <section class="dest-hero argentina">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 class="split-title">
        <span class="thin">DESTINATIONS</span>
        <span class="bold">ARGENTINA</span>
      </h1>
      <div class="blue-line"></div>
      <p class="hero-subtitle">Conquer the highest peaks of South America in the heart of the Central Andes.</p>
    </div>
  </section>

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {argentinaPrograms.map((prog) => (
          <TourCard 
            id={prog.id}
            title={prog.title}
            description={prog.description}
            image={prog.image}
            duration={prog.duration}
            difficulty={prog.difficulty}
            difficultyLevel={prog.difficultyLevel as any}
            path={prog.path}
            prefix={prog.prefix}
            type={prog.type}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .dest-hero {
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('/slider_2.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.85), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.85));
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 800px;
    padding: 0 2rem;
    margin-top: 3rem;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    line-height: 1;
    margin-bottom: 2rem;
  }
  .split-title .thin {
    font-size: clamp(0.9rem, 2.5vw, 1.4rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.9;
    text-transform: uppercase;
  }
  .split-title .bold {
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    font-weight: 900;
    letter-spacing: -1px;
  }

  .blue-line {
    width: 60px;
    height: 4px;
    background: #0090cc;
    margin: 0 auto 3rem;
    box-shadow: 0 0 15px rgba(0, 144, 204, 0.5);
  }

  .hero-subtitle {
    font-size: 1rem;
    font-weight: 300;
    letter-spacing: 1px;
    opacity: 0.8;
    max-width: 600px;
    margin: 0 auto;
  }

  .programs-section {
    padding: 6rem 0;
    background: #f8fafc;
  }

  .container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; }
    .dest-hero { height: 50vh; }
    .container { padding: 0 20px; }
  }
</style>
