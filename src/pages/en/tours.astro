---

<Layout title={`${t('nav.tours')} - Franpisco Adventure`} description="Explore our cultural expeditions and exclusive tours in the most iconic regions of Peru.">
  <section class="tours-hero">
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content">
        <h1 class="split-title">
          <span class="thin">EXPLORE OUR</span>
          <span class="bold">TOURS & EXPEDITIONS</span>
        </h1>
        
        <div class="red-line"></div>
      </div>
    </div>
  </section>

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {tours.map((tour) => (
          <TourCard 
            id={tour.id}
            title={tour.title}
            description={tour.description}
            image={tour.image}
            duration={tour.duration}
            difficulty={tour.difficulty}
            difficultyLevel={tour.difficultyLevel as any}
            path={tour.path}
            prefix={tour.prefix}
            type={tour.type}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .tours-hero {
    position: relative;
    height: 65vh;
    min-height: 500px;
    background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('/slider_4.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.8), rgba(3,4,5,0.2) 30%, rgba(3,4,5,0.8));
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    padding: 0 2rem;
    margin-top: 3rem;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    line-height: 1;
    margin-bottom: 2rem;
  }
  .split-title .thin {
    font-size: clamp(0.9rem, 2.5vw, 1.4rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.9;
  }
  .split-title .bold {
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    font-weight: 900;
    letter-spacing: -1px;
  }

  .red-line {
    width: 60px;
    height: 4px;
    background: var(--brand-red);
    margin: 0 auto 3rem;
    box-shadow: 0 0 15px var(--brand-red);
  }

  .programs-section {
    padding: 6rem 0;
    background: #f8fafc;
  }

  .container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .tours-hero {
      height: 50vh;
    }
    .programs-section {
      padding: 6rem 1.5rem;
    }
    .container { padding: 0; }
  }
</style>
