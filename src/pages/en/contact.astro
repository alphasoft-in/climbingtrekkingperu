---
import Layout from '@layouts/Layout.astro';
import ContactHub from '@components/ContactHub';
import SuggestedRoutes from '@components/SuggestedRoutes';
import { getLangFromUrl } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
---

<Layout 
	title={lang === 'es' ? "Contacto y Reservas | Franpisco Adventure Huaraz" : "Contact & Bookings | Franpisco Adventure Huaraz"}
	description={lang === 'es' ? "Contacta con Franpisco Adventure para planificar tu próxima expedición." : "Contact Franpisco Adventure to plan your next expedition."}
>
  <ContactHub client:load lang={lang as 'es' | 'en'} />
	<SuggestedRoutes lang={lang} currentId="contact" client:visible />
</Layout>
