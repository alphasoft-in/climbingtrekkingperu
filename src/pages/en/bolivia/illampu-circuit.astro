---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import RecommendedTours from '../../components/RecommendedTours.astro';
import TourGallery from '../../components/TourGallery.astro';

const langUrl = getLangFromUrl(Astro.url);
const t = useTranslations(langUrl);

const itinerary = [
  {
    day: 'DAY 01',
    title: 'LA PAZ – SORATA – LACHATHIYA (3850 M)',
    content: 'Scenic journey towards the northern Cordillera Real. Camp at Lachathiya with stunning views of Illampu.',
    stats: { alt: '3850m' }
  },
  {
    day: 'DAY 02',
    title: 'LACHATHIYA – ANCOHUMA PASS – CAMP',
    content: 'Crossing the first high pass (4749m). Views of the high valleys of Sorata and Andean flora.',
    stats: { time: '6h Trek', alt: '3900m' }
  },
  {
    day: 'DAY 03',
    title: 'ANCOHUMA – COCOYO (3850 M)',
    content: 'Hike to Kurahuasi pass (4479m) and descent to the remote village of Cocoyo.',
    stats: { time: '6h Trek', alt: '3850m' }
  },
  {
    day: 'DAY 04',
    title: 'COCOYO – CHAJOLPAYA (3700 M)',
    content: 'Ascent to Sarani pass (4500m). Observation of glaciers and diverse Andean wildlife.',
    stats: { time: '7h Trek', alt: '3700m' }
  },
  {
    day: 'DAY 05',
    title: 'CHAJOLPAYA – CHUJNA QUTA LAGOON (4100 M)',
    content: 'Cross Calzada pass (4900m) near the Kasiri glaciers. Camp by the turquoise lagoon.',
    stats: { time: '7h Trek', alt: '4100m' }
  },
  {
    day: 'DAY 06',
    title: 'CHUJNA QUTA – WARA WARA (3900 M)',
    content: 'Trek to San Francisco lagoon and relax in natural hot springs.',
    stats: { time: '6h Trek', alt: '3900m' }
  },
  {
    day: 'DAY 07',
    title: 'WARA WARA – MILLIPAYA – LA PAZ',
    content: 'Descent through abandoned mines and agricultural villages. Return transport to La Paz.',
    stats: { status: 'Return' }
  },
  {
    day: 'DAY 08',
    title: 'LA PAZ – AIRPORT',
    content: 'Transfer to El Alto airport. End of services.',
    stats: { status: 'Departure' }
  }
];

const includes = [
  'Airport - Hotel - Airport transfers',
  'Private transport La Paz - Sorata and Millipaya - La Paz',
  'Specialized Trekking Guide',
  'Cook and full meals (B/L/D)',
  'Mules for equipment transport',
  'Complete camping gear (Tents, kitchen, dining)',
  'Daily boiled water for bottles',
  'First aid kit'
];

const excludes = [
  'International flights',
  'Hotel in La Paz',
  'Sleeping bag and mat',
  'National Park entrance fees',
  'Personal insurance',
  'Snacks and tips'
];
---

<Layout title="Illampu Circuit: Remote Trekking | Bolivia | Franpisco Adventure" description="Explore one of the most remote and spectacular trekking circuits in the Andes: The Illampu massif in the Cordillera Real. 8 days of pure adventure.">
  <section class="itinerary-hero bolivia-illampu">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <div class="path-log">
          <a href={getRelativeLocaleUrl(langUrl, 'bolivia')} class="back-project">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3"><path d="M19 12H5m7 7l-7-7 7-7"/></svg>
          </a>
          <span class="p-base">BOLIVIA</span>
          <span class="p-divider">/</span>
          <span class="p-base">REMOTE TREKKING</span>
          <span class="p-divider">/</span>
          <span class="p-current">ILLAMPU CIRCUIT</span>
        </div>
        
        <h1 class="split-title">
          <span class="thin">THE WILD ANDES</span>
          <span class="bold">ILLAMPU CIRCUIT</span>
        </h1>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURATION</span>
            <span class="m-value">8 DAYS</span>
          </div>
          <div class="metric">
            <span class="m-label">MAX ALTITUDE</span>
            <span class="m-value">4,900 MSNM</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFFICULTY</span>
            <span class="m-value">
              <span class="dif-tag mod">MODERATE / CHALLENGING</span>
            </span>
          </div>
          <div class="metric">
            <span class="m-label">COST</span>
            <span class="m-value">USD 695.00</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">TREKKING LOGBOOK</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">LOG: BOL-ILL-08</span>
            <h2 class="dossier-title">The <span class="blue">Forgotten</span> Massif</h2>
          </div>
          
          <p class="dossier-p">The **Illampu Circuit** is a journey to the heart of the northern Cordillera Real. It is a route that circles the imposing Illampu massif, crossing high mountain passes above 4000 meters in one of the most pristine and least-traveled areas of the Bolivian Andes.</p>
          <p class="dossier-p">We will walk through traditional Aymara lands, flanked by giant glaciers, turquoise lagoons, and crystal-clear rivers, ending the day in camps under starry skies of absolute clarity.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">DESTINATION</span>
                <span class="d-value">Sorata / Cordillera Real</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">ACTIVITY</span>
                <span class="d-value">High Altitude Trekking</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/slider_4.png" alt="Illampu Massif" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>15° 49' 18" S</span>
              <span class="divider">|</span>
              <span>68° 32' 42" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">MISSION LOGBOOK</span>
            <h2 class="technical-title">Tactical <span class="blue">Itinerary</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">MASL</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.time && (
                        <div class="w-stat">
                          <span class="w-s-label">TIME</span>
                          <span class="w-s-value">{item.stats.time}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">MOD: LOG-INC</span>
              <h3>Included Services</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">REMOTE TREKKING READY</span>
              <h3>Start the Adventure</h3>
              <p>Circle the Illampu massif on one of the most spectacular trekking routes in South America.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">ESTIMATED DATE</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">FULL NAME</label>
                    <input type="text" id="full-name" placeholder="Your name" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  {t('trekking.book')}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={langUrl}
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <RecommendedTours currentId="illampu-trek-bol" />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "ILLAMPU TREKKING CIRCUIT - CORDILLERA REAL";
    
    const message = `Hi Franpisco Adventure! I want to book the Illampu Circuit in Bolivia. My details:\n\n- Name: ${name}\n- Date: ${date}`;
    const whatsappUrl = `https://wa.me/51962421830?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  .itinerary-hero {
    position: relative;
    height: 70vh;
    min-height: 600px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/slider_4.png') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    color: white;
    padding-top: 5rem;
  }
  .itinerary-hero.bolivia-illampu { background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/slider_4.png'); }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .path-log {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #94a3b8;
    margin-bottom: 2rem;
  }

  .back-project {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
    border-radius: 4px;
    text-decoration: none;
    transition: 0.3s;
    margin-right: 0.5rem;
  }
  .back-project:hover {
    background: #0090cc;
    border-color: #0090cc;
    transform: translateX(-5px);
  }

  .p-divider { color: rgba(255,255,255,0.2); font-weight: 300; }
  .p-current { color: #0090cc; }

  .split-title {
    display: flex;
    flex-direction: column;
    margin-bottom: 3.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.9rem, 2.5vw, 1.3rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  .metrics-bar {
    display: flex;
    gap: 4rem;
    padding: 2.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
    flex-wrap: wrap;
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #94a3b8;
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    border-radius: 2px;
    letter-spacing: 1px;
    font-weight: 900;
  }
  .dif-tag.mod { background: #e0f2fe; color: #0369a1; border: 1px solid #bae6fd; }

  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: #94a3b8;
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #0090cc;
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: #030405;
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: #0090cc; }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: #475569;
    margin-bottom: 4rem;
    max-width: 550px;
  }

  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec { display: flex; gap: 1.2rem; align-items: flex-start; }
  .d-icon { color: #0090cc; opacity: 0.6; margin-top: 0.2rem; }
  .d-info { display: flex; flex-direction: column; gap: 0.4rem; }
  .d-label { font-size: 0.6rem; font-weight: 800; color: #94a3b8; letter-spacing: 1.5px; }
  .d-value { font-size: 0.95rem; font-weight: 700; color: #030405; }

  .visual-frame {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 600px;
    object-fit: cover;
  }

  .coordinates-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid #e2e8f0; }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .sub-label { font-size: 0.6rem; font-weight: 800; color: #0090cc; margin-bottom: 0.5rem; display: block; }
  .technical-title { font-size: 2.2rem; font-weight: 900; color: #030405; margin-bottom: 2rem; letter-spacing: -1px; }
  .technical-title .blue { color: #0090cc; }

  .path-timeline { position: relative; padding-left: 2rem; margin-top: 3rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, #0090cc, #94a3b8, #94a3b8);
  }

  .waypoint-item { display: flex; gap: 1.5rem; margin-bottom: 4rem; position: relative; }
  .waypoint-marker { position: relative; z-index: 2; flex-shrink: 0; }
  .marker-box {
    width: 90px;
    height: 40px;
    background: white;
    border: 2px solid #030405;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  .m-day { font-size: 0.75rem; font-weight: 900; color: #030405; }

  .w-title { font-size: 1.15rem; font-weight: 800; color: #030405; margin-bottom: 0.8rem; }
  .w-description { font-size: 0.88rem; line-height: 1.8; color: #475569; margin-bottom: 1rem; }

  .waypoint-stats { display: flex; gap: 2rem; padding-top: 1rem; border-top: 1px solid #e2e8f0; }
  .w-stat { display: flex; flex-direction: column; gap: 0.4rem; }
  .w-s-label { font-size: 0.6rem; font-weight: 800; color: #94a3b8; letter-spacing: 1px; }
  .w-s-value { font-size: 0.75rem; font-weight: 700; color: #030405; }

  .logistics-sidebar { display: flex; flex-direction: column; gap: 3rem; padding-top: 6.5rem; }
  .logistics-card { background: white; padding: 2.5rem; border: 1px solid #e2e8f0; }
  .log-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .log-list li { display: flex; gap: 1rem; align-items: flex-start; font-size: 0.82rem; color: #475569; }
  .log-icon { color: #0090cc; flex-shrink: 0; margin-top: 0.2rem; }

  .mission-cta { background: #030405; color: white; padding: 3rem; }
  .cta-status { font-size: 0.6rem; font-weight: 900; color: #0090cc; letter-spacing: 2px; display: block; margin-bottom: 1.5rem; }
  .mission-cta h3 { font-size: 1.6rem; font-weight: 900; margin-bottom: 1rem; }
  .mission-cta p { font-size: 0.95rem; opacity: 0.7; margin-bottom: 2rem; }

  .btn-tactical {
    width: 100%;
    background: #0090cc;
    color: white;
    border: none;
    padding: 1.2rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    cursor: pointer;
    transition: 0.3s;
  }
  .btn-tactical:hover { background: #0070a0; }

  .form-group { margin-bottom: 1.5rem; }
  .form-group label { display: block; font-size: 0.6rem; font-weight: 800; color: #0090cc; margin-bottom: 0.5rem; }
  .form-group input {
    width: 100%;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 0.8rem;
    color: white;
    outline: none;
  }

  @media (max-width: 1024px) {
    .dossier-layout { grid-template-columns: 1fr; }
    .details-layout { grid-template-columns: 1fr; }
    .logistics-sidebar { padding-top: 0; }
  }
</style>
