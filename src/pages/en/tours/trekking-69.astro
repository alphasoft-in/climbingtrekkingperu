---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import RecommendedTours from '../../../components/RecommendedTours.astro';
import TourGallery from '../../../components/TourGallery.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: '05:00 AM',
    title: 'EARLY DEPARTURE',
    content: 'Departure from Huaraz heading north. Stop on the way for an energetic breakfast (not included).',
    stats: { time: 'Start' }
  },
  {
    day: '08:30 AM',
    title: 'CEBOLLAPAMPA',
    content: 'Arrival at the trekking starting point after passing through the Llanganuco lakes. Gear preparation.',
    stats: { alt: '3900m' }
  },
  {
    day: '09:00 AM',
    title: 'TREKKING START',
    content: 'Ascending hike through the Demanda valley, passing by Consuelo Lake and glacial landscapes.',
    stats: { dist: '7 km' }
  },
  {
    day: '12:00 PM',
    title: 'LAKE 69 (4600M)',
    content: 'Arrival at the blue jewel. Time for photos, relaxation, and enjoying the view of Chacraraju and Pisco peaks.',
    stats: { alt: '4600m', time: '1 h stay' }
  },
  {
    day: '04:00 PM',
    title: 'RETURN TO CEBOLLAPAMPA',
    content: 'Descent along the same route to the transportation. Return journey to Huaraz.',
    stats: { time: 'Descent' }
  },
  {
    day: '07:00 PM',
    title: 'ARRIVAL IN HUARAZ',
    content: 'End of the day at the Huaraz Main Square.',
    stats: { time: 'End' }
  }
];

const includes = [
  'Pick up from your hotel in Huaraz',
  'Private/shared tourist transportation',
  'Official Tour Guide (Bilingual)',
  'Emergency oxygen and first aid kit',
  'Trekking poles (upon request)'
];

const excludes = [
  'Breakfast and lunch (Box lunch recommended)',
  'HNP entrance ticket (Ext: S/. 30.00 / Nac: S/. 12.00)',
  'Personal travel insurance',
  'Personal expenses'
];
---

<Layout title="Laguna 69 Trekking | Huaraz | Franpisco Adventure" description="The most famous one-day trek in the world. A demanding hike to an intense blue lake at 4600m in Huascaran National Park.">
  <section class="itinerary-hero laguna69">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <h1 class="split-title">
          <span class="thin">THE BLUE CHALLENGE</span>
          <span class="bold">LAGUNA 69 TREKKING</span>
        </h1>
        <div class="hero-accent-bar"></div>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURATION</span>
            <span class="m-value">FULL DAY (14h)</span>
          </div>
          <div class="metric">
            <span class="m-label">MAX ALTITUDE</span>
            <span class="m-value">4,600 MSNM</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFFICULTY</span>
            <span class="m-value">
              <span class="dif-tag hard">CHALLENGING</span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">TREKKING LOG</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">EXPEDITION ID: HZ-L69-FD</span>
            <h2 class="dossier-title">The Pinnacle of <span class="blue">Hiking</span></h2>
          </div>
          
          <p class="dossier-p">Laguna 69 is undoubtedly the most iconic one-day hike in the Peruvian Andes. Located at the foot of the imposing Chacraraju, its sapphire blue color and glacial environment offer an unparalleled visual reward after the effort of the ascent.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">DISTANCE</span>
                <span class="d-value">14 KM (Round trip)</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">GRADIENT</span>
                <span class="d-value">+700m Ascent</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">MARCH TIME</span>
                <span class="d-value">5 - 6 Hours</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">REQUIREMENT</span>
                <span class="d-value">Good Acclimatization</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/trekking/blanca/santa-cruz.png" alt="Laguna 69" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>09° 00' 40" S</span>
              <span class="divider">|</span>
              <span>77° 36' 47" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">HIGH MOUNTAIN TRAVERSE</span>
            <h2 class="technical-title">Route <span class="blue">Analysis</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">MASL</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.dist && (
                        <div class="w-stat">
                          <span class="w-s-label">STRETCH</span>
                          <span class="w-s-value">{item.stats.dist}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}

            <div class="timeline-end">
              <div class="end-mark"></div>
              <span class="end-text">SAFE RETURN</span>
            </div>
          </div>
        </div>

        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">REF: SRV-TREK</span>
              <h3>What's Included</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="logistics-card secondary">
            <div class="card-header">
              <span class="c-id">REF: EQP-TCN</span>
              <h3>Recommendations</h3>
            </div>
            <ul class="log-list">
              <li>Carry energetic snacks and 3L of water</li>
              <li>Clothes for wind and cold (layer system)</li>
              <li>Sunblock and UV sunglasses</li>
              <li>Trekking shoes with good grip</li>
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">PHYSICAL CHALLENGE</span>
              <h3>Accept the Challenge</h3>
              <p>Prepare for the most rewarding hike in Huaraz. Small groups and expert guides.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">TREKKING DATE</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">FULL NAME</label>
                    <input type="text" id="full-name" placeholder="Your name" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  {t('trekking.book')}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={lang}
    images={[
      '/trekking/blanca/santa-cruz.png',
      '/slider_4.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_1.png'
    ]} 
  />

  <RecommendedTours currentId="laguna69-fd" />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "LAGUNA 69 TREKKING FULL DAY";
    
    const message = `Hi Franpisco Adventure! I want to book the trekking: ${tourName}. My details are:\n\n- Name: ${name}\n- Date: ${date}`;
    const whatsappUrl = `https://wa.me/51962421830?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  
  
  }
  .itinerary-hero {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/trekking/blanca/santa-cruz.png') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    justify-content: center;
    color: white;
    padding-top: 5rem;
  
    text-align: center;
  }
  .itinerary-hero.laguna69 { background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/trekking/blanca/santa-cruz.png'); 
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .split-title {
    align-items: center;
    gap: 0.5rem;
    display: flex;
    flex-direction: column;
    margin-bottom:  1.5rem;
  
  
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  .metrics-bar {
    justify-content: center;
    display: flex;
    gap: 4rem;
    padding:  1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  
  
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #94a3b8;
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    letter-spacing: 1px;
  }
  .dif-tag.hard { background: #fff1f2; color: #ef4444; border-color: #fecdd3; }

  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: #94a3b8;
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #0090cc;
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: #030405;
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: #0090cc; }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: #475569;
    margin-bottom: 4rem;
    max-width: 550px;
  }

  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec { display: flex; gap: 1.2rem; align-items: flex-start; }
  .d-icon { color: #0090cc; opacity: 0.6; margin-top: 0.2rem; }
  .d-info { display: flex; flex-direction: column; gap: 0.4rem; }
  .d-label { font-size: 0.6rem; font-weight: 800; color: #94a3b8; letter-spacing: 1.5px; }
  .d-value { font-size: 0.95rem; font-weight: 700; color: #030405; }

  .visual-frame {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 550px;
    object-fit: cover;
  }

  .coordinates-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid #e2e8f0; }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .path-timeline { position: relative; padding-left: 2rem; margin-top: 3rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, #0090cc, #ef4444, #ef4444);
  }

  .waypoint-item { display: flex; gap: 1.5rem; margin-bottom: 4rem; position: relative; }
  .waypoint-marker { position: relative; z-index: 2; flex-shrink: 0; }
  .marker-box {
    width: 90px;
    height: 40px;
    background: white;
    border: 2px solid #030405;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  .m-day { font-size: 0.75rem; font-weight: 900; color: #030405; }

  .w-title { font-size: 1.15rem; font-weight: 800; color: #030405; margin-bottom: 0.8rem; }
  .w-description { font-size: 0.88rem; line-height: 1.8; color: #475569; margin-bottom: 1rem; }

  .waypoint-stats { display: flex; gap: 2rem; padding-top: 1rem; border-top: 1px solid #e2e8f0; }
  .w-stat { display: flex; flex-direction: column; gap: 0.4rem; }
  .w-s-label { font-size: 0.6rem; font-weight: 800; color: #94a3b8; letter-spacing: 1px; }
  .w-s-value { font-size: 0.75rem; font-weight: 700; color: #030405; }

  .logistics-sidebar { display: flex; flex-direction: column; gap: 3rem; padding-top: 6.5rem; }
  .logistics-card { background: white; padding: 2.5rem; border: 1px solid #e2e8f0; }
  .log-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .log-list li { display: flex; gap: 1rem; align-items: flex-start; font-size: 0.82rem; color: #475569; }
  .log-icon { color: #0090cc; flex-shrink: 0; margin-top: 0.2rem; }
  .log-icon-alt { color: #ef4444; opacity: 0.5; flex-shrink: 0; margin-top: 0.2rem; }

  .mission-cta { background: #030405; color: white; padding: 3rem; }
  .cta-status { font-size: 0.6rem; font-weight: 900; color: #0090cc; letter-spacing: 2px; display: block; margin-bottom: 1.5rem; }
  .mission-cta h3 { font-size: 1.6rem; font-weight: 900; margin-bottom: 1rem; }
  .mission-cta p { font-size: 0.95rem; opacity: 0.7; margin-bottom: 2rem; }

  .btn-tactical {
    width: 100%;
    background: #0090cc;
    color: white;
    border: none;
    padding: 1.2rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    cursor: pointer;
    transition: 0.3s;
  }
  .btn-tactical:hover { background: #0070a0; }

  .form-group { margin-bottom: 1.5rem; }
  .form-group label { display: block; font-size: 0.6rem; font-weight: 800; color: #0090cc; margin-bottom: 0.5rem; }
  .form-group input {
    width: 100%;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 0.8rem;
    color: white;
    outline: none;
  }

  @media (max-width: 1024px) {
    .dossier-layout { grid-template-columns: 1fr; }
    .details-layout { grid-template-columns: 1fr; }
    .logistics-sidebar { padding-top: 0; }
  }

  .hero-accent-bar {
    width: 60px;
    height: 4px;
    background: var(--brand-red);
    margin:  1.2rem auto;
    box-shadow: 0 0 15px rgba(239, 68, 68, 0.4);
  }

</style>

