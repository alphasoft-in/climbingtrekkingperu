---
import Slider from '../../components/Slider.astro';
import Layout from '../../layouts/Layout.astro';
---

<Layout 
	title="Home - Franpisco Adventure" 
	description="Franpisco Adventure Travel and Tourism Agency. Epic mountain and trekking expeditions in Huaraz and across South America."
>
	<!-- 1. Hero Slider -->
	<section id="hero-slider">
		<Slider />
	</section>

	<!-- 2. Institutional Intro -->
	<section class="about-section">
		<div class="page-content">
			<div class="about-header">
				<h2 class="section-title">FRANPISCO ADVENTURE E.I.R.L.</h2>
				<p class="section-subtitle">Travel and Tourism Agency</p>
				<div class="title-divider"></div>
			</div>
			
			<div class="about-text-columns">
				<p class="lead-text">Consolidated in the very heart of Huaraz, Peru. We are duly registered in the public registries of Peru as a specialized mountain tourist service provider company (All operations fully protected under reserved rights).</p>
				<p>All our teams integrate highly qualified professionals from various backgrounds with extensive and deep knowledge of the South American countries where we operate epic tourist destinations: <strong>Peru, Bolivia, Chile, Argentina, and Ecuador</strong>. Our solid staff shares a massive passion for their work in demanding trekking and mountaineering activities, offering an unbreakable commitment to supreme quality, professionalism, and thrill.</p>
			</div>
		</div>
	</section>

	<!-- 3. Our Pillars -->
	<section class="pillars-section">
		<div class="page-content">
			<div class="pillars-grid">
				<div class="pillar-card">
					<div class="pillar-icon">🎯</div>
					<h3>Our Objective</h3>
					<p>To be an innovative and highly successful company in the extreme tourism field. To train and provide vast opportunities to new generations, fulfilling our clients' biggest dreams by experiencing new expeditions safely and properly.</p>
				</div>
				<div class="pillar-card">
					<div class="pillar-icon">🤝</div>
					<h3>Our Ironclad Commitment</h3>
					<p>To constantly innovate with highly competitive programs scaling in offer and experience. We provide unique expeditions pre-crafted by our own traversing and deep reconnaissance in all Andean routes across the continent.</p>
				</div>
				<div class="pillar-card">
					<div class="pillar-icon">🏔️</div>
					<h3>Our Life Experience</h3>
					<p>Deeply knowing our technical itineraries is vital. Our team perpetually evolves by exploring and battling different Andean ranges. Personalized expert advice and transmitted life knowledge form the true core base of our premium services.</p>
				</div>
				<div class="pillar-card">
					<div class="pillar-icon">🌱</div>
					<h3>The Most Important Thing</h3>
					<p>Our valued elite clients, the absolute unconditional respect for a flawlessly clean environment, our indigenous culture, and the historically rich tradition in each country. All deserve the brand's maximum respect and care.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- 4. Area de Trabajo y Staff -->
	<section class="work-area-section">
		<div class="page-content">
			<div class="about-header">
				<h2 class="section-title">WE OPERATE IN THE SOUTH AMERICAN ANDES</h2>
				<div class="title-divider"></div>
				<p class="section-subtitle" style="max-width: 800px; margin: 0 auto; line-height: 1.6; text-transform:none;">In each destination we proudly claim as "ours", the personnel is 100% genuine local (expert guides, mountain chefs, sturdy porters, among others). Each has been rigorously selected for their impeccable professionalism and high tactical understanding of logistical programs. We dream of delivering authentic local service while respecting natural earthly reserves.</p>
			</div>
			
			<div class="staff-types-grid">
				<div class="staff-box">
					<h4>🧗 Expert Mountain Guides</h4>
					<p>Fully certified <strong>AGMP – UIAGM</strong> internationally recognized guides in demanding mountaineering out in the elements to completely guarantee your absolute safety in any steep ice ascent.</p>
				</div>
				<div class="staff-box">
					<h4>🥾 Trekking Master Guides</h4>
					<p>Official and licensed wilderness tourism guides deeply immersed in native Andean culture, inherently ready to provide the best historical, biological, and technical insights on any altitude activity.</p>
				</div>
				<div class="staff-box">
					<h4>🏕️ High Mountain Tactical Auxiliaries</h4>
					<ul class="clean-list">
						<li><span class="bullet">✓</span> Specialized and legally accredited Mountain Chefs.</li>
						<li><span class="bullet">✓</span> Highly trained tactical Logistics Porters.</li>
						<li><span class="bullet">✓</span> Respected and officially trained Andean Muleteers.</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- 5. Nuestro Equipo -->
	<section class="team-section">
		<div class="page-content">
			<div class="about-header">
				<h2 class="section-title">OUR COMMAND TEAM</h2>
				<div class="title-divider"></div>
			</div>
			
			<div class="team-grid">
				<div class="team-card">
					<div class="team-avatar">FM</div>
					<h4>Francisco Mayhuay Colonia</h4>
					<span class="team-role">General Manager & Founder</span>
				</div>
				<div class="team-card">
					<div class="team-avatar">MM</div>
					<h4>Milagros Moreno Correa</h4>
					<span class="team-role">Head of Field Logistics</span>
				</div>
				<div class="team-card">
					<div class="team-avatar">NA</div>
					<h4>Nilo Aramburu Tafur</h4>
					<span class="team-role">Mountain Guide IVBV – UIAGM – IFMGA</span>
				</div>
				<div class="team-card">
					<div class="team-avatar">HJ</div>
					<h4>Hosterling Guillermo Julca</h4>
					<span class="team-role">Aspirant Mountain Guide</span>
				</div>
			</div>
		</div>
	</section>

	<!-- 6. Experiencia Gastronómica Premium -->
	<section class="gastronomy-section">
		<div class="page-content">
			<div class="about-header">
				<h2 class="section-title">EXPEDITION GASTRONOMY</h2>
				<div class="title-divider"></div>
				<p class="section-subtitle" style="max-width: 800px; margin: 0 auto; line-height: 1.6; text-transform:none;">We offer an impeccable variety of high-energy meals organically designed to nourish physical depletion on extreme mountains, always prepared at high altitude by our highly specialized Mountain Chefs.</p>
				
				<div class="diet-badges">
					<span class="diet-badge normal">Omnivore</span>
					<span class="diet-badge veg">Vegetarian</span>
					<span class="diet-badge vegan">Fully Vegan</span>
					<span class="diet-badge gluten">Gluten-Free</span>
				</div>
			</div>
			
			<div class="gastronomy-grid">
				<div class="gastro-card">
					<div class="gastro-header">
						<div class="gastro-icon">🍳</div>
						<h3>High-Energy Breakfasts</h3>
					</div>
					<div class="food-tags">
						<span class="f-tag">Andean Oats</span>
						<span class="f-tag">Ancestral Quinoa</span>
						<span class="f-tag">Griddle Eggs</span>
						<span class="f-tag">Premium Omelets</span>
						<span class="f-tag">Sweet Pancakes</span>
						<span class="f-tag">Native Drip Coffee</span>
						<span class="f-tag">Exotic Herbal Teas</span>
						<span class="f-tag">Hot Rich Chocolate</span>
						<span class="f-tag">Fresh Local Yogurt</span>
						<span class="f-tag">Rustic Whole Wheat Bread</span>
					</div>
				</div>
				
				<div class="gastro-card">
					<div class="gastro-header">
						<div class="gastro-icon">🥗</div>
						<h3>Fresh Lunch of the Day</h3>
					</div>
					<div class="food-tags">
						<span class="f-tag">Chicken Salpicón</span>
						<span class="f-tag">Avocado & Tuna Salad</span>
						<span class="f-tag">Paella Style Rice</span>
						<span class="f-tag">Papa a la Huancaína</span>
						<span class="f-tag">Native Spicy Ocopa</span>
						<span class="f-tag">Mushroom Ceviche</span>
						<span class="f-tag">Causa Limeña</span>
						<span class="f-tag">Smoked Stuffed Peppers</span>
						<span class="f-tag">Quinoa Chaufa</span>
						<span class="f-tag">Golden Chicken Chicharrón</span>
					</div>
				</div>

				<div class="gastro-card">
					<div class="gastro-header">
						<div class="gastro-icon">☕</div>
						<h3>Afternoon Brunch & Recovery</h3>
					</div>
					<div class="food-tags">
						<span class="f-tag">Green Coca Tea</span>
						<span class="f-tag">Rustic Natural Muña</span>
						<span class="f-tag">Steaming Popcorn</span>
						<span class="f-tag">Fresh Fried Wontons</span>
						<span class="f-tag">Tequeños w/ Guacamole</span>
						<span class="f-tag">Fried Amazonian Yuca</span>
						<span class="f-tag">Andean Cancha w/ Cheese</span>
						<span class="f-tag">Homemade Artisanal Pizzas</span>
					</div>
				</div>

                <div class="gastro-card wide-card">
					<div class="gastro-header">
						<div class="gastro-icon">🍲</div>
						<h3>The Nutritional Night Dinner</h3>
					</div>
					<div class="dinner-split">
						<div class="dinner-side">
							<h4 class="sub-label">Restorative Soups</h4>
							<div class="food-tags mini">
								<span class="f-tag">Arequipa Creole Soup</span>
								<span class="f-tag">Fine Pumpkin Cream</span>
								<span class="f-tag">Pea & Fava Bean Cream</span>
								<span class="f-tag">Minuta Style Soup</span>
								<span class="f-tag">Andean Olluco Chupe</span>
							</div>
						</div>
						<div class="dinner-side">
							<h4 class="sub-label">Masterful Main Courses</h4>
							<div class="food-tags mini">
								<span class="f-tag">Flaming Lomo Saltado</span>
								<span class="f-tag">Chicken Roll w/ Tropical Pineapple</span>
								<span class="f-tag">Fine Herb Chicken Breasts</span>
								<span class="f-tag">Beef Steak with Milky Mash</span>
								<span class="f-tag">Stuffed or Golden Golden Trout</span>
								<span class="f-tag">Artisanal Bolognese Spaghetti</span>
								<span class="f-tag">Select Charcoal Grilled Skewers</span>
							</div>
						</div>
					</div>
				</div>

				<div class="gastro-card">
					<div class="gastro-header">
						<div class="gastro-icon">🍮</div>
						<h3>Magical Premium Desserts</h3>
					</div>
					<div class="food-tags">
						<span class="f-tag">Exotic Flambéed Orange</span>
						<span class="f-tag">Caramelized Banana Flambé</span>
						<span class="f-tag">Peruvian Purple Corn Pudding</span>
						<span class="f-tag">Sweet Andean Oca Roots</span>
						<span class="f-tag">Citrus Rice Pudding</span>
						<span class="f-tag">Artisanal Lemon Meringue Pie</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- 7. Información Logística (Accordion ampliado) -->
	<section class="logistics-section">
		<div class="page-content">
			<div class="about-header">
				<h2 class="section-title">EXPEDITION RULES AND LOGISTICS</h2>
				<div class="title-divider"></div>
			</div>
			
			<div class="accordion-container">
				
				<details class="accordion-item" name="logistics" open>
					<summary class="accordion-title">⛺ Morning Routine: Every Day at the Base Camp</summary>
					<div class="accordion-content">
						<p>Our premium accommodation camping tents will be found impeccably <strong>set up beforehand by our diligent muleteers and chefs</strong>, fully ready to receive you exhausted at sunset to rest without lifting a single finger.</p>
						<p>In the frigid mornings, our robust tents are guarded and diligently collected by the native muleteers securely at 6:00 am. You will only personally need to <strong>leave all your nocturnal baggage firmly packed</strong> and fully closed before heading smoothly to enjoy our rich morning breakfast in the dining tent.</p>
					</div>
				</details>
				
				<details class="accordion-item" name="logistics">
					<summary class="accordion-title">🛅 Exclusive Base Warehouse (Leftover City Luggage)</summary>
					<div class="accordion-content">
						<p>During the arduous glacier trekking time, <strong>you can fiercely guard your hard non-necessary suitcases completely free of charge and under an airtight locker</strong> in our exclusive warehouse physically located at our corporate headquarters in the city of Huaraz.</p>
						<p>You strictly must arrange this included benefit on the precious day of the informative pre-expedition "Briefing", directly talking with our base logistics team.</p>
					</div>
				</details>

				<details class="accordion-item" name="logistics">
					<summary class="accordion-title">🏕️ Our Hard Survival and Camp Equipment Arrays</summary>
					<div class="accordion-content">
						<p>We exclusively and uncompromisingly provide <strong>Imported Thermal Four Season Tents (Rated for 5,000m+)</strong> intensely resistant to the harshest inclemencies of glaciers or Andean highlands. They are deliberately used for clients 2 by 2, for absolute maximum comfort.</p>
						<p>Additionally, we set up the massive <strong>Communitarian Dining Tent</strong> (with dense chairs and solid tables), a sterile <strong>Base Kitchen Tent</strong>, and a comfortable warm <strong>Ecological Toilet Tent</strong>, including brilliant sterile Andean surgical steel tableware and powerful tactical night headlamps.</p>
					</div>
				</details>
				
				<details class="accordion-item" name="logistics">
					<summary class="accordion-title">🧳 Elite Natural Transportation Of Corporate Equipment</summary>
					<div class="accordion-content">
						<p>To transport heavy supplies and cordillera survival equipment up the valleys, <strong>we hire brave local native muleteers and their beasts of burden directly, entirely bypassing exploitative intermediaries</strong>, rigorously according to your group's immense logistical need.</p>
						<p>Directly supporting, without parasitic networks, the humble but utterly noble local South American circular social economy.</p>
					</div>
				</details>

				<details class="accordion-item" name="logistics">
					<summary class="accordion-title">⚖️ Strict Unbreakable Operational Logistics Rules</summary>
					<div class="accordion-content">
						<ul class="clean-list">
							<li><span class="bullet">✓</span> <strong>Inclement Mountaineering (5,000m):</strong> One master UIAGM Andean official guide can lead with strict maximum safety <strong>only 3 people tied to his human life rope</strong> in high snow on classical routes.</li> 
                            <li><span class="bullet">✓</span> <strong>Extreme Technical Summits (6,000m+):</strong> The protocol security lock descends heavily, requiring that the guide assumes <strong>absolute responsibility over a maximum of 2 unique individuals only</strong>.</li>
							<li><span class="bullet">✓</span> <strong>High Prolonged Free Trekking (Huayhuash/Ausangate):</strong> One strong main trek guide firmly physically conducts up to <strong>10 free walking souls</strong>. Surpassing that sacred number, we instantly dispatch a swift Guide Assistant for absolute security.</li>
							<li><span class="bullet">✓</span> <strong>Regulated Fine Feeding:</strong> A native Master Chef cooks exclusively for 10 hikers, achieving pure absolute efficiency at the burner stove. Extra pax necessarily requires a vital Auxiliary Kitchen Assistant.</li>
						</ul>
					</div>
				</details>
			</div>
		</div>
	</section>

	<!-- 8. Compromiso Ético Final BENTO BOX UI -->
	<section class="ethical-bento-section">
		<div class="page-content">
			<div class="bento-header">
				<h2 class="section-title">OUR PRINCIPAL SERVICES AND HONOR CODE</h2>
				<div class="title-divider"></div>
				<p class="bento-subtitle">Before blindly booking a cheap online expedition service, for your noble international soul, literally stop and loudly demand unconditional respect for the pure and loyal ancient Andean nature and its men.</p>
			</div>

			<div class="bento-grid">
				<!-- Bento 1: Warning Piratas -->
				<div class="bento-card b-red b-span-2">
					<div class="b-icon-warn">⚠️ BAD COMPETITIVE MARKET PRACTICE IN THE ANDES</div>
					<h3 class="b-heading">Not all corporate companies show respect.</h3>
					<p>It is pitifully painful to admit that the vast majority of cheap pirated corporate agencies in the ranges, unscrupulously <strong>humiliate the mule weight load and pay entirely miserable pennies to humble base Andean muleteers just to save a few commercial market bills and profit by massive volume—thus bleeding the colossal mountains that feed us in eternal ice and perfectly pristine gorgeous blue Andean lakes.</strong></p>
				</div>

				<!-- Bento 2: Ética y Peso-->
				<div class="bento-card b-blue">
					<div class="b-icon">⚖️</div>
					<h3 class="b-heading">The Absolute 40KG Mule Rule</h3>
					<p>Our beautiful local pack beasts legally withstand as a <strong>STRICT MAXIMUM and uncompromising legal limit exactly 40 ethical kilograms of purely respected, warmly packed weight</strong>. A dignified, warm local muleteer will honorably shepherd only a max of 6 completely healthy grazing animals.</p>
				</div>

				<!-- Bento 3: Seguridad -->
				<div class="bento-card b-dark">
					<div class="b-icon">🛡️</div>
					<h3 class="b-heading">Intransigent Absolute Safety</h3>
					<p>Not even the bitter Andean inclemency and its cold, raging madness will bend our rigid security margin standards by a single centimeter ever.</p>
				</div>

				<!-- Bento 4: Calidad -->
				<div class="bento-card b-dark">
					<div class="b-icon">⭐</div>
					<h3 class="b-heading">High-End Premium Quality</h3>
					<p>Exquisitely fresh master chef food and vastly superior, highly durable solid mountain equipment always ready.</p>
				</div>

				<!-- Bento 5: Medio Ambiente -->
				<div class="bento-card b-green">
					<div class="b-icon">🌱</div>
					<h3 class="b-heading">Total Environmental Protection</h3>
					<p>We deeply guarantee absolute Zero Carbon Footprint tracking. Lethal rigorous care and living immaculate eternal respect for the fragile South American end-of-the-world glaciers.</p>
				</div>

				<!-- Bento 6: Cierre Épico -->
				<div class="bento-card b-gold b-span-2">
					<p class="epic-quote">"Our powerful corporate brand, FRANPISCO ADVENTURE E.I.R.L., DOES deeply value with fierce Andean loyalty, we swear, beg, and implacably respect in a truly ironclad corporate promise the high human payment given down to the base noble mud muleteer, protecting the legally balanced and completely fair animal weight. All wrapped in devoted, fanatic purifying holy care of the intact, pristine clean environment that intensely beats our majestic southern heart."</p>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	/* Same EXACT CSS as Spanish index.astro (White/Corporate layout) */
	section {
		padding: clamp(3rem, 6vw, 6rem) 1rem;
		box-sizing: border-box;
		width: 100%;
	}
	
	#hero-slider {
		padding: 0;
	}

	.page-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0;
		box-sizing: border-box;
	}
	
	.about-header, .bento-header {
		text-align: center;
		margin-bottom: clamp(2.5rem, 5vw, 4rem);
	}

	.section-title {
		font-size: clamp(1.8rem, 4vw, 2.5rem);
		font-weight: 800;
		color: #0f4d82;
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.section-subtitle {
		font-size: clamp(0.95rem, 2vw, 1.15rem);
		color: #555;
		margin-top: 1rem;
		letter-spacing: clamp(1px, 2vw, 2px);
	}

	.bento-subtitle {
		font-size: clamp(1rem, 2.5vw, 1.25rem);
		color: #475569;
		margin-top: 1.5rem;
		line-height: 1.6;
		max-width: 800px;
		margin-inline: auto;
	}

	.title-divider {
		height: 3px;
		width: clamp(40px, 8vw, 60px);
		background: #0a84ff;
		margin: 1.2rem auto;
		border-radius: 2px;
	}

	.clean-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.clean-list li {
		display: flex;
		align-items: flex-start;
		gap: 10px;
		margin-bottom: 0.8rem;
		line-height: 1.6;
	}
	.clean-list .bullet {
		color: #0a84ff;
		font-weight: bold;
	}

	.about-section { background: #fff; }
	.about-text-columns {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 400px), 1fr));
		gap: clamp(1.5rem, 4vw, 3rem);
		font-size: clamp(1.05rem, 2vw, 1.15rem);
		line-height: 1.8;
		color: #444;
	}
	.lead-text {
		font-size: clamp(1.1rem, 2.5vw, 1.35rem);
		font-weight: 300;
		color: #0f4d82;
		line-height: 1.6;
	}

	.pillars-section { background: #f8fbff; }
	.pillars-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 250px), 1fr));
		gap: clamp(1rem, 3vw, 2rem);
	}
	.pillar-card {
		background: white;
		padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 3vw, 2rem);
		border-radius: 12px;
		box-shadow: 0 4px 15px rgba(0,0,0,0.04);
		transition: transform 0.3s ease;
		border-top: 4px solid #0f4d82;
	}
	.pillar-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.08); }
	.pillar-icon { font-size: clamp(2rem, 5vw, 2.8rem); margin-bottom: 1rem; }
	.pillar-card h3 { color: #0f4d82; font-size: clamp(1.1rem, 3vw, 1.3rem); margin-bottom: 1rem; }
	.pillar-card p { color: #555; line-height: 1.6; font-size: clamp(0.9rem, 2vw, 0.95rem); margin: 0; }

	.work-area-section { background: white; }
	.staff-types-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
		gap: clamp(1.5rem, 3vw, 2rem);
	}
	.staff-box {
		padding: clamp(1.5rem, 4vw, 2.5rem);
		background: #f1f5f9;
		border-radius: 12px;
		border-left: 5px solid #0a84ff;
		transition: background 0.3s;
	}
	.staff-box:hover { background: #e2e8f0; }
	.staff-box h4 {
		font-size: clamp(1.1rem, 3vw, 1.3rem);
		color: #0f4d82;
		margin-bottom: 1rem;
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.staff-box p, .staff-box li { color: #555; font-size: clamp(0.95rem, 2vw, 1.05rem); }

	.team-section { background: #0f4d82; color: white; }
	.team-section .section-title { color: white; }
	.team-section .title-divider { background: #4da6ff; }
	.team-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 220px), 1fr));
		gap: clamp(1.5rem, 3vw, 2rem);
	}
	.team-card {
		background: rgba(255, 255, 255, 0.1);
		padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 2vw, 1.5rem);
		border-radius: 12px;
		text-align: center;
		backdrop-filter: blur(10px);
		border: 1px solid rgba(255,255,255,0.2);
		transition: transform 0.3s ease;
	}
	.team-card:hover { transform: translateY(-5px); background: rgba(255, 255, 255, 0.15); }
	.team-avatar {
		width: clamp(60px, 15vw, 80px);
		height: clamp(60px, 15vw, 80px);
		border-radius: 50%;
