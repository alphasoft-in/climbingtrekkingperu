---
import Slider from '../../components/Slider.astro';
import Layout from '../../layouts/Layout.astro';
import RecommendedTours from '../../components/RecommendedTours.astro';
---

<Layout 
	title="Home - Franpisco Adventure" 
	description="Franpisco Adventure Travel and Tourism Agency. Epic mountain and trekking expeditions in Huaraz and across South America."
>
	<!-- 1. Hero Slider -->
	<section id="hero-slider">
		<Slider />
	</section>

	<!-- 2. Institutional Intro: Premium Architectural Redesign -->
	<section class="page-section corporate-identity">
		<div class="page-content">
			<div class="identity-header">
				<h2 class="company-name">FRANPISCO ADVENTURE E.I.R.L.</h2>
				<p class="company-type">Travel and Tourism Agency</p>
				<div class="header-line"></div>
			</div>

			<div class="identity-grid">
				<div class="identity-col">
					<div class="info-badge">OFFICIAL REGISTRATION</div>
					<p class="lead-text">Consolidated in the very heart of Huaraz, Peru. We are duly registered in the public registries of Peru as a specialized mountain tourist service provider company (All operations fully protected under reserved rights).</p>
				</div>
				<div class="identity-col">
					<div class="info-badge">INTERNATIONAL NETWORK</div>
					<p>All our teams integrate highly qualified professionals from various backgrounds with extensive and deep knowledge of the South American countries where we operate epic tourist destinations: <strong>Peru, Bolivia, Chile, Argentina, and Ecuador.</strong></p>
					<p>Our solid staff shares a massive passion for their work in demanding trekking and mountaineering activities, offering an unbreakable commitment to supreme quality, professionalism, and thrill.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- 3. Our Pillars: Technical Institutional Redesign -->
	<section class="pillars-section">
		<div class="page-content">
			<div class="pillars-grid">
				<!-- CARD 01 -->
				<div class="pillar-card">
					<div class="pillar-top">
						<span class="pillar-num">01</span>
						<div class="pillar-icon">🎯</div>
					</div>
					<h3 class="pillar-title">OUR OBJECTIVE</h3>
					<div class="pillar-line"></div>
					<p>To be an <strong>innovative and successful</strong> company in the tourism field. To train and provide opportunities to new generations, fulfilling our clients' dreams in high-level expeditions.</p>
				</div>

				<!-- CARD 02 -->
				<div class="pillar-card">
					<div class="pillar-top">
						<span class="pillar-num">02</span>
						<div class="pillar-icon">🤝</div>
					</div>
					<h3 class="pillar-title">OUR COMMITMENT</h3>
					<div class="pillar-line"></div>
					<p>Innovating with competitive programs. We provide unique expeditions pre-crafted by our own technical traversing in <strong>Peru, Bolivia, Chile, Argentina, and Ecuador.</strong></p>
				</div>

				<!-- CARD 03 -->
				<div class="pillar-card">
					<div class="pillar-top">
						<span class="pillar-num">03</span>
						<div class="pillar-icon">🏔️</div>
					</div>
					<h3 class="pillar-title">OUR EXPERIENCE</h3>
					<div class="pillar-line"></div>
					<p>Deeply knowing our itineraries is vital. Our team perpetually evolves by exploring different Andean ranges. <strong>Personalized expert advice</strong> is the true core of our services.</p>
				</div>

				<!-- CARD 04 -->
				<div class="pillar-card">
					<div class="pillar-top">
						<span class="pillar-num">04</span>
						<div class="pillar-icon">🌱</div>
					</div>
					<h3 class="pillar-title">THE PRIORITY</h3>
					<div class="pillar-line"></div>
					<p>Our clients, the absolute respect for a clean environment and the rich Andean cultural tradition. Every destination deserves <strong>maximum respect and care</strong> from our brand.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- 4. Work Area and Staff: Regional Authority Redesign -->
	<section class="work-area-section">
		<div class="page-content">
			<div class="identity-header">
				<h2 class="company-name">WE OPERATE IN THE ANDES</h2>
				<p class="company-type">REGIONAL TECHNICAL OPERATIONS</p>
				<div class="header-line"></div>
				<p class="section-description">Our staff is 100% local at each destination. Rigorously selected for their impeccable professionalism and high tactical understanding of logistical programs.</p>
			</div>
			
			<div class="staff-types-grid">
				<!-- UNIT 01 -->
				<div class="staff-box">
					<div class="box-tag">AGMP – UIAGM CERTIFICATION</div>
					<h4 class="box-title">MOUNTAIN GUIDES</h4>
					<p>Specialists in demanding mountaineering and ice climbing, guaranteeing absolute safety in any technical ascent.</p>
				</div>

				<!-- UNIT 02 -->
				<div class="staff-box">
					<div class="box-tag">CULTURAL SUPPORT</div>
					<h4 class="box-title">TREKKING GUIDES</h4>
					<p>Official guides deeply immersed in Andean culture, delivering historical and technical insights of the highest caliber.</p>
				</div>

				<!-- UNIT 03 -->
				<div class="staff-box">
					<div class="box-tag">FIELD LOGISTICS</div>
					<h4 class="box-title">TECHNICAL AUXILIARIES</h4>
					<ul class="clean-list">
						<li><span class="bullet">✓</span> Accredited High Altitude Mountain Chefs.</li>
						<li><span class="bullet">✓</span> Specialized Technical Porters.</li>
						<li><span class="bullet">✓</span> Certified Andean Horsemen.</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- 5. Our Team: Tactical Command Redesign -->
	<section class="team-section">
		<div class="page-content">
			<div class="identity-header">
				<h2 class="company-name text-white">COMMAND TEAM</h2>
				<p class="company-type text-light">TECHNICAL AND OPERATIONAL COMMAND</p>
				<div class="header-line"></div>
			</div>
			
			<div class="team-grid">
				<!-- MEMBER 01 -->
				<div class="team-card">
					<div class="unit-badge">STRATEGIC LEAD</div>
					<div class="team-avatar">
						<img src="/perfiles/francisco.png" alt="Francisco Mayhuay Colonia" />
					</div>
					<h4 class="member-name">Francisco Mayhuay Colonia</h4>
					<span class="member-rank">General Manager & Founder</span>
				</div>

				<!-- MEMBER 02 -->
				<div class="team-card">
					<div class="unit-badge">MISSION CONTROL</div>
					<div class="team-avatar">
						<img src="/perfiles/milagros.png" alt="Milagros Moreno Correa" />
					</div>
					<h4 class="member-name">Milagros Moreno Correa</h4>
					<span class="member-rank">Head of Field Logistics</span>
				</div>

				<!-- MEMBER 03 -->
				<div class="team-card">
					<div class="unit-badge">ELITE SUMMIT</div>
					<div class="team-avatar">
						<img src="/perfiles/nilo.png" alt="Nilo Aramburu Tafur" />
					</div>
					<h4 class="member-name">Nilo Aramburu Tafur</h4>
					<span class="member-rank">Mountain Guide IVBV – UIAGM</span>
				</div>

				<!-- MEMBER 04 -->
				<div class="team-card">
					<div class="unit-badge">FRONT LINE</div>
					<div class="team-avatar">
						<img src="/perfiles/hosterling.png" alt="Hosterling Guillermo Julca" />
					</div>
					<h4 class="member-name">Hosterling Guillermo Julca</h4>
					<span class="member-rank">Aspirant Mountain Guide</span>
				</div>
			</div>
		</div>
	</section>

	<!-- 6. Expedition Gastronomy: Editorial Redesign -->
	<section class="gastronomy-section">
		<div class="page-content">
			<div class="identity-header">
				<h2 class="company-name">HIGH MOUNTAIN GASTRONOMY</h2>
				<p class="company-type">TECHNICAL CULINARY & FIELD NUTRITION</p>
				<div class="header-line"></div>
				<p class="section-description">Our kitchen is a fundamental pillar of the expedition. We design high-calorie menus prepared by specialized altitude chefs, ensuring full physical recovery.</p>
			</div>
				
			<div class="diet-badges">
				<span class="diet-tag">AVAILABLE DIETARY OPTIONS</span>
				<span class="diet-badge normal">OMNIVORE</span>
				<span class="diet-badge veg">VEGETARIAN</span>
				<span class="diet-badge vegan">VEGAN</span>
				<span class="diet-badge gluten">GLUTEN FREE</span>
			</div>

			<div class="gastronomy-grid">
				<!-- BREAKFAST -->
				<div class="gastro-card">
					<div class="g-unit">PROGRAM 01</div>
					<h3 class="g-title">ENERGY BREAKFASTS</h3>
					<div class="g-line"></div>
					<ul class="food-list">
						<li>Andean Oatmeal with Nuts</li>
						<li>Digestive Ancestral Quinoa</li>
						<li>Comal Eggs (Local Technique)</li>
						<li>Mountain Premium Omelet</li>
						<li>Sweet Pancakes & Fruit</li>
						<li>Native Filtered Coffee</li>
					</ul>
				</div>

				<!-- LUNCH -->
				<div class="gastro-card">
					<div class="g-unit">PROGRAM 02</div>
					<h3 class="g-title">RECOVERY LUNCH</h3>
					<div class="g-line"></div>
					<ul class="food-list">
						<li>Energetic Chicken Salpicon</li>
						<li>Fresh Tuna & Avocado Salad</li>
						<li>Andean Paella Style Rice</li>
						<li>Traditional Papa a la Huancaína</li>
						<li>Signature Causa Limeña</li>
						<li>Hydrating Fruit Dessert</li>
					</ul>
				</div>

				<!-- BRUNCH -->
				<div class="gastro-card">
					<div class="g-unit">PROGRAM 03</div>
					<h3 class="g-title">BRUNCH & RECHARGE</h3>
					<div class="g-line"></div>
					<ul class="food-list">
						<li>Green Coca Mate (Infusion)</li>
						<li>Natural Rustic Muña</li>
						<li>Steaming Field Popcorn</li>
						<li>Fried Recovery Wantan</li>
						<li>Tequeños with Guacamole</li>
						<li>Fried Amazonian Cassava</li>
					</ul>
				</div>

				<!-- DINNER - WIDE -->
				<div class="gastro-card wide-card">
					<div class="g-unit">SPECIAL PROGRAM</div>
					<h3 class="g-title">HOT TECHNICAL DINNER</h3>
					<div class="g-line"></div>
					<div class="dinner-split">
						<div class="dinner-group">
							<span class="sub-label">STARTERS & SOUPS</span>
							<ul class="food-list">
								<li>Revitalizing Sopa Criolla</li>
								<li>Fine Pumpkin Cream Soup</li>
								<li>Technical Sopa a la Minuta</li>
								<li>Andean Olluco Chupe</li>
							</ul>
						</div>
						<div class="dinner-group">
							<span class="sub-label">MASTER MAIN COURSES</span>
							<ul class="food-list">
								<li>Flame-Seared Lomo Saltado</li>
								<li>Andean Trout (Stuffed or Fried)</li>
								<li>Curry Chicken with Vegetables</li>
								<li>Artisanal Spaghetti Bolognese</li>
							</ul>
						</div>
					</div>
				</div>

				<!-- DESSERTS -->
				<div class="gastro-card">
					<div class="g-unit">END OF JOURNEY</div>
					<h3 class="g-title">PREMIUM DESSERTS</h3>
					<div class="g-line"></div>
					<ul class="food-list">
						<li>Exotic Flamed Orange</li>
						<li>Caramelized Flamed Banana</li>
						<li>Peruvian Mazamorra Morada</li>
						<li>Artisanal Lemon Pie</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- 7. Logistics and Regulation: Institutional Redesign -->
	<section class="logistics-section">
		<div class="page-content">
			<div class="identity-header">
				<h2 class="company-name">LOGISTICS AND OPERATION REGULATIONS</h2>
				<p class="company-type">institutional safety protocols</p>
				<div class="header-line"></div>
				<p class="section-description">Our operation is governed by high safety standards and logistical efficiency. Each procedure is designed to maximize the technical experience and the well-being of the explorer.</p>
			</div>

			<div class="creative-accordion">
				<!-- ITEM 01 -->
				<details class="acc-item" open>
					<summary class="acc-header">
						<div class="acc-num">01</div>
						<div class="acc-title-group">
							<span class="acc-category">FIELD PROTOCOL</span>
							<h3 class="acc-title">Morning Routine: Camp Life</h3>
						</div>
						<div class="acc-icon">
							<span class="icon-line"></span>
							<span class="icon-line"></span>
						</div>
					</summary>
					<div class="acc-content">
						<div class="content-inner">
							<p>You will find our camping accommodation tents impeccably <strong>set up in advance by our muleteers and cooks</strong>, ready to welcome you after an exhausting day so you can rest without lifting a finger.</p>
							<p>In the mornings, our robust tents are guarded and collected by diligent native muleteers at 6:00 am. You only need to <strong>firmly pack all your night luggage</strong> and leave it closed before enjoying our rich morning breakfast in the dining tent.</p>
						</div>
					</div>
				</details>

				<!-- ITEM 02 -->
				<details class="acc-item">
					<summary class="acc-header">
						<div class="acc-num">02</div>
						<div class="acc-title-group">
							<span class="acc-category">SAFETY AND STORAGE</span>
							<h3 class="acc-title">Exclusive Base Warehouse (City Luggage)</h3>
						</div>
						<div class="acc-icon">
							<span class="icon-line"></span>
							<span class="icon-line"></span>
						</div>
					</summary>
					<div class="acc-content">
						<div class="content-inner">
							<p>We have a private and secure warehouse at our operations base. You can leave your city belongings (suitcases, extra clothes) <strong>perfectly guarded</strong> throughout the expedition at no additional cost.</p>
							<p>Each bag is tagged and recorded in our security inventory before departing for the field.</p>
						</div>
					</div>
				</details>

				<!-- ITEM 03 -->
				<details class="acc-item">
					<summary class="acc-header">
						<div class="acc-num">03</div>
						<div class="acc-title-group">
							<span class="acc-category">TECHNICAL EQUIPMENT</span>
							<h3 class="acc-title">High-End Survival and Camping</h3>
						</div>
						<div class="acc-icon">
							<span class="icon-line"></span>
							<span class="icon-line"></span>
						</div>
					</summary>
					<div class="acc-content">
						<div class="content-inner">
							<p>We exclusively use <strong>leading brand equipment</strong> (4-season tents, high-mountain sleeping bags) designed to withstand extreme conditions in the Cordillera Blanca and Huayhuash.</p>
							<p>Our logistics include spacious dining tents, professional field kitchens, and ergonomic chairs to ensure comfort after the technical journey.</p>
						</div>
					</div>
				</details>

				<!-- ITEM 04 -->
				<details class="acc-item">
					<summary class="acc-header">
						<div class="acc-num">04</div>
						<div class="acc-title-group">
							<span class="acc-category">ENVIRONMENTAL REGULATION</span>
							<h3 class="acc-title">Leave No Trace Commitment</h3>
						</div>
						<div class="acc-icon">
							<span class="icon-line"></span>
							<span class="icon-line"></span>
						</div>
					</summary>
					<div class="acc-content">
						<div class="content-inner">
							<p>As certified guides, we apply a strict <strong>waste management</strong> policy. All generated waste is transported out of protected areas.</p>
							<p>We promote total respect for Andean biodiversity, water sources, and the local communities that welcome us into their territories.</p>
						</div>
					</div>
				</details>
			</div>
		</div>
	</section>

	<!-- 8. Ethical Commitment: Command Bento Redesign -->
	<section class="ethical-bento-section">
		<div class="page-content">
			<div class="identity-header">
				<h2 class="company-name">CODE OF HONOR & ETHICS</h2>
				<p class="company-type">OUR UNCOMPROMISING VALUES</p>
				<div class="header-line"></div>
				<p class="section-description">Before choosing a low-budget expedition, demand absolute respect for the integrity of the mountain and the dignity of the Andean personnel.</p>
			</div>

			<div class="bento-grid">
				<!-- Bento 1: Critical Warning -->
				<div class="bento-card b-red b-span-2">
					<div class="b-meta-tag">WARNING / MALPRACTICE</div>
					<h3 class="b-heading">Integrity vs. Exploitation</h3>
					<p>It is alarming to see how "low-cost" agencies bleed the mountain by humiliating mule weight and paying miserable wages to local muleteers to profit from volume. <strong>We choose ethics over profit margins.</strong></p>
					<div class="b-accent-bar"></div>
				</div>

				<!-- Bento 2: Animal Welfare -->
				<div class="bento-card b-blue">
					<div class="b-meta-tag">40KG STANDARD</div>
					<div class="b-icon">⚖️</div>
					<h3 class="b-heading">Animal Welfare</h3>
					<p>Our pack animals carry an ethical maximum of <strong>40kg</strong>. We protect the life of the animal as a pillar of our identity.</p>
				</div>

				<!-- Bento 3: Safety Security -->
				<div class="bento-card b-dark">
					<div class="b-meta-tag">SECURE / 01</div>
					<div class="b-icon">🛡️</div>
					<h3 class="b-heading">Radical Safety</h3>
					<p>We do not compromise on the safety margin, regardless of the extreme conditions.</p>
				</div>

				<!-- Bento 4: Environmental -->
				<div class="bento-card b-green">
					<div class="b-meta-tag">CLEAN / 02</div>
					<div class="b-icon">🌱</div>
					<h3 class="b-heading">Zero Footprint</h3>
					<p>Strict waste management. We return 100% of what we take to the field back to the city.</p>
				</div>

				<!-- Bento 5: Quality Elite -->
				<div class="bento-card b-dark">
					<div class="b-meta-tag">TECH / 03</div>
					<div class="b-icon">⭐</div>
					<h3 class="b-heading">Technical Quality</h3>
					<p>High-end equipment tested in the most hostile scenarios of the Andes.</p>
				</div>

				<!-- Bento 6: Epic Vow -->
				<div class="bento-card b-gold b-span-2">
					<div class="b-meta-tag">BRAND OATH</div>
					<p class="epic-vow">"WE VALUE with Andean loyalty the effort of our human team and the fair animal weight, in devoted care of the pristine environment that pulses our lives."</p>
					<div class="signature-line">
						<span class="sig-name">FRANPISCO ADVENTURE</span>
						<span class="sig-rank">EXPEDITION COMMAND</span>
					</div>
				</div>
			</div>
		</div>
	</section>
  <RecommendedTours />
</Layout>

<style>
	/* Same EXACT CSS as Spanish index.astro (White/Corporate layout) */
	section {
		padding: clamp(3rem, 6vw, 6rem) 1rem;
		box-sizing: border-box;
		width: 100%;
	}
	
	#hero-slider {
		padding: 0;
	}

	.page-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0;
		box-sizing: border-box;
	}
	
	.about-header, .bento-header {
		text-align: center;
		margin-bottom: clamp(2.5rem, 5vw, 4rem);
	}

	.section-title {
		font-size: clamp(1.8rem, 4vw, 2.5rem);
		font-weight: 800;
		color: #0f4d82;
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.section-subtitle {
		font-size: clamp(0.95rem, 2vw, 1.15rem);
		color: #555;
		margin-top: 1rem;
		letter-spacing: clamp(1px, 2vw, 2px);
	}

	.bento-subtitle {
		font-size: clamp(1rem, 2.5vw, 1.25rem);
		color: #475569;
		margin-top: 1.5rem;
		line-height: 1.6;
		max-width: 800px;
		margin-inline: auto;
	}

	.title-divider {
		height: 3px;
		width: clamp(40px, 8vw, 60px);
		background: #0a84ff;
		margin: 1.2rem auto;
		border-radius: 2px;
	}

	.clean-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.clean-list li {
		display: flex;
		align-items: flex-start;
		gap: 10px;
		margin-bottom: 0.8rem;
		line-height: 1.6;
	}
	.clean-list .bullet {
		color: #0a84ff;
		font-weight: bold;
		flex-shrink: 0;
		margin-top: 2px;
	}
	.list-text {
		flex: 1;
	}

	/* --- CORPORATE IDENTITY (ARCHITECTURAL REDESIGN) --- */
	.corporate-identity {
		background: #ffffff;
		padding: clamp(4rem, 8vw, 7rem) 1rem;
	}

	.identity-header {
		text-align: center;
		margin-bottom: clamp(3rem, 6vw, 4.5rem);
	}

	.company-name {
		font-size: clamp(1.8rem, 4.5vw, 2.6rem);
		color: var(--brand-blue);
		font-weight: 900;
		text-transform: uppercase;
		margin: 0 0 0.5rem 0;
		letter-spacing: 1px;
		line-height: 1.1;
	}

	.company-type {
		font-size: clamp(0.9rem, 2vw, 1.1rem);
		color: #555;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 2px;
	}

	.header-line {
		width: 60px;
		height: 4px;
		background: var(--brand-red);
		margin: 1.5rem auto 0;
		border-radius: 2px;
	}

	.identity-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(2rem, 5vw, 5rem);
		align-items: flex-start;
	}

	.identity-col {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.info-badge {
		font-size: 0.65rem;
		font-weight: 900;
		color: var(--brand-red);
		letter-spacing: 2px;
		text-transform: uppercase;
		border-left: 3px solid var(--brand-red);
		padding-left: 12px;
		margin-bottom: 0.5rem;
	}

	.identity-col p {
		font-size: clamp(1rem, 2vw, 1.15rem);
		line-height: 1.7;
		color: #444;
		margin: 0;
	}

	.lead-text {
		font-weight: 400;
		color: var(--brand-dark);
	}

	@media (max-width: 900px) {
		.identity-grid { grid-template-columns: 1fr; text-align: left; }
		.identity-header { margin-bottom: 3rem; }
	}

	.pillars-section { background: #f8fbff; }
	.pillars-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 250px), 1fr));
		gap: clamp(1rem, 3vw, 2rem);
	}
	.pillar-card {
		background: white;
		padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 3vw, 2rem);
		border-radius: 12px;
