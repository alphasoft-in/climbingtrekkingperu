---
import { toursData } from '@data/tours/toursData';
import { regionsData } from '@data/regions';
import CategoryTemplate from '@components/CategoryTemplate.astro';

const lang = 'en';
const metadata = regionsData['peru'];

// Featured selection for Peru hub
const featuredIds = ['santa-cruz', 'huayhuash-360', 'alpamayo', 'trekking-69', 'huascaran', 'camino-inca'];
const programs = toursData.filter(t => featuredIds.includes(t.slug));
---

<CategoryTemplate lang={lang} metadata={metadata} programs={programs} />
