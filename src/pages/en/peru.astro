---
import Layout from '../../layouts/Layout.astro';
import RecommendedTours from '../../components/RecommendedTours.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import TourCard from '../../components/TourCard.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const peruPrograms = [
  {
    id: 'santa-cruz',
    title: 'Santa Cruz Trekking',
    description: 'The most emblematic circuit in the White Range. 4 days of turquoise lagoons and views of Alpamayo.',
    image: '/slider_1.png',
    duration: '4 Days',
    difficulty: 'Moderate',
    difficultyLevel: 'mod',
    path: 'trekking/blanca/santa-cruz',
    prefix: 'PER',
    type: 'CLASSIC TREKKING'
  },
  {
    id: 'huayhuash-360',
    title: 'Huayhuash 360°',
    description: 'Considered one of the best treks in the world. A technical circumnavigation of the Huayhuash range.',
    image: '/slider_2.png',
    duration: '12 Days',
    difficulty: 'Exigent',
    difficultyLevel: 'hard',
    path: 'trekking/huayhuash/360',
    prefix: 'PER',
    type: 'EXPEDITION'
  },
  {
    id: 'alpamayo-climb',
    title: 'Nevado Alpamayo',
    description: 'The most beautiful mountain in the world. Technical ascent via the French Direct face.',
    image: '/slider_3.png',
    duration: '6 Days',
    difficulty: 'Technical',
    difficultyLevel: 'hard',
    path: 'climbing/alpamayo',
    prefix: 'PER',
    type: 'MOUNTAINEERING'
  },
  {
    id: 'laguna-69',
    title: 'Laguna 69 Trekking',
    description: 'Perfect acclimatization. Visit the most famous lagoon in Huaraz under Chacraraju and Pisco peaks.',
    image: '/slider_4.png',
    duration: 'Full Day',
    difficulty: 'Moderate',
    difficultyLevel: 'mod',
    path: 'tours/trekking-69',
    prefix: 'PER',
    type: 'DAY HIKE'
  },
  {
    id: 'huascaran-expedition',
    title: 'Nevado Huascaran',
    description: 'The roof of Peru and the tropics. The ultimate challenge for mountaineers in the Peruvian Andes.',
    image: '/slider_5.png',
    duration: '7 Days',
    difficulty: 'Very Exigent',
    difficultyLevel: 'hard',
    path: 'climbing/huascaran',
    prefix: 'PER',
    type: 'HIGH ALTITUDE'
  },
  {
    id: 'cusco-inca-trail',
    title: 'Inca Trail',
    description: 'Follow the steps of the Incas to the citadel of Machu Picchu. A unique cultural and natural experience.',
    image: '/slider_1.png',
    duration: '4 Days',
    difficulty: 'Moderate',
    difficultyLevel: 'mod',
    path: 'trekking/cusco/camino-inca',
    prefix: 'PER',
    type: 'CULTURAL TREK'
  }
];
---

<Layout title={`Peru - ${t('nav.destinations')} | Franpisco Adventure`} description="Discover the Peruvian Andes with Franpisco Adventure. Trekking in the White Range and Huayhuash, high mountain climbing, and cultural tours in Cusco and Machu Picchu.">
  <section class="hub-hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 class="split-title">
        <span class="thin">DESTINATIONS</span>
        <span class="bold">PERU</span>
      </h1>
      <div class="hero-accent-bar"></div>
      
      <div class="hero-side-technical">
        <div class="tech-item">
          <label>MAX ELEVATION</label>
          <span>6,768 M.S.N.M.</span>
        </div>
        <div class="tech-item">
          <label>COORDINATES</label>
          <span>9°30′S 77°31′W</span>
        </div>
        <div class="tech-item">
          <label>REGION</label>
          <span>ANDES / PERÚ</span>
        </div>
      </div></div>
      
    </div>
  </section>

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {peruPrograms.map((prog) => (
          <TourCard 
            id={prog.id}
            title={prog.title}
            description={prog.description}
            image={prog.image}
            duration={prog.duration}
            difficulty={prog.difficulty}
            difficultyLevel={prog.difficultyLevel as any}
            path={prog.path}
            prefix={prog.prefix}
            type={prog.type}
          />
        ))}
      </div>
    </div>
  </section>
  <RecommendedTours />
</Layout>


<style>
  .hub-hero {
    position: relative;
    height: 75vh;
    min-height: 500px;
    background: #06090f url('/slider_1.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, 
      rgba(3, 4, 5, 0.9) 0%, 
      rgba(3, 4, 5, 0.4) 50%, 
      rgba(3, 4, 5, 0.9) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 900px;
    padding: 0 2rem;
    margin-top: 3rem;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    line-height: 1;
    margin-bottom:  1.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 12px;
    opacity: 0.8;
    text-transform: uppercase;
  }
  .split-title .bold {
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -1px;
  }

  .hero-accent-bar {
    width: 80px;
    height: 4px;
    background: var(--brand-red);
    margin:  1.2rem auto 2.5rem;
    box-shadow: 0 0 20px rgba(239, 68, 68, 0.3);
  }

  .hero-side-technical {
    display: flex;
    justify-content: center;
    gap: clamp(2rem, 5vw, 4rem);
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .tech-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
    text-align: center;
  }

  .tech-item label {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
  }

  .tech-item span {
    font-size: 1rem;
    font-weight: 600;
    color: white;
    font-family: 'Inter', sans-serif;
  }

  .programs-section {
    padding: 8rem 0;
    background: #ffffff;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .hub-hero { height: 50vh; }
    .programs-section { padding: 6rem 1.5rem; }
    .container { padding: 0; }
    .hero-side-technical { gap: 1.5rem; }
  }
</style>
