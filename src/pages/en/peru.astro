---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import TourCard from '../../components/TourCard.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const peruPrograms = [
  {
    id: 'santa-cruz',
    title: 'Santa Cruz Trekking',
    description: 'The most emblematic circuit in the White Range. 4 days of turquoise lagoons and views of Alpamayo.',
    image: '/slider_1.png',
    duration: '4 Days',
    difficulty: 'Moderate',
    difficultyLevel: 'mod',
    path: 'trekking/blanca/santa-cruz',
    prefix: 'PER',
    type: 'CLASSIC TREKKING'
  },
  {
    id: 'huayhuash-360',
    title: 'Huayhuash 360°',
    description: 'Considered one of the best treks in the world. A technical circumnavigation of the Huayhuash range.',
    image: '/slider_2.png',
    duration: '12 Days',
    difficulty: 'Exigent',
    difficultyLevel: 'hard',
    path: 'trekking/huayhuash/360',
    prefix: 'PER',
    type: 'EXPEDITION'
  },
  {
    id: 'alpamayo-climb',
    title: 'Nevado Alpamayo',
    description: 'The most beautiful mountain in the world. Technical ascent via the French Direct face.',
    image: '/slider_3.png',
    duration: '6 Days',
    difficulty: 'Technical',
    difficultyLevel: 'hard',
    path: 'climbing/alpamayo',
    prefix: 'PER',
    type: 'MOUNTAINEERING'
  },
  {
    id: 'laguna-69',
    title: 'Laguna 69 Trekking',
    description: 'Perfect acclimatization. Visit the most famous lagoon in Huaraz under Chacraraju and Pisco peaks.',
    image: '/slider_4.png',
    duration: 'Full Day',
    difficulty: 'Moderate',
    difficultyLevel: 'mod',
    path: 'tours/trekking-69',
    prefix: 'PER',
    type: 'DAY HIKE'
  },
  {
    id: 'huascaran-expedition',
    title: 'Nevado Huascaran',
    description: 'The roof of Peru and the tropics. The ultimate challenge for mountaineers in the Peruvian Andes.',
    image: '/slider_5.png',
    duration: '7 Days',
    difficulty: 'Very Exigent',
    difficultyLevel: 'hard',
    path: 'climbing/huascaran',
    prefix: 'PER',
    type: 'HIGH ALTITUDE'
  },
  {
    id: 'cusco-inca-trail',
    title: 'Inca Trail',
    description: 'Follow the steps of the Incas to the citadel of Machu Picchu. A unique cultural and natural experience.',
    image: '/slider_1.png',
    duration: '4 Days',
    difficulty: 'Moderate',
    difficultyLevel: 'mod',
    path: 'trekking/cusco/camino-inca',
    prefix: 'PER',
    type: 'CULTURAL TREK'
  }
];
---

<Layout title={`Peru - ${t('nav.destinations')} | Franpisco Adventure`} description="Discover the Peruvian Andes with Franpisco Adventure. Trekking in the White Range and Huayhuash, high mountain climbing, and cultural tours in Cusco and Machu Picchu.">
  <section class="dest-hero peru">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 class="split-title">
        <span class="thin">DESTINATIONS</span>
        <span class="bold">PERU</span>
      </h1>
      <div class="blue-line"></div>
      <p class="hero-subtitle">The heart of the Andes. Cradle of ancient civilizations and peaks that challenge the heavens.</p>
    </div>
  </section>

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {peruPrograms.map((prog) => (
          <TourCard 
            id={prog.id}
            title={prog.title}
            description={prog.description}
            image={prog.image}
            duration={prog.duration}
            difficulty={prog.difficulty}
            difficultyLevel={prog.difficultyLevel as any}
            path={prog.path}
            prefix={prog.prefix}
            type={prog.type}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .dest-hero {
    position: relative;
    height: 60vh;
    min-height: 500px;
    background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('/slider_1.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.85), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.85));
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 800px;
    padding: 0 2rem;
    margin-top: 3rem;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    line-height: 1;
    margin-bottom: 2rem;
  }
  .split-title .thin {
    font-size: clamp(0.9rem, 2.5vw, 1.4rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.9;
    text-transform: uppercase;
  }
  .split-title .bold {
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    font-weight: 900;
    letter-spacing: -1px;
  }

  .blue-line {
    width: 60px;
    height: 4px;
    background: #0090cc;
    margin: 0 auto 3rem;
    box-shadow: 0 0 15px rgba(0, 144, 204, 0.5);
  }

  .hero-subtitle {
    font-size: 1rem;
    font-weight: 300;
    letter-spacing: 1px;
    opacity: 0.8;
    max-width: 600px;
    margin: 0 auto;
  }

  .programs-section {
    padding: 6rem 0;
    background: #f8fafc;
  }

  .container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; }
    .dest-hero { height: 50vh; }
    .container { padding: 0 20px; }
  }
</style>
