---
import Layout from '../../layouts/Layout.astro';
import RecommendedTours from '../../components/RecommendedTours.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import TourCard from '../../components/TourCard.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const climbingPrograms = [
  {
    id: 'alpamayo',
    title: t('climbing.alpamayo.name'),
    description: t('climbing.alpamayo.desc'),
    image: '/slider_1.png',
    duration: `6 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/alpamayo',
    prefix: 'CLB',
    type: 'TECHNICAL EXPEDITION'
  },
  {
    id: 'chopicallqui',
    title: t('climbing.chopicallqui.name'),
    description: t('climbing.chopicallqui.desc'),
    image: '/slider_5.png',
    duration: `4 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/chopicallqui',
    prefix: 'CLB',
    type: 'TECHNICAL ASCENT'
  },
  {
    id: 'huascaran',
    title: t('climbing.huascaran.name'),
    description: t('climbing.huascaran.desc'),
    image: '/slider_4.png',
    duration: `6 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/huascaran',
    prefix: 'CLB',
    type: 'TECHNICAL EXPEDITION'
  },
  {
    id: 'pisco',
    title: t('climbing.pisco.name'),
    description: t('climbing.pisco.desc'),
    image: '/slider_2.png',
    duration: `5 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod',
    path: 'climbing/pisco',
    prefix: 'CLB',
    type: 'ACCLIMATIZATION + CLIMB'
  },
  {
    id: 'ishinca-valley',
    title: t('climbing.ishinca.name'),
    description: t('climbing.ishinca.desc'),
    image: '/slider_3.png',
    duration: `8 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/ishinca-valley',
    prefix: 'CLB',
    type: 'TECHNICAL TRILOGY'
  },
  {
    id: 'prep-package',
    title: t('climbing.prep.name'),
    description: t('climbing.prep.desc'),
    image: '/slider_5.png',
    duration: `6 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/prep-package',
    prefix: 'CLB',
    type: 'TECHNICAL TRAINING'
  },
  {
    id: 'artesonraju',
    title: t('climbing.artesonraju.name'),
    description: t('climbing.artesonraju.desc'),
    image: '/slider_1.png',
    duration: `6 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/artesonraju',
    prefix: 'CLB',
    type: 'ELITE EXPEDITION'
  }
];
---

<Layout title={`${t('nav.climbing')} - Franpisco Adventure`} description="Technical high-mountain expeditions in the Cordillera Blanca and Huayhuash. Summit Alpamayo, Huascarán, and more with UIAGM guides.">
  <section class="hub-hero">
    
    <div class="hero-bg-overlay"></div>
    <div class="hero-content">
      <h1 class="split-title">
        <span class="thin">EXPEDITIONS</span>
        <span class="bold">CLIMBING</span>
      </h1>
      <div class="hero-accent-bar"></div>
      
      <div class="hero-side-technical">
        <div class="tech-item">
          <label>MAX ELEVATION</label>
          <span>6,962 M.S.N.M.</span>
        </div>
        <div class="tech-item">
          <label>COORDINATES</label>
          <span>9°08′S 77°36′W</span>
        </div>
        <div class="tech-item">
          <label>REGION</label>
          <span>ANDES / GLOBAL</span>
        </div>
      </div>
    </div>
  </section>

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {climbingPrograms.map((prog) => (
          <TourCard 
            id={prog.id}
            title={prog.title}
            description={prog.description}
            image={prog.image}
            duration={prog.duration}
            difficulty={prog.difficulty}
            difficultyLevel={prog.difficultyLevel as any}
            path={prog.path}
            prefix={prog.prefix}
            type={prog.type}
          />
        ))}
      </div>
    </div>
  </section>
  <RecommendedTours />
</Layout>


<style>
  .hub-hero {
    position: relative;
    height: 75vh;
    min-height: 500px;
    background: #06090f url('/slider_3.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, 
      rgba(3, 4, 5, 0.9) 0%, 
      rgba(3, 4, 5, 0.4) 50%, 
      rgba(3, 4, 5, 0.9) 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 900px;
    padding: 0 2rem;
    margin-top: 3rem;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    line-height: 1;
    margin-bottom:  1.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 12px;
    opacity: 0.8;
    text-transform: uppercase;
  }
  .split-title .bold {
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -1px;
  }

  .hero-accent-bar {
    width: 80px;
    height: 4px;
    background: var(--brand-red);
    margin:  1.2rem auto 2.5rem;
    box-shadow: 0 0 20px rgba(239, 68, 68, 0.3);
  }

  .hero-side-technical {
    display: flex;
    justify-content: center;
    gap: clamp(2rem, 5vw, 4rem);
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .tech-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
    text-align: center;
  }

  .tech-item label {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: var(--brand-blue);
  }

  .tech-item span {
    font-size: 1rem;
    font-weight: 600;
    color: white;
    font-family: 'Inter', sans-serif;
  }

  .programs-section {
    padding: 8rem 0;
    background: #ffffff;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .hub-hero { height: 50vh; }
    .programs-section { padding: 6rem 1.5rem; }
    .container { padding: 0; }
    .hero-side-technical { gap: 1.5rem; }
  }
</style>
