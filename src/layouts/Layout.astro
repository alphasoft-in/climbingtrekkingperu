---
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../i18n/utils';

interface Props {
	title?: string;
	description?: string;
}

const { title = "Franpisco Adventure - Tours & Expediciones", description = "Agencia local especializada en experiencias de montaña y trekking en Perú." } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentPath = Astro.url.pathname;
const routeName = currentPath.replace(/^\/(en)?\/?/, '').replace(/\/$/, '');
const esUrl = `/${routeName}`;
const enUrl = `/en/${routeName}`;
---
<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body>
		<header class="main-header">
			<div class="nav-container">
				<!-- Logo -->
				<a href={getRelativeLocaleUrl(lang, '')} class="nav-logo">
					<img src="/logo.png" alt="Franpisco Adventure Logo" />
				</a>

				<!-- Desktop Nav -->
				<nav class="nav-desktop">
					<ul class="nav-menu">
						<li><a href={getRelativeLocaleUrl(lang, '')} class={routeName === "" ? 'active' : ''}>{t('nav.home')}</a></li>
						<li><a href={getRelativeLocaleUrl(lang, 'tours')} class={routeName.startsWith('tours') ? 'active' : ''}>{t('nav.tours')}</a></li>
						<li><a href={getRelativeLocaleUrl(lang, 'about')} class={routeName.startsWith('about') ? 'active' : ''}>{t('nav.about')}</a></li>
					</ul>
				</nav>

				<!-- Desktop Actions -->
				<div class="nav-actions">
					<div class="lang-switch">
						<a href={esUrl} class={lang === 'es' ? 'active' : ''}>ES</a>
						<span class="divider">/</span>
						<a href={enUrl} class={lang === 'en' ? 'active' : ''}>EN</a>
					</div>
					<a href={getRelativeLocaleUrl(lang, 'contact')} class="header-cta">
						{t('nav.contact')}
					</a>
					
					<!-- Burger Button -->
					<button id="menu-toggle" class="nav-burger" aria-label="Abrir Menú">
						<span></span>
						<span></span>
						<span></span>
					</button>
				</div>
			</div>

			<!-- Mobile Screen Overlay -->
			<div id="full-menu" class="mobile-full-overlay">
				<button id="close-menu" class="btn-close-overlay">&times;</button>
				<div class="overlay-inner">
					<div class="overlay-logo">
						<img src="/logo.png" alt="Logo" />
					</div>
					<nav class="overlay-links">
						<a href={getRelativeLocaleUrl(lang, '')} class={routeName === "" ? 'active' : ''}>{t('nav.home')}</a>
						<a href={getRelativeLocaleUrl(lang, 'tours')} class={routeName.startsWith('tours') ? 'active' : ''}>{t('nav.tours')}</a>
						<a href={getRelativeLocaleUrl(lang, 'about')} class={routeName.startsWith('about') ? 'active' : ''}>{t('nav.about')}</a>
						<a href={getRelativeLocaleUrl(lang, 'contact')} class={`overlay-cta ${routeName.startsWith('contact') ? 'active' : ''}`}>{t('nav.contact')}</a>
					</nav>
					<div class="overlay-lang">
						<a href={esUrl} class={lang === 'es' ? 'active' : ''}>Español</a>
						<span class="sep">/</span>
						<a href={enUrl} class={lang === 'en' ? 'active' : ''}>English</a>
					</div>
				</div>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<Footer />

		<script>
			const burger = document.getElementById('menu-toggle');
			const close = document.getElementById('close-menu');
			const overlay = document.getElementById('full-menu');

			if (burger && close && overlay) {
				const open = () => {
					overlay.classList.add('is-active');
					document.body.style.overflow = 'hidden';
				};
				const hide = () => {
					overlay.classList.remove('is-active');
					document.body.style.overflow = '';
				};

				burger.addEventListener('click', open);
				close.addEventListener('click', hide);
                // Cerrar al hacer clic en enlaces
                overlay.querySelectorAll('a').forEach(link => {
                    link.addEventListener('click', hide);
                });
			}
		</script>

<style is:global>
    :root {
        --color-primary: #0f4d82;
        --color-accent: #0a84ff;
        --color-text: #1e293b;
        --color-text-light: #64748b;
        --header-height: 80px;
    }

	* { box-sizing: border-box; }

	html, body {
		margin: 0;
		padding: 0;
		width: 100%;
		font-family: 'Montserrat', system-ui, -apple-system, sans-serif;
		background: #ffffff;
		color: var(--color-text);
		overflow-x: hidden;
	}

	.main-header {
		position: sticky;
		top: 0;
		z-index: 2000;
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(20px) saturate(180%);
		border-bottom: 1px solid rgba(0,0,0,0.05);
		height: var(--header-height);
		display: flex;
		align-items: center;
	}

	.nav-container {
		width: 100%;
		max-width: 1440px;
		margin: 0 auto;
		padding: 0 2rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.nav-logo img {
		height: 52px;
		width: auto;
		object-fit: contain;
        mix-blend-mode: multiply; 
	}

	.nav-desktop { display: flex; align-items: center; }
	.nav-menu { display: flex; gap: 3rem; list-style: none; margin: 0; padding: 0; }
	.nav-menu a {
		text-decoration: none;
		color: var(--color-text-light);
		font-weight: 600;
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 1px;
		transition: color 0.3s ease;
		position: relative;
	}
	.nav-menu a:hover, .nav-menu a.active { color: var(--color-primary); }
	.nav-menu a::after {
		content: '';
		position: absolute;
		bottom: -6px;
		left: 0;
		width: 0;
		height: 2px;
		background: var(--color-primary);
		transition: width 0.3s ease;
	}
	.nav-menu a.active::after { width: 100%; }

	.nav-actions { display: flex; align-items: center; gap: 2rem; }
	.lang-switch { display: flex; gap: 0.5rem; font-weight: 800; font-size: 0.8rem; color: #cbd5e1; }
	.lang-switch a { text-decoration: none; color: inherit; transition: color 0.3s; }
	.lang-switch a.active, .lang-switch a:hover { color: var(--color-text); }

	.header-cta {
		background: var(--color-primary);
		color: #fff;
		text-decoration: none;
		padding: 12px 28px;
		border-radius: 100px;
		font-weight: 700;
		font-size: 0.85rem;
		letter-spacing: 0.5px;
		box-shadow: 0 4px 15px rgba(15, 77, 130, 0.2);
		transition: all 0.3s ease;
	}
	.header-cta:hover {
		background: var(--color-accent);
		transform: translateY(-2px);
		box-shadow: 0 8px 25px rgba(10, 132, 255, 0.4);
	}

	.nav-burger {
		display: none;
		flex-direction: column;
		gap: 6px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 5px;
	}
	.nav-burger span {
		display: block;
		width: 28px;
		height: 2px;
		background: var(--color-primary);
		border-radius: 2px;
	}

	/* --- FULL SCREEN OVERLAY --- */
	.mobile-full-overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100vh;
		background: #ffffff;
		z-index: 3000;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		visibility: hidden;
		opacity: 0;
		transform: translateY(-10px);
		transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
	}

	.mobile-full-overlay.is-active {
		visibility: visible;
		opacity: 1;
		transform: translateY(0);
	}

	.btn-close-overlay {
		position: absolute;
		top: 2rem;
		right: 2rem;
		background: none;
		border: none;
		font-size: 3rem;
		line-height: 1;
		color: var(--color-primary);
		cursor: pointer;
	}

	.overlay-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		width: 100%;
	}

	.overlay-logo img {
		height: 35px;
		width: auto;
	}

	.overlay-links {
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		text-align: center;
	}

	.overlay-links a {
		text-decoration: none;
		color: var(--color-text);
		font-size: 0.9rem;
		font-weight: 700;
		letter-spacing: 0.5px;
        transition: color 0.3s ease;
	}

    .overlay-links a.active {
        color: var(--color-primary);
        border-bottom: 2px solid var(--color-primary);
        padding-bottom: 4px;
    }

	.overlay-cta {
		background: var(--color-primary);
		color: white !important;
		padding: 0.6rem 1.5rem;
		border-radius: 100px;
		font-size: 0.8rem !important;
		margin-top: 0.5rem;
		box-shadow: 0 4px 10px rgba(0,0,0,0.1);
	}

	.overlay-lang {
		display: flex;
		gap: 1rem;
		font-weight: 800;
		font-size: 1.1rem;
		color: #94a3b8;
		margin-top: 1rem;
	}
	.overlay-lang a { text-decoration: none; color: inherit; }
	.overlay-lang a.active { color: var(--color-primary); }

	@media (max-width: 1024px) {
		.nav-desktop, .lang-switch, .header-cta { display: none; }
		.nav-burger { display: flex; }
		.nav-container { padding: 0 1.5rem; }
	}

    @media (min-width: 1025px) {
        .mobile-full-overlay { display: none !important; }
    }
</style>
	</body>
</html>
