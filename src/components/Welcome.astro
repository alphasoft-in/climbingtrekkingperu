---
---

<div id="container">
	<div id="background-pattern"></div>
	<main>
		<section id="hero" style="background-image: linear-gradient(rgba(0,0,0,0.44), rgba(0,0,0,0.44)), url('/expedicion.jpg')">
			<div id="hero-overlay"></div>
			<div id="header">
				<h1>CLIMBING TREKKING PERÚ</h1>
				<div id="divider"></div>
				<p id="subtitle">Expediciones de Montaña</p>
			</div>
			<div id="content-box">
				<h2>Próximamente</h2>
				<p>Estamos preparando las mejores experiencias de trekking y expediciones en las montañas del Perú. Tu aventura comienza aquí.</p>
			</div>
		</section>
	</main>
</div>

<style>
	#container {
		font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
		height: 100vh;
		width: 100vw;
		background: #080a0d;
		position: relative;
		overflow-x: hidden;
		margin: 0;
		padding: 0;
	}

	#container::before {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(8, 10, 13, 0.55), rgba(8, 10, 13, 0.55));
		z-index: 0;
	}

	#background-pattern {
		position: absolute;
		top: 0;
		left: 0;
		width: 0;
		height: 0;
		z-index: 0;
	}

	main {
		height: 100%;
		width: 100%;
		display: flex;
		justify-content: center;
		align-items: center;
		position: relative;
		z-index: 1;
		padding: 0;
		box-sizing: border-box;
	}

	#hero {
		position: relative;
		display: grid;
		place-items: center;
		width: 100vw;
		min-height: 100vh;
		max-width: 100vw;
		text-align: center;
		padding: 2rem;
		background-size: cover;
		background-position: 50% 45%;
		background-repeat: no-repeat;
		color: white;
		z-index: 1;
	}

	#hero-overlay {
		position: absolute;
		inset: 0;
		background: rgba(0,0,0,0.42);
		z-index: 1;
	}

	#header,
	#content-box {
		position: relative;
		z-index: 2;
		width: 100%;
		max-width: 900px;
	}

	#header {
		animation: fadeIn 0.8s ease-out;
		width: 100%;
	}

	#header h1 {
		font-size: clamp(36px, 6vw, 56px);
		font-weight: 700;
		color: #fff;
		margin: 0;
		letter-spacing: 0.5px;
		line-height: 1.1;
		text-transform: none;
		word-wrap: break-word;
		text-shadow: 0 4px 16px rgba(0, 0, 0, 0.55);
	}


	#divider {
		width: clamp(40px, 15%, 80px);
		height: 4px;
		background: linear-gradient(90deg, #0066cc, #00a8e8);
		margin: 20px auto;
		border-radius: 2px;
	}

	#subtitle {
		font-size: clamp(14px, 2.8vw, 18px);
		color: rgba(240, 240, 240, 0.95);
		margin: 10px 0 0;
		font-weight: 400;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		text-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
	}

	#content-box {
		background: rgba(0, 0, 0, 0.65);
		backdrop-filter: blur(12px);
		border: 1px solid rgba(255, 255, 255, 0.2);
		padding: clamp(30px, 7vw, 48px) clamp(24px, 7vw, 40px);
		border-radius: 20px;
		box-shadow: 0 18px 60px rgba(0, 0, 0, 0.45);
		animation: slideUp 0.8s ease-out 0.2s both;
		width: min(85vw, 850px);
		box-sizing: border-box;
	}

	#content-box h2 {
		font-size: clamp(24px, 4.5vw, 32px);
		color: #fff;
		margin: 0 0 12px 0;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	#content-box p {
		font-size: clamp(16px, 3vw, 18px);
		color: rgba(255, 255, 255, 0.95);
		margin: 0;
		line-height: 1.65;
		max-width: 750px;
		margin-left: auto;
		margin-right: auto;
	}

	@keyframes fadeIn {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	@keyframes slideUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Tablets (768px - 1024px) */
	@media screen and (max-width: 1024px) {
		#background-pattern {
			width: 400px;
			height: 400px;
			top: -40%;
			right: -5%;
		}

		main {
			padding: 20px;
		}

		#hero {
			gap: 35px;
		}
	}

	/* Small tablets (481px - 768px) */
	@media screen and (max-width: 768px) {
		#background-pattern {
			width: 350px;
			height: 350px;
			top: -30%;
			right: 0;
		}

		main {
			padding: 15px;
		}

		#hero {
			gap: 30px;
		}

		#header {
			margin-bottom: 0;
		}

		#divider {
			margin: 15px auto;
		}
	}

	/* Mobile phones (481px - 768px) */
	@media screen and (max-width: 640px) {
		#background-pattern {
			width: 300px;
			height: 300px;
			top: -20%;
			right: -15%;
		}

		#hero {
			gap: 25px;
		}

		#header h1 {
			letter-spacing: 0;
		}

		#subtitle {
			letter-spacing: 1px;
		}
	}

	/* Small mobile phones (max 480px) */
	@media screen and (max-width: 480px) {
		#container {
			height: 100vh;
		}

		main {
			padding: 12px;
			min-height: 100vh;
		}

		#hero {
			gap: 20px;
			width: 100%;
		}

		#background-pattern {
			width: 250px;
			height: 250px;
			top: -10%;
			right: -20%;
		}

		#header {
			width: 100%;
		}

		#header h1 {
			letter-spacing: -1px;
		}

		#divider {
			width: 40px;
			height: 3px;
			margin: 12px auto;
		}

		#subtitle {
			letter-spacing: 0.5px;
		}

		#content-box {
			padding: 25px 18px;
			border-radius: 10px;
		}

		#content-box h2 {
			margin-bottom: 12px;
		}

		#content-box p {
			line-height: 1.5;
		}
	}

	/* Extra small phones (max 375px) */
	@media screen and (max-width: 375px) {
		main {
			padding: 10px;
		}

		#hero {
			gap: 15px;
		}

		#background-pattern {
			width: 200px;
			height: 200px;
			opacity: 0.5;
		}

		#content-box {
			padding: 20px 15px;
		}
	}

	/* Landscape orientation optimization */
	@media screen and (max-height: 600px) {
		main {
			padding: 10px;
		}

		#hero {
			gap: 15px;
		}

		#header {
			margin-bottom: 0;
		}

		#content-box {
			padding: clamp(15px, 4vw, 30px) clamp(15px, 4vw, 30px);
		}
	}
</style>
