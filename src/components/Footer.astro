---
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="site-footer">
    <div class="footer-top-accent"></div>
    <div class="footer-container">
        <!-- Columna 01: Identidad -->
        <div class="footer-col brand-col">
            <div class="f-logo">
                <img src="/logo.png" alt="Franpisco Adventure" />
            </div>
            <p class="f-desc">{t('footer.brandDesc')}</p>
            <div class="footer-socials">
                <a href="#" aria-label="Facebook" class="s-link">FB</a>
                <a href="#" aria-label="Instagram" class="s-link">IG</a>
                <a href="#" aria-label="LinkedIn" class="s-link">LN</a>
            </div>
        </div>

        <!-- Columna 02: Navegación -->
        <div class="footer-col">
            <h4 class="f-sub">{t('footer.navTitle')}</h4>
            <ul class="f-list">
                <li><a href={getRelativeLocaleUrl(lang, '')}>{t('footer.navHome')}</a></li>
                <li><a href={getRelativeLocaleUrl(lang, 'tours')}>{t('footer.navTours')}</a></li>
                <li><a href={getRelativeLocaleUrl(lang, 'about')}>{t('footer.navAbout')}</a></li>
                <li><a href={getRelativeLocaleUrl(lang, 'contact')}>{t('footer.navContact')}</a></li>
            </ul>
        </div>

        <!-- Columna 03: Legal -->
        <div class="footer-col">
            <h4 class="f-sub">{t('footer.legalTitle')}</h4>
            <ul class="f-list">
                <li><a href={getRelativeLocaleUrl(lang, 'about')}>{t('footer.legalEthics')}</a></li>
                <li><a href={getRelativeLocaleUrl(lang, 'tours')}>{t('footer.legalTerms')}</a></li>
                <li><a href={getRelativeLocaleUrl(lang, 'about')}>{t('footer.legalPrivacy')}</a></li>
                <li><a href={getRelativeLocaleUrl(lang, '')}>{t('footer.legalCert')}</a></li>
            </ul>
        </div>

        <!-- Columna 04: Central Operativa -->
        <div class="footer-col contact-col">
            <h4 class="f-sub">{t('footer.contactTitle')}</h4>
            <div class="c-info">
                <div class="c-item">
                    <span class="c-label">HQ / PERÚ</span>
                    <p>{t('footer.contactHq')}</p>
                </div>
                <div class="c-item">
                    <span class="c-label">COMMUNICATION</span>
                    <p>{t('footer.contactEmail')} <a href="mailto:info@franpiscoadventure.com">info@franpiscoadventure.com</a></p>
                </div>
                <div class="c-item">
                    <span class="c-label">24/7 COMMAND</span>
                    <p>{t('footer.contactPhone')} <a href="https://wa.me/51987654321" class="wa-link">+51 987 654 321</a></p>
                </div>
            </div>
        </div>
    </div>
    
    <div class="footer-bottom">
        <div class="footer-container bottom-inner">
            <span class="copy">{t('footer.copy')}</span>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        background: #030405; 
        color: #94a3b8;
        padding-top: 5rem;
        position: relative;
        overflow: hidden;
    }
    .footer-top-accent {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 1px;
        background: linear-gradient(90deg, transparent, var(--brand-blue), transparent);
    }

    .footer-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
        display: grid;
        grid-template-columns: 1.5fr 1fr 1.2fr 1.5fr;
        gap: 4rem;
        margin-bottom: 5rem;
    }
    
    .f-logo { margin-bottom: 0.75rem; }
    .f-logo img { height: 45px; }

    .f-title {
        color: #fff;
        font-size: 0.85rem;
        font-weight: 800;
        letter-spacing: 3px;
        margin-bottom: 2rem;
        text-transform: uppercase;
    }
    .f-desc {
        font-size: 0.9rem;
        line-height: 1.8;
        margin-bottom: 2.5rem;
        color: #64748b;
    }

    .f-sub {
        color: #fff;
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        margin-bottom: 2.5rem;
        position: relative;
        display: inline-block;
    }
    .f-sub::after {
        content: '';
        position: absolute;
        bottom: -10px; left: 0;
        width: 20px; height: 1px;
        background: var(--brand-blue);
    }

    .f-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1rem; }
    .f-list a {
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 500;
        transition: all 0.3s ease;
    }
    .f-list a:hover { color: var(--brand-blue); transform: translateX(5px); }

    .footer-socials { display: flex; gap: 1.5rem; }
    .s-link {
        color: #475569;
        text-decoration: none;
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 1px;
        transition: color 0.3s;
    }
    .s-link:hover { color: var(--brand-red); }

    .c-info { display: flex; flex-direction: column; gap: 2rem; }
    .c-item { display: flex; flex-direction: column; gap: 6px; }
    .c-label {
        font-size: 0.6rem;
        font-weight: 900;
        color: var(--brand-blue);
        letter-spacing: 2px;
    }
    .c-item p { font-size: 0.85rem; color: #cbd5e1; line-height: 1.6; margin: 0; }
    .c-item a { color: inherit; text-decoration: none; transition: color 0.3s; }
    .c-item a:hover { color: var(--brand-blue); }
    .wa-link { color: #22c55e !important; font-weight: 700; }

    .footer-bottom {
        border-top: 1px solid rgba(255,255,255,0.03);
        padding: 3rem 0;
        background: #000000;
    }
    .bottom-inner {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 0;
    }
    .copy { font-size: 0.65rem; color: #475569; letter-spacing: 1px; text-align: center; }

    @media (max-width: 1200px) {
        .footer-container { grid-template-columns: 1fr 1fr; gap: 3rem; }
    }
    @media (max-width: 768px) {
        .footer-container { 
            grid-template-columns: 1fr; 
            padding: 0 25px;
            gap: 3.5rem;
        }
    }
</style>
