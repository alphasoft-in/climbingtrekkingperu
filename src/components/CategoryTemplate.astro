---
import Layout from '@layouts/Layout.astro';
import TourCard from './TourCard';
import SuggestedRoutes from './SuggestedRoutes';
import PageHero from './PageHero';
import { getRelativeLocaleUrl } from '@i18n/utils';

interface Props {
  lang: 'es' | 'en';
  metadata: any;
  programs: any[];
}

const { lang, metadata, programs } = Astro.props;
---

<Layout title={`${metadata[lang].titleMain} - Franpisco Adventure`} description={metadata[lang].description}>
  <PageHero 
    client:load
    titleTop={metadata[lang].titleTop}
    titleMain={metadata[lang].titleMain}
    backgroundImage={metadata[lang].backgroundImage}
    techData={metadata[lang].techData}
  />

  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
        {programs.map((prog) => (
          <TourCard 
            client:visible
            id={prog.id}
            title={prog.title[lang]}
            description={prog.description[lang]}
            image={prog.image}
            duration={prog.duration[lang]}
            difficulty={prog.difficulty[lang]}
            difficultyLevel={prog.difficultyLevel}
            href={getRelativeLocaleUrl(lang, prog.path)}
            prefix={prog.prefix}
            category={prog.category[lang]}
            lang={lang}
          />
        ))}
      </div>
    </div>
  </section>

  <SuggestedRoutes client:load lang={lang} />
</Layout>
