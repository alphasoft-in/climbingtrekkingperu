---
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { currentId } = Astro.props;

const allPrograms = [
  {
    id: '360',
    title: t('huayhuash.prog1.name'),
    image: '/trekking/huayhuash/360.jpeg',
    duration: `15 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'trekking/huayhuash/360'
  },
  {
    id: 'classic',
    title: t('huayhuash.prog2.name'),
    image: '/trekking/huayhuash/clasico.jpeg',
    duration: `11 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus',
    path: 'trekking/huayhuash/clasico'
  },
  {
    id: 'mini',
    title: t('huayhuash.prog3.name'),
    image: '/trekking/huayhuash/mini.jpeg',
    duration: `8 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod',
    path: 'trekking/huayhuash/mini'
  },
  {
    id: 'inca',
    title: lang === 'es' ? 'CAMINO INCA CLÁSICO' : 'CLASSIC INCA TRAIL',
    image: '/slider_1.png',
    duration: `4 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus',
    path: 'tours'
  },
  {
    id: 'pastoruri',
    title: lang === 'es' ? 'GLACIAR PASTORURI' : 'PASTORURI GLACIER',
    image: '/slider_4.png',
    duration: `1 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod',
    path: 'tours'
  },
  {
    id: 'huchuy',
    title: lang === 'es' ? 'HUCHUY QOSQO' : 'HUCHUY QOSQO TREK',
    image: '/slider_2.png',
    duration: `2 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod',
    path: 'tours'
  },
  {
    id: 'peaks',
    title: t('huayhuash.prog4.name'),
    image: '/trekking/huayhuash/360.jpeg',
    duration: `12 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: lang === 'es' ? 'trekking/huayhuash/cumbres' : 'trekking/huayhuash/peaks'
  },
  {
    id: 'spectacular',
    title: t('huayhuash.prog5.name'),
    image: '/trekking/huayhuash/clasico.jpeg',
    duration: `15 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus',
    path: lang === 'es' ? 'trekking/huayhuash/espectacular' : 'trekking/huayhuash/spectacular'
  },
  {
    id: 'santa-cruz',
    title: t('blanca.prog1.name'),
    image: '/slider_2.png',
    duration: `7 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus',
    path: 'trekking/blanca/santa-cruz'
  },
  {
    id: 'blanca-best',
    title: t('blanca.prog2.name'),
    image: '/slider_4.png',
    duration: `10 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus',
    path: lang === 'es' ? 'trekking/blanca/lo-mejor' : 'trekking/blanca/the-best'
  },
  {
    id: 'blanca-alpamayo',
    title: t('blanca.prog3.name'),
    image: '/slider_1.png',
    duration: `11 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'trekking/blanca/alpamayo'
  },
  {
    id: 'blanca-circuit',
    title: t('blanca.prog4.name'),
    image: '/slider_3.png',
    duration: `15 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: lang === 'es' ? 'trekking/blanca/circuito' : 'trekking/blanca/circuit'
  },
  {
    id: 'cusco-choquequirao',
    title: t('cusco.prog1.name'),
    image: '/slider_2.png',
    duration: `4 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'trekking/cusco/choquequirao'
  },
  {
    id: 'cusco-esencia',
    title: t('cusco.prog2.name'),
    image: '/slider_4.png',
    duration: `12 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod',
    path: lang === 'es' ? 'trekking/cusco/esencia-imperial' : 'trekking/cusco/imperial-essence'
  },
  {
    id: 'cusco-inca',
    title: t('cusco.prog3.name'),
    image: '/trekking/huayhuash/clasico.jpeg',
    duration: `4 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus',
    path: lang === 'es' ? 'trekking/cusco/camino-inca' : 'trekking/cusco/inca-trail'
  },
  {
    id: 'cusco-ausangate',
    title: t('cusco.prog4.name'),
    image: '/slider_1.png',
    duration: `4 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'trekking/cusco/ausangate'
  },
  {
    id: 'cusco-lares',
    title: t('cusco.prog5.name'),
    image: '/slider_3.png',
    duration: `4 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus',
    path: 'trekking/cusco/lares'
  }
];

// Randomize and filter current
const filtered = allPrograms.filter(p => p.id !== currentId);
const recommended = filtered.sort(() => Math.random() - 0.5).slice(0, 3);
---

<section class="recommended-section">
  <div class="container">
    <div class="section-header">
      <div class="header-line"></div>
      <span class="sub-label">{lang === 'es' ? 'CONTINUAR LA EXPEDICIÓN' : 'CONTINUE THE EXPEDITION'}</span>
      <h2 class="section-title">{lang === 'es' ? 'Rutas' : 'Related'} <span class="blue">{lang === 'es' ? 'Sugeridas' : 'Tours'}</span></h2>
    </div>

    <div class="grid">
      {recommended.map((prog) => (
        <a href={getRelativeLocaleUrl(lang, prog.path)} class="program-card">
          <div class="card-image">
            <img src={prog.image} alt={prog.title} loading="lazy" />
            <div class="card-overlay"></div>
            <div class="card-badge">
               <span class="b-label">{lang === 'es' ? 'DURACIÓN' : 'DURATION'}</span>
               <span class="b-value">{prog.duration}</span>
            </div>
          </div>
          <div class="card-body">
            <div class="card-meta">
              <span class={`difficulty-tag ${prog.difficultyLevel}`}>
                <span class="dot"></span>
                {prog.difficulty}
              </span>
            </div>
            <h3>{prog.title}</h3>
            <div class="card-footer">
              <span class="footer-text">{t('trekking.viewMore')}</span>
              <div class="footer-arrow">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .recommended-section {
    padding: 10rem 0 8rem;
    background: var(--brand-red);
    position: relative;
    overflow: hidden;
  }

  .recommended-section::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: rgba(0,0,0,0.1);
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .header-line {
    width: 40px;
    height: 3px;
    background: #fff;
    margin-bottom: 1.5rem;
  }

  .sub-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: rgba(255,255,255,0.8);
    display: block;
    margin-bottom: 0.8rem;
    text-transform: uppercase;
  }

  .section-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 900;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: -1px;
    line-height: 1;
  }

  .section-title .blue {
    color: #fff;
    opacity: 0.9;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  .program-card {
    background: #ffffff;
    border: none;
    border-radius: 2px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    box-shadow: none;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .program-card:hover {
    transform: translateY(-15px);
    border: 1px solid #fff;
  }

  .card-image {
    height: 260px;
    overflow: hidden;
    position: relative;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .program-card:hover .card-image img {
    transform: scale(1.1);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 60%);
  }

  .card-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: #000;
    padding: 10px 15px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .b-label {
    font-size: 0.45rem;
    font-weight: 800;
    color: var(--brand-red);
    letter-spacing: 1px;
  }

  .b-value {
    font-size: 0.75rem;
    font-weight: 900;
    color: #fff;
  }

  .card-body {
    padding: 2.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .card-meta {
    margin-bottom: 1.5rem;
  }

  .difficulty-tag {
    font-size: 0.6rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #373737;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #f1f5f9;
    padding: 5px 12px;
    border-radius: 2px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .difficulty-tag.hard .dot { background: var(--brand-red); }
  .difficulty-tag.modplus .dot { background: var(--brand-blue); }
  .difficulty-tag.mod .dot { background: #94a3b8; }

  .card-body h3 {
    font-size: 1.2rem;
    font-weight: 900;
    color: #0b0d10;
    line-height: 1.3;
    margin-bottom: 2.5rem;
    text-transform: uppercase;
    letter-spacing: -0.5px;
    flex-grow: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.8rem;
    border-top: 1px solid #f1f5f9;
  }

  .footer-text {
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 2px;
    color: #64748b;
    text-transform: uppercase;
    transition: 0.3s;
  }

  .footer-arrow {
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f1f5f9;
    border-radius: 50%;
    color: var(--brand-red);
    transition: 0.3s;
  }

  .program-card:hover .footer-text {
    color: var(--brand-red);
  }

  .program-card:hover .footer-arrow {
    background: var(--brand-red);
    color: #fff;
    transform: translateX(5px);
  }

  @media (max-width: 1024px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; }
    .recommended-section { padding: 6rem 0; }
  }
</style>
