---
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { currentId } = Astro.props;

const allPrograms = [
  // HUAYHUASH
  {
    id: '360',
    category: 'trekking',
    title: t('huayhuash.prog1.name'),
    image: '/trekking/huayhuash/360.png',
    duration: `15 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'trekking/huayhuash/360'
  },
  {
    id: 'classic',
    category: 'trekking',
    title: t('huayhuash.prog2.name'),
    image: '/trekking/huayhuash/clasico.png',
    duration: `11 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus',
    path: 'trekking/huayhuash/clasico'
  },
  {
    id: 'mini',
    category: 'trekking',
    title: t('huayhuash.prog3.name'),
    image: '/trekking/huayhuash/mini.png',
    duration: `8 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod',
    path: 'trekking/huayhuash/mini'
  },
  {
    id: 'peaks',
    category: 'trekking',
    title: t('huayhuash.prog4.name'),
    image: '/trekking/huayhuash/cumbres.png',
    duration: `12 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: lang === 'es' ? 'trekking/huayhuash/cumbres' : 'trekking/huayhuash/peaks'
  },
  {
    id: 'spectacular',
    category: 'trekking',
    title: t('huayhuash.prog5.name'),
    image: '/trekking/huayhuash/ruta-huayhuash.png',
    duration: `15 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus',
    path: lang === 'es' ? 'trekking/huayhuash/espectacular' : 'trekking/huayhuash/spectacular'
  },

  // CORDILLERA BLANCA TREKKING
  {
    id: 'blanca-sc',
    category: 'trekking',
    title: t('blanca.prog1.name'),
    image: '/slider_2.png',
    duration: `4-7 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus',
    path: 'trekking/blanca/santa-cruz'
  },
  {
    id: 'blanca-best',
    category: 'trekking',
    title: t('blanca.prog2.name'),
    image: '/slider_4.png',
    duration: `10 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus',
    path: lang === 'es' ? 'trekking/blanca/lo-mejor' : 'trekking/blanca/the-best'
  },
  {
    id: 'blanca-alpamayo',
    category: 'trekking',
    title: t('blanca.prog3.name'),
    image: '/slider_1.png',
    duration: `11 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'trekking/blanca/alpamayo'
  },
  {
    id: 'blanca-circuit',
    category: 'trekking',
    title: t('blanca.prog4.name'),
    image: '/slider_3.png',
    duration: `15 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: lang === 'es' ? 'trekking/blanca/circuito' : 'trekking/blanca/circuit'
  },

  // CLIMBING PERU
  {
    id: 'alpamayo-clb',
    category: 'climbing',
    title: t('climbing.alpamayo.name'),
    image: '/slider_1.png',
    duration: `6 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/alpamayo'
  },
  {
    id: 'huascaran-clb',
    category: 'climbing',
    title: t('climbing.huascaran.name'),
    image: '/slider_4.png',
    duration: `6 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/huascaran'
  },
  {
    id: 'pisco-clb',
    category: 'climbing',
    title: t('climbing.pisco.name'),
    image: '/slider_2.png',
    duration: `5 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod',
    path: 'climbing/pisco'
  },
  {
    id: 'ishinca-valley-clb',
    category: 'climbing',
    title: t('climbing.ishinca.name'),
    image: '/slider_3.png',
    duration: `8 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'climbing/ishinca-valley'
  },

  // CUSCO TREKS
  {
    id: 'cusco-choquequirao',
    category: 'trekking',
    title: t('cusco.prog1.name'),
    image: '/slider_2.png',
    duration: `4 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'trekking/cusco/choquequirao'
  },
  {
    id: 'cusco-inca',
    category: 'trekking',
    title: t('cusco.prog3.name'),
    image: '/trekking/huayhuash/clasico.png',
    duration: `4 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus',
    path: lang === 'es' ? 'trekking/cusco/camino-inca' : 'trekking/cusco/inca-trail'
  },

  // INTERNACIONAL
  {
    id: 'aconcagua-arg',
    category: 'climbing',
    title: t('climbing.aconcagua.name'),
    image: '/slider_1.png',
    duration: `17 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'argentina/aconcagua'
  },
  {
    id: 'avenida-volcanes-ecu',
    category: 'climbing',
    title: t('climbing.ecuador.name'),
    image: '/slider_4.png',
    duration: `12 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard',
    path: 'ecuador/avenida-volcanes'
  }
];

// Logic to find current category and recommend similar ones first
const currentProg = allPrograms.find(p => p.id === currentId);
const currentCategory = currentProg ? currentProg.category : null;

let recommended = [];
const filtered = allPrograms.filter(p => p.id !== currentId);

if (currentCategory) {
  const sameCategory = filtered.filter(p => p.category === currentCategory);
  const otherCategory = filtered.filter(p => p.category !== currentCategory);
  
  // Mix them but prioritize same category
  recommended = [
    ...sameCategory.sort(() => Math.random() - 0.5).slice(0, 2),
    ...otherCategory.sort(() => Math.random() - 0.5).slice(0, 1)
  ];
} else {
  recommended = filtered.sort(() => Math.random() - 0.5).slice(0, 3);
}

// Fallback if not enough
if (recommended.length < 3) {
    recommended = filtered.sort(() => Math.random() - 0.5).slice(0, 3);
}
---

<section class="recommended-section">
  <div class="container">
    <div class="section-header">
      <div class="header-line"></div>
      <span class="sub-label">{lang === 'es' ? 'CONTINUAR LA EXPEDICIÓN' : 'CONTINUE THE EXPEDITION'}</span>
      <h2 class="section-title">{lang === 'es' ? 'Rutas' : 'Related'} <span class="blue">{lang === 'es' ? 'Sugeridas' : 'Tours'}</span></h2>
    </div>

    <div class="grid">
      {recommended.map((prog) => (
        <a href={getRelativeLocaleUrl(lang, prog.path)} class="program-card">
          <div class="card-image">
            <img src={prog.image} alt={prog.title} loading="lazy" />
            <div class="card-overlay"></div>
            <div class="card-badge">
               <span class="b-label">{lang === 'es' ? 'DURACIÓN' : 'DURATION'}</span>
               <span class="b-value">{prog.duration}</span>
            </div>
          </div>
          <div class="card-body">
            <div class="card-meta">
              <span class={`difficulty-tag ${prog.difficultyLevel}`}>
                <span class="dot"></span>
                {prog.difficulty}
              </span>
            </div>
            <h3>{prog.title}</h3>
            <div class="card-footer">
              <span class="footer-text">{t('trekking.viewMore')}</span>
              <div class="footer-arrow">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .recommended-section {
    padding: 8rem 0 6rem;
    background: #ffffff;
    position: relative;
    overflow: hidden;
    border-top: 1px solid #f1f5f9;
  }

  .recommended-section::before {
    display: none;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .header-line {
    width: 40px;
    height: 3px;
    background: var(--brand-red);
    margin-bottom: 1.5rem;
  }

  .sub-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: #64748b;
    margin-bottom: 1rem;
    display: block;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    color: var(--brand-dark);
    letter-spacing: -1.5px;
  }
  .section-title .blue { color: var(--brand-blue); }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2.5rem;
  }

  .program-card {
    display: block;
    background: #ffffff;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    position: relative;
    border: 1px solid #f1f5f9;
    border-radius: 4px;
    overflow: hidden;
  }

  .program-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 30px 60px rgba(0,0,0,0.06);
    border-color: var(--brand-blue);
  }

  .card-image {
    position: relative;
    height: 280px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .program-card:hover .card-image img {
    transform: scale(1.1);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.6));
  }

  .card-badge {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .b-label { font-size: 0.55rem; font-weight: 800; color: #fff; opacity: 0.8; letter-spacing: 1px; }
  .b-value { font-size: 0.9rem; font-weight: 900; color: #fff; }

  .card-body {
    padding: 2rem;
  }

  .card-meta {
    margin-bottom: 1rem;
  }

  .difficulty-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #64748b;
  }

  .difficulty-tag .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #94a3b8;
  }

  .difficulty-tag.hard { color: #ef4444; }
  .difficulty-tag.hard .dot { background: #ef4444; }
  .difficulty-tag.modplus { color: var(--brand-blue); }
  .difficulty-tag.modplus .dot { background: var(--brand-blue); }

  .card-body h3 {
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--brand-dark);
    margin-bottom: 2rem;
    line-height: 1.3;
    letter-spacing: -0.5px;
    min-height: 3.2rem;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    border-top: 1px solid #f1f5f9;
  }

  .footer-text {
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--brand-blue);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .footer-arrow {
    color: var(--brand-blue);
    transform: translateX(0);
    transition: transform 0.3s ease;
  }

  .program-card:hover .footer-arrow {
    transform: translateX(5px);
  }

  @media (max-width: 768px) {
    .recommended-section { padding: 6rem 0; }
    .section-header { margin-bottom: 3rem; }
    .grid { grid-template-columns: 1fr; }
  }
</style>
