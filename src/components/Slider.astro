---
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const slidesEs = [
  { src: '/slider_1.png', pretitle: 'DESCUBRE LA MAGIA', title: 'CAMINO INCA CLÁSICO', subtitle: 'Sigue los pasos de los antiguos incas a través de selvas nubladas y valles sagrados, una expedición inolvidable.'},
  { src: '/slider_2.png', pretitle: 'EXPERIENCIA PREMIUM', title: 'MACHU PICCHU AL AMANECER', subtitle: 'Contempla la ciudadela perdida de los Incas bañado por la primera luz del sol entre las nubes.'},
  { src: '/slider_3.png', pretitle: 'TREKKING DE ALTURA', title: 'MONTAÑA VINICUNCA', subtitle: 'Camina por valles de ensueño hasta conquistar el surrealista y pintoresco valle rojo y la montaña de colores.'},
  { src: '/slider_4.png', pretitle: 'EL GIGANTE BLANCO', title: 'NEVADO HUASCARÁN', subtitle: 'Enfréntate a las inmensas cumbres del Parque Nacional Huascarán rodeado de lagunas glaciares.'},
  { src: '/slider_5.png', pretitle: 'EXPEDICIÓN ANDINA', title: 'RUTA DEL AUSANGATE', subtitle: 'Piérdete entre alpacas, picos nevados y lagunas turquesas bajo el aura del nevado más sagrado del Cusco.'}
];

const slidesEn = [
  { src: '/slider_1.png', pretitle: 'DISCOVER THE MAGIC', title: 'CLASSIC INCA TRAIL', subtitle: 'Follow the footsteps of the ancient Incas through cloud forests and sacred valleys, an unforgettable expedition.'},
  { src: '/slider_2.png', pretitle: 'PREMIUM EXPERIENCE', title: 'MACHU PICCHU AT DAWN', subtitle: 'Witness the lost citadel of the Incas bathed in the first light of the sun breaking through the clouds.'},
  { src: '/slider_3.png', pretitle: 'HIGH ALTITUDE TREK', title: 'VINICUNCA MOUNTAIN', subtitle: 'Trek through dreamlike valleys to conquer the surreal and picturesque red valley and the rainbow mountain.'},
  { src: '/slider_4.png', pretitle: 'THE WHITE GIANT', title: 'MOUNT HUASCARAN', subtitle: 'Face the immense peaks of Huascaran National Park surrounded by pristine glacial lakes.'},
  { src: '/slider_5.png', pretitle: 'ANDEAN EXPEDITION', title: 'AUSANGATE ROUTE', subtitle: 'Lose yourself among alpacas, snow-capped peaks, and turquoise lagoons under the aura of Cusco\'s most sacred mountain.'}
];

const slides = lang === 'en' ? slidesEn : slidesEs;
---

<div class="hero-slider-wrapper">
  
  <div class="slider-container" id="creative-slider">
    {slides.map((slide, index) => (
      <div class:list={["slide", { active: index === 0 }]} data-index={index}>
        
        <!-- Image & Vignette -->
        <img src={slide.src} alt={slide.title} loading={index === 0 ? "eager" : "lazy"} />
        <div class="slide-overlay"></div>
        
        <!-- Dynamic Cinematic Content -->
        <div class="hero-content">
          <div class="hero-content-inner">
            <span class="pretitle">{slide.pretitle}</span>
            <h2 class="title">{slide.title}</h2>
            <p class="subtitle">{slide.subtitle}</p>
            <a href={getRelativeLocaleUrl(lang, 'tours')} class="cta-btn">
              {t('slider.btn')}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

      </div>
    ))}

    <!-- Navigation Arrows -->
    <button class="slider-btn prev-btn" id="prev-btn" aria-label="Anterior">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <button class="slider-btn next-btn" id="next-btn" aria-label="Siguiente">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </button>
    
    <!-- Progress Bars -->
    <div class="slider-progress-container">
      {slides.map((_, index) => (
        <div class="progress-bar-wrap" data-index={index}>
          <div class:list={["progress-bar", { active: index === 0 }]}>
            <div class="progress-fill"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .hero-slider-wrapper {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    background: #000;
  }

  .slider-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 1s cubic-bezier(0.4, 0, 0.2, 1), visibility 1s;
    z-index: 1;
    overflow: hidden;
  }

  .slide.active {
    opacity: 1;
    visibility: visible;
    z-index: 2;
  }

  /* Image & Ken Burns */
  .slide img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transform: scale(1);
    transition: transform 8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .slide.active img {
    transform: scale(1.1); 
  }

  /* Lateral Gradient Overlay */
  .slide-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    /* Gradient ensures legibility on left */
    background: linear-gradient(90deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 50%, transparent 100%),
                linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 30%);
    z-index: 2;
    transition: opacity 0.8s ease;
  }

  /* Content Wrapper */
  .hero-content {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    /* Responsive scalable padding */
    padding: 12vh clamp(1rem, 6vw, 8%) 0;
    z-index: 3;
    pointer-events: none;
    box-sizing: border-box;
  }

  .hero-content-inner {
    max-width: 750px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Staggered Animations Setup */
  .hero-content-inner > * {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Stagger delay when active */
  .slide.active .hero-content-inner .pretitle { transition-delay: 0.2s; opacity: 1; transform: translateY(0); }
  .slide.active .hero-content-inner .title { transition-delay: 0.4s; opacity: 1; transform: translateY(0); }
  .slide.active .hero-content-inner .subtitle { transition-delay: 0.6s; opacity: 1; transform: translateY(0); }
  .slide.active .hero-content-inner .cta-btn { transition-delay: 0.8s; opacity: 1; transform: translateY(0); pointer-events: auto; }

  /* Typography */
  .pretitle {
    color: var(--brand-blue);
    font-size: clamp(0.75rem, 1.2vw, 0.9rem);
    font-weight: 700;
    letter-spacing: clamp(1px, 0.5vw, 2px);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    position: relative;
    padding-left: clamp(15px, 2vw, 30px);
    line-height: 1.2;
  }

  .pretitle::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: clamp(10px, 1.5vw, 25px);
    height: 2px;
    background: var(--brand-blue);
  }

  .title {
    color: white;
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 1rem 0;
    text-transform: uppercase;
    text-shadow: 0 10px 30px rgba(0,0,0,0.5);
    letter-spacing: -0.5px;
  }

  .subtitle {
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(0.85rem, 1.5vw, 1.1rem);
    line-height: 1.6;
    font-weight: 400;
    margin: 0 0 2rem 0;
    max-width: 550px;
    width: 100%;
    text-shadow: 0 2px 10px rgba(0,0,0,0.6);
  }

  /* Call to Action Button */
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 0.8rem 2.5rem;
    background: var(--brand-blue);
    color: white;
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.3s ease;
    box-shadow: 0 10px 25px rgba(0, 144, 204, 0.3);
    pointer-events: auto;
    text-transform: uppercase;
  }

  .cta-btn:hover {
    background: var(--brand-red);
    color: #fff;
    transform: translateY(-3px);
    box-shadow: 0 15px 35px rgba(216, 2, 2, 0.3);
  }

  .cta-btn svg {
    transition: transform 0.3s ease;
  }

  .cta-btn:hover svg {
    transform: translateX(5px);
  }

  /* Navigation Side Arrows */
  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.05);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.2);
    width: clamp(40px, 5vw, 60px);
    height: clamp(40px, 5vw, 60px);
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 20;
    backdrop-filter: blur(8px);
  }

  .slider-btn:hover {
    background: white;
    color: #000;
    transform: translateY(-50%) scale(1.1);
    border-color: white;
  }

  .prev-btn { left: clamp(10px, 3vw, 40px); }
  .next-btn { right: clamp(10px, 3vw, 40px); }

  /* Navigation Progress Bars */
  .slider-progress-container {
    position: absolute;
    bottom: clamp(15px, 4vw, 40px);
    left: 8%;
    display: flex;
    gap: 12px;
    z-index: 20;
    width: 80%;
    max-width: 400px;
  }

  .progress-bar-wrap {
    flex: 1;
    height: 20px;
    display: flex;
    align-items: center;
    cursor: pointer;
  }

  .progress-bar {
    width: 100%;
    height: 3px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }

  .progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    background: var(--brand-blue);
    border-radius: 2px;
  }

  .progress-bar.active .progress-fill {
    animation: fillProgress 6.1s linear forwards;
  }

  @keyframes fillProgress {
    from { width: 0%; }
    to { width: 100%; }
  }

  /* Mobile Tweaks */
  @media (max-width: 768px) {
    .slide-overlay {
      background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.5) 60%, transparent 100%);
    }

    .hero-content {
      align-items: flex-end; 
      padding-bottom: 80px; 
    }

    .hero-content-inner {
      align-items: center;
      text-align: center;
    }

    .pretitle {
      padding-left: 0;
    }

    .pretitle::before {
      display: none;
    }

    .slider-btn {
      display: none; 
    }

    .slider-progress-container {
      left: 50%;
      transform: translateX(-50%);
      width: 90%;
      max-width: 320px;
    }
  }
</style>

<script>
  function initCinematicSlider() {
    const slides = document.querySelectorAll('.slide');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const progressBars = document.querySelectorAll('.progress-bar');
    const progressBarWraps = document.querySelectorAll('.progress-bar-wrap');
    
    if (slides.length === 0) return;

    let currentIndex = 0;
    const totalSlides = slides.length;
    let autoPlayInterval: ReturnType<typeof setTimeout> | undefined;
    const slideDuration = 6000;
    let isTransitioning = false;

    function triggerReflow(element: Element) {
      void (element as HTMLElement).offsetWidth;
    }

    function goToSlide(index: number) {
      if (isTransitioning || index === currentIndex) return;
      isTransitioning = true;
      
      slides[currentIndex].classList.remove('active');
      progressBars[currentIndex].classList.remove('active');
      
      if (index < 0) {
        currentIndex = totalSlides - 1;
      } else if (index >= totalSlides) {
        currentIndex = 0;
      } else {
        currentIndex = index;
      }
      
      const nextSlideEl = slides[currentIndex];
      const nextBarEl = progressBars[currentIndex];
      
      nextSlideEl.classList.add('active');
      triggerReflow(nextBarEl);
      nextBarEl.classList.add('active');

      setTimeout(() => {
        isTransitioning = false;
      }, 1000); 
    }

    function nextSlide() { goToSlide(currentIndex + 1); }
    function prevSlide() { goToSlide(currentIndex - 1); }

    function startAutoPlay() {
      if (autoPlayInterval) clearInterval(autoPlayInterval);
      const activeBar = progressBars[currentIndex];
      if (activeBar) {
         activeBar.classList.remove('active');
         triggerReflow(activeBar);
         activeBar.classList.add('active');
      }
      autoPlayInterval = setInterval(nextSlide, slideDuration);
    }

    // Controls
    prevBtn?.addEventListener('click', () => { prevSlide(); startAutoPlay(); });
    nextBtn?.addEventListener('click', () => { nextSlide(); startAutoPlay(); });

    progressBarWraps.forEach((wrap, index) => {
      wrap.addEventListener('click', () => {
        if (index !== currentIndex) {
           goToSlide(index);
           startAutoPlay();
        }
      });
    });

    // Mobile Swipe Logic
    let touchStartX = 0;
    let touchEndX = 0;
    const container = document.getElementById('creative-slider');
    
    container?.addEventListener('touchstart', (e: Event) => {
      touchStartX = (e as TouchEvent).changedTouches[0].screenX;
      if (autoPlayInterval) clearInterval(autoPlayInterval);
    }, {passive: true});

    container?.addEventListener('touchend', (e: Event) => {
      touchEndX = (e as TouchEvent).changedTouches[0].screenX;
      if (touchEndX < touchStartX - 50) nextSlide();
      if (touchEndX > touchStartX + 50) prevSlide();
      startAutoPlay();
    }, {passive: true});

    startAutoPlay();
  }

  document.addEventListener('DOMContentLoaded', initCinematicSlider);
  initCinematicSlider();
</script>
