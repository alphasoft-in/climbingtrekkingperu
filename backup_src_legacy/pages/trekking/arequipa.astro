---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import TourCard from '../../components/TourCard';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import PageHero from '../../components/PageHero';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const programs = [
  {
    id: 'volcanes',
    title: t('arequipa.prog1.name'),
    description: t('arequipa.prog1.desc'),
    image: '/slider_2.png',
    duration: `7 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard'
  }
];
---

<Layout title={`${t('arequipa.title')} - Franpisco Adventure`} description={t('arequipa.subtitle')}>
  <PageHero 
    client:load
    titleTop="AVENTURAS"
    titleMain="AREQUIPA"
    backgroundImage="/slider_5.png"
    techData={[
      { label: "ELEVACIÓN MÁX", value: "6,075 M.S.N.M." },
      { label: "COORDENADAS", value: "16°24′S 71°32′W" },
      { label: "REGIÓN", value: "AREQUIPA / PERÚ" }
    ]}
  />

  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
        {programs.map((prog, index) => (
          <TourCard 
            client:visible
            id={prog.id}
            title={prog.title}
            description={prog.description}
            image={prog.image}
            duration={prog.duration}
            difficulty={prog.difficulty}
            difficultyLevel={prog.difficultyLevel as any}
            href={getRelativeLocaleUrl(lang, `trekking/arequipa/arequipa-volcanes`)}
            prefix="AQP"
            category="EXPEDICIÓN VOLCÁNICA"
            lang={lang as 'es' | 'en'}
          />
        ))}
      </div>
    </div>
  </section>

  <SuggestedRoutes client:load lang={lang as 'es' | 'en'} />
</Layout>
