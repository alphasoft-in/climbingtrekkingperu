---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import SuggestedRoutes from '../../../components/SuggestedRoutes';
import TourGallery from '../../../components/TourGallery';
import ItineraryHero from '../../../components/ItineraryHero';
import ItineraryIntro from '../../../components/ItineraryIntro';
import ItinerarySchedule from '../../../components/ItinerarySchedule';
import LogisticsCard from '../../../components/LogisticsCard';
import ItineraryBooking from '../../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DIA 01',
    title: 'CUSCO – CACHORA – CAPULIYOC – CHIKISCA',
    content: 'Salida de Cusco (7:00 am). Visita al Parque Arqueológico de Piedra de Saywite. Traslado a Capuliyoc para el almuerzo. Inicio de caminata descendiendo al Cañón del Apurímac hasta Chikisca.',
    stats: { alt: '1930m', time: '3 h 20 min' }
  },
  {
    day: 'DIA 02',
    title: 'CHIKISCA – PLAYA ROSALINAS – SANTA ROSA – MARAMPATA',
    content: 'Descenso al Río Apurímac (Playa Rosalinas). Ascenso exigente pasando por Santa Rosa hasta el poblado de Marampata. Disfrute del atardecer andino.',
    stats: { alt: '2920m', time: '4 h 30 min' }
  },
  {
    day: 'DIA 03',
    title: 'MARAMPATA – PARQUE ARQUEOLÓGICO DE CHOQUEQUIRAO – MARAMPATA',
    content: 'Día central: Exploración de la ciudadela de Choquequirao (Plaza Mayor, Templo Ceremonial, Andenes, Sector Llamas). Almuerzo en el sitio y retorno a Marampata.',
    stats: { alt: '3035m', time: '5-6 h' }
  },
  {
    day: 'DIA 04',
    title: 'MARAMPATA – PLAYA ROSALINAS – CAPULIYOC – CUSCO',
    content: 'Descenso temprano al Río Apurímac para evitar el calor. Ascenso final a Capuliyoc. Traslado de retorno a la Ciudad Imperial del Cusco.',
    stats: { trans: '4 hs', dist: 'Caminata final', time: '7 h' }
  }
];

const includes = [
  'Transporte privado Cusco – Cachora – Capuliyoc (Ida y Vuelta)',
  'Alimentación completa (3 desayunos, 4 almuerzos, 3 cenas)',
  '3 Noches en hospedajes rústicos locales',
  'Guía oficial de turismo bilingüe especializado',
  'Caballos de carga para equipo general y personal (5kg pp)',
  'Arrieros experimentados',
  'Botiquín de primeros auxilios y logística de seguridad'
];

const excludes = [
  'Primer desayuno (Día 1) y última cena (Día 4)',
  'Tickets de ingreso a Choquequirao (S/. 60.00)',
  'Ticket de ingreso a Piedra de Saywite (S/. 10.00)',
  'Bebidas, snacks y gastos personales',
  'Caballo de silla (opcional S/. 160.00 por día)',
  'Propinas para el equipo de apoyo'
];

const equipment = [
  'Documentos originales (DNI / Pasaporte)',
  'Mochila de trekking (25 a 35 Ltrs)',
  'Botas de montaña con buen agarre',
  'Ropa por capas (Pantalones, polvos, casaca, chompa)',
  'Bloqueador solar y repelente de mosquitos (indispensable)',
  'Sombrero, bastones y linterna',
  'Poncho de lluvia o ropa impermeable',
  'Cargador portátil (energía limitada por paneles)'
];
---

<Layout title="Trekking Choquequirao 4 Días | Cusco | Franpisco Adventure" description="Explora la ciudadela de Choquequirao, la verdadera ciudad perdida de los Incas. 4 días de trekking intenso por el Cañón del Apurímac.">
  <ItineraryHero
    client:load
    titleTop="EXPEDICIÓN CULTURAL"
    titleMain="TREKKING CHOQUEQUIRAO"
    backgroundImage="/trekking/cusco/bg-busco.png"
    duration="4 DÍAS / 3 NOCHES"
    price="USD. 595.00"
    difficulty="DIFÍCIL"
    difficultyLevel="hard"
  />

  <ItineraryIntro
    client:visible
    code="CSQ-CHO-04D"
    titlePrefix="La Hermana de"
    titleAccent="Machu Picchu"
    description="Choquequirao no es solo una ruina; es una prueba de resistencia y faith. Cruzar el imponente Cañón del Apurímac para llegar a sus terrazas sagradas es, para muchos, la experiencia más auténtica de los Andes cusqueños."
    image="/slider_2.png"
    lat={`13° 23' 21" S`}
    lon={`72° 52' 33" W`}
    specs={[
      { label: "PUNTO DE INICIO", value: "Cusco, Perú", icon: "location" },
      { label: "ZONA TÉCNICA", value: "Cañón del Apurímac", icon: "zone" },
      { label: "TIPO DE VIAJE", value: "Trekking y Cultural", icon: "season" },
      { label: "CONECTIVIDAD", value: "WiFi en campamentos", icon: "service" },
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule
            client:visible
            days={itinerary.map((item) => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats,
            }))}
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard
              client:visible
              title="Servicios Incluidos"
              items={includes}
              refCode="SRV-INC"
              variant="primary"
            />

            <LogisticsCard
              client:visible
              title="Equipo Recomendado"
              items={equipment}
              refCode="EQP-TCN"
              variant="secondary"
            />

            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking
                client:load
                tourName="TREKKING CHOQUEQUIRAO 4D"
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery client:visible 
    lang={lang}
    tourName="Choquequirao Trek"
    images={[
      '/slider_2.png',
      '/slider_1.png',
      '/slider_3.png',
      '/slider_4.png',
      '/trekking/huayhuash/clasico.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="choquequirao" client:visible />
</Layout>


