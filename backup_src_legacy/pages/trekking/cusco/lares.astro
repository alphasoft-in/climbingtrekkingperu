---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import SuggestedRoutes from '../../../components/SuggestedRoutes';
import TourGallery from '../../../components/TourGallery';
import ItineraryHero from '../../../components/ItineraryHero';
import ItineraryIntro from '../../../components/ItineraryIntro';
import ItinerarySchedule from '../../../components/ItinerarySchedule';
import LogisticsCard from '../../../components/LogisticsCard';
import ItineraryBooking from '../../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DIA 01',
    title: 'CUSCO – AGUAS TERMALES LARES – HUACAWASI',
    content: 'Viaje escénico al valle de Lares. Tiempo de relax en las aguas termales medicinales. Caminata de ascenso hacia la comunidad quechua de Huacawasi.',
    stats: { alt: '3800m', dist: '8 km', time: '4 h' }
  },
  {
    day: 'DIA 02',
    title: 'HUACAWASI – PASO LARES (4600M) – MISKI UNUYOC',
    content: 'Día más exigente. Cruce del Abra Huacawasi rodeado de alpacas y llamas. Vistas espectaculares de la laguna Auroray y descenso al campamento.',
    stats: { alt: '4600m', dist: '14 km', time: '6-7 h' }
  },
  {
    day: 'DIA 03',
    title: 'MISKI UNUYOC – YANAHUARA – AGUAS CALIENTES',
    content: 'Descenso al Valle Sagrado a través del pintoresco pueblo de Yanahuara. Viaje en tren desde Ollantaytambo hacia el pueblo de Machu Picchu.',
    stats: { alt: '2950m', dist: '10 km', time: '3-4 h' }
  },
  {
    day: 'DIA 04',
    title: 'MACHU PICCHU – RETORNO A CUSCO',
    content: 'Tour guiado en la ciudadela de Machu Picchu. Exploración libre y retorno en tren y bus hacia la ciudad de Cusco.',
    stats: { alt: '2430m', dist: 'Bus', time: '2 h (Tour)' }
  }
];

const includes = [
  'Traslados Aeropuerto - Hotel - Aeropuerto (Cusco)',
  '2 Noches de hotel 3* en Cusco',
  'Transporte privado Cusco – Lares / Ollantaytambo',
  'Guía profesional bilingüe especializado',
  'Ticket de entrada a Machu Picchu',
  'Boletos de tren Ollantaytambo – Aguas Calientes – Ollantaytambo',
  'Bus subida/bajada a la ciudadela de Machu Picchu',
  'Equipo de campamento completo (Carpa, comedor, cocina)',
  'Cocinero y asistentes de cocina',
  'Caballos para transporte de equipo y 6kg personales',
  'Alimentación completa (3D, 3A, 3C)',
  'Hostal en Aguas Calientes (Habitación privada)'
];

const excludes = [
  'Vuelos nacionales e internacionales',
  'Entrada a aguas termales de Lares (S/. 10)',
  'Entrada a Huayna Picchu (S/. 60)',
  'Bolsa de dormir y matras inflables',
  'Bastones de trekking',
  'Seguro personal de viaje'
];

const equipment = [
  'Mochila de trekking (30-40L)',
  'Bolsa de dormir (resistencia -10°C)',
  'Zapatos de trekking impermeables',
  'Ropa técnica: capas térmicas, polar, impermeable',
  'Protección solar (gorro, bloqueador, lentes)',
  'Linterna de cabeza con baterías extra',
  'Cantimplora para agua',
  'Artículos de higiene personal'
];
---

<Layout title="Trekking Lares a Machu Picchu 4 Días | Cusco | Franpisco Adventure" description="Explora la ruta cultural de Lares. Encuentros con comunidades locales, aguas termales y la llegada mágica a Machu Picchu. 4 días de inmersión andina.">
  <ItineraryHero
    client:load
    titleTop="EL VALLE DE LOS TEJEDORES"
    titleMain="LARES TREK 4D / 3N"
    backgroundImage="/slider_1.png"
    duration="4 DÍAS / 3 NOCHES"
    price="USD. 795.00"
    difficulty="MODERADO +"
    difficultyLevel="modplus"
  />

  <ItineraryIntro
    client:visible
    code="CSQ-LAR-04D"
    titlePrefix="La Ruta de la"
    titleAccent="Tradición"
    description="El camino de Lares es la alternativa perfecta al Camino Inca para quienes buscan contacto real con comunidades quechuas. A lo largo del trayecto, verás a los locales vistiendo sus trajes tradicionales rojos."
    image="/slider_3.png"
    lat={`13° 07' 42" S`}
    lon={`72° 02' 14" W`}
    specs={[
      { label: "DESTACADO", value: "Aguas Termales Medicinales", icon: "location" },
      { label: "PUNTO MÁXIMO", value: "Abra Huacawasi (4,600m)", icon: "zone" },
      { label: "CONEXIÓN", value: "Tren Ollantaytambo", icon: "season" },
      { label: "EXPERIENCIA", value: "Comunidades de Tejedores", icon: "service" },
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule
            client:visible
            days={itinerary.map((item) => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats,
            }))}
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard
              client:visible
              title="Servicios Incluidos"
              items={includes}
              refCode="SRV-INC"
              variant="primary"
            />
            <LogisticsCard
              client:visible
              title="No Incluye"
              items={excludes}
              refCode="SRV-EXC"
              variant="secondary"
            />
            <LogisticsCard
              client:visible
              title="Equipo Técnico"
              items={equipment}
              refCode="EQP-INFO"
              variant="secondary"
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking
                client:load
                tourName="TREKKING LARES A MACHU PICCHU 4D"
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery client:visible 
    lang={lang}
    tourName="Lares Trek"
    images={[
      '/slider_3.png',
      '/slider_1.png',
      '/slider_2.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="lares" client:visible />
</Layout>
