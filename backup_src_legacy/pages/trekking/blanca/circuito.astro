const includes = [
  "Recepción en aeropuerto y traslados completos",
  "Tickets de bus Lima - Huaraz - Lima",
  "Hoteles en Huaraz y Lima según itinerario",
  "Días de aclimatación técnica",
  "Guía oficial de Trekking (UIAGM)",
  "Cocinero especializado y asistentes",
