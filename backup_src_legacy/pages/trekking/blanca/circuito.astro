---

<Layout
  title="Circuito Cordillera Blanca 15 Días | Franpisco Adventure"
  description="La travesía definitiva de 15 días en la Cordillera Blanca. Santa Cruz, Los Cedros y Alpamayo en una sola expedición de alto nivel."
>
  <ItineraryHero
    client:load
    titleTop="EXPEDICIÓN DE ÉLITE"
    titleMain="CIRCUITO CORDILLERA BLANCA"
    backgroundImage="/trekking/blanca/bg-cordillera-blanca.png"
    duration="15 DÍAS / 14 NOCHES"
    price="USD. 1,695.00"
    difficulty="MUY DIFÍCIL"
    difficultyLevel="hard"
  />

  <ItineraryIntro
    client:visible
    code="BLN-CIRC-15D"
    titlePrefix="La Travesía"
    titleAccent="Total"
    description="Esta es nuestra expedición insignia en la Cordillera Blanca. Durante 15 días, recorreremos los valles más remotos uniendo la ruta clásica de Santa Cruz con el imponente circuito de Los Cedros Alpamayo."
    image="/trekking/blanca/trekking-blanca.png"
    lat={`08° 50' 11" S`}
    lon={`77° 40' 05" W`}
    specs={[
      { label: "COBERTURA", value: "Norte y Centro de la Blanca", icon: "location" },
      { label: "PUNTOS CLAVE", value: "Alpamayo y Punta Unión", icon: "zone" },
      { label: "TEMPORADA", value: "Abril - Noviembre", icon: "season" },
      { label: "SERVICIO", value: "Expedición Premium", icon: "service" },
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule
            client:visible
            days={itinerary.map((item) => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats,
            }))}
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard
              client:visible
              title="Qué Incluye"
              items={includes}
              refCode="SRV-INC"
              variant="primary"
            />
            <LogisticsCard
              client:visible
              title="No Incluye"
              items={excludes}
              refCode="SRV-EXC"
              variant="secondary"
            />
            <LogisticsCard
              client:visible
              title="Equipo Técnico"
              items={equipment}
              refCode="EQP-TCN"
              variant="secondary"
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking
                client:load
                tourName="CIRCUITO CORDILLERA BLANCA 15D"
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery
    client:visible
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png',
      '/slider_6.png'
    ]}
    lang={lang}
    tourName="Circuito Alpamayo"
  />

  <SuggestedRoutes lang={lang} currentId="circuit" client:visible />
</Layout>
