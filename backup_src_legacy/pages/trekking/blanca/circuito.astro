    stats: { alt: "4450m", time: "9-10 h" },
  },
  {
    day: "DÍA 03",
    title: "DÍA LIBRE EN HUARAZ",
    content: "Descanso y preparación para la expedición. Opcional realizar tours ligeros.",
  },
  {
    day: "DÍA 04",
    title: "HUARAZ – VAQUERÍA – PARIA (3900 MSNM)",
    content: "Traslado por el paso Portachuelo (4760m). Inicio del trek en Vaquería hasta Paria.",
    stats: { trans: "5 h", alt: "4760m", dist: "8.5 km", time: "5 h" },
  },
  {
    day: "DÍA 05",
    title: "PARIA – PUNTA UNIÓN (4750 MSNM) – TUCTU",
