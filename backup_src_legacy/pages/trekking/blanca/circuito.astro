const equipment = [
  "Bolsa de dormir (-15°C)",
  "Botas de trekking impermeables",
  "Ropa técnica por capas",
  "Casaca de pluma o térmica pesada",
  "Mochila de ataque (40L)",
  "Bastones de trekking",
  "Linterna frontal con pilas",
  "Protección solar completa"
