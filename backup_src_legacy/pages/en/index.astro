---
import Slider from '../../components/Slider';
import Institutional from '../../components/Institutional';
import WorkArea from '../../components/WorkArea';
import TeamSection from '../../components/TeamSection';
import Gastronomy from '../../components/Gastronomy';
import Logistics from '../../components/Logistics';
import EthicsBento from '../../components/EthicsBento';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const slidesEn = [
  { src: '/slider_1.png', pretitle: 'DISCOVER THE MAGIC', title: 'CLASSIC INCA TRAIL', subtitle: 'Follow the footsteps of the ancient Incas through cloud forests and sacred valleys, an unforgettable expedition.'},
  { src: '/slider_2.png', pretitle: 'PREMIUM EXPERIENCE', title: 'MACHU PICCHU AT DAWN', subtitle: 'Witness the lost citadel of the Incas bathed in the first light of the sun breaking through the clouds.'},
  { src: '/slider_3.png', pretitle: 'HIGH ALTITUDE TREK', title: 'VINICUNCA MOUNTAIN', subtitle: 'Trek through dreamlike valleys to conquer the surreal and picturesque red valley and the rainbow mountain.'},
  { src: '/slider_4.png', pretitle: 'THE WHITE GIANT', title: 'MOUNT HUASCARAN', subtitle: 'Face the immense peaks of Huascaran National Park surrounded by pristine glacial lakes.'},
  { src: '/slider_5.png', pretitle: 'ANDEAN EXPEDITION', title: 'AUSANGATE ROUTE', subtitle: 'Lose yourself among alpacas, snow-capped peaks, and turquoise lagoons under the aura of Cusco\'s most sacred mountain.'}
];
---

<Layout 
	title="Home - Franpisco Adventure" 
	description="Franpisco Adventure Travel and Tourism Agency. Epic mountain and trekking expeditions in Huaraz and across South America."
>
	<!-- 1. Hero Slider -->
	<Slider client:load lang={lang as 'es' | 'en'} slides={slidesEn} buttonLabel={t('slider.btn')} />

	<!-- 2. Institutional Section -->
	<Institutional client:load lang={lang as 'es' | 'en'} />

	<!-- 4. Work Area Section -->
	<WorkArea client:load lang={lang as 'es' | 'en'} />

	<!-- 5. Team Section -->
	<TeamSection client:load lang={lang as 'es' | 'en'} />

	<!-- 6. Gastronomy Section -->
	<Gastronomy client:load lang={lang as 'es' | 'en'} />

	<!-- 7. Logistics Section -->
	<Logistics client:load lang={lang as 'es' | 'en'} />

	<!-- 8. Ethics Bento Section -->
	<EthicsBento client:load lang={lang as 'es' | 'en'} />
	<!-- 9. Suggested Routes Section -->
	<SuggestedRoutes client:load lang={lang as 'es' | 'en'} />
</Layout>

<style>
	/* Same EXACT CSS as Spanish index.astro (White/Corporate layout) */
	section {
		padding: clamp(3rem, 6vw, 6rem) 1rem;
		box-sizing: border-box;
		width: 100%;
	}
	

	.page-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0;
		box-sizing: border-box;
	}
	
	.about-header, .bento-header {
		text-align: center;
		margin-bottom: clamp(2.5rem, 5vw, 4rem);
	}

	.section-title {
		font-size: clamp(1.8rem, 4vw, 2.5rem);
		font-weight: 800;
		color: #0f4d82;
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.section-subtitle {
		font-size: clamp(0.95rem, 2vw, 1.15rem);
		color: #555;
		margin-top: 1rem;
		letter-spacing: clamp(1px, 2vw, 2px);
	}

	.bento-subtitle {
		font-size: clamp(1rem, 2.5vw, 1.25rem);
		color: #475569;
		margin-top: 1.5rem;
		line-height: 1.6;
		max-width: 800px;
		margin-inline: auto;
	}

	.title-divider {
		height: 3px;
		width: clamp(40px, 8vw, 60px);
		background: #0a84ff;
		margin: 1.2rem auto;
		border-radius: 2px;
	}

	.clean-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.clean-list li {
		display: flex;
		align-items: flex-start;
		gap: 10px;
		margin-bottom: 0.8rem;
		line-height: 1.6;
	}
	.clean-list .bullet {
		color: #0a84ff;
		font-weight: bold;
		flex-shrink: 0;
		margin-top: 2px;
	}
	.list-text {
		flex: 1;
	}

	/* --- CORPORATE IDENTITY (ARCHITECTURAL REDESIGN) --- */
	.corporate-identity {
		background: #ffffff;
		padding: clamp(4rem, 8vw, 7rem) 1rem;
	}

	.identity-header {
		text-align: center;
		margin-bottom: clamp(3rem, 6vw, 4.5rem);
	}

	.company-name {
		font-size: clamp(1.8rem, 4.5vw, 2.6rem);
		color: var(--brand-blue);
		font-weight: 900;
		text-transform: uppercase;
		margin: 0 0 0.5rem 0;
		letter-spacing: 1px;
		line-height: 1.1;
	}

	.company-type {
		font-size: clamp(0.9rem, 2vw, 1.1rem);
		color: #555;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 2px;
	}

	.header-line {
		width: 60px;
		height: 4px;
		background: var(--brand-red);
		margin: 1.5rem auto 0;
		border-radius: 2px;
	}

	.identity-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(2rem, 5vw, 5rem);
		align-items: flex-start;
	}

	.identity-col {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.info-badge {
		font-size: 0.65rem;
		font-weight: 900;
		color: var(--brand-red);
		letter-spacing: 2px;
		text-transform: uppercase;
		border-left: 3px solid var(--brand-red);
		padding-left: 12px;
		margin-bottom: 0.5rem;
	}

	.identity-col p {
		font-size: clamp(1rem, 2vw, 1.15rem);
		line-height: 1.7;
		color: #444;
		margin: 0;
	}

	.lead-text {
		font-weight: 400;
		color: var(--brand-dark);
	}

	@media (max-width: 900px) {
		.identity-grid { grid-template-columns: 1fr; text-align: left; }
		.identity-header { margin-bottom: 3rem; }
	}

	.pillars-section { background: #f8fbff; }
	.pillars-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 250px), 1fr));
		gap: clamp(1rem, 3vw, 2rem);
	}
	.pillar-card {
		background: white;
		padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 3vw, 2rem);
		border-radius: 12px;
		box-shadow: 0 4px 15px rgba(0,0,0,0.04);
		transition: transform 0.3s ease;
		border-top: 4px solid #0f4d82;
	}
	.pillar-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.08); }
	.pillar-icon { font-size: clamp(2rem, 5vw, 2.8rem); margin-bottom: 1rem; }
	.pillar-card h3 { color: #0f4d82; font-size: clamp(1.1rem, 3vw, 1.3rem); margin-bottom: 1rem; }
	.pillar-card p { color: #555; line-height: 1.6; font-size: clamp(0.9rem, 2vw, 0.95rem); margin: 0; }

	.work-area-section { 
		background: #ffffff;
		padding: clamp(4rem, 8vw, 7rem) 1rem;
	}
	.section-description {
		max-width: 800px;
		margin: 1.5rem auto 0;
		font-size: 1rem;
		line-height: 1.6;
		color: #64748b;
	}
	.staff-types-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
		gap: 2.5rem;
		margin-top: 4rem;
	}
	.staff-box {
		padding: 2.5rem;
		background: #f8fafc;
		border-left: 4px solid var(--brand-blue);
		transition: all 0.4s ease;
		display: flex;
		flex-direction: column;
		height: 100%;
	}
	.staff-box:hover {
		background: #fff;
		box-shadow: 0 20px 50px rgba(0,0,0,0.08);
		border-left-color: var(--brand-red);
		transform: translateX(10px);
	}
	.box-tag {
		font-size: 0.65rem;
		font-weight: 900;
		color: var(--brand-blue);
		letter-spacing: 2px;
		text-transform: uppercase;
		margin-bottom: 1rem;
	}
	.box-title {
		font-size: 1.25rem;
		font-weight: 800;
		color: var(--brand-dark);
		margin: 0 0 1.2rem 0;
		letter-spacing: 1px;
	}
	.staff-box p, .staff-box li { 
		color: #475569; 
		font-size: 0.95rem; 
		line-height: 1.7; 
		margin: 0; 
	}

	.team-section { 
		background: #1a1a1a;
		padding: clamp(4rem, 8vw, 7rem) 1rem;
		position: relative;
		overflow: hidden;
	}
	.team-section::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: radial-gradient(circle at 50% 50%, #2a2a2a 0%, #1a1a1a 100%);
		opacity: 0.5;
	}
	.text-white { color: #ffffff !important; }
	.text-light { color: #94a3b8 !important; }

	.team-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
		gap: 2rem;
		margin-top: 4rem;
	}
	.team-card {
		background: rgba(255, 255, 255, 0.03);
		padding: 3rem 1.5rem;
		border-radius: 4px;
		text-align: center;
		border: 1px solid rgba(255, 255, 255, 0.05);
		transition: all 0.4s ease;
		position: relative;
	}
	.team-card:hover {
		background: rgba(255, 255, 255, 0.06);
		border-color: var(--brand-blue);
		transform: translateY(-10px);
		box-shadow: 0 20px 40px rgba(0,0,0,0.4);
	}
	.unit-badge {
		font-size: 0.6rem;
		font-weight: 900;
		color: var(--brand-blue);
		letter-spacing: 2px;
		position: absolute;
		top: 1.5rem;
		left: 50%;
		transform: translateX(-50%);
		opacity: 0.5;
	}
	.team-avatar {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		background: #2a2a2a;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0 auto 2rem auto;
		border: 2px solid var(--brand-blue);
		box-shadow: 0 0 20px rgba(0, 144, 204, 0.3);
		transition: all 0.4s ease;
	}
	.team-avatar img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: grayscale(100%);
		transition: all 0.4s ease;
	}
	.team-card:hover .team-avatar {
		box-shadow: 0 0 30px rgba(216, 2, 2, 0.5);
		border-color: var(--brand-red);
		transform: scale(1.1);
	}
	.team-card:hover .team-avatar img {
		filter: grayscale(0%);
	}
	.member-name {
		font-size: 1.1rem;
		font-weight: 700;
		color: white;
		margin: 0 0 0.5rem 0;
		letter-spacing: 0.5px;
	}
	.member-rank {
		font-size: 0.65rem;
		font-weight: 900;
		color: var(--brand-blue);
		text-transform: uppercase;
		letter-spacing: 2px;
	}

	.gastronomy-section { 
		background: #ffffff;
		padding: clamp(4rem, 8vw, 7rem) 1rem;
		position: relative;
	}
	.diet-badges {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: center;
		gap: 1rem;
		margin-top: 3rem;
		margin-bottom: 4rem;
	}
	.diet-tag {
		font-size: 0.65rem;
		font-weight: 900;
		color: #94a3b8;
		letter-spacing: 2px;
		margin-right: 0.5rem;
	}
	.diet-badge {
		padding: 6px 16px;
		border: 1px solid #e2e8f0;
		border-radius: 4px;
		font-size: 0.7rem;
		font-weight: 800;
		color: var(--brand-dark);
		letter-spacing: 1px;
	}
	.diet-badge.normal { color: #64748b; }
	.diet-badge.veg { border-color: #22c55e; color: #166534; }
	.diet-badge.vegan { border-color: #eab308; color: #854d0e; }
	.diet-badge.gluten { border-color: var(--brand-red); color: var(--brand-red); }

	.gastronomy-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 340px), 1fr));
		gap: 2.5rem;
	}
	.gastro-card {
		padding: 3rem;
		background: #f8fafc;
		border-radius: 4px;
		transition: all 0.4s ease;
		display: flex;
		flex-direction: column;
		border: 1px solid transparent;
	}
	.gastro-card:hover {
		background: #fff;
		box-shadow: 0 30px 60px rgba(0,0,0,0.06);
		border-color: #e2e8f0;
		transform: translateY(-5px);
	}
	.g-unit {
		font-size: 0.6rem;
		font-weight: 900;
		color: var(--brand-blue);
		letter-spacing: 2px;
		margin-bottom: 1rem;
	}
	.g-title {
		font-size: 1.25rem;
		font-weight: 800;
		color: var(--brand-dark);
		margin: 0 0 1.2rem 0;
		letter-spacing: 1px;
	}
	.g-line {
		width: 40px;
		height: 3px;
		background: var(--brand-red);
		margin-bottom: 2rem;
	}
	.food-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.food-list li {
		font-size: 0.95rem;
		color: #475569;
		margin-bottom: 0.8rem;
		padding-left: 1.5rem;
		position: relative;
	}
	.food-list li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.6rem;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--brand-blue);
	}
	.dinner-split {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2.5rem;
	}
	.sub-label {
		display: block;
		font-size: 0.7rem;
		font-weight: 900;
		color: var(--brand-blue);
		letter-spacing: 2px;
		margin-bottom: 1.5rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid #e2e8f0;
	}
	@media (max-width: 768px) {
		.dinner-split { grid-template-columns: 1fr; }
	}

	/* Logistics Institutional Accordion */
	.logistics-section { 
		background: #f8fbff;
		padding: clamp(4rem, 8vw, 7rem) 1rem;
	}
	.creative-accordion {
		max-width: 900px;
		margin: 4rem auto 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.acc-item {
		background: #ffffff;
		border: 1px solid #e2e8f0;
		border-radius: 4px;
		overflow: hidden;
		transition: all 0.4s ease;
	}
	.acc-item[open] {
		border-color: var(--brand-blue);
		box-shadow: 0 20px 40px rgba(15, 77, 130, 0.05);
	}
	.acc-header {
		padding: 2rem;
		display: flex;
		align-items: center;
		gap: 2rem;
		cursor: pointer;
		list-style: none;
		user-select: none;
		transition: all 0.3s ease;
	}
	.acc-header::-webkit-details-marker { display: none; }
	.acc-header::marker { content: ""; display: none; }
	.acc-header:hover { background: #fdfdfd; }

	.acc-num {
		font-size: 2.5rem;
		font-weight: 800;
		color: #e2e8f0;
		line-height: 1;
		font-family: serif;
		transition: all 0.4s ease;
	}
	.acc-item[open] .acc-num {
		color: var(--brand-blue);
		opacity: 0.3;
	}
	.acc-title-group {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 6px;
	}
	.acc-category {
		font-size: 0.65rem;
		font-weight: 900;
		letter-spacing: 2px;
		color: #94a3b8;
		text-transform: uppercase;
	}
	.acc-item[open] .acc-category { color: var(--brand-blue); }
	
	.acc-title {
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--brand-dark);
		margin: 0;
	}
	.acc-icon {
		width: 24px;
		height: 24px;
		position: relative;
		transition: transform 0.4s ease;
	}
	.icon-line {
		position: absolute;
		background: #94a3b8;
		transition: all 0.4s ease;
	}
	.icon-line:first-child {
		width: 100%;
		height: 2px;
		top: 50%;
		left: 0;
		margin-top: -1px;
	}
	.icon-line:last-child {
		width: 2px;
		height: 100%;
		top: 0;
		left: 50%;
		margin-left: -1px;
	}
	.acc-item[open] .acc-icon { transform: rotate(45deg); }
	.acc-item[open] .icon-line { background: var(--brand-red); }

	.acc-content {
		padding: 0 2rem 2rem 5.5rem;
	}
	.content-inner {
		border-left: 2px solid #e2e8f0;
		padding-left: 2rem;
		font-size: 1rem;
		color: #475569;
		line-height: 1.7;
	}
	.content-inner p { margin-bottom: 1.2rem; }
	.content-inner p:last-child { margin-bottom: 0; }

	@media (max-width: 768px) {
		.acc-header { padding: 1.5rem; gap: 1.5rem; }
		.acc-num { font-size: 2rem; }
		.acc-content { padding: 0 1.5rem 1.5rem 1.5rem; }
		.content-inner { border-left: none; padding-left: 0; }
	}

	/* Ethical Command Bento UI */
	.ethical-bento-section {
		background: #ffffff;
		padding: clamp(4rem, 8vw, 7rem) 1rem;
		border-top: 1px solid #f1f5f9;
	}
	.bento-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
		margin-top: 4rem;
	}

	.bento-card {
		padding: 3rem;
		background: #f8fafc;
		border-radius: 4px;
		display: flex;
		flex-direction: column;
		position: relative;
		border: 1px solid transparent;
		transition: all 0.4s ease;
	}
	.bento-card:hover {
		background: #fff;
		box-shadow: 0 30px 60px rgba(0,0,0,0.06);
		border-color: #e2e8f0;
		transform: translateY(-5px);
	}
	/* Override for dark gold card hover */
	.bento-card.b-gold:hover {
		background: var(--brand-dark);
		box-shadow: 0 30px 60px rgba(0,0,0,0.3);
		border-color: #eab308;
	}
	.b-meta-tag {
		font-size: 0.6rem;
		font-weight: 900;
		color: #94a3b8;
		letter-spacing: 2px;
		margin-bottom: 2rem;
		display: block;
	}
	.b-heading {
		font-size: 1.25rem;
		font-weight: 800;
		color: var(--brand-dark);
		margin-bottom: 1rem;
	}
	.bento-card p {
		font-size: 0.95rem;
		color: #475569;
		line-height: 1.6;
		margin: 0;
	}
	.b-icon {
		font-size: 2rem;
		margin-bottom: 1.5rem;
	}

	/* Card Variants */
	.b-span-2 { grid-column: span 2; }
	.b-red { border-top: 3px solid var(--brand-red); }
	.b-blue { border-top: 3px solid var(--brand-blue); }
	.b-green { border-top: 3px solid #22c55e; }
	.b-dark { border-top: 3px solid var(--brand-dark); }
	.b-gold { 
		background: var(--brand-dark); 
		color: #fff;
		border-top: 3px solid #eab308;
	}

	.b-gold .b-heading, .b-gold p, .b-gold .b-meta-tag { color: rgba(255,255,255,0.8); }
	
	.b-accent-bar {
		width: 40px;
		height: 2px;
		background: var(--brand-red);
		margin-top: 2rem;
	}

	.epic-vow {
		font-size: 1.15rem !important;
		font-weight: 300;
		font-style: italic;
		line-height: 1.5 !important;
		color: #fff !important;
		margin-bottom: 2rem !important;
	}
	.signature-line {
		margin-top: auto;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.sig-name {
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 2px;
		color: #eab308;
	}
	.sig-rank {
		font-size: 0.6rem;
		font-weight: 600;
		color: rgba(255,255,255,0.4);
		letter-spacing: 1px;
	}

	@media (max-width: 1024px) {
		.bento-grid { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 640px) {
		.bento-grid { grid-template-columns: 1fr; }
		.b-span-2 { grid-column: span 1; }
	}
</style>
