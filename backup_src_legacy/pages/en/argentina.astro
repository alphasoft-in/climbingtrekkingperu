---
import Layout from '../../layouts/Layout.astro';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import PageHero from '../../components/PageHero';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import TourCard from '../../components/TourCard';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const argentinaPrograms = [
  {
    id: 'aconcagua',
    title: t('climbing.aconcagua.name'),
    description: t('climbing.aconcagua.desc'),
    image: '/slider_2.png',
    duration: `17 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard' as const,
    path: 'argentina/aconcagua',
    prefix: 'ARG',
    type: 'HIGH ALTITUDE EXPEDITION'
  }
];
---

<Layout title={`Argentina - ${t('nav.destinations')} | Franpisco Adventure`} description="Explore the Argentinian Andes with Franpisco Adventure. Expeditions to Aconcagua, the roof of America, with top-tier logistics and expert guides.">
  <PageHero 
    client:load
    titleTop="DESTINATIONS"
    titleMain="ARGENTINA"
    backgroundImage="/slider_3.png"
    techData={[
      { label: "MAX ELEVATION", value: "6,962 M.S.N.M." },
      { label: "COORDINATES", value: "32°39′S 70°00′W" },
      { label: "REGION", value: "ANDES / ARGENTINA" }
    ]}
  />

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {argentinaPrograms.map((prog) => (
          <TourCard 
            client:visible
            id={prog.id}
            title={prog.title}
            description={prog.description}
            image={prog.image}
            duration={prog.duration}
            difficulty={prog.difficulty}
            difficultyLevel={prog.difficultyLevel}
            href={getRelativeLocaleUrl(lang, prog.path)}
            prefix={prog.prefix}
            category={prog.type}
            lang={lang as 'es' | 'en'}
          />
        ))}
      </div>
    </div>
  </section>
  <SuggestedRoutes lang={lang} client:visible />
</Layout>

<style>
  .programs-section {
    padding: 8rem 0;
    background: #ffffff;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .programs-section { padding: 6rem 1.5rem; }
    .container { padding: 0; }
  }
</style>
