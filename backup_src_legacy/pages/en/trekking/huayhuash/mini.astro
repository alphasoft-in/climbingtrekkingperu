---
import Layout from "../../../../layouts/Layout.astro";
import {
  getLangFromUrl,
  useTranslations,
  getRelativeLocaleUrl,
} from "../../../../i18n/utils";
import SuggestedRoutes from "../../../../components/SuggestedRoutes";
import TourGallery from "../../../../components/TourGallery";
import ItineraryHero from "../../../../components/ItineraryHero";
import ItineraryIntro from "../../../../components/ItineraryIntro";
import ItinerarySchedule from "../../../../components/ItinerarySchedule";
import LogisticsCard from "../../../../components/LogisticsCard";
import ItineraryBooking from "../../../../components/ItineraryBooking";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: "DAY 01",
    title: "LIMA PERU (100 MASL) – HUARAZ (3100 MASL)",
    content:
      "Travel by bus (8 hours) or flight (50 min) to Huaraz. We recommend at least one day of acclimatization in the Cordillera Blanca before starting.",
  },
  {
    day: "DAY 02",
    title: "FULL DAY ROCUTOYOC LAGOON (4450 MASL) – ACCLIMATIZATION",
    content:
      "Visit Rocutuyoc lagoon, Ruripaccha waterfall, and Ruripaccha glacier (4,650 masl). Return to Huaraz.",
    stats: { time: "9-10 hours", alt: "4450m" },
  },
  {
    day: "DAY 03",
    title: "FREE DAY",
    content:
      "Strategic rest day to optimize altitude adjustment before starting the Mini Trek Huayhuash.",
  },
  {
    day: "DAY 04",
    title: "HUARAZ (3100M) CUARTELWAIN (4180 MASL) - MITUCOCHA (4280 MASL)",
    content:
      "Transfer to Cuartelwain. Cacananpunta Pass (4700 masl). Descend to Jancapampa campsite (Mitucocha).",
    stats: { trans: "05 hours", alt: "4700 m", time: "5 h" },
  },
  {
    day: "DAY 05",
    title: "MITUCOCHA (4230 MASL) - CARHUACOCHA (4,280 MASL)",
    content:
      "Carhuac Pass (4,650 masl). Optional alternate route to the Three Lagoons viewpoint for spectacular vistas of Yerupaja and Siula.",
    stats: { alt: "4650 m", dist: "13 km", time: "6 h" },
  },
  {
    day: "DAY 06",
    title: "CARHUACOCHA (4280 MASL) - HUAYHUASH (4350 MASL)",
    content:
      "Most demanding day. Three lagoons viewpoint. Siula Pass (4,800 masl). Views of Trapecio and Leon Dormido peaks.",
    stats: { alt: "4800 m", dist: "15 km", time: "08 h" },
  },
  {
    day: "DAY 07",
    title: "HUAYHUASH (4,350 MASL) - CUYOCPAMPA (4550 MASL)",
    content:
      "Trapecio Pass (5,030 masl). View of Azulcocha lagoon. Optional: San Antonio Viewpoint (5,120 masl).",
    stats: { alt: "5,030 m", dist: "13 km", time: "6 h" },
  },
  {
    day: "DAY 08",
    title: "CUYOCPAMPA (4,550 MASL) - HUAYLLAPA (3630 MASL)",
    content:
      "Santa Rosa Pass (5,080 masl). Incredible northern face views of Huayhuash. Descend to Huayllapa and transfer to Cajatambo.",
    stats: { alt: "5080 m", dist: "19 km", time: "09 h" },
  },
];

const includes = [
  "Pre-trek briefing at Huaraz office",
  "Shared acclimatization tour",
  "Private transport Huaraz - Queropalca",
  "Huayllapa - Cajatambo transfer",
  "Certified Mountain Guide",
  "Specialized trekking cook",
  "5 days full board during the trek",
  "6kg personal gear allowance on mules",
  "Complete trekking and camping gear",
  "First aid kit and Oxygen",
];

const equipment = [
  "Sleeping bag (-10°C recommended)",
  "Daypack (40L)",
  "Waterproof trekking boots",
  "Thermal and warm layers",
  "Hat, gloves, and sun protection",
  "Trekking poles",
  "Rain poncho",
  "Water bottle or hydration pack",
];
---

<Layout
  title="Mini Trek Huayhuash - 8 Days | Franpisco Adventure"
  description="The essential and spectacular 8-day Huayhuash circuit. From Mitucocha to Huayllapa."
>
  <ItineraryHero
    client:load
    titleTop="TREKKING CORDILLERA"
    titleMain="HUAYHUASH MINI 08D"
    backgroundImage="/trekking/huayhuash/bg-mini.png"
    duration="08 DAYS / 07 NIGHTS"
    price="USD. 695.00"
    difficulty="HARD"
    difficultyLevel="hard"
  />

  <ItineraryIntro
    client:visible
    code="HYH-MN-08D"
    titlePrefix="Andean"
    titleAccent="Essence"
    description="This compact itinerary selects the most impactful spots of the Huayhuash circuit, crossing passes over 5,000 meters and concluding in the historic town of Cajatambo."
    image="/trekking/huayhuash/bg-mini.png"
    lat={`10° 20' 05" S`}
    lon={`76° 59' 12" W`}
    specs={[
      {
        label: "START / LOGISTICS",
        value: "Huaraz, Peru",
        icon: "location",
      },
      { label: "TECHNICAL ZONES", value: "Ancash, Huánuco, Lima", icon: "zone" },
      { label: "SEASON", value: "April - December", icon: "season" },
      { label: "SERVICE", value: "Specialized Expedition", icon: "service" },
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div
        class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start"
      >
        <!-- Main Timeline -->
        <div class="flex-1">
          <ItinerarySchedule
            client:visible
            days={itinerary.map((item) => {
              return {
                day: item.day,
                title: item.title,
                description: item.content,
                stats: item.stats,
              };
            })}
          />
        </div>

        <!-- Logistics Sidebar -->
        <aside class="sticky top-24 h-fit">
          <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12"
          >
            <LogisticsCard
              client:visible
              title="Services Included"
              items={includes}
              refCode="SRV-INC"
              variant="primary"
            />

            <LogisticsCard
              client:visible
              title="Suggested Equipment"
              items={equipment}
              refCode="EQP-TCN"
              variant="secondary"
            />

            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking
                client:load
                tourName="HUAYHUASH MINI TREK 08D EXPEDITION"
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery
    client:visible
    images={[
      "/trekking/huayhuash/mini/1.png",
      "/trekking/huayhuash/mini/2.png",
      "/trekking/huayhuash/mini/3.png",
      "/trekking/huayhuash/mini/4.png",
      "/trekking/huayhuash/mini/5.png",
      "/trekking/huayhuash/mini/6.png",
      "/trekking/huayhuash/mini/7.png",
      "/trekking/huayhuash/mini/8.png",
    ]}
    lang={lang}
    tourName="Huayhuash Mini"
  />

  <SuggestedRoutes lang={lang} currentId="mini" client:visible />

  <style>
    /* Base styles for expedition dossiers */
    .logistics-card {
      background: white;
      padding: 2.5rem;
      border: 1px solid var(--brand-light);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
    }
  </style>
</Layout>
