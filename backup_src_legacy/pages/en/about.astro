---
import Layout from '../../layouts/Layout.astro';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import PageHero from '../../components/PageHero';

const isEs = false;
const techData = [
	{ label: isEs ? "ELEVACIÓN" : "ELEVATION", value: "3,052 M.S.L." },
	{ label: isEs ? "COORDENADAS" : "COORDINATES", value: "9°31′48″S 77°31′44″W" },
	{ label: isEs ? "FUNDADA" : "FOUNDED", value: isEs ? "EST. 2015 / PERÚ" : "EST. 2015 / PERU" }
];
---

<Layout 
	title="About Us - Franpisco Adventure"
	description="Learn more about our corporate history, mission, and the technical mountaineering team in Huaraz."
>
	<!-- High-End Technical Hero: Editorial Expedition Log -->
	<PageHero 
		client:load
		titleTop={isEs ? "NUESTRA" : "OUR"}
		titleMain={isEs ? "HISTORIA" : "HISTORY"}
		backgroundImage="/bg-nosotros.png"
		techData={techData}
	/>

	<section class="py-20 md:py-32 bg-white px-6">
		<div class="max-w-[1200px] mx-auto">
			<!-- ARCHITECTURAL NARRATIVE HEADER -->
			<div class="flex flex-col items-center text-center gap-8 mb-12 md:mb-16 border-b border-slate-100 pb-10">
				<div class="max-w-2xl">
					<span class="text-[9px] md:text-[10px] font-black text-brand-red tracking-[0.4em] uppercase mb-4 block">CORPORATE CHRONOLOGY</span>
					<h2 class="text-3xl md:text-5xl text-brand-dark leading-[0.9] font-extralight uppercase tracking-tighter">
						The Origin of the <br/><strong class="font-black block mt-2">Technical Ascent</strong>
					</h2>
				</div>
				
				<div class="flex gap-10 md:gap-16 pt-2">
					<div class="flex flex-col gap-2 items-center">
						<label class="text-[9px] font-black text-brand-blue tracking-[0.25em] uppercase">BASE HQ</label>
						<span class="text-xs md:text-sm font-bold text-brand-dark font-mono">HUARAZ, PERÚ</span>
					</div>
					<div class="flex flex-col gap-2 border-l border-slate-100 pl-10 md:pl-16 items-center">
						<label class="text-[9px] font-black text-brand-blue tracking-[0.25em] uppercase">ACCREDITATION</label>
						<span class="text-xs md:text-sm font-bold text-brand-dark uppercase font-mono tracking-tighter">UIAGM / AGMP</span>
					</div>
				</div>
			</div>
			
			<!-- MAIN NARRATIVE CONTENT -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-16 md:gap-24 items-start">
				<div class="lg:col-span-7 space-y-16">
					<div class="relative">
						<div class="absolute -left-6 top-0 w-1 h-full bg-brand-blue shadow-[0_0_15px_rgba(0,114,206,0.3)]"></div>
						<p class="text-xl md:text-2xl text-brand-dark font-light leading-relaxed italic pr-4">
							Our corporate life was forged under the immense protection of the majestic Cordillera Blanca. We were native guides deeply knowing the Andean network before becoming tourism managers.
						</p>
					</div>
					
					<div class="grid grid-cols-1 md:grid-cols-2 gap-10 text-slate-500 text-sm md:text-base leading-relaxed font-medium">
						<p>We are defined by our absolute devotion to technical mountaineering. At <strong>Franpisco Adventure</strong>, we logistically guide international explorers every year, fulfilling unbreakable agreements and the highest Andean safety canons.</p>
						<p>We have <strong>UIAGM</strong> national and international backing, working in alliance with local bases of muleteers, protecting this millennial ecosystem under a zero-impact footprint.</p>
					</div>
				</div>

				<!-- EDITORIAL MISSION/VISION CARDS -->
				<div class="lg:col-span-5 flex flex-col gap-5">
					<div class="bg-slate-50/50 p-8 md:p-10 border-l-2 border-slate-100 transition-all duration-500 hover:bg-white hover:shadow-xl hover:shadow-slate-100 hover:border-brand-red group">
						<span class="text-[9px] font-black text-brand-red tracking-[0.3em] uppercase mb-6 block opacity-60 group-hover:opacity-100 transition-opacity">OPERATIONAL MISSION</span>
						<p class="text-brand-dark/70 text-sm md:text-base leading-relaxed font-medium">
							Guarantee absolute control in operational reserves and solid corporate security, delivering a logistical service of premium standards.
						</p>
					</div>
					<div class="bg-slate-50/50 p-8 md:p-10 border-l-2 border-slate-100 transition-all duration-500 hover:bg-white hover:shadow-xl hover:shadow-slate-100 hover:border-brand-blue group">
						<span class="text-[9px] font-black text-brand-blue tracking-[0.3em] uppercase mb-6 block opacity-60 group-hover:opacity-100 transition-opacity">LOGISTICAL VISION</span>
						<p class="text-brand-dark/70 text-sm md:text-base leading-relaxed font-medium">
							Eternally maintain the first place in trust and implacable technical honesty with the pure global mountaineer seeking excellence.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

  <SuggestedRoutes client:load lang="en" />
</Layout>
