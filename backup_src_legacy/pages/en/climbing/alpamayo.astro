---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import SuggestedRoutes from '../../../components/SuggestedRoutes';
import TourGallery from '../../../components/TourGallery';
import ItineraryHero from '../../../components/ItineraryHero';
import ItineraryIntro from '../../../components/ItineraryIntro';
import ItinerarySchedule from '../../../components/ItinerarySchedule';
import LogisticsCard from '../../../components/LogisticsCard';
import ItineraryBooking from '../../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DAY 01',
    title: 'HUARAZ (3100M) – CASHAPAMPA – LLAMACORAL (3760M)',
    content: 'Departure at 7:00 am from Huaraz to Cashapampa (2900m). Meet the donkey drivers and start the hike to Llamacoral (3760m) following the Yurakmayu river.',
    stats: { time: '3h Trans / 5h Hike', alt: '3760m' }
  },
  {
    day: 'DAY 02',
    title: 'LLAMACORAL (3760M) – ALPAMAYO BASE CAMP (4350M)',
    content: 'Hike through the Santa Cruz valley, passing Jatuncocha lagoon. Enter the base camp through Arhuaycocha ravine.',
    stats: { time: '5-6h Hike', alt: '4350m' }
  },
  {
    day: 'DAY 03',
    title: 'BASE CAMP (4350M) – HIGH CAMP (5450M)',
    content: 'Ascend to the high camp. Technical ascent through the glacier moraine to reach the camp at 5450m.',
    stats: { time: '6-7h Ascent', alt: '5450m' }
  },
  {
    day: 'DAY 04',
    title: 'HIGH CAMP (5450M) – ALPAMAYO SUMMIT (5947M)',
    content: 'Summit day. Technical climbing on ice walls (60° to 90°). Reach the peak and enjoy the reward. Rappel down 7-8 lengths back to high camp.',
    stats: { time: '10-11h Jornada', alt: '5947m' }
  },
  {
    day: 'DAY 05',
    title: 'HIGH CAMP (5450M) – BASE CAMP (4350M)',
    content: 'Descend back to base camp, including a 40-50m rappel section. Crossing the glacier and moraine.',
    stats: { time: '6-7h Descent', alt: '4350m' }
  },
  {
    day: 'DAY 06',
    title: 'BASE CAMP (4350M) – CASHAPAMPA (2900M) – HUARAZ',
    content: 'Final descent to Cashapampa village. Private transport back to Huaraz city.',
    stats: { time: 'Return', alt: '3100m' }
  }
];

const includes = [
  'Transfer bus terminal - hotel in Huaraz',
  'Expedition briefing at the office',
  'PNH Entrance Tickets',
  'Private transport Huaraz - Cashapampa - Huaraz',
  'UIAGM Certified Guide (International)',
  'Certified HNP Cook',
  'Porter for equipment to High Camp',
  'Full meals during the expedition',
  'Camping equipment and personal tent',
  'Ropes and snow stakes',
  'Walkie-talkies and First Aid kit'
];

const equipment = [
  'Sleeping bag (-20°C) and mat',
  'Mountain helmet and sun hat',
  'Glacier glasses (Cat. 4)',
  'Sunblock',
  'Down jacket and Gore-Tex jacket',
  'Technical snow gloves',
  'Harness and technical ice axes (pair)',
  'Double mountaineering boots and Crampons',
  'Daypack (40L)'
];
---

<Layout title="Alpamayo Expedition 5947m | White Range | Franpisco Adventure" description="Scale the most beautiful mountain in the world. 6-day technical expedition to Alpamayo Peak in the Peruvian Andes.">
  <ItineraryHero
    client:load
    titleTop="THE MOST BEAUTIFUL MOUNTAIN"
    titleMain="NEVADO ALPAMAYO 5947M"
    backgroundImage="/slider_5.png"
    duration="06 DAYS / 05 NIGHTS"
    price="USD. 1,950.00"
    difficulty="HARD / TECHNICAL"
    difficultyLevel="hard"
  />

  <ItineraryIntro
    client:visible
    code="CLB-ALP-06"
    titlePrefix="The Pyramid"
    titleAccent="of Ice"
    description="Alpamayo is considered the most beautiful mountain in the world. Its perfect pyramid shape attracts mountaineers worldwide. A high-level technical challenge requiring experience and adaptation."
    image="/slider_1.png"
    lat={`08° 52' 45" S`}
    lon={`77° 39' 12" W`}
    specs={[
      { label: "START POINT", value: "Huaraz, Peru", icon: "location" },
      { label: "INCLINATION", value: "60° - 90° Wall", icon: "activity" },
      { label: "MIN GROUP", value: "02 Passengers", icon: "duration" },
      { label: "REQUIREMENT", value: "Technical", icon: "difficulty" }
    ]}
  />

  <section class="details-section bg-[#fafafa] py-24 border-t border-slate-200">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Itinerary Column -->
        <div class="lg:col-span-8">
          <ItinerarySchedule 
            client:visible
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats
            }))}
            title="Ascent"
            subtitle="Timeline"
          />
        </div>

        <!-- Logistics Sidebar -->
        <aside class="lg:col-span-4 sticky top-24 h-fit">
          <div class="flex flex-col gap-10">
            <LogisticsCard
              client:visible
              title="What's Included"
              items={includes}
              refCode="SRV-INC"
              variant="primary"
            />

            <LogisticsCard
              client:visible
              title="Technical Gear"
              items={equipment}
              refCode="EQP-TCN"
              variant="secondary"
            />

            <ItineraryBooking
              client:visible
              lang={lang}
              tourName="Alpamayo Expedition"
            />
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery 
    client:visible 
    lang={lang}
    tourName="Nevado Alpamayo"
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="alpamayo" client:visible />
</Layout>

<style>
  .details-section {
    position: relative;
    z-index: 10;
  }
</style>
