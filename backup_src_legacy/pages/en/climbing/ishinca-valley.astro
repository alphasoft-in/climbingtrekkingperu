---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import SuggestedRoutes from '../../../components/SuggestedRoutes';
import TourGallery from '../../../components/TourGallery';
import ItineraryHero from '../../../components/ItineraryHero';
import ItineraryIntro from '../../../components/ItineraryIntro';
import ItinerarySchedule from '../../../components/ItinerarySchedule';
import LogisticsCard from '../../../components/LogisticsCard';
import ItineraryBooking from '../../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DAY 01',
    title: 'HUARAZ (3100M) – ISHINCA BASE CAMP (4350M)',
    content: 'Transfer to Collon. Approach hike through the Ishinca valley among queñual forests to the base camp.',
    stats: { time: '5h Hike', alt: '4350m' }
  },
  {
    day: 'DAY 02',
    title: 'BASE CAMP (4350M) – URUS SUMMIT (5424M)',
    content: 'Acclimatization technical ascent to the Urus summit. Views of Ranrapalca and Tocllaraju. Return to base.',
    stats: { time: '9-10h Full Day', alt: '5424m' }
  },
  {
    day: 'DAY 03',
    title: 'BASE CAMP (4350M) – ISHINCA SUMMIT (5350M)',
    content: 'Summit push to Nevado Ishinca. Excellent technical preparation peak for Tocllaraju.',
    stats: { time: '13-14h Full Day', alt: '5350m' }
  },
  {
    day: 'DAY 04',
    title: 'STRATEGIC REST DAY',
    content: 'Day to recover energy and review technical equipment at the base camp.',
    stats: { time: 'Rest', alt: '4350m' }
  },
  {
    day: 'DAY 05',
    title: 'BASE CAMP – TOCLLARAJU HIGH CAMP (4950M)',
    content: 'Ascent carrying high-mountain equipment to the Tocllaraju moraine camp.',
    stats: { time: '4h Ascent', alt: '4950m' }
  },
  {
    day: 'DAY 06',
    title: 'HIGH CAMP – TOCLLARAJU SUMMIT (6030M) – BASE',
    content: 'Midnight summit push. Technical climbing to reach 6030m. Descent to base camp.',
    stats: { time: '13-14h Full Day', alt: '6030m' }
  },
  {
    day: 'DAY 07',
    title: 'BASE CAMP – COLLON – HUARAZ (3100M)',
    content: 'Final return through the valley to Collon and private transport back to Huaraz.',
    stats: { time: 'Return', alt: '3100m' }
  }
];

const includes = [
  'Transfer terminal - hotel in Huaraz',
  'Full technical and logistics briefing',
  'Private transport Huaraz - Collon - Huaraz',
  'UIAGM Certified mountain guide',
  'Specialized high-mountain cook',
  'Porters for high camp equipment',
  'Full expedition meals',
  'High-mountain camping gear',
  'Donkeys and driver for base camp logistics',
  'HNP entrance fees',
  'Ropes, stakes and communication radios'
];

const excludes = [
  'Travel and rescue insurance',
  'City meals',
  'Personal technical equipment',
  'Personal expenses and tips',
  'Personal sleeping bag (-20°C)'
];

const equipment = [
  'Sleeping bag (-20°C)',
  'Mountain helmet and headlamp',
  'UV glasses Cat 4 and sunblock',
  'Down jacket and Gore-Tex',
  'Harness and technical ice axes (pair)',
  'High-mountain boots and crampons',
  'Daypack (40L)'
];
---

<Layout title="Ishinca Trilogy 6030m | White Range | Franpisco Adventure" description="7-day expedition in the Ishinca Valley. Conquer Urus, Ishinca and the imposing Tocllaraju (6030m) with UIAGM guides.">
  <ItineraryHero
    client:load
    titleTop="THE VALLEY TRILOGY"
    titleMain="ISHINCA & TOCLLARAJU 6030M"
    backgroundImage="/slider_3.png"
    duration="07 DAYS / 06 NIGHTS"
    price="USD. 1,795.00"
    difficulty="HIGH / TECHNICAL"
    difficultyLevel="hard"
  />

  <ItineraryIntro
    client:visible
    code="CLB-ISH-07"
    titlePrefix="The Valley of"
    titleAccent="the Giants"
    description="The Ishinca valley allows for ideal progressive ascent. Urus and Ishinca serve as perfect acclimatization before the technical challenge of Tocllaraju (6030m)."
    image="/slider_3.png"
    lat={`09° 20' 52" S`}
    lon={`77° 19' 26" W`}
    specs={[
      { label: 'MAX SUMMIT', value: '6,030 MASL', icon: 'location' },
      { label: 'TYPE', value: 'Summit Trilogy', icon: 'activity' },
      { label: 'SEASON', value: 'May - September', icon: 'season' },
      { label: 'SERVICE', value: 'Elite UIAGM Guide', icon: 'service' }
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule 
            client:visible 
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats
            }))} 
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard 
              client:visible 
              title="What's Included" 
              items={includes} 
              refCode="SRV-INC" 
              variant="primary" 
            />
            <LogisticsCard 
              client:visible 
              title="Not Included" 
              items={excludes} 
              refCode="SRV-EXC" 
              variant="secondary" 
            />
            <LogisticsCard 
              client:visible 
              title="Technical Gear" 
              items={equipment} 
              refCode="EQP-TCN" 
              variant="secondary" 
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking 
                client:load 
                tourName="ISHINCA VALLEY TRILOGY 6030M" 
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery 
    client:visible 
    lang={lang}
    tourName="Ishinca Valley"
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="ishinca-valley" client:visible />
</Layout>
