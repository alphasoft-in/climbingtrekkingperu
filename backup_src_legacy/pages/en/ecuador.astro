---
import Layout from '../../layouts/Layout.astro';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import PageHero from '../../components/PageHero';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import TourCard from '../../components/TourCard';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const ecuadorPrograms = [
  {
    id: 'avenida-volcanes',
    title: t('climbing.ecuador.name'),
    description: t('climbing.ecuador.desc'),
    image: '/slider_4.png',
    duration: `12 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard' as const,
    path: 'ecuador/avenida-volcanes',
    prefix: 'ECU',
    type: 'VOLCANO EXPEDITION'
  },
  {
    id: 'lagunas-pichincha',
    title: t('climbing.ecuador_tours.name'),
    description: t('climbing.ecuador_tours.desc'),
    image: '/slider_2.png',
    duration: `5 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod' as const,
    path: 'ecuador/lagunas-pichincha',
    prefix: 'ECU',
    type: 'ACCLIMATIZATION & TOURS'
  }
];
---

<Layout title={`Ecuador - ${t('nav.destinations')} | Franpisco Adventure`} description="Explore the Avenue of Volcanoes in Ecuador. Expeditions to Cotopaxi, Chimborazo, Cayambe, and Ilinizas with certified guides and premium logistics.">
  <PageHero 
    client:load
    titleTop="DESTINATIONS"
    titleMain="ECUADOR"
    backgroundImage="/slider_4.png"
    techData={[
      { label: "MAX ELEVATION", value: "6,263 M.S.N.M." },
      { label: "COORDINATES", value: "0°13′S 78°31′W" },
      { label: "REGION", value: "ANDES / ECUADOR" }
    ]}
  />

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {ecuadorPrograms.map((prog) => (
          <TourCard 
            client:visible
            id={prog.id}
            title={prog.title}
            description={prog.description}
            image={prog.image}
            duration={prog.duration}
            difficulty={prog.difficulty}
            difficultyLevel={prog.difficultyLevel}
            href={getRelativeLocaleUrl(lang, prog.path)}
            prefix={prog.prefix}
            category={prog.type}
            lang={lang as 'es' | 'en'}
          />
        ))}
      </div>
    </div>
  </section>
  <SuggestedRoutes lang={lang} client:visible />
</Layout>

<style>
  .programs-section {
    padding: 8rem 0;
    background: #ffffff;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .programs-section { padding: 6rem 1.5rem; }
    .container { padding: 0; }
  }
</style>
