---
import Layout from '../../layouts/Layout.astro';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import PageHero from '../../components/PageHero';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import TourCard from '../../components/TourCard';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const boliviaPrograms = [
  {
    id: 'cordillera-real-expedition',
    title: t('climbing.bolivia_1.name'),
    description: t('climbing.bolivia_1.desc'),
    image: '/slider_3.png',
    duration: `11 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod' as const,
    path: 'bolivia/cordillera-real-expedition',
    prefix: 'BOL',
    type: 'CLIMBING & TREKKING'
  },
  {
    id: 'condoriri-huayna-expedition',
    title: t('climbing.bolivia_2.name'),
    description: t('climbing.bolivia_2.desc'),
    image: '/slider_5.png',
    duration: `6 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard' as const,
    path: 'bolivia/condoriri-huayna-expedition',
    prefix: 'BOL',
    type: 'TECHNICAL CLIMBING'
  },
  {
    id: 'uyuni-huayna-potosi',
    title: t('climbing.bolivia_3.name'),
    description: t('climbing.bolivia_3.desc'),
    image: '/slider_2.png',
    duration: `10 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod' as const,
    path: 'bolivia/uyuni-huayna-potosi',
    prefix: 'BOL',
    type: 'TOUR & CLIMBING'
  },
  {
    id: 'illampu-circuit',
    title: t('climbing.bolivia_4.name'),
    description: t('climbing.bolivia_4.desc'),
    image: '/slider_4.png',
    duration: `8 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod' as const,
    path: 'bolivia/illampu-circuit',
    prefix: 'BOL',
    type: 'REMOTE TREKKING'
  },
  {
    id: 'cotia-huayna-trek',
    title: t('climbing.bolivia_5.name'),
    description: t('climbing.bolivia_5.desc'),
    image: '/slider_3.png',
    duration: `7 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod' as const,
    path: 'bolivia/cotia-huayna-trek',
    prefix: 'BOL',
    type: 'GLACIER TREKKING'
  },
  {
    id: 'condoriri-huayna-expedition-alt',
    title: t('climbing.bolivia_6.name'),
    description: t('climbing.bolivia_6.desc'),
    image: '/slider_1.png',
    duration: `6 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard' as const,
    path: 'bolivia/condoriri-huayna-expedition',
    prefix: 'BOL',
    type: 'TECHNICAL CLIMBING'
  },
  {
    id: 'apolobamba-expedition',
    title: t('climbing.bolivia_7.name'),
    description: t('climbing.bolivia_7.desc'),
    image: '/slider_5.png',
    duration: `8 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard' as const,
    path: 'bolivia/apolobamba-expedition',
    prefix: 'BOL',
    type: 'REMOTE EXPEDITION'
  },
  {
    id: 'illimani-sajama',
    title: t('climbing.bolivia_8.name'),
    description: t('climbing.bolivia_8.desc'),
    image: '/slider_1.png',
    duration: `13 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard' as const,
    path: 'bolivia/illimani-sajama',
    prefix: 'BOL',
    type: 'HIGH ALTITUDE'
  }
];
---

<Layout title={`Bolivia - ${t('nav.destinations')} | Franpisco Adventure`} description="Explore the Cordillera Real, Salar de Uyuni and Bolivia's giants like Sajama and Illimani. Elite mountaineering and trekking expeditions.">
  <PageHero 
    client:load
    titleTop="DESTINATIONS"
    titleMain="BOLIVIA"
    backgroundImage="/slider_2.png"
    techData={[
      { label: "MAX ELEVATION", value: "6,542 M.S.N.M." },
      { label: "COORDINATES", value: "16°29′S 68°09′W" },
      { label: "REGION", value: "ANDES / BOLIVIA" }
    ]}
  />

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {boliviaPrograms.map((prog) => (
          <TourCard 
            client:visible
            id={prog.id}
            title={prog.title}
            description={prog.description}
            image={prog.image}
            duration={prog.duration}
            difficulty={prog.difficulty}
            difficultyLevel={prog.difficultyLevel}
            href={getRelativeLocaleUrl(lang, prog.path)}
            prefix={prog.prefix}
            category={prog.type}
            lang={lang as 'es' | 'en'}
          />
        ))}
      </div>
    </div>
  </section>
  <SuggestedRoutes lang={lang} client:visible />
</Layout>

<style>
  .programs-section {
    padding: 8rem 0;
    background: #ffffff;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .programs-section { padding: 6rem 1.5rem; }
    .container { padding: 0; }
  }
</style>
