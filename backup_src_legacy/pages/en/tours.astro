    prefix: 'MDD',
    type: 'AMAZON EXPEDITION'
  },
  {
    id: 'iquitos-amazonas',
    title: t('iquitos.prog1.name'),
    description: t('iquitos.prog1.desc'),
    image: '/slider_2.png',
    duration: `2 - 5 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.easy'),
    difficultyLevel: 'easy' as const,
    path: 'tours/iquitos-amazonas',
    prefix: 'IQT',
    type: 'RIVER EXPEDITION'
  },
  {
    id: 'lima-city',
    title: t('lima.prog1.name'),
    description: t('lima.prog1.desc'),
    image: '/slider_3.png',
    duration: `4 ${t('trekking.hours')}`,
    difficulty: t('trekking.diff.easy'),
    difficultyLevel: 'easy' as const,
    path: 'tours/lima-city',
    prefix: 'LIM',
    type: 'CITY EXPEDITION'
  },
  {
    id: 'lima-pachacamac',
    title: t('lima.prog2.name'),
    description: t('lima.prog2.desc'),
    image: '/slider_1.png',
    duration: `8 ${t('trekking.hours')}`,
    difficulty: t('trekking.diff.easy'),
    difficultyLevel: 'easy' as const,
    path: 'tours/lima-pachacamac',
    prefix: 'LIM',
    type: 'ARCHAEOLOGICAL EXPEDITION'
  },
  {
    id: 'maravillas-peru-17d',
    title: t('tours.vip.name'),
    description: t('tours.vip.desc'),
    image: '/trekking/huayhuash/clasico.png',
    duration: `17 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.mod'),
    difficultyLevel: 'mod' as const,
    path: 'tours/maravillas-peru-17d',
    prefix: 'PER',
    type: 'GRAND EXPEDITION'
  }
];
---

<Layout title={`${t('nav.tours')} - Franpisco Adventure`} description="Explore our cultural expeditions and exclusive tours in the most iconic regions of Peru.">
  <PageHero 
    client:load
    titleTop="OUR"
    titleMain="TOURS"
    backgroundImage="/slider_2.png"
    techData={[
      { label: "MAX ELEVATION", value: "4,600 M.S.N.M." },
      { label: "COORDINATES", value: "9°30′S 77°31′W" },
      { label: "REGION", value: "CORDILLERA BLANCA" }
    ]}
  />

  <section class="programs-section">
    <div class="container">
      <div class="grid">
        {tours.map((tour) => (
          <TourCard 
            client:visible
            id={tour.id}
            title={tour.title}
            description={tour.description}
            image={tour.image}
            duration={tour.duration}
            difficulty={tour.difficulty}
            difficultyLevel={tour.difficultyLevel}
            href={getRelativeLocaleUrl(lang, tour.path)}
            prefix={tour.prefix}
            category={tour.type}
            lang={lang as 'es' | 'en'}
          />
        ))}
      </div>
    </div>
  </section>
  <SuggestedRoutes lang={lang} client:visible />
</Layout>

<style>
  .programs-section {
    padding: 8rem 0;
    background: #ffffff;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .programs-section { padding: 6rem 1.5rem; }
    .container { padding: 0; }
  }
</style>
