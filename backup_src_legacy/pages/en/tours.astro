    difficulty: t('trekking.diff.easy'),
    difficultyLevel: 'easy' as const,
    path: 'tours/laguna-llanganuco',
    prefix: 'HZ',
    type: 'CLASSIC TOUR'
  },
  {
    id: 'trekking-69',
    title: t('tours.huaraz.69.name'),
    description: t('tours.huaraz.69.desc'),
    image: '/slider_3.png',
    duration: `1 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus' as const,
    path: 'tours/trekking-69',
    prefix: 'HZ',
    type: 'TREKKING FD'
  },
  {
    id: 'laguna-rocotuyoc',
    title: t('tours.huaraz.rocotuyoc.name'),
    description: t('tours.huaraz.rocotuyoc.desc'),
    image: '/slider_4.png',
    duration: `1 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.easy'),
    difficultyLevel: 'easy' as const,
    path: 'tours/laguna-rocotuyoc',
    prefix: 'HZ',
    type: 'CLASSIC TOUR'
  },
  {
    id: 'pastoruri',
    title: t('tours.huaraz.pastoruri.name'),
    description: t('tours.huaraz.pastoruri.desc'),
    image: '/slider_2.png',
    duration: `1 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.easy'),
    difficultyLevel: 'easy' as const,
    path: 'tours/pastoruri',
    prefix: 'HZ',
    type: 'CLASSIC TOUR'
  },
  {
    id: 'chavin-huantar',
    title: t('tours.huaraz.chavin.name'),
    description: t('tours.huaraz.chavin.desc'),
    image: '/slider_1.png',
    duration: `1 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.easy'),
    difficultyLevel: 'easy' as const,
    path: 'tours/chavin-huantar',
    prefix: 'HZ',
    type: 'CULTURAL TOUR'
  },
  {
    id: 'chacas',
    title: t('tours.huaraz.chacas.name'),
    description: t('tours.huaraz.chacas.desc'),
    image: '/slider_4.png',
    duration: `1 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.easy'),
    difficultyLevel: 'easy' as const,
    path: 'tours/chacas',
    prefix: 'HZ',
    type: 'SCENIC TOUR'
  },
  {
    id: 'trekking-churup',
    title: t('tours.huaraz.churup.name'),
    description: t('tours.huaraz.churup.desc'),
    image: '/slider_2.png',
    duration: `1 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.modplus'),
    difficultyLevel: 'modplus' as const,
    path: 'tours/trekking-churup',
    prefix: 'HZ',
    type: 'TREKKING FD'
  },
  {
    id: 'arequipa-volcanoes',
    title: t('arequipa.prog1.name'),
    description: t('arequipa.prog1.desc'),
    image: '/slider_2.png',
    duration: `7 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard' as const,
    path: 'trekking/arequipa/arequipa-volcanes',
    prefix: 'AQP',
    type: 'VOLCANIC EXPEDITION'
  },
  {
    id: 'ica-paracas',
    title: t('ica.prog1.name'),
    description: t('ica.prog1.desc'),
    image: '/slider_1.png',
    duration: `3 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.easy'),
    difficultyLevel: 'easy' as const,
