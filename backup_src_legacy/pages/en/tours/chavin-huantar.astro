---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import SuggestedRoutes from '../../../components/SuggestedRoutes';
import TourGallery from '../../../components/TourGallery';
import ItineraryHero from '../../../components/ItineraryHero';
import ItineraryIntro from '../../../components/ItineraryIntro';
import ItinerarySchedule from '../../../components/ItinerarySchedule';
import LogisticsCard from '../../../components/LogisticsCard';
import ItineraryBooking from '../../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: '08:30 AM',
    title: 'DEPARTURE FROM HUARAZ',
    content: 'Departure southwards through the Huaylas Valley. We pass through the villages of Recuay and Catac.',
    stats: { time: 'Start' }
  },
  {
    day: '10:30 AM',
    title: 'QUEROCOCHA LAKE',
    content: 'Photographic stop at Querococha Lake (3980m). Views of the "map of Peru" naturally formed on the mountain.',
    stats: { alt: '3980m' }
  },
  {
    day: '11:30 AM',
    title: 'CAWISH TUNNEL',
    content: 'Crossing the Cordillera Blanca through the Cawish tunnel. Descent towards the Conchucos Valley.',
    stats: { alt: '4500m' }
  },
  {
    day: '01:00 PM',
    title: 'CHAVIN COMPLEX',
    content: 'Guided visit to the oldest ceremonial center in the Andes. Exploration of plazas, underground galleries, and the Lanzon Monolith.',
    stats: { alt: '3137m', time: '2.5 h stay' }
  },
  {
    day: '03:30 PM',
    title: 'MUSEUM & LUNCH',
    content: 'Visit to the Chavin National Museum (optional) and lunch at a local restaurant in the village.',
    stats: { time: 'Culture' }
  },
  {
    day: '07:30 PM',
    title: 'RETURN TO HUARAZ',
    content: 'Arrival at the city after crossing the range again. End of services.',
    stats: { time: 'End' }
  }
];

const includes = [
  'Pick up from your hotel in Huaraz',
  'Equipped tourist transportation',
  'Official Tour Guide (Specialist)',
  'Assistance at the archaeological site',
  'First aid kit'
];

const excludes = [
  'Meals (Regional lunch)',
  'Site entrance ticket (S/. 15.00)',
  'Museum entrance ticket',
  'Personal expenses'
];

const equipment = [
  'Comfortable walking shoes',
  'Sun protection (hat, sunscreen)',
  'Light jacket and rain poncho',
  'Camera with extra battery',
  'Personal medications',
  'Extra cash for lunch and tickets'
];
---

<Layout title="Chavin de Huantar Full Day | Ancash | Franpisco Adventure" description="Explore the origin of Andean culture. Visit the ancient ceremonial center of Chavin de Huantar, its galleries and the Lanzon Monolith.">
  <ItineraryHero 
    client:load
    titleTop="CENTER OF THE WORLD"
    titleMain="CHAVIN DE HUANTAR"
    backgroundImage="/slider_1.png"
    duration="FULL DAY (11H)"
    price="CONSULT"
    difficulty="EASY"
    difficultyLevel="easy"
  />

  <ItineraryIntro 
    client:visible
    code="HZ-CHA-FD"
    titlePrefix="Architecture of"
    titleAccent="Mystery"
    description="Chavin de Huantar is one of the most important archaeological sites in America. Considered the first Andean integration center, its impressive stone structures and complex underground gallery systems are unique."
    image="/slider_2.png"
    lat={`09° 35' 33" S`}
    lon={`77° 10' 42" W`}
    specs={[
      { label: 'LOCATION', value: 'Conchucos Valley', icon: 'location' },
      { label: 'SCULPTURE', value: 'Lanzon Monolith', icon: 'zone' },
      { label: 'STATUS', value: 'UNESCO Heritage', icon: 'season' },
      { label: 'PUBLIC', value: 'Family / Cultural', icon: 'service' }
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule 
            client:visible 
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats
            }))} 
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard 
              client:visible 
              title="What's Included" 
              items={includes} 
              refCode="SRV-INC" 
              variant="primary" 
            />
            <LogisticsCard 
              client:visible 
              title="Not Included" 
              items={excludes} 
              refCode="SRV-EXC" 
              variant="secondary" 
            />
            <LogisticsCard 
              client:visible 
              title="Suggested Gear" 
              items={equipment} 
              refCode="EQP-INFO" 
              variant="secondary" 
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking 
                client:load 
                tourName="CHAVIN DE HUANTAR FULL DAY" 
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery client:visible 
    lang={lang}
    tourName="Chavin de Huantar"
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="chavin-huantar" client:visible />
</Layout>
