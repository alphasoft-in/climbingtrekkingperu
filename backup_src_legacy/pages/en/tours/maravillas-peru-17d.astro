---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import SuggestedRoutes from '../../../components/SuggestedRoutes';
import TourGallery from '../../../components/TourGallery';
import ItineraryHero from '../../../components/ItineraryHero';
import ItineraryIntro from '../../../components/ItineraryIntro';
import ItinerarySchedule from '../../../components/ItinerarySchedule';
import LogisticsCard from '../../../components/LogisticsCard';
import ItineraryBooking from '../../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  { day: 'DAY 01', title: 'Arrival in Lima', content: 'Assistance and personalized transfer from Jorge Chávez airport to the hotel in Miraflores.' },
  { day: 'DAY 02', title: 'Lima – Ica – Huacachina', content: 'Trip to Ica. Visit to the Plaza de Armas, wine/pisco cellars, and the Huacachina Oasis with dune tour and buggies.' },
  { day: 'DAY 03', title: 'Paracas – Ballestas Islands', content: 'Maritime excursion to the Ballestas Islands to see penguins and sea lions. Visit to the Paracas National Reserve.' },
  { day: 'DAY 04', title: 'Ica – Nazca – Arequipa', content: 'Transfer to Nazca for the flight over the Nazca Lines. Night bus journey in a sleeper bus to Arequipa.' },
  { day: 'DAY 05', title: 'Arequipa – Sillar Route', content: 'Arrival and accommodation. Tour to the sillar quarries and Culebrillas canyon with ancient petroglyphs.' },
  { day: 'DAY 06', title: 'Colca Canyon', content: 'Journey to the Cruz del Cóndor Viewpoint to observe the condor\'s flight and the canyon\'s depth.' },
  { day: 'DAY 07', title: 'Salinas Lagoon', content: 'Visit to the Volcanoes Viewpoint in Chiguata and expedition to the Salinas Lagoon (Yaretales).' },
  { day: 'DAY 08', title: 'Arequipa – Puno', content: 'Bus journey to the city of Puno, on the shores of Lake Titicaca (6.5 hours).' },
  { day: 'DAY 09', title: 'Uros and Taquile', content: 'Navigation on Lake Titicaca. Visit to the Uros floating islands and the cultural island of Taquile.' },
  { day: 'DAY 10', title: 'Puno – Cusco', content: 'Bus transfer to the Imperial City of Cusco. Free afternoon for acclimatization.' },
  { day: 'DAY 11', title: 'Cusco City Tour & Sacsayhuaman', content: 'Visit to Qoricancha (Sun Temple) and the complexes of Sacsayhuaman, Qenqo, Pukapukara, and Tambomachay.' },
  { day: 'DAY 12', title: 'Sacred Valley VIP', content: 'Chincheros, Maras Salt Mines, Moray, and Ollantaytambo. Train to Aguas Calientes in the evening.' },
  { day: 'DAY 13', title: 'Machu Picchu', content: 'Guided visit to the citadel of Machu Picchu, one of the 7 wonders of the world. Return to Cusco.' },
  { day: 'DAY 14', title: 'Free Day in Cusco', content: 'Rest day to enjoy Cusco\'s gastronomy and local handicraft shopping.' },
  { day: 'DAY 15', title: '7-Color Mountain', content: 'Expedition to Vinicunca (5,100 masl) and the Red Valley. Stunning high Andean landscapes.' },
  { day: 'DAY 16', title: 'Cusco – Lima', content: 'Return flight to the capital. Transfer to the hotel in Lima.' },
  { day: 'DAY 17', title: 'Return to Country of Origin', content: 'Transfer to the international airport 4 hours before your flight. End of services.' }
];

const includes = [
  'Personalized attention from Franpisco Adventure',
  '3-star hotels in all cities',
  'Private transport and sleeper buses for long distances',
  'Train tickets Ollantaytambo - Aguas Calientes (Expedition)',
  'Entrance tickets to Machu Picchu, Sacred Valley, and 7-Color Mountain',
  'Nazca Lines flight and Paracas maritime tour',
  'Official tour guides in each destination',
  'Daily breakfasts in hotels and some buffet lunches'
];

const excludes = [
  'International and domestic flights (Lima-Cusco)',
  'Horse at 7-Color Mountain (100 soles optional)',
  'Meals not mentioned in the program',
  'Travel insurance and tips',
  'Personal excursion equipment'
];
---

<Layout title="Wonders of Peru VIP 17D | Franpisco Adventure" description="The ultimate expedition through Southern Peru. 17 days visiting Lima, Paracas, Nazca, Arequipa, Puno, and Cusco with personalized VIP service.">
  <ItineraryHero 
    client:load
    titleTop="THE ULTIMATE EXPEDITION"
    titleMain="WONDERS OF PERU 17D"
    backgroundImage="/slider_2.png"
    duration="17 DAYS / 16 NIGHTS"
    price="USD. 2,465.00"
    difficulty="MODERATE"
    difficultyLevel="mod"
  />

  <ItineraryIntro 
    client:visible
    code="PER-VIP-17D"
    titlePrefix="The Soul of"
    titleAccent="Southern Peru"
    description="This is not just a trip; it is a deep immersion into the living history of South America. From the modernity of Lima to the mysticism of Machu Picchu, through the Nazca deserts and the sacred waters of Titicaca. 17 days of personalized service, top-class hotels, and peerless cultural experiences."
    image="/slider_1.png"
    lat={`13° 09' 47" S`}
    lon={`72° 32' 44" W`}
    specs={[
      { label: 'DESTINATIONS', value: 'Southern Peru', icon: 'location' },
      { label: 'CATEGORY', value: 'VIP Cultural', icon: 'zone' },
      { label: 'ACCOMMODATION', value: '3★ Superior', icon: 'service' },
      { label: 'CONNECTIONS', value: 'Train, Bus & Flights', icon: 'season' }
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule 
            client:visible 
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content
            }))} 
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard 
              client:visible 
              title="Included Services" 
              items={includes} 
              refCode="SRV-VIP-17D" 
              variant="primary" 
            />
            <LogisticsCard 
              client:visible 
              title="Not Included / Notes" 
              items={excludes} 
              refCode="SRV-EXC" 
              variant="secondary" 
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking 
                client:load 
                tourName="WONDERS OF PERU VIP 17D" 
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery client:visible 
    lang={lang}
    tourName="Wonders of Peru"
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="maravillas-peru-17d" client:visible />
</Layout>
