---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import SuggestedRoutes from '../../../components/SuggestedRoutes';
import TourGallery from '../../../components/TourGallery';
import ItineraryHero from '../../../components/ItineraryHero';
import ItineraryIntro from '../../../components/ItineraryIntro';
import ItinerarySchedule from '../../../components/ItinerarySchedule';
import LogisticsCard from '../../../components/LogisticsCard';
import ItineraryBooking from '../../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DAY 01',
    title: 'PUERTO MALDONADO – MADRE DE DIOS – MONKEY ISLAND',
    content: 'Reception and navigation along the Madre de Dios River. Jungle hike to observe ancient trees and wildlife. Afternoon of Kayaking and visit to the Capuchin Monkey Island. Night boat tour searching for caimans.',
    stats: { alt: '183m', dist: 'River', time: '8-10 h' }
  },
  {
    day: 'DAY 02',
    title: 'SANDOVAL LAKE – TAMBOPATA RESERVE',
    content: 'Exploration of Sandoval Lake, one of the most biodiverse in the world. Observation of giant otters, black caimans, and prehistoric birds (Hoatzin). Sport fishing for piranhas and night walk through the jungle symphony.',
    stats: { alt: 'Lowland Forest', dist: 'Trekking/Canoe', time: '12 h' }
  },
  {
    day: 'DAY 03',
    title: 'TAPIR TRAIL – RETURN',
    content: 'Hike along the Tapir trail and exploration of the aguaje palm swamps (swamplands). Observation of large mammal tracks and oropendola birds. Return to the city of Puerto Maldonado.',
    stats: { alt: 'Humid', dist: 'Trekking', time: '5-6 h' }
  }
];

const includes = [
  'Airport - Port - Lodge Transfers',
  'Accommodation in the heart of the jungle',
  'Full meals (Veg/Vgn option)',
  'Local expert Amazon guide',
  'River transport (Peque-peque)',
  'Entrance tickets to Tambopata National Reserve',
  'Kayak and Fishing equipment',
  'Rubber boots for jungle hikes'
];

const excludes = [
  'Flights Lima - Puerto Maldonado - Lima',
  'Additional bar drinks',
  'Staff tips',
  'First breakfast on day 1'
];

const equipment = [
  'Light, fast-drying clothing',
  'Repelente with 50% DEET',
  'Sun hat and UV sunglasses',
  'Flashlight or headlamp with batteries',
  'Personal hygiene kit',
  'Raincoat or poncho',
  'Binoculars (optional but recommended)'
];
---

<Layout title="Amazon Rainforest: Tambopata and Sandoval Lake | Franpisco Adventure" description="Immerse yourself in the Peruvian Amazon. 3-day expedition to Puerto Maldonado, Tambopata Reserve, and the mystic Sandoval Lake. Pure nature and extreme biodiversity.">
  <ItineraryHero 
    client:load
    titleTop="PUERTO MALDONADO"
    titleMain="TAMBOPATA & SANDOVAL 3D"
    backgroundImage="/slider_4.png"
    duration="3 DAYS / 2 NIGHTS"
    price="CONSULT"
    difficulty="LOW"
    difficultyLevel="easy"
  />

  <ItineraryIntro 
    client:visible
    code="MDD-TAM-03D"
    titlePrefix="The Lungs of"
    titleAccent="Madre de Dios"
    description="Puerto Maldonado is the gateway to one of the most vibrant ecosystems on the planet. This expedition takes you to the heart of the Tambopata National Reserve and Sandoval Lake, a pristine mirror of water surrounded by ancient palm trees."
    image="/slider_1.png"
    lat={`12° 35' 39" S`}
    lon={`69° 10' 48" W`}
    specs={[
      { label: 'REGION', value: 'Madre de Dios', icon: 'location' },
      { label: 'RESERVES', value: 'Tambopata & Sandoval', icon: 'zone' },
      { label: 'ECOSYSTEM', value: 'Lowland Jungle', icon: 'season' },
      { label: 'LOGISTICS', value: 'Eco-Lodge', icon: 'service' }
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule 
            client:visible 
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats
            }))} 
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard 
              client:visible 
              title="Included Services" 
              items={includes} 
              refCode="SRV-INC" 
              variant="primary" 
            />
            <LogisticsCard 
              client:visible 
              title="Not Included" 
              items={excludes} 
              refCode="SRV-EXC" 
              variant="secondary" 
            />
            <LogisticsCard 
              client:visible 
              title="Suggested Gear" 
              items={equipment} 
              refCode="EQP-INFO" 
              variant="secondary" 
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking 
                client:load 
                tourName="TAMBOPATA & SANDOVAL LAKE 3D" 
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery client:visible 
    lang={lang}
    tourName="Selva Tambopata"
    images={[
      '/slider_4.png',
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="selva-tambopata" client:visible />
</Layout>
