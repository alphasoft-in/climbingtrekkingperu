---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import SuggestedRoutes from '../../../components/SuggestedRoutes';
import TourGallery from '../../../components/TourGallery';
import ItineraryHero from '../../../components/ItineraryHero';
import ItineraryIntro from '../../../components/ItineraryIntro';
import ItinerarySchedule from '../../../components/ItinerarySchedule';
import LogisticsCard from '../../../components/LogisticsCard';
import ItineraryBooking from '../../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: '08:00 AM',
    title: 'DEPARTURE FROM HUARAZ',
    content: 'Pick up from your hotel and heading north through the Huaylas Valley. Brief stop in Carhuaz to enjoy artisanal ice cream.',
    stats: { time: 'Start' }
  },
  {
    day: '10:30 AM',
    title: 'CARAZ & CONTROL POINT',
    content: 'We pass through Caraz "Dulzura" and ascend towards the Paron valley. Registration at the community control.',
    stats: { alt: '2290m' }
  },
  {
    day: '12:00 PM',
    title: 'PARON LAKE (4250M)',
    content: 'Arrival at the largest lake in the Cordillera Blanca. Free time to hike to the viewpoint, boat rides, or kayaking.',
    stats: { alt: '4250m', time: '3-4 h stay' }
  },
  {
    day: '03:30 PM',
    title: 'RETURN & LUNCH',
    content: 'Descent from the valley and strategic stop at a local restaurant for a regional lunch.',
    stats: { time: 'Descent' }
  },
  {
    day: '07:00 PM',
    title: 'ARRIVAL IN HUARAZ',
    content: 'Arrival in Huaraz city and final drop-off at the Main Square. End of services.',
    stats: { time: 'End' }
  }
];

const includes = [
  'Pick up from your hotel in Huaraz',
  'Shared tourist transportation (Round trip)',
  'Official Tour Guide (Bilingual)',
  'First aid kit',
  'Personalized assistance'
];

const excludes = [
  'Meals (Lunch on route)',
  'Community entrance ticket (S/. 5.00)',
  'Boat or kayak services at the lake',
  'Personal expenses and tips'
];

const equipment = [
  'Light jacket and rain poncho',
  'Sun protection (hat, sunscreen, sunglasses)',
  'Comfortable walking shoes',
  'Camera with extra battery',
  'Water and snacks',
  'Extra cash for lunch and tickets'
];
---

<Layout title="Paron Lake Full Day | Huaraz | Franpisco Adventure" description="Explore the largest lake in the Cordillera Blanca. Stunning views of Artesonraju (Paramount Pyramid) and Huandoy.">
  <ItineraryHero 
    client:load
    titleTop="JEWEL OF THE RANGE"
    titleMain="PARON LAKE 4250M"
    backgroundImage="/trekking/blanca/santa-cruz.png"
    duration="FULL DAY (11H)"
    price="CONSULT"
    difficulty="EASY"
    difficultyLevel="easy"
  />

  <ItineraryIntro 
    client:visible
    code="HZ-PAR-FD"
    titlePrefix="Mirror of"
    titleAccent="The Andes"
    description="Paron Lake is considered the most important freshwater reservoir in the Cordillera Blanca. Its intense turquoise color and the amphitheater of snow-capped mountains are unique."
    image="/slider_3.png"
    lat={`09° 00' 00" S`}
    lon={`77° 41' 00" W`}
    specs={[
      { label: 'LOCATION', value: 'Caraz, Ancash', icon: 'location' },
      { label: 'VIEWS', value: 'Artesonraju, Huandoy', icon: 'zone' },
      { label: 'ACTIVITY', value: 'Navigation / Lookout', icon: 'season' },
      { label: 'PUBLIC', value: 'All levels', icon: 'service' }
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule 
            client:visible 
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats
            }))} 
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard 
              client:visible 
              title="What's Included" 
              items={includes} 
              refCode="SRV-INC" 
              variant="primary" 
            />
            <LogisticsCard 
              client:visible 
              title="Not Included" 
              items={excludes} 
              refCode="SRV-EXC" 
              variant="secondary" 
            />
            <LogisticsCard 
              client:visible 
              title="Suggested Gear" 
              items={equipment} 
              refCode="EQP-INFO" 
              variant="secondary" 
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking 
                client:load 
                tourName="PARON LAKE FULL DAY" 
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery client:visible 
    lang={lang}
    tourName="Paron"
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="laguna-paron" client:visible />
</Layout>
