---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import SuggestedRoutes from '../../../components/SuggestedRoutes';
import TourGallery from '../../../components/TourGallery';
import ItineraryHero from '../../../components/ItineraryHero';
import ItineraryIntro from '../../../components/ItineraryIntro';
import ItinerarySchedule from '../../../components/ItinerarySchedule';
import LogisticsCard from '../../../components/LogisticsCard';
import ItineraryBooking from '../../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'MORNING',
    title: 'COMPLETE LIMA CITY TOUR',
    content: 'We begin with the traditional City Tour: Ancestral Lima (Huaca Pucllana), Colonial Lima (Plaza Mayor, San Francisco and Catacombs) and Contemporary Lima (San Isidro and Miraflores). Buffet Lunch included at a tourist restaurant.',
    stats: { alt: 'Historical', dist: 'Urban', time: '4 h' }
  },
  {
    day: 'MIDDAY',
    title: 'BARRANCO & COSTA VERDE',
    content: 'Visit to the bohemian district of Barranco, the Bridge of Sighs and a panoramic tour along the beaches of the Costa Verde, the Friar\'s Leap and the Villa Swamps.',
    stats: { alt: 'Coast', dist: 'Panoramic', time: '1.5 h' }
  },
  {
    day: 'AFTERNOON',
    title: 'PACHACAMAC SANCTUARY',
    content: 'Exploration of the Pachacamac archaeological citadel, ceremonial center of the creator of the universe. Visit to the pyramidal temples, the Temple of the Sun and the Acllahuasi.',
    stats: { alt: 'Archaeological', dist: 'Walking', time: '2.5 h' }
  }
];

const includes = [
  'Pickup and return to your hotel (Miraflores, San Isidro, Lima)',
  'Private tourist transport for the entire tour',
  'Specialized professional bilingual tour guide',
  'Buffet Lunch at a tourist restaurant',
  'Guided visit to San Francisco and Catacombs',
  'Complete excursion to the Pachacamac Sanctuary'
];

const excludes = [
  'Entrance tickets to Pachacamac and Museums',
  'Additional drinks during lunch',
  'Tips for guide and driver',
  'Services not specified'
];

const equipment = [
  'Comfortable walking shoes',
  'Sunscreen and hat',
  'Camera',
  'Bottled water',
  'Light clothing and a jacket for the sea breeze',
  'Original identity document or passport'
];
---

<Layout title="Lima & Pachacamac Full Day | Franpisco Adventure" description="The most complete Lima tour. Combines the classic City Tour with the mystic Pachacamac Sanctuary. 8 hours of history, culture and gastronomy by the sea.">
  <ItineraryHero
    client:load
    titleTop="THE PACIFIC ORACLE"
    titleMain="LIMA & PACHACAMAC 8H"
    backgroundImage="/slider_1.png"
    duration="FULL DAY (8 HOURS)"
    price="UPON REQUEST"
    difficulty="LOW"
    difficultyLevel="easy"
  />

  <ItineraryIntro
    client:visible
    code="LIM-PACH-08H"
    titlePrefix="Between the Oracle"
    titleAccent="and the City"
    description="This is the ultimate experience in the capital. A journey that connects the mysticism of the god Pachacamac with the colonial elegance of Lima. We will travel from the underground crypts of San Francisco to the temples of the Sun."
    image="/slider_3.png"
    lat={`12° 15' 32" S`}
    lon={`76° 54' 00" W`}
    specs={[
      { label: 'DEPARTURES', value: 'Tuesday to Saturday', icon: 'location' },
      { label: 'TEMPLES', value: 'Pachacamac & Sun', icon: 'zone' },
      { label: 'SCHEDULE', value: 'Full Day', icon: 'season' },
      { label: 'INCLUDES', value: 'Buffet Lunch', icon: 'service' }
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule 
            client:visible 
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats
            }))} 
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard 
              client:visible 
              title="What's Included" 
              items={includes} 
              refCode="SRV-INC" 
              variant="primary" 
            />
            <LogisticsCard 
              client:visible 
              title="Not Included" 
              items={excludes} 
              refCode="SRV-EXC" 
              variant="secondary" 
            />
            <LogisticsCard 
              client:visible 
              title="Suggested Gear" 
              items={equipment} 
              refCode="EQP-INFO" 
              variant="secondary" 
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking 
                client:load 
                tourName="LIMA & PACHACAMAC FULL DAY (8H)" 
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery 
    client:visible 
    lang={lang}
    tourName="Lima Pachacamac"
    images={[
      '/slider_1.png',
      '/slider_3.png',
      '/slider_2.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="lima-pachacamac" client:visible />
</Layout>
