---
import Layout from '../../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../../i18n/utils';
import SuggestedRoutes from '../../../components/SuggestedRoutes';
import TourGallery from '../../../components/TourGallery';
import ItineraryHero from '../../../components/ItineraryHero';
import ItineraryIntro from '../../../components/ItineraryIntro';
import ItinerarySchedule from '../../../components/ItinerarySchedule';
import LogisticsCard from '../../../components/LogisticsCard';
import ItineraryBooking from '../../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: '08:00 AM',
    title: 'DEPARTURE FROM HUARAZ',
    content: 'Departure northwards, passing through the historic community of Vicos. Brief stop at the Cashapunta viewpoint.',
    stats: { time: 'Start' }
  },
  {
    day: '10:30 AM',
    title: 'RURIPACCHA',
    content: 'Visit to the Ruripaccha waterfall and observation of ancient cave paintings in the area.',
    stats: { alt: '3800m' }
  },
  {
    day: '12:00 PM',
    title: 'ROCOTUYOC LAKE',
    content: 'Arrival at the main lake. Exploration of the frozen lagoon and views of the Ruripaccha glacier.',
    stats: { alt: '4450m', time: '3h stay' }
  },
  {
    day: '03:30 PM',
    title: 'RETURN & CULTURE',
    content: 'Descent towards Huaraz. Stop to learn more about the Vicos community and its social organization.',
    stats: { time: 'Descent' }
  },
  {
    day: '07:00 PM',
    title: 'ARRIVAL IN HUARAZ',
    content: 'Arrival at the city center. End of services.',
    stats: { time: 'End' }
  }
];

const includes = [
  'Pick up from your hotel in Huaraz',
  'Private/shared tourist transportation',
  'Official Tour Guide (Bilingual)',
  'First aid kit',
  'Personalized assistance'
];

const excludes = [
  'Meals (Lunch on route)',
  'Vicos Community entrance ticket (S/. 10.00)',
  'Travel and accident insurance',
  'Personal expenses'
];

const equipment = [
  'Light jacket and rain poncho',
  'Sun protection (hat, sunblock, glasses)',
  'Comfortable walking shoes',
  'Camera with extra battery',
  'Water bottle and snacks',
  'Cash for lunch and entrance fees'
];
---

<Layout title="Rocotuyoc Lake & Glacier | Huaraz | Franpisco Adventure" description="Discover one of the less conventional routes in Huaraz. Rocotuyoc Lake, cave paintings, and the imposing Ruripaccha glacier.">
  <ItineraryHero
    client:load
    titleTop="ICE & ANCESTRY"
    titleMain="ROCOTUYOC LAKE"
    backgroundImage="/slider_2.png"
    duration="FULL DAY (11H)"
    price="UPON REQUEST"
    difficulty="MODERATE"
    difficultyLevel="moderate"
  />

  <ItineraryIntro
    client:visible
    code="HZ-ROC-FD"
    titlePrefix="The Guardian of"
    titleAccent="the Glacier"
    description="Rocotuyoc Lake is an emerging destination that offers a wilder and more solitary experience. In addition to the deep blue lagoon, the circuit includes a frozen lagoon, ancient cave paintings, and tactile proximity to the Ruripaccha glacier."
    image="/slider_1.png"
    lat={`09° 16' 00" S`}
    lon={`77° 28' 00" W`}
    specs={[
      { label: 'LOCATION', value: 'Vicos, Cordillera Blanca', icon: 'location' },
      { label: 'ATTRACTIONS', value: 'Ice, Cave Paintings', icon: 'zone' },
      { label: 'STATUS', value: 'Scenic Route', icon: 'season' },
      { label: 'PUBLIC', value: 'Adventurers', icon: 'service' }
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule 
            client:visible 
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats
            }))} 
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard 
              client:visible 
              title="What's Included" 
              items={includes} 
              refCode="SRV-INC" 
              variant="primary" 
            />
            <LogisticsCard 
              client:visible 
              title="Not Included" 
              items={excludes} 
              refCode="SRV-EXC" 
              variant="secondary" 
            />
            <LogisticsCard 
              client:visible 
              title="Suggested Gear" 
              items={equipment} 
              refCode="EQP-INFO" 
              variant="secondary" 
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking 
                client:load 
                tourName="ROCOTUYOC LAKE FULL DAY" 
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery 
    client:visible 
    lang={lang}
    tourName="Rocotuyoc"
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="laguna-rocotuyoc" client:visible />
</Layout>
