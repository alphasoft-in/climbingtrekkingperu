---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import TourGallery from '../../components/TourGallery';
import ItineraryHero from '../../components/ItineraryHero';
import ItineraryIntro from '../../components/ItineraryIntro';
import ItinerarySchedule from '../../components/ItinerarySchedule';
import LogisticsCard from '../../components/LogisticsCard';
import ItineraryBooking from '../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: '08:30 AM',
    title: 'SALIDA DE HUARAZ',
    content: 'Partida hacia el sur del Callejón de Huaylas. Pasamos por los pueblos de Recuay y Catac.',
    stats: { time: 'Inicio' }
  },
  {
    day: '10:30 AM',
    title: 'LAGUNA QUEROCOCHA',
    content: 'Parada fotográfica en la laguna Querococha (3980m). Vistas del mapa del Perú formado naturalmente en la montaña.',
    stats: { alt: '3980m' }
  },
  {
    day: '11:30 AM',
    title: 'TÚNEL CAWISH',
    content: 'Cruce de la Cordillera Blanca a través del túnel Cawish. Descenso hacia el Callejón de Conchucos.',
    stats: { alt: '4500m' }
  },
  {
    day: '01:00 PM',
    title: 'COMPLEJO CHAVÍN',
    content: 'Visita guiada al centro ceremonial más antiguo de los Andes. Exploración de plazas, galerías subterráneas y el Lanzón Monolítico.',
    stats: { alt: '3137m', time: '2.5 h estancia' }
  },
  {
    day: '03:30 PM',
    title: 'MUSEO Y ALMUERZO',
    content: 'Visita al Museo Nacional Chavín (opcional) y almuerzo en un restaurante local del pueblo.',
    stats: { time: 'Cultura' }
  },
  {
    day: '07:30 PM',
    title: 'RETORNO A HUARAZ',
    content: 'Llegada a la ciudad tras cruzar nuevamente la cordillera. Fin de servicios.',
    stats: { time: 'Fin' }
  }
];

const includes = [
  'Recojo de su hotel en Huaraz',
  'Transporte turístico equipado',
  'Guía Oficial de Turismo (Especialista)',
  'Asistencia en el sitio arqueológico',
  'Botiquín de primeros auxilios'
];

const excludes = [
  'Alimentación (Almuerzo regional)',
  'Ticket de entrada al sitio (S/. 15.00)',
  'Ticket de entrada al museo',
  'Gastos personales'
];

const equipment = [
  'Calzado cómodo para caminar',
  'Protección solar (gorro, bloqueador)',
  'Casaca ligera y poncho de lluvia',
  'Cámara fotográfica con batería extra',
  'Medicamentos personales',
  'Efectivo extra para almuerzo y tickets'
];
---

<Layout title="Chavín de Huántar Full Day | Ancash | Franpisco Adventure" description="Explora el origen de la cultura andina. Visita el milenario centro ceremonial de Chavín de Huántar, sus galerías y el Lanzón Monolítico.">
  <ItineraryHero 
    client:load
    titleTop="EL CENTRO DEL MUNDO"
    titleMain="CHAVÍN DE HUÁNTAR"
    backgroundImage="/slider_1.png"
    duration="FULL DAY (11H)"
    price="CONSULTAR"
    difficulty="FÁCIL"
    difficultyLevel="easy"
  />

  <ItineraryIntro 
    client:visible
    code="HZ-CHA-FD"
    titlePrefix="Arquitectura del"
    titleAccent="Misterio"
    description="Chavín de Huántar es uno de los sitios arqueológicos más importantes de América. Considerado el primer centro de integración andina, sus impresionantes estructuras de piedra y galerías son únicas."
    image="/slider_2.png"
    lat={`09° 35' 33" S`}
    lon={`77° 10' 42" W`}
    specs={[
      { label: 'LOCALIZACIÓN', value: 'Callejón de Conchucos', icon: 'location' },
      { label: 'ESCULTURA', value: 'Lanzón Monolítico', icon: 'zone' },
      { label: 'STATUS', value: 'Patrimonio UNESCO', icon: 'season' },
      { label: 'PÚBLICO', value: 'Familiar / Cultural', icon: 'service' }
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule 
            client:visible 
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats
            }))} 
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard 
              client:visible 
              title="Qué Incluye" 
              items={includes} 
              refCode="SRV-INC" 
              variant="primary" 
            />
            <LogisticsCard 
              client:visible 
              title="No Incluye" 
              items={excludes} 
              refCode="SRV-EXC" 
              variant="secondary" 
            />
            <LogisticsCard 
              client:visible 
              title="Equipo Sugerido" 
              items={equipment} 
              refCode="EQP-INFO" 
              variant="secondary" 
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking 
                client:load 
                tourName="CHAVÍN DE HUÁNTAR FULL DAY" 
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery client:visible 
    lang={lang}
    tourName="Chavin de Huantar"
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="chavin-huantar" client:visible />
</Layout>
