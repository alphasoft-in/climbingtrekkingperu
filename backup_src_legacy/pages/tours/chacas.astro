---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import TourGallery from '../../components/TourGallery';
import ItineraryHero from '../../components/ItineraryHero';
import ItineraryIntro from '../../components/ItineraryIntro';
import ItinerarySchedule from '../../components/ItinerarySchedule';
import LogisticsCard from '../../components/LogisticsCard';
import ItineraryBooking from '../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: '07:30 AM',
    title: 'SALIDA DE HUARAZ',
    content: 'Partida hacia Carhuaz y ascenso por el valle de Ulta. Vistas panorámicas del Huascarán.',
    stats: { time: 'Inicio' }
  },
  {
    day: '10:00 AM',
    title: 'PUNTA OLÍMPICA',
    content: 'Cruce del túnel transandino más alto del mundo (4736m). Parada para ver el glaciar Contrahierbas.',
    stats: { alt: '4736m' }
  },
  {
    day: '12:00 PM',
    title: 'LLEGADA A CHACAS',
    content: 'Visita al pintoresco pueblo de Chacas. Conocido por sus tallados en madera de la escuela Don Bosco.',
    stats: { alt: '3360m', time: 'Cultura' }
  },
  {
    day: '01:30 PM',
    title: 'TALLERES DON BOSCO',
    content: 'Visita a los talleres de carpintería y la iglesia matriz con su retablo restaurado en pan de oro.',
    stats: { time: 'Arte' }
  },
  {
    day: '03:30 PM',
    title: 'RETORNO POR ULTA',
    content: 'Viaje de regreso a Huaraz disfrutando nuevamente de los paisajes de alta montaña.',
    stats: { time: 'Descenso' }
  },
  {
    day: '07:30 PM',
    title: 'LLEGADA A HUARAZ',
    content: 'Arribo al centro de la ciudad. Fin de servicios.',
    stats: { time: 'Fin' }
  }
];

const includes = [
  'Recojo de su hotel en Huaraz',
  'Transporte turístico privado/compartido',
  'Guía Oficial de Turismo (Bilingüe)',
  'Botiquín de primeros auxilios',
  'Asistencia personalizada'
];

const excludes = [
  'Alimentación (Almuerzo regional)',
  'Propinas',
  'Seguro de viaje',
  'Gastos personales'
];

const equipment = [
  'Calzado cómodo',
  'Ropa de abrigo y cortavientos',
  'Protección solar (gorro, bloqueador)',
  'Cámara fotográfica',
  'Agua y snacks',
  'Efectivo para almuerzo y compras'
];
---

<Layout title="Chacas & Punta Olímpica Full Day | Ancash | Franpisco Adventure" description="Cruza el túnel transandino más alto del mundo y descubre la belleza artística y espiritual de Chacas y los talleres Don Bosco.">
  <ItineraryHero 
    client:load
    titleTop="ARTE Y MONTAÑAS"
    titleMain="CHACAS & PUNTA OLÍMPICA"
    backgroundImage="/slider_4.png"
    duration="FULL DAY (12H)"
    price="CONSULTAR"
    difficulty="FÁCIL"
    difficultyLevel="easy"
  />

  <ItineraryIntro 
    client:visible
    code="HZ-CHS-FD"
    titlePrefix="El Refugio del"
    titleAccent="Tallador"
    description="Chacas no es solo un pueblo; es una obra de arte viva. Ubicado al otro lado de la Cordillera Blanca, combina el vértigo de Punta Olímpica con la paz de una comunidad dedicada al arte."
    image="/slider_3.png"
    lat={`09° 09' 00" S`}
    lon={`77° 22' 00" W`}
    specs={[
      { label: 'LOCALIZACIÓN', value: 'Valle de Conchucos', icon: 'location' },
      { label: 'ATRACCIÓN', value: 'Artesanía Don Bosco', icon: 'zone' },
      { label: 'INFRAESTRUCTURA', value: 'Túnel Transandino', icon: 'season' },
      { label: 'PAISAJE', value: 'Glaciares y Valles', icon: 'service' }
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule 
            client:visible 
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats
            }))} 
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard 
              client:visible 
              title="Qué Incluye" 
              items={includes} 
              refCode="SRV-INC" 
              variant="primary" 
            />
            <LogisticsCard 
              client:visible 
              title="No Incluye" 
              items={excludes} 
              refCode="SRV-EXC" 
              variant="secondary" 
            />
            <LogisticsCard 
              client:visible 
              title="Equipo Sugerido" 
              items={equipment} 
              refCode="EQP-INFO" 
              variant="secondary" 
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking 
                client:load 
                tourName="CHACAS & PUNTA OLÍMPICA FULL DAY" 
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery client:visible 
    lang={lang}
    tourName="Chacas"
    images={[
      '/slider_4.png',
      '/slider_3.png',
      '/slider_2.png',
      '/slider_1.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="chacas" client:visible />
</Layout>
