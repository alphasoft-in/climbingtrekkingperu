---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import TourGallery from '../../components/TourGallery';
import ItineraryHero from '../../components/ItineraryHero';
import ItineraryIntro from '../../components/ItineraryIntro';
import ItinerarySchedule from '../../components/ItinerarySchedule';
import LogisticsCard from '../../components/LogisticsCard';
import ItineraryBooking from '../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: '08:00 AM',
    title: 'SALIDA DE HUARAZ',
    content: 'Partida desde su hotel con dirección al norte del Callejón de Huaylas. Breve parada en Carhuaz para disfrutar de los helados artesanales.',
    stats: { time: 'Inicio' }
  },
  {
    day: '10:30 AM',
    title: 'CARAZ Y CONTROL',
    content: 'Pasamos por Caraz "Dulzura" y ascendemos hacia la quebrada Parón. Registro en el control de la comunidad Cruz de Mayo.',
    stats: { alt: '2290m' }
  },
  {
    day: '12:00 PM',
    title: 'LAGUNA PARÓN (4250 MSNM)',
    content: 'Arribo a la laguna más grande de la Cordillera Blanca. Tiempo libre para caminar hacia el mirador, paseos en bote o kayak.',
    stats: { alt: '4250m', time: '3-4 h estancia' }
  },
  {
    day: '03:30 PM',
    title: 'RETORNO Y ALMUERZO',
    content: 'Descenso de la quebrada y parada estratégica en un recreo campestre para el almuerzo regional.',
    stats: { time: 'Descenso' }
  },
  {
    day: '07:00 PM',
    title: 'ARRIBO A HUARAZ',
    content: 'Llegada a la ciudad de Huaraz y última parada en la Plaza de Armas. Fin de servicios.',
    stats: { time: 'Fin' }
  }
];

const includes = [
  'Recojo de su hotel en Huaraz',
  'Transporte turístico compartido (I/V)',
  'Guía Oficial de Turismo (Bilingüe)',
  'Botiquín de primeros auxilios',
  'Asistencia personalizada'
];

const excludes = [
  'Alimentación (Almuerzo en ruta)',
  'Ticket de entrada Comunidad (S/. 5.00)',
  'Servicios de bote o kayak en la laguna',
  'Gastos personales y propinas'
];

const equipment = [
  'Casaca ligera y poncho de lluvia',
  'Protección solar (gorro, bloqueador, lentes)',
  'Calzado cómodo para caminata',
  'Cámara fotográfica con batería extra',
  'Agua y snacks',
  'Efectivo para almuerzo y tickets'
];
---

<Layout title="Laguna Parón Full Day | Huaraz | Franpisco Adventure" description="Explora la laguna más grande de la Cordillera Blanca. Vistas impresionantes del Artesonraju (Pirámide de Paramount) y el Huandoy.">
  <ItineraryHero 
    client:load
    titleTop="LA JOYA DE LA CORDILLERA"
    titleMain="LAGUNA PARÓN 4250M"
    backgroundImage="/trekking/blanca/santa-cruz.png"
    duration="FULL DAY (11H)"
    price="CONSULTAR"
    difficulty="FÁCIL"
    difficultyLevel="easy"
  />

  <ItineraryIntro 
    client:visible
    code="HZ-PAR-FD"
    titlePrefix="El Espejo de"
    titleAccent="Los Andes"
    description="La Laguna Parón es considerada el depósito de agua dulce más importante de la Cordillera Blanca. Su color turquesa intenso y el anfiteatro de montañas nevadas son únicos."
    image="/slider_3.png"
    lat={`09° 00' 00" S`}
    lon={`77° 41' 00" W`}
    specs={[
      { label: 'LOCALIZACIÓN', value: 'Caraz, Ancash', icon: 'location' },
      { label: 'VISTAS', value: 'Artesonraju, Huandoy', icon: 'zone' },
      { label: 'ACTIVIDAD', value: 'Navegación / Mirador', icon: 'season' },
      { label: 'PÚBLICO', value: 'Todo nivel', icon: 'service' }
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule 
            client:visible 
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats
            }))} 
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard 
              client:visible 
              title="Qué Incluye" 
              items={includes} 
              refCode="SRV-INC" 
              variant="primary" 
            />
            <LogisticsCard 
              client:visible 
              title="No Incluye" 
              items={excludes} 
              refCode="SRV-EXC" 
              variant="secondary" 
            />
            <LogisticsCard 
              client:visible 
              title="Equipo Sugerido" 
              items={equipment} 
              refCode="EQP-INFO" 
              variant="secondary" 
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking 
                client:load 
                tourName="LAGUNA PARÓN FULL DAY" 
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery client:visible 
    lang={lang}
    tourName="Paron"
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="laguna-paron" client:visible />
</Layout>
