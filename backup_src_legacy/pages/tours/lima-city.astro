---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import TourGallery from '../../components/TourGallery';
import ItineraryHero from '../../components/ItineraryHero';
import ItineraryIntro from '../../components/ItineraryIntro';
import ItinerarySchedule from '../../components/ItinerarySchedule';
import LogisticsCard from '../../components/LogisticsCard';
import ItineraryBooking from '../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'ANCESTRAL',
    title: 'HUACA PUCLLANA',
    content: 'Iniciamos con una vista panorámica de la Huaca Pucllana, un magnífico centro ceremonial y arqueológico del siglo IV D.C. construido en adobe, considerado un pueblo sagrado por los Incas.',
    stats: { alt: 'Nivel del mar', dist: 'Panorámica', time: '45 min' }
  },
  {
    day: 'COLONIAL',
    title: 'CENTRO HISTÓRICO Y CATACUMBAS',
    content: 'Recorrido por el Centro Histórico de Lima: Plaza Mayor, Palacio de Gobierno, Catedral y Palacio Municipal. Visita al Convento de San Francisco y sus famosas criptas subterráneas (Catacumbas).',
    stats: { alt: 'Histórico', dist: 'Caminata', time: '2 h' }
  },
  {
    day: 'MODERNA',
    title: 'SAN ISIDRO Y MIRAFLORES',
    content: 'Visita a las zonas residenciales tradicionales: El Olivar de San Isidro y el Parque del Amor en Miraflores, con una vista espectacular del Océano Pacífico.',
    stats: { alt: 'Costa', dist: 'Transporte', time: '1 h' }
  }
];

const includes = [
  'Recojo desde su hotel (Miraflores, San Isidro, Lima)',
  'Transporte turístico con aire acondicionado',
  'Guía oficial de turismo bilingüe',
  'Visita guiada a San Francisco y Catacumbas',
  'Retorno a su hotel al finalizar el tour'
];

const excludes = [
  'Tickets de entrada a sitios turísticos',
  'Alimentación y bebidas',
  'Propinas para guía y conductor',
  'Gastos personales'
];

const equipment = [
  'Calzado cómodo para caminar',
  'Bloqueador solar y lentes de sol',
  'Cámara fotográfica con batería extra',
  'Agua embotellada',
  'Casaca ligera (Lima puede ser nublada)',
  'Efectivo extra para compras personales'
];
---

<Layout title="City Tour Lima Clásico | Franpisco Adventure" description="Explora Lima en sus tres etapas: Ancestral, Colonial y Contemporánea. Un recorrido de 4 horas por los puntos más emblemáticos de la capital peruana.">
  <ItineraryHero 
    client:load
    titleTop="CIUDAD DE LOS REYES"
    titleMain="LIMA CITY TOUR 4H"
    backgroundImage="/slider_3.png"
    duration="4 HORAS APROX"
    price="CONSULTAR"
    difficulty="EASY"
    difficultyLevel="easy"
  />

  <ItineraryIntro 
    client:visible
    code="LIM-CTY-04H"
    titlePrefix="Tres Eras en una"
    titleAccent="Sola Ciudad"
    description="Lima es una metrópoli que respira historia en cada esquina. Este recorrido optimizado de 4 horas te permite contrastar la Lima Ancestral de los oráculos de adobe, la Lima Colonial del virreinato más importante de América, y la Lima Contemporánea."
    image="/slider_1.png"
    lat={`12° 02' 35" S`}
    lon={`77° 01' 42" W`}
    specs={[
      { label: 'SALIDAS', value: 'Diarias (AM/PM)', icon: 'location' },
      { label: 'HISTORIA', value: 'Ancestral & Colonial', icon: 'zone' },
      { label: 'DURACIÓN', value: '4 Horas', icon: 'season' },
      { label: 'MODALIDAD', value: 'Compartido / Privado', icon: 'service' }
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule 
            client:visible 
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats
            }))} 
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard 
              client:visible 
              title="Servicios Incluidos" 
              items={includes} 
              refCode="SRV-INC" 
              variant="primary" 
            />
            <LogisticsCard 
              client:visible 
              title="No Incluye" 
              items={excludes} 
              refCode="SRV-EXC" 
              variant="secondary" 
            />
            <LogisticsCard 
              client:visible 
              title="Equipo Sugerido" 
              items={equipment} 
              refCode="EQP-INFO" 
              variant="secondary" 
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking 
                client:load 
                tourName="LIMA CITY TOUR (4H)" 
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery client:visible 
    lang={lang}
    tourName="Lima City Tour"
    images={[
      '/slider_3.png',
      '/slider_1.png',
      '/slider_2.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="lima-city" client:visible />
</Layout>
