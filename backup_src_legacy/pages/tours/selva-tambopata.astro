---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import TourGallery from '../../components/TourGallery';
import ItineraryHero from '../../components/ItineraryHero';
import ItineraryIntro from '../../components/ItineraryIntro';
import ItinerarySchedule from '../../components/ItinerarySchedule';
import LogisticsCard from '../../components/LogisticsCard';
import ItineraryBooking from '../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DÍA 01',
    title: 'PUERTO MALDONADO – MADRE DE DIOS – ISLA DE MONOS',
    content: 'Recepción y navegación por el río Madre de Dios. Caminata por la selva para observar árboles milenarios y vida silvestre. Tarde de Kayak y visita a la Isla de los Monos Capuchinos. Paseo nocturno buscando caimanes.',
    stats: { alt: '183m', dist: 'Fluvial', time: '8-10 h' }
  },
  {
    day: 'DÍA 02',
    title: 'LAGO SANDOVAL – RESERVA TAMBOPATA',
    content: 'Exploración del Lago Sandoval, uno de los más biodiversos del mundo. Observación de nutrias gigantes, caimanes negros y aves prehistóricas (Shansho). Pesca deportiva de pirañas y caminata nocturna por la sinfonía de la selva.',
    stats: { alt: 'Selva Baja', dist: 'Trekking/Canoa', time: '12 h' }
  },
  {
    day: 'DÍA 03',
    title: 'TROCHA DEL TAPIR – RETORNO',
    content: 'Caminata por el sendero del Tapir y exploración de los aguajales (pantanos). Observación de rastros de grandes mamíferos y aves oropéndolas. Retorno a la ciudad de Puerto Maldonado.',
    stats: { alt: 'Húmedo', dist: 'Trekking', time: '5-6 h' }
  }
];

const includes = [
  'Traslados Aeropuerto - Puerto - Lodge',
  'Alojamiento en el corazón de la selva',
  'Alimentación completa (Opción Veg/Vgn)',
  'Guía local experto en Amazonía',
  'Transporte fluvial (Peque-peque)',
  'Entradas a la Reserva Nacional Tambopata',
  'Equipos para Kayak y Pesca',
  'Botas de caucho para caminatas'
];

const excludes = [
  'Vuelos Lima - Puerto Maldonado - Lima',
  'Bebidas adicionales del bar',
  'Propinas para el personal',
  'Primer desayuno del día 1'
];

const equipment = [
  'Ropa ligera y de secado rápido',
  'Repelente con 50% DEET',
  'Sombrero y lentes con protección UV',
  'Linterna de mano o frontal con pilas',
  'Kit de aseo personal',
  'Impermeable o poncho de lluvia',
  'Binoculares (opcional)'
];
---

<Layout title="Selva Amazónica: Tambopata y Lago Sandoval | Franpisco Adventure" description="Sumérgete en la Amazonía peruana. Expedición de 3 días a Puerto Maldonado, Reserva Tambopata y el místico Lago Sandoval. Naturaleza pura y biodiversidad extrema.">
  <ItineraryHero 
    client:load
    titleTop="PUERTO MALDONADO"
    titleMain="TAMBOPATA & SANDOVAL 3D"
    backgroundImage="/slider_4.png"
    duration="3 DÍAS / 2 NOCHES"
    price="CONSULTAR"
    difficulty="BAJA"
    difficultyLevel="easy"
  />

  <ItineraryIntro 
    client:visible
    code="MDD-TAM-03D"
    titlePrefix="El Pulmón de"
    titleAccent="Madre de Dios"
    description="Puerto Maldonado es la puerta de entrada a uno de los ecosistemas más vibrantes del planeta. Esta expedición te lleva al corazón de la Reserva Nacional Tambopata y al Lago Sandoval, un espejo de agua prístino rodeado de palmeras milenarias."
    image="/slider_1.png"
    lat={`12° 35' 39" S`}
    lon={`69° 10' 48" W`}
    specs={[
      { label: 'REGIÓN', value: 'Madre de Dios', icon: 'location' },
      { label: 'RESERVAS', value: 'Tambopata y Sandoval', icon: 'zone' },
      { label: 'ECOSISTEMA', value: 'Selva Baja', icon: 'season' },
      { label: 'LOGÍSTICA', value: 'Lodge Ecológico', icon: 'service' }
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule 
            client:visible 
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats
            }))} 
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard 
              client:visible 
              title="Servicios Incluidos" 
              items={includes} 
              refCode="SRV-INC" 
              variant="primary" 
            />
            <LogisticsCard 
              client:visible 
              title="No Incluye" 
              items={excludes} 
              refCode="SRV-EXC" 
              variant="secondary" 
            />
            <LogisticsCard 
              client:visible 
              title="Equipo Sugerido" 
              items={equipment} 
              refCode="EQP-INFO" 
              variant="secondary" 
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking 
                client:load 
                tourName="TAMBOPATA & SANDOVAL LAKE 3D" 
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery client:visible 
    lang={lang}
    tourName="Selva Tambopata"
    images={[
      '/slider_4.png',
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="selva-tambopata" client:visible />
</Layout>
