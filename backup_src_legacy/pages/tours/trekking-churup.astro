---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import TourGallery from '../../components/TourGallery';
import ItineraryHero from '../../components/ItineraryHero';
import ItineraryIntro from '../../components/ItineraryIntro';
import ItinerarySchedule from '../../components/ItinerarySchedule';
import LogisticsCard from '../../components/LogisticsCard';
import ItineraryBooking from '../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: '07:30 AM',
    title: 'SALIDA DE HUARAZ',
    content: 'Partida hacia el este de la ciudad hasta el pueblo de Pitec (3850m). Punto de inicio del trekking.',
    stats: { time: 'Inicio' }
  },
  {
    day: '08:30 AM',
    title: 'PITEC - ASCENSO',
    content: 'Inicio de la caminata. Sendero con pendiente pronunciada que ofrece vistas increíbles de la ciudad y el Huamashraju.',
    stats: { alt: '3850m' }
  },
  {
    day: '10:30 AM',
    title: 'ZONA DE CUERDAS',
    content: 'Superación del tramo técnico con cuerdas fijas (opcional) para alcanzar la parte alta de la morrena.',
    stats: { dist: 'Tramo Técnico' }
  },
  {
    day: '11:30 AM',
    title: 'LAGUNA CHURUP (4450 MSNM)',
    content: 'Arribo a la laguna "de los siete colores". Tiempo para relax, fotos y almuerzo frente al nevado Churup.',
    stats: { alt: '4450m', time: '1.5 h estancia' }
  },
  {
    day: '02:00 PM',
    title: 'DESCENSO A PITEC',
    content: 'Regreso por el mismo sendero con precaución en los tramos empinados.',
    stats: { time: 'Descenso' }
  },
  {
    day: '04:30 PM',
    title: 'RETORNO A HUARAZ',
    content: 'Llegada a la ciudad. Fin de la aventura.',
    stats: { time: 'Fin' }
  }
];

const includes = [
  'Recojo de su hotel en Huaraz',
  'Transporte turístico privado/compartido',
  'Guía Oficial de Turismo (Bilingüe)',
  'Botiquín de primeros auxilios',
  'Asistencia personalizada'
];

const excludes = [
  'Alimentación (Box lunch recomendado)',
  'Ticket de entrada PNH (S/. 10.00 diario)',
  'Seguro de viaje personal',
  'Gastos personales'
];

const equipment = [
  'Calzado de montaña (obligatorio)',
  'Mochila pequeña (20-30L)',
  '2L de agua y snacks',
  'Casaca cortaviento y polar',
  'Protección solar (gorro, lentes, bloqueador)',
  'Poncho de lluvia'
];
---

<Layout title="Trekking Laguna Churup | Huaraz | Franpisco Adventure" description="La caminata de aclimatación ideal. Asciende a los 4450m y descubre la laguna Churup a los pies de su nevado homónimo.">
  <ItineraryHero 
    client:load
    titleTop="LA LAGUNA DE CRISTAL"
    titleMain="TREKKING CHURUP 4450M"
    backgroundImage="/slider_2.png"
    duration="FULL DAY (8H)"
    price="CONSULTAR"
    difficulty="MODERADA+"
    difficultyLevel="modplus"
  />

  <ItineraryIntro 
    client:visible
    code="HZ-CHU-FD"
    titlePrefix="El Ojo de la"
    titleAccent="Montaña"
    description="Laguna Churup es la ruta preferida para quienes buscan un desafío físico cercano a Huaraz. Con sus aguas de tonos turquesas, es una experiencia completa."
    image="/slider_3.png"
    lat={`09° 29' 00" S`}
    lon={`77° 24' 00" W`}
    specs={[
      { label: 'DISTANCIA', value: '7 KM (I/V)', icon: 'location' },
      { label: 'GRADIENTE', value: '+600m Ascenso', icon: 'zone' },
      { label: 'MARCHA', value: '4 - 5 Horas', icon: 'season' },
      { label: 'REQUISITO', value: 'Aclimatación Básica', icon: 'service' }
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule 
            client:visible 
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats
            }))} 
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard 
              client:visible 
              title="Qué Incluye" 
              items={includes} 
              refCode="SRV-INC" 
              variant="primary" 
            />
            <LogisticsCard 
              client:visible 
              title="No Incluye" 
              items={excludes} 
              refCode="SRV-EXC" 
              variant="secondary" 
            />
            <LogisticsCard 
              client:visible 
              title="Equipo Sugerido" 
              items={equipment} 
              refCode="EQP-INFO" 
              variant="secondary" 
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking 
                client:load 
                tourName="TREKKING LAGUNA CHURUP FULL DAY" 
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery client:visible 
    lang={lang}
    tourName="Churup"
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="trekking-churup" client:visible />
</Layout>
