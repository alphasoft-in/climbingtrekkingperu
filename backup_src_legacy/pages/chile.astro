---
import Layout from '../layouts/Layout.astro';
import SuggestedRoutes from '../components/SuggestedRoutes';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../i18n/utils';
import TourCard from '../components/TourCard';
import PageHero from '../components/PageHero';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const chilePrograms = [
  {
    id: 'ojos-del-salado',
    title: t('climbing.ojos_salado.name'),
    description: t('climbing.ojos_salado.desc'),
    image: '/slider_5.png',
    duration: `13 ${t('trekking.days')}`,
    difficulty: t('trekking.diff.hard'),
    difficultyLevel: 'hard' as const,
    prefix: 'CHI',
    category: 'EXPEDICIÓN DE VOLCANES'
  }
];
---

<Layout title={`Chile - ${t('nav.destinations')} | Franpisco Adventure`} description="Descubre el Volcán Ojos del Salado en Chile, el volcán más alto del mundo. Expediciones extremas en el desierto de Atacama con guías expertos.">
  <PageHero 
    client:load
    titleTop="DESTINOS"
    titleMain="CHILE"
    backgroundImage="/slider_5.png"
    techData={[
      { label: "ELEVACIÓN MÁX", value: "6,893 M.S.N.M." },
      { label: "COORDENADAS", value: "22°33′S 67°51′W" },
      { label: "REGIÓN", value: "ANDES / CHILE" }
    ]}
  />

  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
        {chilePrograms.map((prog) => (
          <TourCard 
            client:visible
            id={prog.id}
            title={prog.title}
            description={prog.description}
            image={prog.image}
            duration={prog.duration}
            difficulty={prog.difficulty}
            difficultyLevel={prog.difficultyLevel}
            href={getRelativeLocaleUrl(lang, `chile/${prog.id}`)}
            prefix={prog.prefix}
            category={prog.category}
            lang={lang as 'es' | 'en'}
          />
        ))}
      </div>
    </div>
  </section>

  <SuggestedRoutes lang={lang} currentId="chile-hub" client:visible />
</Layout>
