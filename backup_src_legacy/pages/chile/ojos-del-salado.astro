---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import TourGallery from '../../components/TourGallery';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DÍA 01',
    title: 'LLEGADA A SANTIAGO - COPIAPÓ',
    content: 'Recepción en Copiapó (vía aérea o terrestre desde Santiago). Traslado al hotel y descanso.',
    stats: { alt: '391m' }
  },
  {
    day: 'DÍA 02',
    title: 'DÍA LIBRE EN COPIAPÓ',
    content: 'Día de preparación, revisión de equipo técnico y última logística antes de internarnos en el desierto de Atacama.',
    stats: { status: 'Logistics' }
  },
  {
    day: 'DÍA 03',
    title: 'COPIAPÓ – LAGUNA SANTA ROSA (3800 M)',
    content: 'Traslado en 4x4 al altiplano. Primer campamento junto a la laguna. Aclimatación suave con vistas de flamencos y volcanes.',
    stats: { time: '4h Drive', alt: '3800m' }
  },
  {
    day: 'DÍA 04',
    title: 'LAGUNA SANTA ROSA – LAGUNA VERDE (4350 M)',
    content: 'Continuamos hacia Laguna Verde. Campamento cerca de aguas termales naturales. Paisajes surrealistas de color turquesa.',
    stats: { time: '3h Drive', alt: '4350m' }
  },
  {
    day: 'DÍA 05',
    title: 'CUMBRE VOLCÁN MULAS MUERTAS (5897 M)',
    content: 'Ascensión de aclimatación activa. Una cumbre de casi 6000m para preparar el cuerpo para la altitud extrema. Retorno a Laguna Verde.',
    stats: { time: '6-7h Ascent', alt: '5897m' }
  },
  {
    day: 'DÍA 06',
    title: 'LAGUNA VERDE – REFUGIO ATACAMA (5250 M)',
    content: 'Traslado al campo base alto. Establecimiento del campamento en el Refugio Atacama.',
    stats: { time: '4h Drive', alt: '5250m' }
  },
  {
    day: 'DÍA 07',
    title: 'REFUGIO ATACAMA – TEJOS (PORTEO)',
    content: 'Caminata de porteo de equipo al Refugio Tejos (5800m) y retorno a Atacama para dormir. Mejora la aclimatación.',
    stats: { time: '5h Day', alt: '5800m' }
  },
  {
    day: 'DÍA 08',
    title: 'ESTABLECIMIENTO EN REFUGIO TEJOS (5800 M)',
    content: 'Ascenso final al Refugio Tejos para pernoctar. Preparación táctica para el ataque a la cumbre.',
    stats: { time: '3h Ascent', alt: '5800m' }
  },
  {
    day: 'DÍA 09',
    title: 'DÍA EXTRA / FLEXIBLE',
    content: 'Día de reserva para mal tiempo o refuerzo de aclimatación. Crucial para el éxito en esta altitud.',
    stats: { status: 'Flexible' }
  },
  {
    day: 'DÍA 10',
    title: 'CUMBRE OJOS DEL SALADO (6893 M)',
    content: 'Ataque a la cumbre del volcán más alto del mundo. Escalada técnica final en el cráter. El techo de Chile alcanzado. Descenso a Atacama.',
    stats: { time: '14h Day', alt: '6893m' }
  },
  {
    day: 'DÍA 11',
    title: 'REFUGIO ATACAMA – COPIAPÓ',
    content: 'Largo descenso en 4x4 desde el altiplano de regreso a la civilización. Noche en hotel en Copiapó.',
    stats: { time: '8h Drive', alt: '391m' }
  },
  {
    day: 'DÍA 12',
    title: 'COPIAPÓ – SANTIAGO',
    content: 'Traslado al aeropuerto o terminal para el retorno a Santiago.',
    stats: { status: 'Transfer' }
  },
  {
    day: 'DÍA 13',
    title: 'SANTIAGO – VUELO INTERNACIONAL',
    content: 'Fin de los servicios. Vuelo de retorno a su país de origen.',
    stats: { status: 'Departure' }
  }
];

const includes = [
  'Traslados Aeropuerto/Terminal - Hotel en Copiapó',
  '2 noches de hotel en Copiapó con desayuno',
  'Transporte privado 4x4 durante toda la expedición',
  'Guía de Montaña Profesional Certificado',
  'Alimentación completa durante la expedición',
  'Equipos de campamento (Carpas, cocina, gas)',
  'Permisos de ascensión y acceso al Parque Nacional',
  'Oxígeno de emergencia y comunicaciones satelitales',
  'Botiquín de primeros auxilios avanzado'
];

const excludes = [
  'Vuelos internacionales y domésticos (Santiago - Copiapó)',
  'Seguro de montaña obligatorio (con rescate)',
  'Equipo técnico personal (Saco de dormir, botas, etc.)',
  'Gastos personales y propinas',
  'Hoteles y comidas en Santiago'
];

const equipment = [
  'Saco de dormir de alta montaña (-30°C)',
  'Botas dobles o triples para 7000m',
  'Grampones de 12 puntas y Piolet (según temporada)',
  'Arnés de montaña y Casco',
  'Ropa técnica extrema (Gore-Tex, Pluma pesada)',
  'Guantes de expedición y mitones de pluma',
  'Gafas de ventisca y sol (Cat. 4)',
  'Mochila de expedición (70L) y mochila de ataque (40L)',
  'Termos de acero inoxidable'
];
---

<Layout title="Expedición Ojos del Salado 6893m | Chile | Franpisco Adventure" description="Conquista el volcán más alto del mundo: Ojos del Salado (6893m) en Chile. Expedición extrema de 13 días con logística 4x4 de élite.">
  <section class="itinerary-hero chile-ojos">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <h1 class="split-title">
          <span class="thin">THE WORLD'S HIGHEST VOLCANO</span>
          <span class="bold">OJOS DEL SALADO 6893M</span>
        </h1>
        <div class="hero-accent-bar"></div>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURACIÓN</span>
            <span class="m-value">13 DÍAS</span>
          </div>
          <div class="metric">
            <span class="m-label">ALTITUD MÁX</span>
            <span class="m-value">6,893 MSNM</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFICULTAD</span>
            <span class="m-value">
              <span class="dif-tag hard">EXTREMA / ALTA MONTAÑA</span>
            </span>
          </div>
          <div class="metric">
            <span class="m-label">COSTO</span>
            <span class="m-value">USD 4,950.00</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">EXPEDITION DOSSIER</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">CÓDIGO: CHI-OJS-13</span>
            <h2 class="dossier-title">El Gigante del <span class="blue">Atacama</span></h2>
          </div>
          
          <p class="dossier-p">El Volcán Ojos del Salado, con sus imponentes 6893 metros, ostenta el título del volcán más alto del mundo y la segunda cumbre más elevada de América. Ubicado en el corazón del Desierto de Atacama, es un desafío de aislamiento absoluto y condiciones extremas.</p>
          <p class="dossier-p">Nuestra expedición de 13 días utiliza una estrategia de aclimatación progresiva, campamentos tácticos cerca de aguas termales y apoyo logístico 4x4 integral. Es una prueba de resistencia física y mental en uno de los paisajes más surrealistas y hermosos del planeta.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">PUNTO PARTIDA</span>
                <span class="d-value">Copiapó, Chile</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">ACTIVIDAD</span>
                <span class="d-value">Expedición 6000+</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">TEMPORADA</span>
                <span class="d-value">Octubre - Abril</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">DIFICULTAD</span>
                <span class="d-value">Física Extrema</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/slider_5.png" alt="Ojos del Salado Summit" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>27° 06' 34" S</span>
              <span class="divider">|</span>
              <span>68° 32' 32" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">ITINERARIO DE EXPEDICIÓN</span>
            <h2 class="technical-title">Itinerario <span class="blue">de 13 Días</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">MSNM</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.time && (
                        <div class="w-stat">
                          <span class="w-s-label">DURACIÓN</span>
                          <span class="w-s-value">{item.stats.time}</span>
                        </div>
                      )}
                      {item.stats.status && (
                        <div class="w-stat">
                          <span class="w-s-label">TIPO</span>
                          <span class="w-s-value">{item.stats.status}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">REF: SRV-INC</span>
              <h3>Servicios Incluidos</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="logistics-card secondary">
            <div class="card-header">
              <span class="c-id">REF: EQP-GEAR</span>
              <h3>Equipo Requerido</h3>
            </div>
            <ul class="log-list">
              {equipment.map(item => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon-blue"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">ULTIMATE MISSION</span>
              <h3>Reserva tu Expedición</h3>
              <p>Conquista el volcán más alto del mundo con el equipo de Franpisco Adventure. Logística de élite para un desafío extremo.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">FECHA ESTIMADA</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">NOMBRE COMPLETO</label>
                    <input type="text" id="full-name" placeholder="Tu nombre" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  {t('trekking.book')}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery 
    lang={lang}
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang as 'es' | 'en'} currentId="ojos-del-salado" client:visible />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "EXPEDICIÓN VOLCÁN OJOS DEL SALADO 6893M - CHILE";
    
    const message = `¡Hola Franpisco Adventure! Deseo reservar cupo para la expedición Ojos del Salado en Chile: ${tourName}. Mis datos:\n\n- Nombre: ${name}\n- Fecha: ${date}`;
    const whatsappUrl = `https://wa.me/51962421830?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  .itinerary-hero {
    position: relative;
    height: 70vh;
    min-height: 600px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/slider_5.png') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    color: white;
    padding-top: 5rem;
  
    justify-content: center;
    text-align: center;
  }
  .itinerary-hero.chile-ojos { background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/slider_5.png'); 
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    margin-bottom:  1.5rem;
  
    align-items: center;
    gap: 0.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  .metrics-bar {
    display: flex;
    gap: 4rem;
    padding:  1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
    flex-wrap: wrap;
  
    justify-content: center;
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #94a3b8;
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    border-radius: 2px;
    letter-spacing: 1px;
    font-weight: 900;
  }
  .dif-tag.hard { background: #fee2e2; color: #ef4444; border: 1px solid #fecaca; }

  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: #94a3b8;
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #0090cc;
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: #030405;
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: #0090cc; }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: #475569;
    margin-bottom: 4rem;
    max-width: 550px;
  }

  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec { display: flex; gap: 1.2rem; align-items: flex-start; }
  .d-icon { color: #0090cc; opacity: 0.6; margin-top: 0.2rem; }
  .d-info { display: flex; flex-direction: column; gap: 0.4rem; }
  .d-label { font-size: 0.6rem; font-weight: 800; color: #94a3b8; letter-spacing: 1.5px; }
  .d-value { font-size: 0.95rem; font-weight: 700; color: #030405; }

  .visual-frame {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 600px;
    object-fit: cover;
  }

  .coordinates-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid #e2e8f0; }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .sub-label { font-size: 0.6rem; font-weight: 800; color: #0090cc; margin-bottom: 0.5rem; display: block; }
  .technical-title { font-size: 2.2rem; font-weight: 900; color: #030405; margin-bottom: 2rem; letter-spacing: -1px; }
  .technical-title .blue { color: #0090cc; }

  .path-timeline { position: relative; padding-left: 2rem; margin-top: 3rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, #0090cc, #94a3b8, #94a3b8);
  }

  .waypoint-item { display: flex; gap: 1.5rem; margin-bottom: 4rem; position: relative; }
  .waypoint-marker { position: relative; z-index: 2; flex-shrink: 0; }
  .marker-box {
    width: 90px;
    height: 40px;
    background: white;
    border: 2px solid #030405;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  .m-day { font-size: 0.75rem; font-weight: 900; color: #030405; }

  .w-title { font-size: 1.15rem; font-weight: 800; color: #030405; margin-bottom: 0.8rem; }
  .w-description { font-size: 0.88rem; line-height: 1.8; color: #475569; margin-bottom: 1rem; }

  .waypoint-stats { display: flex; gap: 2rem; padding-top: 1rem; border-top: 1px solid #e2e8f0; }
  .w-stat { display: flex; flex-direction: column; gap: 0.4rem; }
  .w-s-label { font-size: 0.6rem; font-weight: 800; color: #94a3b8; letter-spacing: 1px; }
  .w-s-value { font-size: 0.75rem; font-weight: 700; color: #030405; }

  .logistics-sidebar { display: flex; flex-direction: column; gap: 3rem; padding-top: 6.5rem; }
  .logistics-card { background: white; padding: 2.5rem; border: 1px solid #e2e8f0; }
  .log-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .log-list li { display: flex; gap: 1rem; align-items: flex-start; font-size: 0.82rem; color: #475569; }
  .log-icon { color: #0090cc; flex-shrink: 0; margin-top: 0.2rem; }
  .log-icon-blue { color: #0090cc; flex-shrink: 0; margin-top: 0.2rem; }

