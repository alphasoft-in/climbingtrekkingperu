---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import TourGallery from '../../components/TourGallery';

const langUrl = getLangFromUrl(Astro.url);
const t = useTranslations(langUrl);

const itinerary = [
  {
    day: 'DÍA 01',
    title: 'LLEGADA A LA PAZ – TRASLADO A UYUNI',
    content: 'Recepción en el aeropuerto El Alto. Traslado a la terminal para el viaje nocturno en bus hacia Uyuni.',
    stats: { status: 'Night Bus' }
  },
  {
    day: 'DÍA 02',
    title: 'SALAR DE UYUNI – ISLA INCAHUASI',
    content: 'Inicio del tour 4x4. Cementerio de trenes, Colchani y el espejo de sal. Atardecer en el salar.',
    stats: { alt: '3650m' }
  },
  {
    day: 'DÍA 03',
    title: 'LAGUNA COLORADA – DESIERTO DE SILOLI',
    content: 'Exploración de lagunas altiplánicas y avistamiento de flamencos. Paisajes surrealistas en el desierto.',
    stats: { alt: '4280m' }
  },
  {
    day: 'DÍA 04',
    title: 'RESERVA EDUARDO AVAROA – RETORNO A LA PAZ',
    content: 'Géiseres Sol de Mañana, aguas termales y Laguna Verde. Regreso a Uyuni y bus nocturno a La Paz.',
    stats: { status: 'Night Bus' }
  },
  {
    day: 'DÍA 05',
    title: 'DÍA LIBRE EN LA PAZ',
    content: 'Descanso en el hotel. Tiempo libre para explorar el mercado de las brujas y teleféricos.',
    stats: { status: 'Rest' }
  },
  {
    day: 'DÍA 06',
    title: 'PREPARACIÓN Y ACLIMATACIÓN',
    content: 'Revisión de equipo técnico para la ascensión al Huayna Potosí.',
    stats: { status: 'Prep' }
  },
  {
    day: 'DÍA 07',
    title: 'LA PAZ – REFUGIO HUAYNA POTOSÍ (4680 M)',
    content: 'Traslado al paso Zongo. Caminata suave al refugio y práctica en glaciar.',
    stats: { time: '4h Drive/Trek', alt: '4680m' }
  },
  {
    day: 'DÍA 08',
    title: 'REFUGIO – CAMPO ALTO (5280 M)',
    content: 'Ascenso al Refugio Roca (Campo Alto). Preparación logística para la cumbre.',
    stats: { time: '3h Ascent', alt: '5280m' }
  },
  {
    day: 'DÍA 09',
    title: 'CUMBRE HUAYNA POTOSÍ (6088 M) – LA PAZ',
    content: 'Ataque a la cumbre a medianoche. Vistas del Titicaca y Cordillera Real. Retorno a La Paz.',
    stats: { time: '10h Day', alt: '6088m' }
  },
  {
    day: 'DÍA 10',
    title: 'LA PAZ – AEROPUERTO',
    content: 'Traslado al aeropuerto para el vuelo internacional.',
    stats: { status: 'Departure' }
  }
];

const includes = [
  'Traslados Aeropuerto - Hotel - Aeropuerto',
  'Tickets de bus cama La Paz - Uyuni - La Paz',
  'Tour 4x4 en el Salar de Uyuni (3 días)',
  'Hospedajes en el Salar y La Paz',
  'Guía de montaña para la ascensión al Huayna Potosí',
  'Cocinero y alimentación completa en expedición',
  'Porteadores para equipo grupal',
  'Tickets de entrada a Uyuni y Huayna Potosí',
  'Equipo de campamento y seguridad'
];

const excludes = [
  'Vuelos internacionales',
  'Alimentación en ciudades (La Paz/Uyuni)',
  'Equipo técnico personal (alquiler disponible)',
  'Saco de dormir y colchoneta',
  'Seguro de montaña',
  'Propinas'
];

const equipment = [
  'Ropa abrigada (Capas térmicas)',
  'Chaqueta impermeable (Gore-Tex)',
  'Botas de montaña técnicas',
  'Grampones y Piolet (Incluidos en logística)',
  'Gafas de sol Cat. 4',
  'Mochila de 40L',
  'Linterna frontal con baterías extra'
];
---

<Layout title="Salar de Uyuni + Huayna Potosí 6088m | Bolivia | Franpisco Adventure" description="El combo perfecto en Bolivia: Explora el Salar de Uyuni y conquista tu primer 6000m en el Huayna Potosí. 10 días de aventura total.">
  <section class="itinerary-hero bolivia-combo">
    <div class="hero-overlay"></div>
    <div class="container--narrow">
      <div class="hero-content">
        <h1 class="split-title">
          <span class="thin">SALT FLATS & SUMMITS</span>
          <span class="bold">UYUNI + HUAYNA 6088M</span>
        </h1>
        <div class="hero-accent-bar"></div>

        <div class="metrics-bar">
          <div class="metric">
            <span class="m-label">DURACIÓN</span>
            <span class="m-value">10 DÍAS</span>
          </div>
          <div class="metric">
            <span class="m-label">ALTITUD MÁX</span>
            <span class="m-value">6,088 MSNM</span>
          </div>
          <div class="metric">
            <span class="m-label">DIFICULTAD</span>
            <span class="m-value">
              <span class="dif-tag mod">MODERADA / AVENTURA</span>
            </span>
          </div>
          <div class="metric">
            <span class="m-label">COSTO</span>
            <span class="m-value">USD 995.00</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-intro">
    <div class="container--narrow">
      <div class="dossier-layout">
        <div class="dossier-sidebar">
          <span class="vertical-label">ADVENTURE DOSSIER</span>
        </div>
        
        <div class="dossier-content">
          <div class="dossier-header">
            <span class="log-id">CÓDIGO: BOL-UYH-10</span>
            <h2 class="dossier-title">Espejos de <span class="blue">Sal y Hielo</span></h2>
          </div>
          
          <p class="dossier-p">Este programa combina las dos experiencias más impactantes de Bolivia. Comenzamos en el **Salar de Uyuni**, el desierto de sal más grande del mundo, donde los paisajes parecen de otro planeta, para luego regresar a la Cordillera Real y enfrentar el desafío del **Huayna Potosí**.</p>
          <p class="dossier-p">Es la opción ideal para quienes desean experimentar la diversidad geográfica de Bolivia en poco tiempo, combinando un tour cultural de alta gama con una expedición de montañismo técnica pero accesible.</p>
          
          <div class="dossier-specs">
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">PUNTOS CLAVE</span>
                <span class="d-value">Uyuni & Cordillera Real</span>
              </div>
            </div>
            <div class="d-spec">
              <div class="d-icon">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="d-info">
                <span class="d-label">ACTIVIDAD</span>
                <span class="d-value">Tour 4x4 + Alpinismo</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dossier-visual">
          <div class="visual-frame">
            <img src="/slider_2.png" alt="Salar de Uyuni" class="dossier-img" />
            <div class="coordinates-overlay">
              <span>20° 08' 01" S</span>
              <span class="divider">|</span>
              <span>67° 29' 20" W</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="itinerary-details">
    <div class="container--narrow">
      <div class="details-layout">
        <div class="path-log-container">
          <div class="details-header-technical">
            <span class="sub-label">ITINERARIO DE EXPEDICIÓN</span>
            <h2 class="technical-title">Cronología de <span class="blue">Misión</span></h2>
          </div>

          <div class="path-timeline">
            {itinerary.map((item) => (
              <div class="waypoint-item">
                <div class="waypoint-marker">
                  <div class="marker-box">
                    <span class="m-day">{item.day}</span>
                  </div>
                  <div class="connector"></div>
                </div>
                
                <div class="waypoint-content">
                  <div class="waypoint-header">
                    <h3 class="w-title">{item.title}</h3>
                  </div>
                  
                  <p class="w-description">{item.content}</p>
                  
                  {item.stats && (
                    <div class="waypoint-stats">
                      {item.stats.alt && (
                        <div class="w-stat">
                          <span class="w-s-label">MSNM</span>
                          <span class="w-s-value">{item.stats.alt}</span>
                        </div>
                      )}
                      {item.stats.status && (
                        <div class="w-stat">
                          <span class="w-s-label">MODALIDAD</span>
                          <span class="w-s-value">{item.stats.status}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <aside class="logistics-sidebar">
          <div class="logistics-card">
            <div class="card-header">
              <span class="c-id">REF: SRV-INC</span>
              <h3>Qué Incluye</h3>
            </div>
            <ul class="log-list">
              {includes.map(inc => (
                <li>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" class="log-icon"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{inc}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="mission-cta">
            <div class="cta-inner">
              <span class="cta-status">6000M + SALT EXPERIENCE</span>
              <h3>Inicia el Viaje</h3>
              <p>Reserva tu lugar en el programa más completo de Bolivia. Salar de Uyuni y cumbre en Huayna Potosí.</p>
              
              <form class="booking-form" id="booking-form">
                <div class="form-row">
                  <div class="form-group">
                    <label for="approx-date">FECHA ESTIMADA</label>
                    <input type="date" id="approx-date" required />
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="full-name">NOMBRE COMPLETO</label>
                    <input type="text" id="full-name" placeholder="Tu nombre" required />
                  </div>
                </div>
                <button type="submit" class="btn-tactical">
                  {t('trekking.book')}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
              </form>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery client:visible 
    lang={langUrl}
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId= client:visible />
</Layout>

<script>
  const bookingForm = document.getElementById('booking-form');
  bookingForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const date = (document.getElementById('approx-date') as HTMLInputElement).value;
    const name = (document.getElementById('full-name') as HTMLInputElement).value;
    const tourName = "SALAR DE UYUNI + HUAYNA POTOSÍ 6088M";
    
    const message = `¡Hola Franpisco Adventure! Deseo reservar para el combo Salar de Uyuni + Huayna Potosí. Mis datos:\n\n- Nombre: ${name}\n- Fecha: ${date}`;
    const whatsappUrl = `https://wa.me/51962421830?text=${encodeURIComponent(message)}`;
    
    window.open(whatsappUrl, '_blank');
  });
</script>

<style>
  .itinerary-hero {
    position: relative;
    height: 70vh;
    min-height: 600px;
    background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/slider_2.png') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    color: white;
    padding-top: 5rem;
  
    justify-content: center;
    text-align: center;
  }
  .itinerary-hero.bolivia-combo { background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/slider_2.png'); 
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(3,4,5,0.95), rgba(3,4,5,0.2) 40%, rgba(3,4,5,0.95));
    z-index: 1;
  }

  .container--narrow {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .split-title {
    display: flex;
    flex-direction: column;
    margin-bottom:  1.5rem;
  
    align-items: center;
    gap: 0.5rem;
  }
  .split-title .thin {
    font-size: clamp(0.8rem, 2vw, 1.1rem);
    font-weight: 200;
    letter-spacing: 8px;
    opacity: 0.8;
  }
  .split-title .bold {
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 1;
  }

  .metrics-bar {
    display: flex;
    gap: 4rem;
    padding:  1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
    flex-wrap: wrap;
  
    justify-content: center;
  }

  .metric { display: flex; flex-direction: column; gap: 0.5rem; }
  .m-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #94a3b8;
  }
  .m-value {
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
  }
  
  .dif-tag {
    font-size: 0.65rem;
    padding: 2px 8px;
    border-radius: 2px;
    letter-spacing: 1px;
    font-weight: 900;
  }
  .dif-tag.mod { background: #e0f2fe; color: #0369a1; border: 1px solid #bae6fd; }

  .itinerary-intro {
    padding: 10rem 0;
    background: #ffffff;
    overflow: hidden;
  }

  .dossier-layout {
    display: grid;
    grid-template-columns: 40px 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .vertical-label {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 5px;
    color: #94a3b8;
    white-space: nowrap;
  }

  .log-id {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #0090cc;
    margin-bottom: 1rem;
    display: block;
  }

  .dossier-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -1.5px;
    line-height: 1;
    color: #030405;
    margin-bottom: 2.5rem;
  }
  .dossier-title .blue { color: #0090cc; }

  .dossier-p {
    font-size: 0.95rem;
    line-height: 1.9;
    color: #475569;
    margin-bottom: 4rem;
    max-width: 550px;
  }

  .dossier-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  .d-spec { display: flex; gap: 1.2rem; align-items: flex-start; }
  .d-icon { color: #0090cc; opacity: 0.6; margin-top: 0.2rem; }
  .d-info { display: flex; flex-direction: column; gap: 0.4rem; }
  .d-label { font-size: 0.6rem; font-weight: 800; color: #94a3b8; letter-spacing: 1.5px; }
  .d-value { font-size: 0.95rem; font-weight: 700; color: #030405; }

  .visual-frame {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }
  .dossier-img {
    width: 100%;
    height: 600px;
    object-fit: cover;
  }

  .coordinates-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: rgba(3,4,5,0.8);
    backdrop-filter: blur(10px);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 3px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .itinerary-details { padding: 8rem 0 4rem; background: #fafafa; border-top: 1px solid #e2e8f0; }
  .details-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .sub-label { font-size: 0.6rem; font-weight: 800; color: #0090cc; margin-bottom: 0.5rem; display: block; }
  .technical-title { font-size: 2.2rem; font-weight: 900; color: #030405; margin-bottom: 2rem; letter-spacing: -1px; }
  .technical-title .blue { color: #0090cc; }

  .path-timeline { position: relative; padding-left: 2rem; margin-top: 3rem; }
  .path-timeline::before {
    content: '';
    position: absolute;
    left: 45px; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, #0090cc, #94a3b8, #94a3b8);
  }

  .waypoint-item { display: flex; gap: 1.5rem; margin-bottom: 4rem; position: relative; }
  .waypoint-marker { position: relative; z-index: 2; flex-shrink: 0; }
  .marker-box {
    width: 90px;
    height: 40px;
    background: white;
    border: 2px solid #030405;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  .m-day { font-size: 0.75rem; font-weight: 900; color: #030405; }

  .w-title { font-size: 1.15rem; font-weight: 800; color: #030405; margin-bottom: 0.8rem; }
  .w-description { font-size: 0.88rem; line-height: 1.8; color: #475569; margin-bottom: 1rem; }

  .waypoint-stats { display: flex; gap: 2rem; padding-top: 1rem; border-top: 1px solid #e2e8f0; }
  .w-stat { display: flex; flex-direction: column; gap: 0.4rem; }
  .w-s-label { font-size: 0.6rem; font-weight: 800; color: #94a3b8; letter-spacing: 1px; }
  .w-s-value { font-size: 0.75rem; font-weight: 700; color: #030405; }

  .logistics-sidebar { display: flex; flex-direction: column; gap: 3rem; padding-top: 6.5rem; }
  .logistics-card { background: white; padding: 2.5rem; border: 1px solid #e2e8f0; }
  .log-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .log-list li { display: flex; gap: 1rem; align-items: flex-start; font-size: 0.82rem; color: #475569; }
  .log-icon { color: #0090cc; flex-shrink: 0; margin-top: 0.2rem; }

  .mission-cta { background: #030405; color: white; padding: 3rem; }
  .cta-status { font-size: 0.6rem; font-weight: 900; color: #0090cc; letter-spacing: 2px; display: block; margin-bottom: 1.5rem; }
  .mission-cta h3 { font-size: 1.6rem; font-weight: 900; margin-bottom: 1rem; }
  .mission-cta p { font-size: 0.95rem; opacity: 0.7; margin-bottom: 2rem; }

  .btn-tactical {
    width: 100%;
    background: #0090cc;
    color: white;
    border: none;
    padding: 1.2rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    cursor: pointer;
    transition: 0.3s;
  }
  .btn-tactical:hover { background: #0070a0; }

  .form-group { margin-bottom: 1.5rem; }
  .form-group label { display: block; font-size: 0.6rem; font-weight: 800; color: #0090cc; margin-bottom: 0.5rem; }
  .form-group input {
    width: 100%;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 0.8rem;
    color: white;
    outline: none;
  }

  @media (max-width: 1024px) {
    .dossier-layout { grid-template-columns: 1fr; }
    .details-layout { grid-template-columns: 1fr; }
    .logistics-sidebar { padding-top: 0; }
  }

  .hero-accent-bar {
    width: 60px;
    height: 4px;
    background: var(--brand-red);
    margin:  1.2rem auto;
    box-shadow: 0 0 15px rgba(239, 68, 68, 0.4);
  }

</style>
