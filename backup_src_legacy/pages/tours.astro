---

<Layout title={`${t('nav.tours')} - Franpisco Adventure`} description="Explora nuestras expediciones culturales y tours exclusivos en las regiones más emblemáticas del Perú.">
  <PageHero 
    client:load
    titleTop="NUESTROS"
    titleMain="TOURS"
    backgroundImage="/slider_2.png"
    techData={[
      { label: "ELEVACIÓN MÁX", value: "4,600 M.S.N.M." },
      { label: "COORDENADAS", value: "9°30′S 77°31′W" },
      { label: "REGIÓN", value: "CORDILLERA BLANCA" }
    ]}
  />

  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
        {tours.map((tour) => (
          <TourCard 
            client:visible
            id={tour.id}
            title={tour.title}
            description={tour.description}
            image={tour.image}
            duration={tour.duration}
            difficulty={tour.difficulty}
            difficultyLevel={tour.difficultyLevel}
            href={getRelativeLocaleUrl(lang, tour.href)}
            prefix={tour.prefix}
            category={tour.category}
            lang={lang as 'es' | 'en'}
          />
        ))}
      </div>
    </div>
  </section>

  <SuggestedRoutes lang={lang} currentId="tours-hub" client:visible />
</Layout>
