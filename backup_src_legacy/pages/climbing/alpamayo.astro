---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from '../../i18n/utils';
import SuggestedRoutes from '../../components/SuggestedRoutes';
import TourGallery from '../../components/TourGallery';
import ItineraryHero from '../../components/ItineraryHero';
import ItineraryIntro from '../../components/ItineraryIntro';
import ItinerarySchedule from '../../components/ItinerarySchedule';
import LogisticsCard from '../../components/LogisticsCard';
import ItineraryBooking from '../../components/ItineraryBooking';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const itinerary = [
  {
    day: 'DÍA 01',
    title: 'HUARAZ (3100M) – CASHAPAMPA – LLAMACORAL (3760M)',
    content: 'Salida de Huaraz hacia Cashapampa (2900m). Encuentro con los arrieros y caminata hacia Llamacoral siguiendo el río Yurakmayu.',
    stats: { time: '5h Caminata', alt: '3760m' }
  },
  {
    day: 'DÍA 02',
    title: 'LLAMACORAL (3760M) – CAMPO BASE ALPAMAYO (4350M)',
    content: 'Caminata por el valle de Santa Cruz, pasando por la laguna Jatuncocha. Entrada al campo base por la quebrada Arhuaycocha.',
    stats: { time: '5-6h Caminata', alt: '4350m' }
  },
  {
    day: 'DÍA 03',
    title: 'CAMPO BASE (4350M) – CAMPO ALTO (5450M)',
    content: 'Ascenso al campo alto. Escalada técnica por la morrena del glaciar hasta alcanzar el campamento de altura.',
    stats: { time: '6-7h Ascenso', alt: '5450m' }
  },
  {
    day: 'DÍA 04',
    title: 'CAMPO ALTO (5450M) – CUMBRE ALPAMAYO (5947M)',
    content: 'Día de cumbre. Escalada técnica en paredes de hielo (60° a 90°). Descenso en rappel de regreso al campo alto.',
    stats: { time: '10-11h Jornada', alt: '5947m' }
  },
  {
    day: 'DÍA 05',
    title: 'CAMPO ALTO (5450M) – CAMPO BASE (4350M)',
    content: 'Descenso al campo base, incluyendo tramos de rappel técnicos. Cruce del glaciar y morrena.',
    stats: { time: '6-7h Descenso', alt: '4350m' }
  },
  {
    day: 'DÍA 06',
    title: 'CAMPO BASE (4350M) – CASHAPAMPA (2900M) – HUARAZ',
    content: 'Descenso final hacia Cashapampa y transporte privado de retorno a la ciudad de Huaraz.',
    stats: { time: 'Retorno', alt: '3100m' }
  }
];

const includes = [
  'Traslados terminal - hotel en Huaraz',
  'Charla técnica en la oficina',
  'Tickets de entrada al P.N. Huascarán',
  'Transporte privado Huaraz - Cashapampa - Huaraz',
  'Guía Certificado UIAGM (Internacional)',
  'Cocinero certificado y asistente',
  'Portero para equipo al Campo Alto',
  'Alimentación completa en expedición',
  'Equipo de camping de alta montaña',
  'Cuerdas y estacas de nieve',
  'Burros y arrieros para logística',
  'Walkie-talkies y botiquín'
];

const excludes = [
  'Seguros de viaje y accidentes',
  'Alimentación en la ciudad',
  'Equipo personal de montaña',
  'Gastos personales y propinas',
  'Saco de dormir personal (-20°C)'
];

const equipment = [
  'Saco de dormir (-20°C)',
  'Casco de montaña y gafas UV Cat 4',
  'Chaqueta de plumas y Gore-Tex',
  'Guantes técnicos de nieve',
  'Arnés y piolets técnicos (par)',
  'Botas dobles y grampones',
  'Mochila de ataque (40L)'
];
---

<Layout title="Expedición Alpamayo 5947m | Cordillera Blanca | Franpisco Adventure" description="Escala la montaña más hermosa del mundo. Expedición técnica de 6 días al Nevado Alpamayo en los Andes Peruanos.">
  <ItineraryHero
    client:load
    titleTop="LA MONTAÑA MÁS HERMOSA"
    titleMain="NEVADO ALPAMAYO 5947M"
    backgroundImage="/slider_5.png"
    duration="06 DÍAS / 05 NOCHES"
    price="USD. 1,950.00"
    difficulty="DIFÍCIL"
    difficultyLevel="hard"
  />

  <ItineraryIntro
    client:visible
    code="CLB-ALP-06"
    titlePrefix="La Pirámide"
    titleAccent="de Cristal"
    description="El Alpamayo es considerado la montaña más bella del mundo por su perfecta forma piramidal. Una expedición técnica de alto nivel que requiere experiencia."
    image="/slider_1.png"
    lat={`08° 52' 45" S`}
    lon={`77° 39' 12" W`}
    specs={[
      { label: "PUNTO MÁXIMO", value: "5,947 MSNM", icon: "location" },
      { label: "INCLINACIÓN", value: "60° - 90° Hielo", icon: "activity" },
      { label: "TEMPORADA", value: "Mayo - Agosto", icon: "season" },
      { label: "SERVICIO", value: "Logística Técnica", icon: "service" }
    ]}
  />

  <section class="py-24 md:py-32 bg-[#fafafa]">
    <div class="max-w-[1400px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start">
        <div class="flex-1">
          <ItinerarySchedule 
            client:visible 
            days={itinerary.map(item => ({
              day: item.day,
              title: item.title,
              description: item.content,
              stats: item.stats
            }))} 
          />
        </div>

        <aside class="sticky top-24 h-fit">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 gap-8 md:gap-10 lg:gap-12">
            <LogisticsCard 
              client:visible 
              title="Qué Incluye" 
              items={includes} 
              refCode="SRV-INC" 
              variant="primary" 
            />
            <LogisticsCard 
              client:visible 
              title="No Incluye" 
              items={excludes} 
              refCode="SRV-EXC" 
              variant="secondary" 
            />
            <LogisticsCard 
              client:visible 
              title="Equipo Técnico" 
              items={equipment} 
              refCode="EQP-TCN" 
              variant="secondary" 
            />
            <div class="md:col-span-2 lg:col-span-1">
              <ItineraryBooking 
                client:load 
                tourName="EXPEDICIÓN ALPAMAYO 5947M" 
              />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <TourGallery 
    client:visible 
    lang={lang}
    tourName="Nevado Alpamayo"
    images={[
      '/slider_1.png',
      '/slider_2.png',
      '/slider_3.png',
      '/slider_4.png',
      '/slider_5.png'
    ]} 
  />

  <SuggestedRoutes lang={lang} currentId="alpamayo" client:visible />
</Layout>
